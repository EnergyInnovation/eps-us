Min Allowed Distributed Solar Capacity=
	MIN(
	  Min Elec Output from Distributed Solar
	  / Distributed Solar Capacity Factor x Hours per Year,
	  SUM(MDSC Maximum Distributed Solar Capacity[Building Type!,Electricity Source!])
	)
	~	MW
	~		|

Min Elec Output from Distributed Solar=
	Last Year Total Electricity Demand
	* Min Fraction of Total Elec Demand to be Met by Distributed Solar PV This Year
	~	MW*hour
	~		|

Min Fraction of Total Elec Demand to be Met by Distributed Solar PV=
	0
	~	Dmnl [0,0.24]
	~		|

Min Fraction of Total Elec Demand to be Met by Distributed Solar PV This Year=
	Min Fraction of Total Elec Demand to be Met by Distributed Solar PV
	* Selected Policy Implementation Schedule[bldgs min fraction distributed solar X]
	~	Dmnl
	~		|

Min Required Rooftop Solar Capacity[Building Type]=
	0
	~	MW [0,600000,5000]
	~		|

Min Required Rooftop Solar Capacity This Year[Building Type]=
	Min Required Rooftop Solar Capacity[Building Type]
	* VECTOR ELM MAP(
	    Selected Policy Implementation Schedule[bldgs min req rooftop solar X urban residential\
		],
	    (Building Type - 1)
	  )
	~	MW
	~		|

Minimum Additional Grid Batteries Deployed=
	0
	~	MW*hr [0,500000]
	~		|

Minimum Buildable Capacity for Plants=
	CSCMBCfPTwNEC Minimum Buildable Capacity for Plant Types with No Existing Capacity
	*SUM(Last Year Electricity Generation Capacity[Electricity Source!])
	~	MW
	~		|

Minimum Distributed Solar to Meet Capacity Requirement[Building Type,Electricity Source\
		]=
	MIN(
	  Min Required Rooftop Solar Capacity This Year[Building Type],
	  MDSC Maximum Distributed Solar Capacity[Building Type,Electricity Source]
	)
	~	MW
	~		|

