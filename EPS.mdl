	)
	~	Dmnl
	~		|

CCP CO2 Capture Potential by Hydrogen Sector=
	GET DIRECT CONSTANTS(
	   'InputData/ccs/CCP/CPPbHS.csv',
	   ',',
	   'B2'
	)
	~	Dmnl
	~		|

CCS Cost per Ton Blue Hydrogen Produced=
	MAX(
	  ZIDZ(Capital Cost of Eqpt to Sequester One Ton of Hydrogen Sector CO2 per Year * One Year\
		,
	    Discount Factor to Levelize Capital Costs)
	  + CC CCS Total OM Cost per Hydrogen Sector Ton Sequestered
	  + Hydrogen Sector CCS Transportation and Storage Costs per Ton Sequestered
	
	  ,
	
	  0
	)
	/ Grams per Metric Ton CO2e
	/ Grams Pollutant per Gram CO2e Unit Converter
	
	
	* Industrial Fuel Pollutant Emissions Intensities This Year[chemicals 20,CO2,natural gas if\
		]
	
	* FIoHP Fuel Intensity of Hydrogen Production[natural gas reforming with CCS,natural gas if\
		]
	
	* CCP CO2 Capture Potential by Hydrogen Sector
	~	$/BTU
	~		|

CCS New Capital Eqpt Cost by Hydrogen Sector=
	This Year Increase in Pollutants Sequestered by Hydrogen Sector[CO2]
	* Capital Cost of Eqpt to Sequester One Ton of Hydrogen Sector CO2 per Year
	  / Grams Pollutant per Gram CO2e Unit Converter / Grams per Metric Ton CO2e * One Year
	~	$
	~		|

CCS New Capital Eqpt Cost by Industry[Industry Category]=
	SUM(This Year Increase in Pollutants Sequestered by Industry Sector[Industry Category\
		,CO2,Emissions Type!]
	  * Capital Cost of Epqt to Sequester One Ton of Industry CO2 per Year[Industry Category\
		,Emissions Type!]
	)
	  / Grams Pollutant per Gram CO2e Unit Converter / Grams per Metric Ton CO2e * One Year
	~	$
	~		|

CCS OM Cost by Hydrogen Sector=
	This Year Pollutants Sequestered by Hydrogen Sector[CO2]
	* CC CCS Total OM Cost per Hydrogen Sector Ton Sequestered
	/ Grams per Metric Ton CO2e
	/ Grams Pollutant per Gram CO2e Unit Converter
	~	$
	~		|

CCS OM Cost by Industry Sector[Industry Category]=
	SUM(This Year Pollutants Sequestered by Industry Sector[Industry Category,CO2,Emissions Type\
		!]
	 * CC CCS Total OM Cost per Industry Ton Sequestered[Industry Category,Emissions Type\
		!]
	)
	/ Grams per Metric Ton CO2e
	/ Grams Pollutant per Gram CO2e Unit Converter
	~	$
	~		|

CCS Retrofit Capacity Construction Started This Year[Industry Category,Emissions Type\
		]=
	MIN(
	  Demand for CCS Not Already Existing or In Progress[Industry Category,Emissions Type\
		],
	
	  MAX(
	    CCS Retrofit Capacity Desired[Industry Category,Emissions Type]
	    - Start Year BAU Fraction of CCS Potential Achieved by Industry Sector[Industry Category\
		,Emissions Type],
	    0
	  )
	  * SoCECRCSiaY Share of Cost Effective CCS Retrofit Construction Started in a Year
	)
	~	Dmnl
	~		|

CCS Retrofit Capacity Desired[Industry Category,Emissions Type]=
	IF THEN ELSE(
	  Value of CCS[Industry Category,Emissions Type] <= 0,
	
	  0,
	
	  LOOKUP BACKWARD(
	    CECRCbI Cost Effective CCS Retrofit Capacity by Industry[Industry Category,Emissions Type\
		],
	    Value of CCS[Industry Category,Emissions Type]
	    / One Dollar
	    * One Metric Ton CO2e
	  )
	)
	~	Dmnl
	~	Lookup functions like LOOKUP BACKWARD are recommended to be dimensionless; \
		we divide by One Dollar and multiply by One Metric Ton CO2e to supress \
		warnings from the lookup function.
	|

CCS Retrofit Capacity in Conveyor[Industry Category,Emissions Type]= 
	DELAY FIXED(
	  CCS Retrofit Capacity Construction Started This Year[Industry Category,Emissions Type\
		], 
	  CRDT CCS Retrofit Deployment Time[Industry Category,Emissions Type],
	  0
	)
	~	Dmnl
	~		|

CCS Sectors:
	electricity sector,
	industry sector
	~	
	~		|

CCS Subsidies Paid per Unit Electricity Output for Newly Eligible CCS Capacity[Electricity Source\
		]=
	New and Retrofit Generation Capacity[Electricity Source]
	* Expected Capacity Factor x Hours per Year for Plants Built This Year[Electricity Source\
		]
	* Electricity Sector CCS Subsidy per MWh[Electricity Source]
	~	$
	~		|

CCS Subsidy Amount Paid to Hydrogen Sector=
	This Year Pollutants Sequestered by Hydrogen Sector[CO2]
	 / Grams Pollutant per Gram CO2e Unit Converter / Grams per Metric Ton CO2e
	 * BCS BAU Industry CCS Subsidy
	~	$
	~		|

CCS Subsidy Amount Paid to Industry Sector[Industry Category]=
	SUM(This Year Pollutants Sequestered by Industry Sector[Industry Category,CO2,Emissions Type\
		!])
	 / Grams Pollutant per Gram CO2e Unit Converter / Grams per Metric Ton CO2e
	 * Industry Sector CCS Subsidy by Industry Category[Industry Category]
	~	$
	~		|

CCS Subsidy Payments per Unit Electricity Output Expiring After CCS Subsidy Duration Period\
		[Electricity Source]= DELAY FIXED (
	CCS Subsidies Paid per Unit Electricity Output for Newly Eligible CCS Capacity[Electricity Source\
		], BCS Duration of Subsidies for Carbon Sequestration, 0)
	~	$
	~		|

CCS Subsidy per MWh Adjusted for Subsidy Duration[Electricity Source]=
	Electricity Sector CCS Subsidy per MWh[Electricity Source]
	*Duration Multiplier for Subsidies for Carbon Sequestration[Electricity Source]
	~	$/(MW*hr)
	~		|

CCS Subsidy per Unit Output for Dispatch[Electricity Source]=
	IF THEN ELSE(
	  Last Year Electricity Generation Capacity[Electricity Source]=0,
	                 
	  Electricity Sector CCS Subsidy per MWh[Electricity Source],
	                 
	  ZIDZ(
	    SUM(
	      Last Year Electricity Generation Capacity by Vintage[Electricity Source,Modeled Vintage\
		!]
	      * CCS Subsidy per Unit Output for Dispatch by Vintage[Electricity Source,Modeled Vintage\
		!]
	    ),
	    Last Year Electricity Generation Capacity[Electricity Source]
	  )
	)
	~	$/(MW*hr)
	~		|

CCS Subsidy per Unit Output for Dispatch by Vintage[Electricity Source,Modeled Vintage\
		]=
	DEPRECIATE STRAIGHTLINE(
	
	  Electricity Sector CCS Subsidy per MWh[Electricity Source]
	  * BCS Duration of Subsidies for Carbon Sequestration / One Year
	  *This Year Modeled Vintage Flag[Modeled Vintage],
	 
	  BCS Duration of Subsidies for Carbon Sequestration,
	
	  1,
	
	  0
	)
	~	$/(MW*hr)
	~		|

