CpUDSC Cost per Unit Distributed Solar Capacity:INTERPOLATE::=
	GET DIRECT DATA(
	   'InputData/bldgs/CpUDSC/CpUDSC-totalcost.csv',
	   ',',
	   'A',
	   'B2'
	)
	~	$/MW
	~		|

CpUDSC Soft Costs per Unit Distributed Solar Capacity:=
	GET DIRECT DATA(
	   'InputData/bldgs/CpUDSC/CpUDSC-softcosts.csv',
	   ',',
	   'A',
	   'B2'
	)
	~	$/MW
	~		|

CRbQ Capacity Retirements before Quantization[Electricity Source]:=
	GET DIRECT DATA(
	   'InputData/elec/CRbQ/CRbQ.csv',
	   ',',
	   '1',
	   'B2'
	)
	~	MW
	~		|

CRDT CCS Retrofit Deployment Time[Industry Category,Emissions Type]=
	GET DIRECT CONSTANTS(
	   'InputData/ccs/CRDT/CRDT.csv',
	   ',',
	   'B2'
	)
	~	years
	~		|

CRpUNL Capacity Retired per Unit Net Loss[Electricity Source]=
	GET DIRECT CONSTANTS(
	   'InputData/elec/CRpUNL/CRpUNL.csv',
	   ',',
	   'B2*'
	)
	~	MW/($/(MW))
	~		|

CSCCCMvSoECBtY Capacity Cost Multiplier vs Share of Existing Capacity Built This Year\
		[summer]=
	GET DIRECT LOOKUPS(
	   'InputData/elec/CSC/CSC-CSCCCMvSoECBtY.csv',
	   ',',
	   '1',
	   'B2'
	)
	~	$/(MW*hr)
	~	This lookup has the percent of existing capacity (of a given electricity \
		source type) on the X-axis and the "cost multiplier" (the increase in cost \
		per unit capacity due to building a lot of capacity all in the current \
		year) on the Y-axis.  It is meant to be read via LOOKUP INVERT(), using a \
		known capacity cost multiplier (a multiplier that makes revenue equal \
		cost) to find the corresponding percent of existing capacity that must be \
		added.  Also, we add an artificial subscript element here ("summer") to \
		work around an issue where SDEverywhere cannot handle lookups without \
		subscripts.
	|

CSCMBCfPTwNEC Minimum Buildable Capacity for Plant Types with No Existing Capacity=
	GET DIRECT CONSTANTS(
	   'InputData/elec/CSC/CSC-CSCMBCfPTwNEC.csv',
	   ',',
	   'B2*'
	)
	~	Dmnl
	~		|

CSCSoCECBiaSY Share of Cost Effective Capacity Built in a Single Year[Electricity Source\
		]:INTERPOLATE::=
	GET DIRECT DATA(
	   'InputData/elec/CSC/CSC-CSCSoCECBiaSY.csv',
	   ',',
	   '1',
	   'B2'
	)
	~	Dmnl
	~		|

