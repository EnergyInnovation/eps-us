Fraction of Preexisting Industrial Equipment Retired by Industry Specific Retirement Profile\
		[Industry Category,Industrial Process]=
	MAX(
	  BIISRP BAU Individual Industrial Site Retirement Profile[Industry Category],
	
	  (1 - 
	    SUM(Start Year BAU Fuel Type Shares in Electricity Equivalent[Industry Category,\
		Industrial Process,Industrial Fuel!
	]
	  * IFTQfEERP Industrial Fuel Types Qualifying for Early Equipment Retirement Policy\
		[Industrial Fuel!])
	  )
	  * BIISRP BAU Individual Industrial Site Retirement Profile[Industry Category]
	
	  +
	
	  Minimum Share of Start Year Industrial Equipment Retired To Date[Industry Category\
		,Industrial Process]
	  * 
	  SUM(Start Year BAU Fuel Type Shares in Electricity Equivalent[Industry Category,Industrial Process\
		,Industrial Fuel!]
	    * IFTQfEERP Industrial Fuel Types Qualifying for Early Equipment Retirement Policy\
		[Industrial Fuel!]
	  )
	)
	~	Dmnl
	~		|

Fraction of Preexisting Industrial Equipment Retired by Natural Aging Curves[Industry Category\
		,Industrial Process]=
	MAX(
	  IESD Fraction of Preexisting Equipment Retired Naturally by Age[Industrial Process\
		],
	
	  (1 - 
	    SUM(Start Year BAU Fuel Type Shares in Electricity Equivalent[Industry Category,\
		Industrial Process,Industrial Fuel!
	]
	  * IFTQfEERP Industrial Fuel Types Qualifying for Early Equipment Retirement Policy\
		[Industrial Fuel!])
	  )
	  * IESD Fraction of Preexisting Equipment Retired Naturally by Age[Industrial Process\
		]
	
	  +
	
	  Minimum Share of Start Year Industrial Equipment Retired To Date[Industry Category\
		,Industrial Process]
	  * 
	  SUM(Start Year BAU Fuel Type Shares in Electricity Equivalent[Industry Category,Industrial Process\
		,Industrial Fuel!]
	    * IFTQfEERP Industrial Fuel Types Qualifying for Early Equipment Retirement Policy\
		[Industrial Fuel!]
	  )
	)
	~	Dmnl
	~		|

Fraction of Process Emissions Reductions by Policy[Industry Category,Industry Process Emissions Policy\
		,Pollutant]=
	ZIDZ(
	
	  This Year Decrease in Process Emissions by Policy and Industry[Industry Category,Industry Process Emissions Policy\
		,Pollutant],
	
	  SUM(This Year Decrease in Process Emissions by Policy and Industry[Industry Category\
		,Industry Process Emissions Policy!,Pollutant])
	)
	~	Dmnl
	~		|

Fraction of Vehicles Owned by Entity after Allocation to Energy Supplier Entities[Vehicle Type\
		,Cash Flow Entity,Cargo Type] :EXCEPT:  [road vehicle type,nonenergy industries,freight\
		],[road vehicle type,energy supplier cash flow entity,freight]=
