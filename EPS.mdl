LCFS Credit Price=
	MIN(
	  LCPC LCFS Credit Price Cap,
	
	  ZIDZ(
	    Incremental Costs from Substitute Fuel Production due to LCFS,
	    LCFS Credits Generated
	  )
	)
	~	$/LCFS credit
	~	Although some substitute fuels have no incremental cost to produce, they \
		still create LCFS credits and thus reduce the market price for LCFS \
		credits, so we divide total costs by total credits, rather than \
		subscripting by fuel type.
	~	:SUPPLEMENTARY 
	|

LCFS Credits Generated=
	SUM(Reduction in CO2 Emissions due to LCFS[Vehicle Type!,Cargo Type!,Vehicle Technology\
		!,Transportation Fuel!])
	/ GCApLC Grams CO2e Avoided per LCFS Credit
	~	LCFS credits
	~		|

