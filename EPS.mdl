		[summer],
	    MAX(0,
	  Total Energy Market and Capacity Market Revenue for Seasonal Dispatchable Reliability\
		[Electricity Source,Optimization Pass]
	
	  -(
	     Annualized Fixed Costs per Unit New Capacity[Electricity Source]
	     * SoCtMbCtbDP Share of Costs that Must be Covered to Be Deemed Profitable[Electricity Source
	]
	  )
	)
	  )
	)
	= :NA:,
	
	  0,
	
	 IF THEN ELSE(
	  MAX(0,
	  Total Energy Market and Capacity Market Revenue for Seasonal Dispatchable Reliability\
		[Electricity Source,Optimization Pass]
	
	  -(
	     Annualized Fixed Costs per Unit New Capacity[Electricity Source]
	     * SoCtMbCtbDP Share of Costs that Must be Covered to Be Deemed Profitable[Electricity Source
	]
	  )
	) <= 0,
	
