Portion of Change in Passthrough Expenses as Share of Nonenergy Industry Output Affecting Imports and Exports\
		[Industry Category]=
	IF THEN ELSE(
	
	  Change in Passthrough Expenses as Share of Nonenergy Industry Output After Carbon Tax Border Adjustment by Industry Category\
		[Industry Category] < 0, 
	 
	  Change in Passthrough Expenses as Share of Nonenergy Industry Output After Carbon Tax Border Adjustment by Industry Category\
		[Industry Category], 
	
	  Change in Passthrough Expenses as Share of Nonenergy Industry Output After Carbon Tax Border Adjustment by Industry Category\
		[Industry Category] 
	  * (1 - Fraction of Imported Industrial Outputs Shifted to In Region Suppliers This Year\
		[Industry Category])
	
	)
	~	Dmnl
	~		|

Positive Cost Electricity Dispatched to Meet CES[Electricity Timeslice,Hour,Electricity Source\
		]=
	MIN(
	
	Expected CES Qualifying Output After Guaranteed and RPS Dispatch[Electricity Source,\
		Electricity Timeslice,Hour],
	
	IF THEN ELSE(
	 
	       Remaining CES Required Generation after Guaranteed Dispatch and RPS Dispatch
	= 0,
	 
	       0,
	
	 
	       IF THEN ELSE(
	          SUM(
	            Expected CES Qualifying Output After Guaranteed and RPS Dispatch[Electricity Source\
		!,Electricity Timeslice
	,Hour] 
	          )
	          > Unmet Electricity Demand After RPS and Zero and Negative Cost CES Allocation Steps\
		[Electricity Timeslice,Hour],
	 
	          MIN(
	            Unmet Electricity Demand After RPS and Zero and Negative Cost CES Allocation Steps\
		[Electricity Timeslice,Hour]
	            * ZIDZ(
	                Expected CES Qualifying Output After Guaranteed and RPS Dispatch[Electricity Source\
		,Electricity Timeslice
	,Hour],
	                SUM(Expected CES Qualifying Output After Guaranteed and RPS Dispatch\
		[Electricity Source!,Electricity Timeslice
	,Hour])
	              ),
	
	            ZIDZ(
	              Remaining CES Required Generation after Guaranteed Dispatch and RPS Dispatch\
		,
	   
	              SUM(
	                Expected CES Qualifying Output After Guaranteed and RPS Dispatch[Electricity Source\
		!,Electricity Timeslice
	!,Hour!]
	                *Plant Types with Positive Dispatch Cost After Subsidies[Electricity Source\
		!]
	              )
	            )
	 
	            * Expected CES Qualifying Output After Guaranteed and RPS Dispatch[Electricity Source\
		,Electricity Timeslice
	,Hour]
	            *Plant Types with Positive Dispatch Cost After Subsidies[Electricity Source\
		]
	          ),
	 
	          Expected CES Qualifying Output After Guaranteed and RPS Dispatch[Electricity Source\
		,Electricity Timeslice,Hour
	]
	          * Plant Types with Positive Dispatch Cost After Subsidies[Electricity Source\
		]
	          * ZIDZ(
	              Remaining CES Required Generation after Guaranteed Dispatch and RPS Dispatch\
		,
	              SUM(
	                Expected CES Qualifying Output After Guaranteed and RPS Dispatch[Electricity Source\
		!,Electricity Timeslice
	!,Hour!]
	                *SHELF Days per Electricity Timeslice[Electricity Timeslice!]
	              )
	            )
	     )
	)
	)
	~	MW*hour
	~		|

Positive Cost Electricity Dispatched to Meet RPS[Electricity Timeslice,Hour,Electricity Source\
		]=
	MIN(
	
	Expected RPS Qualifying Capacity After Zero and Negative Cost RPS Dispatch[Electricity Timeslice\
		,Hour,Electricity Source]*One Hour,
	
	IF THEN ELSE(
	 
	       Remaining RPS Required Generation after Guaranteed Dispatch and Zero and Negative Cost Electricity Dispatched to Meet RPS
	= 0,
	 
	       0,
	
	 
	       IF THEN ELSE(
	          SUM(
	            Expected RPS Qualifying Capacity After Zero and Negative Cost RPS Dispatch\
		[Electricity Timeslice,Hour,Electricity Source!] 
	            *One Hour
	          )
	          > Unmet Electricity Demand After Zero and Negative Cost RPS Dispatch[Electricity Timeslice\
		,Hour],
	 
	          MIN(
	            Unmet Electricity Demand After Zero and Negative Cost RPS Dispatch[Electricity Timeslice\
		,Hour]
	            * ZIDZ(
	                Expected RPS Qualifying Capacity After Zero and Negative Cost RPS Dispatch\
		[Electricity Timeslice,Hour,Electricity Source],
	                SUM(Expected RPS Qualifying Capacity After Zero and Negative Cost RPS Dispatch\
		[Electricity Timeslice,Hour,Electricity Source!])
	              ),
	
	            ZIDZ(
	              Remaining RPS Required Generation after Guaranteed Dispatch and Zero and Negative Cost Electricity Dispatched to Meet RPS\
		,
	   
	              SUM(
	                Expected RPS Qualifying Capacity After Zero and Negative Cost RPS Dispatch\
		[Electricity Timeslice!,Hour!,Electricity Source!]
	                *Plant Types with Positive Dispatch Cost After Subsidies[Electricity Source\
		!]
	              )
	              * One Hour 
	            )
	 
	            * Expected RPS Qualifying Capacity After Zero and Negative Cost RPS Dispatch\
		[Electricity Timeslice,Hour,Electricity Source]
	            *Plant Types with Positive Dispatch Cost After Subsidies[Electricity Source\
		]
	            * One Hour
	          ),
	 
	          Expected RPS Qualifying Capacity After Zero and Negative Cost RPS Dispatch\
		[Electricity Timeslice,Hour,Electricity Source]
	          * Plant Types with Positive Dispatch Cost After Subsidies[Electricity Source\
		]
	          * ZIDZ(
	              Remaining RPS Required Generation after Guaranteed Dispatch and Zero and Negative Cost Electricity Dispatched to Meet RPS\
		,
	              SUM(
	                Expected RPS Qualifying Capacity After Zero and Negative Cost RPS Dispatch\
		[Electricity Timeslice!,Hour!,Electricity Source!]
	                *SHELF Days per Electricity Timeslice[Electricity Timeslice!]
	              )
	            )
	     )
	)
	)
	~	MW*hr
	~		|

Potential Buildings Fuel Cost[Building Type,Building Fuel,Building Component]=
	Components Potential Energy Use[Building Type,Building Fuel,Building Component]
	* Buildings Fuel Cost per Unit Energy[Building Fuel,Building Type]
	~	$
	~		|

Potential Capacity by Hour[Electricity Source,Electricity Timeslice,Hour]=
