Hour:
	(Hour0-Hour23)
	~	
	~		|

Hourly Bid Electricity Capacity Factors by Plant Type[Electricity Timeslice,Hour,Electricity Source\
		]=
	IF THEN ELSE(
	  BDTPTUMCF Boolean Does This Plant Type Use Maximum Capacity Factor[Electricity Source\
		] > 0,
	
	  Maximum Capacity Factor after RAF[Electricity Source],
	
	  Weighted Average Expected Capacity Factors by Hour Without Hypothetical Adjustments\
		[Electricity Source,Electricity Timeslice,Hour]
	)
	~	Dmnl
	~		|

Hourly Bid Electricity Factors for Plants Built This Year[Electricity Timeslice,Hour,\
		Electricity Source] :EXCEPT:        [
peak day electricity timeslice,Hour,Electricity Source]=
	IF THEN ELSE(
	  BDTPTUMCF Boolean Does This Plant Type Use Maximum Capacity Factor[Electricity Source\
		] > 0,
	
	  Maximum Capacity Factor after RAF[Electricity Source],
	
	  Expected Capacity Factors by Hour for Plants Built This Year Without Hypothetical Calculations\
		[Electricity Source
	,Electricity Timeslice,Hour]
	) ~~|
Hourly Bid Electricity Factors for Plants Built This Year[peak day electricity timeslice\
		,Hour,Electricity Source]=
	IF THEN ELSE(
	  BDTPTUMCF Boolean Does This Plant Type Use Maximum Capacity Factor[Electricity Source\
		] > 0,
	
	  MCF Maximum Capacity Factor[Electricity Source],
	
	  Expected Capacity Factors by Hour for Plants Built This Year Without Hypothetical Calculations\
		[Electricity Source
	,peak day electricity timeslice,Hour]
	)
	~	Dmnl
	~		|

Hourly CDF Values for Total Dispatch by Power Plant Type[Electricity Source,Electricity Timeslice\
		,Hour]=
	IF THEN ELSE(Hourly Z Score by Power Plant Type for Total Dispatch[Electricity Source\
		,Electricity Timeslice,Hour]>=0,
	
	  1 - Hourly PDF Values for Total Dispatch by Power Plant Type[Electricity Source,Electricity Timeslice\
		,Hour] * (Abramowitz and Stegun Values for CDF
	[a1]*Hourly T Values for Total Dispatch by Power Plant Type[Electricity Source
	  ,Electricity Timeslice,Hour] + Abramowitz and Stegun Values for CDF[a2]*Hourly T Values for Total Dispatch by Power Plant Type
	[Electricity Source,Electricity Timeslice,Hour
	]^2
	   +Abramowitz and Stegun Values for CDF[a3]*Hourly T Values for Total Dispatch by Power Plant Type\
		[Electricity Source,
	Electricity Timeslice,Hour]^3+Abramowitz and Stegun Values for CDF
	  [a4]*Hourly T Values for Total Dispatch by Power Plant Type[Electricity Source,Electricity Timeslice\
		,Hour]^4+Abramowitz and Stegun Values for CDF
	[a5]*Hourly T Values for Total Dispatch by Power Plant Type[Electricity Source
	  ,Electricity Timeslice,Hour]^5),
	
	  1-(1 - Hourly PDF Values for Total Dispatch by Power Plant Type[Electricity Source\
		,Electricity Timeslice,Hour] * (Abramowitz and Stegun Values for CDF
	[a1]*Hourly T Values for Total Dispatch by Power Plant Type[Electricity Source
	  ,Electricity Timeslice,Hour] + Abramowitz and Stegun Values for CDF[a2]*Hourly T Values for Total Dispatch by Power Plant Type
	[Electricity Source,Electricity Timeslice,Hour
	]^2
	   +Abramowitz and Stegun Values for CDF[a3]*Hourly T Values for Total Dispatch by Power Plant Type\
		[Electricity Source,
	Electricity Timeslice,Hour]^3+Abramowitz and Stegun Values for CDF
	  [a4]*Hourly T Values for Total Dispatch by Power Plant Type[Electricity Source,Electricity Timeslice\
		,Hour]^4+Abramowitz and Stegun Values for CDF
	[a5]*Hourly T Values for Total Dispatch by Power Plant Type[Electricity Source
	  ,Electricity Timeslice,Hour]^5)))
	
	{1- flipped PDF function[Electricity Source,Electricity Timeslice,Hour] * (Abramowitz and stegun values[a1]*t value[Electricity Source
	  ,Electricity Timeslice,Hour] + Abramowitz and stegun values[a2]*t value[Electricity Source,Electricity Timeslice,Hour
	]^2
	   +Abramowitz and stegun values[a3]*t value[Electricity Source,Electricity Timeslice,Hour]^3+Abramowitz and stegun values
	  [a4]*-t value[Electricity Source,Electricity Timeslice,Hour]^4+Abramowitz and stegun values[a5]*t value[Electricity Source
	  ,Electricity Timeslice,Hour]^5)
	)}
	~	Dmnl
	~		|

Hourly Energy Market Revenue from Total Electricity Dispatched by Power Plant Type[Electricity Timeslice\
		,Hour,Electricity Source]=
	Marginal Dispatch Cost by Hour[Electricity Timeslice,Hour]
	*Total Electricity Dispatched by Hour by Plant Type[Electricity Timeslice,Hour,Electricity Source\
		]
	~	$
	~		|

Hourly Expected Dispatch Cost per Unit Total Electricity Dispatched by Power Plant Type\
		[Electricity Source,Electricity Timeslice,Hour]=
	Dispatch Cost per Unit Electricity Output before Subsidies[Electricity Source]
	  -(Dispatch Cost per Unit Electricity Output[Electricity Source]*NSDoDC Normalized Standard Deviation of Dispatch Costs
	[Electricity Source])*ZIDZ(Hourly PDF Values for Total Dispatch by Power Plant Type[\
		Electricity Source,Electricity Timeslice
	,Hour],Hourly CDF Values for Total Dispatch by Power Plant Type[Electricity Source,Electricity Timeslice\
		,Hour])
	~	$/(MW*hour)
	~		|

Hourly Expected Dispatch Costs by Power Plant Type[Electricity Timeslice,Hour,Electricity Source\
		]=
	Hourly Expected Dispatch Cost per Unit Total Electricity Dispatched by Power Plant Type\
		[Electricity Source,Electricity Timeslice,Hour]*Total Electricity Dispatched by Hour by Plant Type\
		[Electricity Timeslice,Hour,Electricity Source]
	~	$
	~		|

Hourly Net Energy Market Revenue from Total Electricity Dispatched by Power Plant Type\
		[Electricity Timeslice,Hour,Electricity Source]=
	Hourly Energy Market Revenue from Total Electricity Dispatched by Power Plant Type[Electricity Timeslice\
		,Hour,Electricity Source]
	-Hourly Expected Dispatch Costs by Power Plant Type[Electricity Timeslice,Hour,Electricity Source\
		]
	~	$
	~		|

Hourly Output from Distribued Solar Capacity on Peak Summer Day[Hour]=
	SUM(Hourly Output from Distributed Electricity Capacity[solar PV es, peak summer day electricity timeslice\
		!,Hour])
	/ ELMCOUNT(peak summer day electricity timeslice)
	~	MW*hour
	~		|

Hourly Output from Distributed Electricity Capacity[Electricity Source,Electricity Timeslice\
		,Hour]=
	SUM(Hourly Output from Distributed Electricity Capacity by Building Type[Electricity Source\
		,Electricity Timeslice,Hour,Building Type!])
	~	MW*hr
	~		|

Hourly Output from Distributed Electricity Capacity by Building Type[Electricity Source\
		,Electricity Timeslice,Hour,Building Type] :EXCEPT:    [solar PV es,Electricity Timeslice\
		,Hour,Building Type]=
	SYSHECF Start year Seasonal Expected Capacity Factor for Distributed Sources[Electricity Source\
		,Electricity Timeslice
	,Hour]
	  * Distributed Electricity Source Capacity[Building Type,Electricity Source]
	  *One Hour ~~|
Hourly Output from Distributed Electricity Capacity by Building Type[solar PV es,Electricity Timeslice\
		,Hour,Building Type]=
	MIN(
	
	  SYSHECF Start year Seasonal Expected Capacity Factor for Distributed Sources[solar PV es\
		,Electricity Timeslice,Hour]
	  * Distributed Electricity Source Capacity[Building Type,solar PV es]
	  *One Hour,
	
	  SUM(Buildings Sector Electricity Demand[Building Type,Building Component!])
	)
	~	MW*hr
	~		|

Hourly Output from Distributed Non Solar Capacity on Peak Summer Day[Hour]=
	SUM(Hourly Output from Distributed Electricity Capacity[Electricity Source!,peak summer day electricity timeslice\
		!,Hour
	])
	/ ELMCOUNT(peak summer day electricity timeslice)
	
	-Hourly Output from Distribued Solar Capacity on Peak Summer Day[Hour]
	~	MW*hour
	~		|

Hourly Output from Distributed Non Solar Capacity on Peak Winter Day[Hour]=
	SUM(Hourly Output from Distributed Electricity Capacity[Electricity Source!,peak winter day electricity timeslice\
		!,Hour
	])
	/ ELMCOUNT(peak winter day electricity timeslice)
	-Hourly Output from Distributed Solar Capacity on Peak Winter Day[Hour]
	~	MW*hour
	~		|

Hourly Output from Distributed Solar Capacity on Peak Winter Day[Hour]=
	SUM(Hourly Output from Distributed Electricity Capacity[solar PV es, peak winter day electricity timeslice\
		!,Hour])
	/ ELMCOUNT(peak winter day electricity timeslice)
	~	MW*hour
	~		|

Hourly PDF Values for Total Dispatch by Power Plant Type[Electricity Source,Electricity Timeslice\
		,Hour]=
	(1/sqrt(2*3.14159))*exp(-Hourly Z Score by Power Plant Type for Total Dispatch[Electricity Source\
		,Electricity Timeslice,Hour]^2/2)
	~	Dmnl
	~		|

Hourly Share of Battery Capacity That Can be Charged[Hybrid Electricity Source,Electricity Timeslice\
		,Hour]=
	MIN( 
	  Expected Capacity Factors by Hour for Plants Built This Year[Hybrid Electricity Source\
		,Electricity Timeslice,Hour],
	  HESBCpUEC Hybrid Electricity Source Battery Capacity per Unit Electricity Capacity
	 )
	~	Dmnl
	~		|

Hourly Share of Capacity that Can be Discharged[Hybrid Electricity Source,Electricity Timeslice\
		,Hour]=
	HESBCpUEC Hybrid Electricity Source Battery Capacity per Unit Electricity Capacity
	~	Dmnl
	~		|

Hourly T Values for Total Dispatch by Power Plant Type[Electricity Source,Electricity Timeslice\
		,Hour]=
	1/(1+0.231642*ABS(Hourly Z Score by Power Plant Type for Total Dispatch[Electricity Source\
		,Electricity Timeslice,Hour]))
	~	Dmnl
	~		|

Hourly Z Score by Power Plant Type for Total Dispatch[Electricity Source, Electricity Timeslice\
		, Hour]=
	ZIDZ((Marginal Dispatch Cost by Hour[Electricity Timeslice,Hour]-Dispatch Cost per Unit Electricity Output
	[Electricity Source]),ABS(NSDoDC Normalized Standard Deviation of Dispatch Costs[Electricity Source\
		]*Dispatch Cost per Unit Electricity Output
	[Electricity Source]))
	~	Dmnl
	~		|

Hours per Year=
	8760
	
	{
	We ignore leap years so that we can get consistent results
	for various values used in the model that should not change
	every four years, such as Expected Capacity Factor x Hours per Year.
	If we want to change this value for leap years, instead
	use the following code:
	
	IF THEN ELSE(
	   (MODULO(Time, 4) = 0 :AND: MODULO(Time, 100) <> 0) :OR: MODULO(Time, 400) = 0,
	   8784 {leap year},
	   8760 {normal year}
	)
	}
	~	hours
	~	Calculates the number of hours in the year, ignoring leap years.
	|

Household and Government Contribution to Change in Domestic Output by ISIC Code[ISIC Code\
		]=
	Government Contribution to Change in Domestic Output by ISIC Code[ISIC Code]
	+ Household Contribution to Change in Domestic Output by ISIC Code[ISIC Code]
	~	$
	~		|

Household Contribution to Change in Domestic Output by ISIC Code[ISIC Code]=
	Domestic Content Share of Consumption by ISIC Code[ISIC Code]
	* Household Contribution to Change in Global Output by ISIC Code[ISIC Code]
	~	$
	~		|

Household Contribution to Change in Global Output by ISIC Code[ISIC Code]=
	Change in Household Spending
	* Percent of Household Expenditures by ISIC Code[ISIC Code]
	~	$
	~		|

Household Expenditures by ISIC Code by Year[ISIC Code]=
	GaHEbIC Household Expenditures by ISIC Code[ISIC Code]
	* (1 + BAU Percent Change in Output by ISIC Code Using Endogenous Energy Revenues[ISIC Code\
		])
	~	$
	~		|

HPEC Hydrogen Production Equipment CapEx[Hydrogen Production Pathway]:INTERPOLATE::=
	GET DIRECT DATA(
	   'InputData/hydgn/HPEC/HPEC.csv',
	   ',',
	   '1',
	   'B2'
	)
	~	$/BTU
	~		|

HPEC Hydrogen Production Equipment OpEx[Hydrogen Production Pathway]:INTERPOLATE::=
	GET DIRECT DATA(
	   'InputData/hydgn/HPEC/HPEO.csv',
	   ',',
	   '1',
	   'B2'
	)
	~	$/BTU
	~		|

HPLC Hydrogen Production Logit Coefficient=
	GET DIRECT CONSTANTS(
	   'InputData/hydgn/HPLC/HPLC.csv',
	   ',',
	   'B2*'
	)
	~	Dmnl
	~		|

HPPECbP Hydrogen Production Percent Excess Capacity by Pathway[Hydrogen Production Pathway\
		]:INTERPOLATE::=
	GET DIRECT DATA(
	   'InputData/hydgn/HPPECbP/HPPECbP.csv',
	   ',',
	   '1',
	   'B2'
	)
	~	Dmnl
	~		|

HPS Hydrogen Production Shareweights[Hydrogen Production Pathway]:INTERPOLATE::=
	GET DIRECT DATA(
	   'InputData/hydgn/HPS/HPS.csv',
	   ',',
	   '1',
	   'B2'
	)
	~	Dmnl
	~		|

HPSD Hydrogen Production Subsidy Duration=
	GET DIRECT CONSTANTS(
	   'InputData/hydgn/HPSD/HPSD.csv',
	   ',',
	   'B2'
	)
	~	years
	~		|

HSR Household Savings Rate=
	GET DIRECT CONSTANTS(
	   'InputData/io-model/HSR/HSR.csv',
	   ',',
	   'B2'
	)
	~	Dmnl
	~		|

Hybrid Battery Cost per Unit Power Plant Capacity=
	(Battery Energy Cost per Unit Capacity
	  * GBSC Diurnal Grid Battery Daily Storage Duration
	  + Battery Power Cost per Unit Capacity
	)
	
	* HESBCpUEC Hybrid Electricity Source Battery Capacity per Unit Electricity Capacity
	~	$/MW
	~		|

Hybrid Battery Cost per Unit Power Plant Capacity after Construction Subsidies=
	Hybrid Battery Cost per Unit Power Plant Capacity
	* (1 - Percent Subsidy per Unit Grid Battery Capacity Deployed)
	~	$/MW
	~		|

Hybrid Electricity Source:
	onshore wind es,
	solar PV es,
	offshore wind es
	~	
	~		|

Hydrogen Demand by Sector[transportation sector]=
	SUM(Transportation Sector Fuel Used[Vehicle Type!,Cargo Type!,Vehicle Technology!,hydrogen tf\
		]) ~~|
Hydrogen Demand by Sector[electricity sector]=
	Last Year Electricity Fuel Use[hydrogen combustion turbine es]
	+ Last Year Electricity Fuel Use[hydrogen combined cycle es] ~~|
Hydrogen Demand by Sector[residential buildings sector]=
	SUM(Building Components Energy Use[urban residential,hydrogen bf,Building Component!\
		])
	+ SUM(Building Components Energy Use[rural residential,hydrogen bf,Building Component\
		!]) ~~|
Hydrogen Demand by Sector[commercial buildings sector]=
	SUM(Building Components Energy Use[commercial,hydrogen bf,Building Component!]) ~~|
Hydrogen Demand by Sector[industry sector]=
	SUM(Industrial Fuel Use[hydrogen if,Industry Category!])
	+ SUM(Industrial Fuel Use[green hydrogen if,Industry Category!])
	+ SUM(Industrial Fuel Use[low carbon hydrogen if,Industry Category!]) ~~|
Hydrogen Demand by Sector[district heat and hydrogen sector]=
	Fuel Used to Generate Heat[hydrogen if]
	+ Fuel Used to Generate Heat[green hydrogen if]
	+ Fuel Used to Generate Heat[low carbon hydrogen if] ~~|
Hydrogen Demand by Sector[LULUCF sector]=
	0 ~~|
Hydrogen Demand by Sector[geoengineering sector]=
	Geoengineering Sector Energy Use[hydrogen if]
	+ Geoengineering Sector Energy Use[green hydrogen if]
	+ Geoengineering Sector Energy Use[low carbon hydrogen if]
	~	BTU
	~		|

Hydrogen Fuel Carbon Tax Amount per Unit Energy[Industrial Fuel]=
	Carbon Tax Rate[district heat and hydrogen sector]
	/ Grams per Metric Ton CO2e
	* Hydrogen Fuel Taxable CO2e Emissions Intensity[Industrial Fuel]
	~	$/BTU
	~		|

Hydrogen Fuel Cost per Unit Energy[Industrial Fuel]=
	MAX(Pretax Fuel Cost per Unit Energy by Sector after Fuel Price Deregulation[industrial fuel within all fuels\
		,district heat and hydrogen sector
	]
	  + Hydrogen Fuel Total Tax or Subsidy Amount per Unit Energy[Industrial Fuel],
	0
	)
	~	$/BTU
	~		|

Hydrogen Fuel Taxable CO2e Emissions Intensity[Industrial Fuel]=
	SUM(
	  Industrial Fuel Pollutant Emissions Intensities This Year[cement and other nonmetallic minerals 239\
		,Pollutant!,Industrial Fuel
	]
	  * GWP by Pollutant[Pollutant!]
	  * Hydrogen Pollutants Taxed by Carbon Pricing[Pollutant!]
	)
	~	g CO2e/BTU
	~		|

Hydrogen Fuel Total Tax or Subsidy Amount per Unit Energy[Industrial Fuel]=
	Hydrogen Fuel Carbon Tax Amount per Unit Energy[Industrial Fuel]
	+ District Heat and Hydrogen Fuel Other Tax or Subsidy Amount per Unit Energy[Industrial Fuel\
		]
	~	$/BTU
	~		|

Hydrogen Pollutants Taxed by Carbon Pricing[Pollutant]=
	IF THEN ELSE(
	  Boolean Non BAU Pollutants Affected by Carbon Tax This Year = 0,
	  BPTbCP BAU Hydrogen Pollutants Taxed by Carbon Pricing[Pollutant],
	  PTbCP Hydrogen Pollutants Taxed by Carbon Pricing[Pollutant]
	)
	~	Dmnl
	~		|

Hydrogen Production by Pathway[Hydrogen Production Pathway]=
	New Hydrogen Production Capacity[Hydrogen Production Pathway] * One Year
	+ Surviving Capacity Used for Hydrogen Production[Hydrogen Production Pathway]
	~	BTU
	~		|

Hydrogen Production Capacity[Hydrogen Production Pathway]=
	Surviving Preexisting Hydrogen Production Capacity[Hydrogen Production Pathway]
	+ Hydrogen Production Capacity Installed During Model Run[Hydrogen Production Pathway\
		]
	~	BTU
	~		|

Hydrogen Production Capacity Factors by Pathway[Hydrogen Production Pathway]=
	ZIDZ(
	  Hydrogen Production by Pathway[Hydrogen Production Pathway],
	  Hydrogen Production Capacity[Hydrogen Production Pathway]
	)
	~	Dmnl
	~		|

Hydrogen Production Capacity Installed During Model Run[Hydrogen Production Pathway]=
	Surviving Hydrogen Production Capacity Installed During Model Run[Hydrogen Production Pathway\
		]
	+ New Hydrogen Production Capacity[Hydrogen Production Pathway] * One Year
	~	BTU
	~		|

Hydrogen Production Dispatch Cost[Hydrogen Production Pathway]=
	Cost per Unit New Hydrogen Production[Hydrogen Production Pathway]
	- ZIDZ(Hydrogen Production Equipment CapEx[Hydrogen Production Pathway],
	    Discount Factor to Levelize Capital Costs)
	- HPEC Hydrogen Production Equipment OpEx[Hydrogen Production Pathway]
	~	$/BTU
	~		|

Hydrogen Production Dispatch Cost Parameters as Vector[Hydrogen Production Pathway,ptype\
		]=
	3 ~~|
Hydrogen Production Dispatch Cost Parameters as Vector[Hydrogen Production Pathway,ppriority\
		]=
	Hydrogen Production Dispatch Cost[Hydrogen Production Pathway] * One BTU / One Dollar\
		 ~~|
Hydrogen Production Dispatch Cost Parameters as Vector[Hydrogen Production Pathway,pwidth\
		]=
	ABS(Normalized Standard Deviation of Dispatch Costs Mapped to Hydrogen Production Pathways\
		[Hydrogen Production Pathway]*Hydrogen Production Dispatch Cost[Hydrogen Production Pathway\
		] * One BTU / One Dollar) ~~|
Hydrogen Production Dispatch Cost Parameters as Vector[Hydrogen Production Pathway,pextra\
		]=
	0
	~	Dmnl
	~		|

Hydrogen Production Equipment CapEx[Hydrogen Production Pathway]=
	HPEC Hydrogen Production Equipment CapEx[Hydrogen Production Pathway]
	* (1 - RnD Hydrogen Capital Cost Perc Reduction This Year[Hydrogen Production Pathway\
		])
	~	$/BTU
	~		|

Hydrogen Production Pathway:
	electrolysis,
	natural gas reforming,
	coal gasification,
	biomass gasification,
	hydrocarbon partial oxidation,
	electrolysis with guaranteed clean electricity,
	natural gas reforming with CCS
	~	
	~		|

Hydrogen Production Pathways Qualifying as Low Carbon[Hydrogen Production Pathway] :EXCEPT:\
		 [electrolysis with guaranteed clean electricity],[natural gas reforming with CCS]=
	0 ~~|
Hydrogen Production Pathways Qualifying as Low Carbon[electrolysis with guaranteed clean electricity\
		]=
	1 ~~|
Hydrogen Production Pathways Qualifying as Low Carbon[natural gas reforming with CCS]\
		=
	1
	~	Dmnl
	~		|

Hydrogen Production Subsidies Expiring This Year[Hydrogen Production Pathway]= DELAY FIXED\
		 (
	Hydrogen Production Subsidies for Newly Built Plants[Hydrogen Production Pathway],
	HPSD Hydrogen Production Subsidy Duration,
	0)
	~	$/Year
	~		|

Hydrogen Production Subsidies for Newly Built Plants[Hydrogen Production Pathway]=
	New Hydrogen Production Capacity[Hydrogen Production Pathway]
	* Subsidy for Hydrogen Production by Pathway[Hydrogen Production Pathway]
	~	$/Year
	~		|

Hydrogen Production Subsidy Payments[Hydrogen Production Pathway]=
	(Last Year Hydrogen Production Subsidy Payments[Hydrogen Production Pathway]
	+ Hydrogen Production Subsidies for Newly Built Plants[Hydrogen Production Pathway] \
		* One Year
	- Hydrogen Production Subsidies Expiring This Year[Hydrogen Production Pathway] * One Year\
		)
	
	* Hydrogen Production Capacity Factors by Pathway[Hydrogen Production Pathway]
	~	$
	~		|

Hydrogen Sector Carbon Tax Rebate due to CCS=
	Amount of CO2 Sequestered by Hydrogen Sector
	* Carbon Tax Rate[district heat and hydrogen sector]
	~	$
	~		|

Hydrogen Sector Carbon Tax Revenue=
	SUM(
	  Hydrogen Sector Fuel Use[Industrial Fuel!]
	  * Hydrogen Fuel Carbon Tax Amount per Unit Energy[Industrial Fuel!]
	)
	~	$
	~		|

Hydrogen Sector CCS Transportation and Storage Costs=
	This Year Pollutants Sequestered by Hydrogen Sector[CO2]
	/ Grams per Metric Ton CO2e
	/ Grams Pollutant per Gram CO2e Unit Converter
	
	* Hydrogen Sector CCS Transportation and Storage Costs per Ton Sequestered
	~	$
	~		|

Hydrogen Sector CCS Transportation and Storage Costs per Ton Sequestered=
	MAX(
	  (CCSTaSC CCS Transportation and Storage Costs
	  - CCSTaSC CCS Transportation and Storage Subsidies)
	  * (1 - Perc Subsidy for Hydrogen Sector CCS Transport and Storage Costs This Year)\
		,
	
	  0
	)
	~	$/metric ton CO2e
	~		|

Hydrogen Sector CCS Transportation and Storage Subsidies=
	This Year Pollutants Sequestered by Hydrogen Sector[CO2]
	/ Grams per Metric Ton CO2e
	/ Grams Pollutant per Gram CO2e Unit Converter
	
	* 
	(
	  CCSTaSC CCS Transportation and Storage Subsidies
	  + 
	  ((CCSTaSC CCS Transportation and Storage Costs - CCSTaSC CCS Transportation and Storage Subsidies\
		)
	    * Perc Subsidy for Hydrogen Sector CCS Transport and Storage Costs This Year
	  )
	)
	~	$
	~		|

Hydrogen Sector Change in Energy Expenditures by Entity[Cash Flow Entity] :EXCEPT: [other energy suppliers\
		]=
	0 ~~|
Hydrogen Sector Change in Energy Expenditures by Entity[other energy suppliers]=
	SUM(Change in Amount Spent on Hydrogen Sector Fuels[Industrial Fuel!])
	~	$
	~		|

Hydrogen Sector Change in Fuel Industry Cash Flow[Industrial Fuel]=
	Change in Amount Spent on Hydrogen Sector Fuels[Industrial Fuel]
	- Change in Taxes Paid on Hydrogen Sector Fuels[Industrial Fuel]
	~	$
	~		|

Hydrogen Sector Change in Fuel Industry Cash Flow Mapped to All Fuels Subscript[All Fuels\
		] :EXCEPT: [industrial fuel within all fuels]=
	0 ~~|
Hydrogen Sector Change in Fuel Industry Cash Flow Mapped to All Fuels Subscript[industrial fuel within all fuels\
		] :EXCEPT: [hydrogen]=
	Hydrogen Sector Change in Fuel Industry Cash Flow[Industrial Fuel] ~~|
Hydrogen Sector Change in Fuel Industry Cash Flow Mapped to All Fuels Subscript[hydrogen\
		]=
	Hydrogen Sector Change in Fuel Industry Cash Flow[hydrogen if]
	+ Hydrogen Sector Change in Fuel Industry Cash Flow[green hydrogen if]
	+ Hydrogen Sector Change in Fuel Industry Cash Flow[low carbon hydrogen if]
	~	$
	~		|

Hydrogen Sector Change in Nonenergy Expenditures by Entity[Cash Flow Entity] :EXCEPT:\
		          [other energy suppliers],[government
]=
	0 ~~|
Hydrogen Sector Change in Nonenergy Expenditures by Entity[other energy suppliers]=
	SUM(Change in Amount Spent on Hydrogen Production Capital Eqpt[Hydrogen Production Pathway\
		!])
	+ SUM(Change in Amount Spent on Hydrogen Production OpEx[Hydrogen Production Pathway\
		!])
	+ Change in Hydrogen Sector CCS Transportation and Storage Costs
	+ Change in CCS OM Cost by Hydrogen Sector
	+ Change in CCS New Capital Eqpt Cost by Hydrogen Sector
	+ SUM(Change in Green Hydrogen Electricity Capacity Construction Costs[Electricity Source\
		!])
	+ SUM(Change in Green Hydrogen Electricity Fixed OM Costs[Electricity Source!])
	+ SUM(Change in Green Hydrogen Electricity Variable OM Costs[Electricity Source!])
	+ SUM(Change in Ongoing Capital Costs for Green Hydrogen Electricity[Electricity Source\
		!])
	+ Change in Hydrogen Sector Carbon Tax Rebate due to CCS
	+ SUM(Change in Financing Repayments for Hydrogen Production Eqpt[Hydrogen Production Pathway\
		!]) ~~|
Hydrogen Sector Change in Nonenergy Expenditures by Entity[government]=
	Change in CCS Subsidy Amount Paid to Hydrogen Sector
	+ Change in Hydrogen Sector CCS Transportation and Storage Subsidies
	+ SUM(Change in Green Hydrogen Electricity Capacity Construction Subsidies Paid[Electricity Source\
		!])
	+ SUM(Change in Green Hydrogen Electricity Generation Subsidies Paid[Electricity Source\
		!])
	+ SUM(Change in Hydrogen Production Subsidy Payments[Hydrogen Production Pathway!])
	~	$
	~		|

Hydrogen Sector Change in Nonenergy Industry Revenue by ISIC Code[ISIC Code] :EXCEPT:\
		                  [ISIC 31T33],[ISIC 352T353],[ISIC 20],[ISIC 64T66]=
	SUM(
	  (Change in Amount Spent on Hydrogen Production Capital Eqpt[Hydrogen Production Pathway\
		!]
	   + Change in CCS New Capital Eqpt Cost by Hydrogen Sector)
	  * SoHPCCbRIC Share of Hydrogen Production Capital Costs by Recipient ISIC Code[Hydrogen Production Pathway\
		!,ISIC Code
	]
	)
	
	+ SUM(Change in Green Hydrogen Electricity Capacity Construction Costs[Electricity Source\
		!]
	   * SoESCaOMCbIC Share of Electricity Sector Capital Costs by ISIC Code[Electricity Source\
		!,ISIC Code]
	  )
	
	+ SUM(Change in Ongoing Capital Costs for Green Hydrogen Electricity[Electricity Source\
		!]
	   * SoESCaOMCbIC Share of Electricity Sector Capital Costs by ISIC Code[Electricity Source\
		!,ISIC Code]
	  )
	
	+ SUM(Change in Green Hydrogen Electricity Fixed OM Costs[Electricity Source!]
	   * SoESCaOMCbIC Share of Electricity Sector Fixed OM Costs by ISIC Code[Electricity Source\
		!,ISIC Code]
	  )
	
	+ SUM(Change in Green Hydrogen Electricity Variable OM Costs[Electricity Source!]
	   * SoESCaOMCbIC Share of Electricity Sector Variable OM Costs by ISIC Code[Electricity Source\
		!,ISIC Code]
	  ) ~~|
Hydrogen Sector Change in Nonenergy Industry Revenue by ISIC Code[ISIC 31T33 {Other manufacturing; repair and installation of machinery and equipment}\
		]=
	SUM(
	  Change in Amount Spent on Hydrogen Production Capital Eqpt[Hydrogen Production Pathway\
		!]
	  * SoHPCCbRIC Share of Hydrogen Production Capital Costs by Recipient ISIC Code[Hydrogen Production Pathway\
		!,ISIC 31T33
	]
	)
	
	+ SUM(Change in Green Hydrogen Electricity Capacity Construction Costs[Electricity Source\
		!]
	   * SoESCaOMCbIC Share of Electricity Sector Capital Costs by ISIC Code[Electricity Source\
		!,ISIC 31T33]
	)
	
	+ SUM(Change in Ongoing Capital Costs for Green Hydrogen Electricity[Electricity Source\
		!]
	   * SoESCaOMCbIC Share of Electricity Sector Capital Costs by ISIC Code[Electricity Source\
		!,ISIC 31T33]
	)
	
	+ SUM(Change in Green Hydrogen Electricity Fixed OM Costs[Electricity Source!]
	   * SoESCaOMCbIC Share of Electricity Sector Fixed OM Costs by ISIC Code[Electricity Source\
		!,ISIC 31T33]
	)
	
	+ SUM(Change in Green Hydrogen Electricity Variable OM Costs[Electricity Source!]
	   * SoESCaOMCbIC Share of Electricity Sector Variable OM Costs by ISIC Code[Electricity Source\
		!,ISIC 31T33]
	)
	
	+ SUM(Change in Amount Spent on Hydrogen Production OpEx[Hydrogen Production Pathway\
		!])
	
	+ Change in CCS OM Cost by Hydrogen Sector ~~|
Hydrogen Sector Change in Nonenergy Industry Revenue by ISIC Code[ISIC 352T353 {energy pipelines and gas processing}\
		]=
	SUM(
	  Change in Amount Spent on Hydrogen Production Capital Eqpt[Hydrogen Production Pathway\
		!]
	  * SoHPCCbRIC Share of Hydrogen Production Capital Costs by Recipient ISIC Code[Hydrogen Production Pathway\
		!,ISIC 352T353
	]
	)
	
	+ SUM(Change in Green Hydrogen Electricity Capacity Construction Costs[Electricity Source\
		!]
	   * SoESCaOMCbIC Share of Electricity Sector Capital Costs by ISIC Code[Electricity Source\
		!,ISIC 352T353]
	)
	
	+ SUM(Change in Ongoing Capital Costs for Green Hydrogen Electricity[Electricity Source\
		!]
	   * SoESCaOMCbIC Share of Electricity Sector Capital Costs by ISIC Code[Electricity Source\
		!,ISIC 352T353]
	)
	
	+ SUM(Change in Green Hydrogen Electricity Fixed OM Costs[Electricity Source!]
	   * SoESCaOMCbIC Share of Electricity Sector Fixed OM Costs by ISIC Code[Electricity Source\
		!,ISIC 352T353]
	)
	
	+ SUM(Change in Green Hydrogen Electricity Variable OM Costs[Electricity Source!]
	   * SoESCaOMCbIC Share of Electricity Sector Variable OM Costs by ISIC Code[Electricity Source\
		!,ISIC 352T353]
	)
	
	+ Change in Hydrogen Sector CCS Transportation and Storage Costs
	+ Change in Hydrogen Sector CCS Transportation and Storage Subsidies ~~|
Hydrogen Sector Change in Nonenergy Industry Revenue by ISIC Code[ISIC 20 {chemicals}\
		]=
	SUM(
	  (Change in Amount Spent on Hydrogen Production Capital Eqpt[Hydrogen Production Pathway\
		!]
	   + Change in CCS New Capital Eqpt Cost by Hydrogen Sector)
	  * SoHPCCbRIC Share of Hydrogen Production Capital Costs by Recipient ISIC Code[Hydrogen Production Pathway\
		!,ISIC 20
	]
	)
	
	+ SUM(Change in Green Hydrogen Electricity Capacity Construction Costs[Electricity Source\
		!]
	   * SoESCaOMCbIC Share of Electricity Sector Capital Costs by ISIC Code[Electricity Source\
		!,ISIC 20]
	)
	
	+ SUM(Change in Ongoing Capital Costs for Green Hydrogen Electricity[Electricity Source\
		!]
	   * SoESCaOMCbIC Share of Electricity Sector Capital Costs by ISIC Code[Electricity Source\
		!,ISIC 20]
	)
	
	+ SUM(Change in Green Hydrogen Electricity Fixed OM Costs[Electricity Source!]
	   * SoESCaOMCbIC Share of Electricity Sector Fixed OM Costs by ISIC Code[Electricity Source\
		!,ISIC 20]
	)
	
	+ SUM(Change in Green Hydrogen Electricity Variable OM Costs[Electricity Source!]
	   * SoESCaOMCbIC Share of Electricity Sector Variable OM Costs by ISIC Code[Electricity Source\
		!,ISIC 20]
	)
	
	+ Change in CCS Subsidy Amount Paid to Hydrogen Sector
	+ SUM(Change in Hydrogen Production Subsidy Payments[Hydrogen Production Pathway!])
	+ SUM(Change in Green Hydrogen Electricity Capacity Construction Subsidies Paid[Electricity Source\
		!])
	+ SUM(Change in Green Hydrogen Electricity Generation Subsidies Paid[Electricity Source\
		!])
	+ Change in Hydrogen Sector Carbon Tax Rebate due to CCS ~~|
Hydrogen Sector Change in Nonenergy Industry Revenue by ISIC Code[ISIC 64T66 {Financial and insurance activities}\
		]=
	SUM(
	  (Change in Amount Spent on Hydrogen Production Capital Eqpt[Hydrogen Production Pathway\
		!]
	   + Change in CCS New Capital Eqpt Cost by Hydrogen Sector)
	  * SoHPCCbRIC Share of Hydrogen Production Capital Costs by Recipient ISIC Code[Hydrogen Production Pathway\
		!,ISIC 64T66
	]
	)
	
	+ SUM(Change in Green Hydrogen Electricity Capacity Construction Costs[Electricity Source\
		!]
	   * SoESCaOMCbIC Share of Electricity Sector Capital Costs by ISIC Code[Electricity Source\
		!,ISIC 64T66]
	  )
	
	+ SUM(Change in Ongoing Capital Costs for Green Hydrogen Electricity[Electricity Source\
		!]
	   * SoESCaOMCbIC Share of Electricity Sector Capital Costs by ISIC Code[Electricity Source\
		!,ISIC 64T66]
	  )
	
	+ SUM(Change in Green Hydrogen Electricity Fixed OM Costs[Electricity Source!]
	   * SoESCaOMCbIC Share of Electricity Sector Fixed OM Costs by ISIC Code[Electricity Source\
		!,ISIC 64T66]
	  )
	
	+ SUM(Change in Green Hydrogen Electricity Variable OM Costs[Electricity Source!]
	   * SoESCaOMCbIC Share of Electricity Sector Variable OM Costs by ISIC Code[Electricity Source\
		!,ISIC 64T66]
	  )
	
	+ SUM(Change in Financing Repayments for Hydrogen Production Eqpt[Hydrogen Production Pathway\
		!])
	~	$
	~		|

Hydrogen Sector Change in Revenue by Entity[government]=
	SUM(Change in Taxes Paid on Hydrogen Sector Fuels[Industrial Fuel!]) ~~|
Hydrogen Sector Change in Revenue by Entity[nonenergy industries]=
	SUM(Hydrogen Sector Change in Nonenergy Industry Revenue by ISIC Code[ISIC Code!]) ~~|
Hydrogen Sector Change in Revenue by Entity[labor and consumers]=
	0 ~~|
Hydrogen Sector Change in Revenue by Entity[foreign entities]=
	0 ~~|
Hydrogen Sector Change in Revenue by Entity[electricity suppliers]=
	Hydrogen Sector Change in Fuel Industry Cash Flow[electricity if] ~~|
Hydrogen Sector Change in Revenue by Entity[coal suppliers]=
	Hydrogen Sector Change in Fuel Industry Cash Flow[hard coal if] ~~|
Hydrogen Sector Change in Revenue by Entity[natural gas and petroleum suppliers]=
	Hydrogen Sector Change in Fuel Industry Cash Flow[natural gas if]
	+ Hydrogen Sector Change in Fuel Industry Cash Flow[petroleum diesel if]
	+ Hydrogen Sector Change in Fuel Industry Cash Flow[crude oil if]
	+ Hydrogen Sector Change in Fuel Industry Cash Flow[heavy or residual fuel oil if]
	+ Hydrogen Sector Change in Fuel Industry Cash Flow[LPG propane or butane if] ~~|
Hydrogen Sector Change in Revenue by Entity[biomass and biofuel suppliers]=
	Hydrogen Sector Change in Fuel Industry Cash Flow[biomass if] ~~|
Hydrogen Sector Change in Revenue by Entity[other energy suppliers]=
	Hydrogen Sector Change in Fuel Industry Cash Flow[heat if]
	+ Hydrogen Sector Change in Fuel Industry Cash Flow[hydrogen if]
	~	$
	~		|

Hydrogen Sector CO2e Emissions=
	SUM(
	  Hydrogen Sector Pollutant Emissions[Pollutant!,Industrial Fuel!]
	  * GWP by Pollutant[Pollutant!]
	)
	~	g CO2e
	~		~	:SUPPLEMENTARY 
	|

Hydrogen Sector Electricity Demand=
	Hydrogen Sector Fuel Use Before Green Hydrogen[electricity if]
	* MWh per BTU
	~	MW*hr
	~		|

Hydrogen Sector Fuel Use[Industrial Fuel]=
	Hydrogen Sector Fuel Use Before Green Hydrogen[Industrial Fuel]
	+ Fuel Use for Green Hydrogen Production[Industrial Fuel]
	~	BTU
	~		|

Hydrogen Sector Fuel Use Before Green Hydrogen[Industrial Fuel]=
	SUM(Hydrogen Sector Fuel Use by Pathway[Hydrogen Production Pathway!,Industrial Fuel\
		])
	+ Fuel Used for CCS by Hydrogen Sector[Industrial Fuel]
	~	BTU
	~		|

Hydrogen Sector Fuel Use by Pathway[Hydrogen Production Pathway,Industrial Fuel]=
	Hydrogen Production by Pathway[Hydrogen Production Pathway]
	
	* FIoHP Fuel Intensity of Hydrogen Production[Hydrogen Production Pathway,Industrial Fuel\
		]
	~	BTU
	~		|

Hydrogen Sector Grid Electricity Demand=
	Hydrogen Sector Electricity Demand
	- Hydrogen Sector Off Grid Electricity Demand for Green Hydrogen
	~	MW*hour
	~		|

Hydrogen Sector Off Grid Electricity Demand for Green Hydrogen=
	Hydrogen Sector Electricity Demand
	  * ZIDZ(
	      Hydrogen Sector Fuel Use by Pathway[electrolysis with guaranteed clean electricity\
		,electricity if],
	
	      (Hydrogen Sector Fuel Use by Pathway[electrolysis with guaranteed clean electricity\
		,electricity if]
	        + Hydrogen Sector Fuel Use by Pathway[electrolysis,electricity if]
	       )
	    )
	~	MW*hour
	~		|

Hydrogen Sector Off Grid Electricity Demand for Green Hydrogen That is New This Year=
	MAX(
	  Hydrogen Sector Off Grid Electricity Demand for Green Hydrogen
	  - Last Year Hydrogen Sector Off Grid Electricity Demand for Green Hydrogen,
	
	  0
	)
	~	MW*hour
	~		|

Hydrogen Sector Pollutant Emissions[Pollutant,Industrial Fuel] :EXCEPT:  [Pollutant, \
		natural gas if]=
	Hydrogen Sector Fuel Use[Industrial Fuel]
	* Industrial Fuel Pollutant Emissions Intensities This Year[cement and other nonmetallic minerals 239\
		,Pollutant,Industrial Fuel
	] ~~|
Hydrogen Sector Pollutant Emissions[Pollutant,natural gas if]=
	Hydrogen Sector Fuel Use[natural gas if]
	* Industrial Fuel Pollutant Emissions Intensities This Year[cement and other nonmetallic minerals 239\
		,Pollutant,natural gas if]
	- This Year Pollutants Sequestered by Hydrogen Sector[Pollutant]
	~	g pollutant
	~	Hydrogen supply isn't an industry, but it uses industrial sector fuel \
		emissions intensities.  Since the emissions intensities are subscripted by \
		industry, we must choose an industry to use, though the emissions \
		intensities may be the same for all industries.  We use the cement \
		industry as our model, as cement is produced all over the world, is a \
		major emitter, and therefore is unlikely to be repurposed as another \
		industry in EPS model adaptations.
	|

Hydrogen Sector Subtotal Change in Capital Expenditures=
	SUM(Change in Amount Spent on Hydrogen Production Capital Eqpt[Hydrogen Production Pathway\
		!])
	+ Change in CCS OM Cost by Hydrogen Sector
	~	$
	~		|

Hydrogen Sector Subtotal Change in OM Expenditures=
	SUM(Change in Amount Spent on Hydrogen Production OpEx[Hydrogen Production Pathway!]\
		)
	+ Change in CCS OM Cost by Hydrogen Sector
	+ Change in Hydrogen Sector CCS Transportation and Storage Costs
	~	$
	~		|

Hydrogen Subtotal Change in Subsidies=
	Change in CCS Subsidy Amount Paid to Hydrogen Sector
	+ Change in Hydrogen Sector CCS Transportation and Storage Subsidies
	+ SUM(Change in Hydrogen Production Subsidy Payments[Hydrogen Production Pathway!])
	+ Change in Hydrogen Sector Carbon Tax Rebate due to CCS
	~	$
	~		|

Hypothetical Annual Costs for Plant Types with No Capacity[Electricity Source]=
	SUM(Five Year Average Hourly Expected Dispatch Cost per Unit Total Electricity Dispatched by Power Plant Type\
		[Electricity Source
	,Electricity Timeslice!,Hour!]*SHELF Days per Electricity Timeslice[Electricity Timeslice\
		!]*Hypothetical Hourly Electricity Capacity Factor
	[Electricity Timeslice!,Hour!,Electricity Source])
	* One Hour
	~	$/MW
	~		|

Hypothetical Annual Revenue for Plant Types with No Capacity[Electricity Source]=
	SUM(Five Year Average Marginal Dispatch Cost by Hour[Electricity Timeslice!,Hour!]*Hypothetical Hourly Electricity Capacity Factor
	[Electricity Timeslice!,Hour!,Electricity Source]*SHELF Days per Electricity Timeslice\
		[Electricity Timeslice!])
	* One Hour
	~	$/MW
	~		|

Hypothetical BAU Components Energy Use[Building Type,Building Fuel,Building Component\
		]=
	Hypothetical BAU Last Year Components Energy Use[Building Type,Building Fuel,Building Component\
		]
	+ Hypothetical BAU New Components Energy Use after Envelope Effects[Building Type,Building Fuel\
		,Building Component] * One Year
	- Hypothetical BAU Retiring Components Energy Use after Envelope Effects[Building Type\
		,Building Fuel,Building Component] * One Year
	~	BTU
	~		|

Hypothetical BAU Last Year Components Energy Use[Building Type,Building Fuel,Building Component\
		]= INTEG (
	Hypothetical BAU New Components Energy Use after Envelope Effects[Building Type,Building Fuel\
		,Building Component]
	- Hypothetical BAU Retiring Components Energy Use after Envelope Effects[Building Type\
		,Building Fuel,Building Component],
		SYCEU Start Year Components Energy Use[Building Type,Building Fuel,Building Component\
		])
	~	BTU
	~		|

Hypothetical BAU New Components Energy Use after Envelope Effects[Building Type,Building Fuel\
		,heating]=
	Hypothetical BAU New Components Energy Use after Fuel Shifting[Building Type,Building Fuel\
		,heating]
	* Hypothetical BAU New Components Energy Use after Fuel Shifting[Building Type,Building Fuel\
		,envelope]
	* Envelope Multiplier Unit Correction Factor
	/ One Year ~~|
Hypothetical BAU New Components Energy Use after Envelope Effects[Building Type,Building Fuel\
		,cooling and ventilation]=
	Hypothetical BAU New Components Energy Use after Fuel Shifting[Building Type,Building Fuel\
		,cooling and ventilation]
	* Hypothetical BAU New Components Energy Use after Fuel Shifting[Building Type,Building Fuel\
		,envelope]
	* Envelope Multiplier Unit Correction Factor
	/ One Year ~~|
Hypothetical BAU New Components Energy Use after Envelope Effects[Building Type,Building Fuel\
		,envelope]=
	0 ~~|
Hypothetical BAU New Components Energy Use after Envelope Effects[Building Type,Building Fuel\
		,lighting]=
	Hypothetical BAU New Components Energy Use after Fuel Shifting[Building Type,Building Fuel\
		,lighting]
	/ One Year ~~|
Hypothetical BAU New Components Energy Use after Envelope Effects[Building Type,Building Fuel\
		,appliances]=
	Hypothetical BAU New Components Energy Use after Fuel Shifting[Building Type,Building Fuel\
		,appliances]
	/ One Year ~~|
Hypothetical BAU New Components Energy Use after Envelope Effects[Building Type,Building Fuel\
		,other component]=
	Hypothetical BAU New Components Energy Use after Fuel Shifting[Building Type,Building Fuel\
		,other component]
	/ One Year
	~	BTU/Year
	~		|

Hypothetical BAU New Components Energy Use after Envelope Effects after Lifetime[Building Type\
		,Building Fuel,Building Component]= DELAY FIXED (
	Hypothetical BAU New Components Energy Use after Envelope Effects[Building Type,Building Fuel\
		,Building Component],
	CL Component Lifetime[Building Type,Building Component],
	0)
	~	BTU/Year
	~		|

Hypothetical BAU New Components Energy Use after Fuel Shifting[Building Type,electricity bf\
		,Building Component] :EXCEPT: [Building Type,electricity bf,envelope]=
	{Remove fuel use in accordance with policy setting.}
	
	BAU New Components Energy Use[Building Type,electricity bf,Building Component]
	* (1 - Fraction of New Bldg Components Shifted to Other Fuels This Year[Building Component\
		,Building Type])
	
	
	{Add all fuels shifting to electricity with an efficiency adjustment.}
	
	+ SUM(
	    BAU New Components Energy Use[Building Type,Source Building Fuel!,Building Component\
		]
	    * Fraction of New Bldg Components Shifted to Other Fuels This Year[Building Component\
		,Building Type]
	    * RBFF Recipient Buildings Fuel Fractions[Source Building Fuel!,electricity bf]
	  )
	  * (1 - PCFURfE Percentage Components Fuel Use Reduction for Electricity[Building Component\
		])
	
	
	{Electricity that was removed and returned as electricity (unchanged) shouldn't have an efficiency adjustment.
	This section adds back in the electricity that was removed due to the efficiency adjustment applied to electricity that remained electricity.}
	
	+ BAU New Components Energy Use[Building Type,electricity bf,Building Component]
	  * Fraction of New Bldg Components Shifted to Other Fuels This Year[Building Component\
		,Building Type]
	  * RBFF Recipient Buildings Fuel Fractions[electricity bf,electricity bf]
	  * PCFURfE Percentage Components Fuel Use Reduction for Electricity[Building Component\
		] ~~|
Hypothetical BAU New Components Energy Use after Fuel Shifting[Building Type,Target Building Fuel\
		,Building Component] :EXCEPT: [Building Type,Building Fuel,envelope],[Building Type\
		,electricity bf,Building Component]=
	{Remove fuel use in accordance with policy setting.}
	
	BAU New Components Energy Use[Building Type,Target Building Fuel,Building Component]
	* (1 - Fraction of New Bldg Components Shifted to Other Fuels This Year[Building Component\
		,Building Type])
	
	
	{Add all fuels without an efficiency adjustment.}
	
	+ SUM(
	    BAU New Components Energy Use[Building Type,Source Building Fuel!,Building Component\
		]
	    * Fraction of New Bldg Components Shifted to Other Fuels This Year[Building Component\
		,Building Type]
	    * RBFF Recipient Buildings Fuel Fractions[Source Building Fuel!,Target Building Fuel\
		]
	  )
	
	
	{Electricity that was shifted to a non-electricity fuel needs an efficiency adjustment.
	This section adds the extra fuel needed to provide similar useful work as electricity used to provide.}
	
	+ BAU New Components Energy Use[Building Type,electricity bf,Building Component]
	  * Fraction of New Bldg Components Shifted to Other Fuels This Year[Building Component\
		,Building Type]
	  * RBFF Recipient Buildings Fuel Fractions[electricity bf,Target Building Fuel]
	  * (
	      1 / (1 - PCFURfE Percentage Components Fuel Use Reduction for Electricity[Building Component\
		])
	      - 1
	    ) ~~|
Hypothetical BAU New Components Energy Use after Fuel Shifting[Building Type,Building Fuel\
		,envelope]=
	BAU New Components Energy Use[Building Type,Building Fuel,envelope]
	~	BTU
	~	These equations are complicated because we need to apply an efficiency \
		adjustment when fuels shift between electricity and a non-electricity \
		fuel.  We first remove all the fuels that are being shifted (including \
		some that may be staying the same), then we add in all the fuels \
		reallocated to their target fuel types.  When the target fuel is \
		electricity, we apply an efficiency adjustment to all of the added fuels, \
		and then we undo the adjustment for electricitiy that was "shifted" to \
		electricity (i.e. stayed the same).  When the target fuel is not \
		electricity, we add all of the fuels without an efficiency adjustment, and \
		then we add additional fuel to the target fuel if the source fuel was \
		electricity to make the efficiency adjustment.  If you are having trouble \
		understanding these equations, first make sure you understand the simpler \
		examples of fuel shifting code that don't involve electricity efficiency \
		adjustments, which can be found in the calculated variables immediately \
		downstream of the following two input variables: hydgn/RHPF and indst/RIFF.
	|

Hypothetical BAU Potential Buildings Fuel Cost[Building Type,Building Fuel,Building Component\
		]=
	Hypothetical BAU Components Energy Use[Building Type,Building Fuel,Building Component\
		]
	* BAU Buildings Fuel Cost per Unit Energy[Building Fuel,Building Type]
	~	$
	~		|

Hypothetical BAU Retiring Components Energy Use after Envelope Effects[Building Type,\
		Building Fuel,Building Component]=
	MAX(
	  0,
	
	  MIN(
	    Hypothetical BAU Last Year Components Energy Use[Building Type,Building Fuel,Building Component\
		]
	    / One Year,
	
	    IF THEN ELSE(
	      Time < INITIAL TIME + CL Component Lifetime[Building Type,Building Component],
	
	      ZIDZ(
	        SYCEU Start Year Components Energy Use[Building Type,Building Fuel,Building Component\
		],
	        CL Component Lifetime[Building Type,Building Component]
	      ),
	
	      Hypothetical BAU New Components Energy Use after Envelope Effects after Lifetime\
		[Building Type,Building Fuel,Building Component]
	    )
	  )
	)
	~	BTU/Year
	~		|

Hypothetical Fraction of Capacity Dispatched Through Elec Portfolio Dispatch[Electricity Source\
		,Electricity Timeslice,Hour,RPS]=
	IF THEN ELSE(
	
	  Total Electricity Demand Including TnD Losses
	  * Elec Portfolio Percentage to Seek This Year[RPS] <
	
	  Expected Elec Portfolio Qualifying Dispatch from Last Year Capacity and This Year Mandated Change in Capacity\
		[RPS],
	
	  0,
	
	  MAX(
	  Marginal Capacity Factor by Hour[Electricity Source,Electricity Timeslice,Hour,RPS\
		]
	  * RQSD RPS Qualifying Source Definitions[Electricity Source]
	  
	  - Weighted Average Expected Capacity Factors by Hour Without Hypothetical Adjustments\
		[Electricity Source,Electricity Timeslice
	,Hour]
	  * Guaranteed Dispatch Percentage for Elec Portfolio Std Qualifying Resources[Electricity Source\
		,RPS],
	
	  0
	 )
	) ~~|
Hypothetical Fraction of Capacity Dispatched Through Elec Portfolio Dispatch[Electricity Source\
		,Electricity Timeslice,Hour,CES]=
	IF THEN ELSE(
	
	  Total Electricity Demand Including TnD Losses
	  * Elec Portfolio Percentage to Seek This Year[CES] <
	
	  Expected Elec Portfolio Qualifying Dispatch from Last Year Capacity and This Year Mandated Change in Capacity\
		[CES],
	
	  0,
	
	  MAX(
	  Marginal Capacity Factor by Hour[Electricity Source,Electricity Timeslice,Hour,CES\
		]
	  * RQSD CES Qualifying Source Definitions[Electricity Source]
	  
	  - Weighted Average Expected Capacity Factors by Hour Without Hypothetical Adjustments\
		[Electricity Source,Electricity Timeslice
	,Hour]
	  * Guaranteed Dispatch Percentage for Elec Portfolio Std Qualifying Resources[Electricity Source\
		,CES],
	
	  0
	 )
	)
	~	Dmnl
	~		|

Hypothetical Fraction of Capacity Dispatched Through Guaranteed Dispatch[Electricity Source\
		,Electricity Timeslice,Hour]=
	IF THEN ELSE(
	
	  Total Electricity Demand by Hour After Demand Altering Technologies[Electricity Timeslice\
		,Hour] <
	
	  SUM(Last Year Capacity and This Year Mandated Change in Capacity by Electricity Source\
		[Electricity Source!]
	  * Weighted Average Expected Capacity Factors by Hour Without Hypothetical Adjustments\
		[Electricity Source!,Electricity Timeslice,Hour]
	  * Guaranteed Dispatch Percentages for Policy Case[Electricity Source!]
	  * One Hour
	  ),
	
	  0,
	
	  Expected Capacity Factors by Hour for Plants Built This Year Without Hypothetical Calculations\
		[Electricity Source
	,Electricity Timeslice,Hour]
	  * Guaranteed Dispatch Percentages for Policy Case[Electricity Source]
	)
	~	Dmnl
	~		|

Hypothetical Hourly Electricity Capacity Factor[Electricity Timeslice,Hour,Electricity Source\
		]=
	MIN(
	  Hourly Bid Electricity Factors for Plants Built This Year[Electricity Timeslice,Hour\
		,Electricity Source],
	
	  Hypothetical Hourly Electricity Capacity Factor for Least Cost Dispatch[Electricity Timeslice\
		,Hour,Electricity Source
	]
	  + MAX(Hypothetical Fraction of Capacity Dispatched Through Elec Portfolio Dispatch\
		[Electricity Source,Electricity Timeslice
	,Hour,RPS],
	        Hypothetical Fraction of Capacity Dispatched Through Elec Portfolio Dispatch\
		[Electricity Source,Electricity Timeslice
	,Hour,CES]
	    )
	  + Hypothetical Fraction of Capacity Dispatched Through Guaranteed Dispatch[Electricity Source\
		,Electricity Timeslice,Hour
	]
	)
	~	Dmnl
	~		|

Hypothetical Hourly Electricity Capacity Factor for Least Cost Dispatch[Electricity Timeslice\
		,Hour,Electricity Source]=
	SUPPLY AT PRICE(
	    Hourly Bid Electricity Factors for Plants Built This Year[Electricity Timeslice,\
		Hour,Electricity Source],
	    Five Year Average Power Plant Dispatch Parameters as Vector for New Plants[Electricity Source\
		,ptype],
	    Five Year Average Marginal Dispatch Cost by Hour[Electricity Timeslice,Hour])
	~	Dmnl
	~		|

Hypothetical Net Revenue for Plant Types with No Capacity per MW[Electricity Source]=
	Hypothetical Annual Revenue for Plant Types with No Capacity[Electricity Source]
	-Hypothetical Annual Costs for Plant Types with No Capacity[Electricity Source]
	~	$/MW
