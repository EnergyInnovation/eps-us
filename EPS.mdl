Clean Dispatchable Electricity Source:
	hard coal w CCS es,
	natural gas combined cycle w CCS es,
	biomass w CCS es,
	lignite w CCS es,
	small modular reactor es,
	hydrogen combustion turbine es,
	hydrogen combined cycle es
	~	
	~		|

Clean Elec Requirement:
	RPS,
	CES
	~	
	~		|

Clean Electricity Std Percentage=
	0
	~	Dmnl
	~		|

Clean Industrial Heat Investment Subsidy Amount Paid[Industry Category]=
	SUM(Clean Industrial Heat Investment Subsidy Rate[Industry Category,industrial heating process\
		!,Industrial Fuel!]
	  * New Industrial Equipment Potential Energy Use by Fuel Type and Process[Industry Category\
		,Industrial Fuel!,industrial heating process!]
	)
	~	$
	~		|

Clean Industrial Heat Investment Subsidy Rate[Industry Category,industrial heating process\
		,Industrial Fuel]=
	Industrial Equipment Capital Cost per Unit Energy Before Clean Heat Subsidy[Industry Category\
		,Industrial Fuel,industrial heating process]
	* (BCHSR BAU Clean Heat Investment Subsidy Rate[industrial heating process]
	  + Perc Subsidy for Clean Industrial Heat Equipment This Year[industrial heating process\
		])
	* IFTQfS Industrial Fuel Types Qualifying for Clean Heat Investment Subsidy[Industrial Fuel\
		]
	~	$/BTU
	~		|

Clean Industrial Heat Production Subsidy Rate by Equipment Vintage[Industrial Fuel,industrial heating process\
		,Model Run Vintage]=
	IF THEN ELSE(
	  This Year Model Run Vintage Flag[Model Run Vintage] = 1,
	  Clean Industrial Heat Subsidy Rate by Fuel Type[Industrial Fuel,industrial heating process\
		],
	  IF THEN ELSE(
	    Dimensionless Time < Model Run Vintage to Year Mapping[Model Run Vintage],
	    0,
	    IF THEN ELSE(
	      Dimensionless Time >= Model Run Vintage to Year Mapping[Model Run Vintage] + BCHPD BAU Clean Heat PTC Duration\
		/One Year,
	      0,
	      Last Year Clean Industrial Heat Production Subsidy Rate by Equipment Vintage[Industrial Fuel\
		,industrial heating process
	,Model Run Vintage]
	    )
	
	  )
	)
	~	$/BTU
	~		|

Clean Industrial Heat Subsidy Rate by Fuel Type[Industrial Fuel,industrial heating process\
		]=
	(
	 Subsidy for Clean Industrial Heat Production This Year[industrial heating process]
	 / BpTPEU BTU per Medium Primary Energy Unit
	
	 + BCHSR BAU Clean Heat Production Subsidy Rate[industrial heating process]
	)
	
	* IFTQfS Industrial Fuel Types Qualifying for Clean Heat Production Subsidy[Industrial Fuel\
		]
	~	$/BTU
	~		|

Clean Industrial Heat Subsidy Rate by Fuel Type in Future Years[Industrial Fuel,industrial heating process\
		,Future Year]=
	IF THEN ELSE(
	
	  Numerical Future Year Definitions[Future Year] - Time < 0,
	  0, 
	  IF THEN ELSE(
	    Numerical Future Year Definitions[Future Year] - Time >= BCHPD BAU Clean Heat PTC Duration\
		, 
	    0,
	    Clean Industrial Heat Subsidy Rate by Fuel Type[Industrial Fuel,industrial heating process\
		]
	  )
	)
	~	$/BTU
	~		|

CO2 Abated by Improved Forest Management This Year=
	Land Area Newly Affected by Policy[land forest management] * One Year
	* CApULAbIFM CO2 Abated per Unit Land Area by Improved Forest Management
	~	g pollutant
	~		|

CO2 Abated by Land Use Policy This Year[Land Use Policy] :EXCEPT:  [land forest management\
		]=
	Cumulative Total Land Area Affected by Policy[Land Use Policy]
	* CSpULApYbP CO2 Sequestered per Unit Land Area per Year by Policy[Land Use Policy] ~~|
CO2 Abated by Land Use Policy This Year[land forest management]=
	CO2 Abated by Improved Forest Management This Year
	~	g pollutant
	~		|

CO2 Captured via DAC=
	DACD Direct Air Capture Potential
	*
	(BFoDACPA BAU Fraction of Direct Air Capture Potential Achieved
	 + (1 - BFoDACPA BAU Fraction of Direct Air Capture Potential Achieved)
	 * Fraction of Direct Air Capture Potential Achieved This Year
	)
	~	metric tons CO2e
	~		|

CO2 Captured via DAC in Grams=
	CO2 Captured via Geoengineering
	* Grams per Metric Ton CO2e
	* Grams Pollutant per Gram CO2e Unit Converter
	~	g pollutant
	~		|

CO2 Captured via Enhanced Rock Weathering=
	ERWD Enhanced Rock Weathering Potential
	* 
	(BFoERWPA BAU Fraction of Enhanced Rock Weathering Potential Achieved
	 + (1 - BFoERWPA BAU Fraction of Enhanced Rock Weathering Potential Achieved)
	 * Fraction of Enhanced Rock Weathering Potential Achieved This Year
	)
	~	metric tons CO2e
	~		|

CO2 Captured via Geoengineering=
	CO2 Captured via DAC
	+ CO2 Captured via Enhanced Rock Weathering
	~	metric tons CO2e
	~		|

CO2 Emissions Intensity by Fuel for All Fuels[All Fuels] :EXCEPT:     [hard coal],[natural gas\
		],[biomass],[petroleum gasoline
],[petroleum diesel],[biofuel gasoline],[biofuel diesel],[jet fuel or kerosene],[lignite\
		],[crude oil],[heavy or residual fuel oil
],[LPG propane or butane],[municipal solid waste]=
	0 ~~|
CO2 Emissions Intensity by Fuel for All Fuels[hard coal]=
	Electricity Fuel Pollutant Emissions Intensities This Year[CO2,hard coal es] ~~|
CO2 Emissions Intensity by Fuel for All Fuels[natural gas]=
	Electricity Fuel Pollutant Emissions Intensities This Year[CO2,natural gas combined cycle es\
		] ~~|
CO2 Emissions Intensity by Fuel for All Fuels[biomass]=
	Electricity Fuel Pollutant Emissions Intensities This Year[CO2,biomass es] ~~|
CO2 Emissions Intensity by Fuel for All Fuels[petroleum gasoline]=
	Transportation Fuel Pollutant Emissions Intensities This Year[LDVs,CO2,petroleum gasoline tf\
		] ~~|
CO2 Emissions Intensity by Fuel for All Fuels[petroleum diesel]=
