	SUM(SHELF Seasonal Hourly Equipment Load Factors for Residential Buildings Sector[Building Component\
		,Electricity Timeslice,Hour!])
	/ ELMCOUNT(Hour)
	~	Dmnl
	~		|

Mean Load Factors for Transportation Sector[Vehicle Type,Electricity Timeslice]=
	SUM(SHELF Seasonal Hourly Equipment Load Factors for Transportation Sector[Vehicle Type\
		,Electricity Timeslice,Hour!])
	/ ELMCOUNT(Hour)
	~	Dmnl
	~		|

Metric Tons CO2 Stored per MWh[Electricity Source] :EXCEPT:  [biomass w CCS es]=
	Heat Rate by Electricity Fuel for Plants Built This Year[Electricity Source]
	* Electricity Fuel Pollutant Emissions Intensities This Year[CO2,Electricity Source]
	* CCP CO2 Capture Potential by Electricity Source[Electricity Source]
	/ Grams per Metric Ton CO2e
	/ Grams Pollutant per Gram CO2e Unit Converter ~~|
Metric Tons CO2 Stored per MWh[biomass w CCS es]=
	BwCCSSpM Biomass with CCS Storage per MWh
	~	metric ton CO2e/(MW*hour)
	~		|

MHV Methane Heating Value=
