Fuel Production[All Fuels]=
	BAU Fuel Production Imports and Exports[All Fuels,production]
	+ Change in Fuel Production[All Fuels]
	~	BTU
	~		|

Fuel Production Cap[All Fuels]=
	Initial BAU Fuel Production Imports and Exports[All Fuels,production]
	+ Maximum Absolute Increase in Fuel Production[All Fuels]
	~	BTU
	~		|

Fuel Production Mapped to ISIC Codes[ISIC Code]=
	BAU Fuel Production Mapped to ISIC Codes[ISIC Code]
	+ Change in Fuel Production Mapped to ISIC Codes[ISIC Code]
	~	BTU
	~		|

Fuel Tax or Subsidy by Sector[All Fuels,Sectors] :EXCEPT:      [electricity,Sectors]=
	MAX(BAU Fuel Tax by Sector[All Fuels,Sectors]
	
	  + BAU Pretax Fuel Price by Sector[All Fuels,Sectors]
	    * Additional Fuel Tax or Subsidy Rate by Fuel This Year[All Fuels,Sectors],
	
	BAU Pretax Fuel Price by Sector[All Fuels,Sectors] * -1
	) ~~|
Fuel Tax or Subsidy by Sector[electricity,Sectors]=
	MAX(BAU Fuel Tax by Sector[electricity,Sectors]
	
	  + This Year Pretax Electricity Price by Sector[Sectors]
	    * Additional Fuel Tax or Subsidy Rate by Fuel This Year[electricity,Sectors],
	
	This Year Pretax Electricity Price by Sector[Sectors]* -1
	)
	~	$/BTU
	~		|

Fuel Tax or Subsidy Rate by Fuel in Future Years[All Fuels,Sectors,Future Year]=
	IF THEN ELSE(
	  Dimensionless Time >= FYIbFP First Year Impacted by Future Policies,
	
	  BFPaT BAU Fuel Tax by Sector[All Fuels,Sectors,Future Year]
	  + 
	  (
	    Additional Fuel Tax or Subsidy Rate by Fuel by Year from Policy Setting[All Fuels\
		,Sectors,Future Year]
	    * BFPAT BAU Pretax Fuel Price by Sector[All Fuels,Sectors,Future Year]
	  ),
	
	  BFPaT BAU Fuel Tax by Sector[All Fuels,Sectors,Future Year]
	)
	~	$/BTU
	~		|

Fuel that would be Used by Regulated Vehicle Types in Absence of LCFS with Elec Eff Adj\
		[Vehicle Type,Cargo Type
,Vehicle Technology,Transportation Fuel] :EXCEPT:    [Vehicle Type,Cargo Type,Vehicle Technology\
		,electricity tf]=
	Transportation Sector Fuel that would be Used in Absence of LCFS by Regulated Vehicle Types\
		[Vehicle Type,Cargo Type,Vehicle Technology,Transportation Fuel] ~~|
Fuel that would be Used by Regulated Vehicle Types in Absence of LCFS with Elec Eff Adj\
		[Vehicle Type,Cargo Type
,Vehicle Technology,electricity tf]=
	Transportation Sector Fuel that would be Used in Absence of LCFS by Regulated Vehicle Types\
		[Vehicle Type,Cargo Type,Vehicle Technology,electricity tf]
	/ (1 - PTFURfE Percentage Transportation Fuel Use Reduction for Electricity[Vehicle Type\
		,Cargo Type])
	~	BTU
	~		|

Fuel Trade and Subsidy Change in Energy Expenditures by Entity[government]=
	SUM(Change in Thermal Fuel Subsidies Paid[All Fuels!]) ~~|
Fuel Trade and Subsidy Change in Energy Expenditures by Entity[nonenergy industries]=
	0 ~~|
Fuel Trade and Subsidy Change in Energy Expenditures by Entity[labor and consumers]=
	0 ~~|
Fuel Trade and Subsidy Change in Energy Expenditures by Entity[foreign entities]=
	SUM(Change in Fuel Export Revenue[All Fuels!]) ~~|
Fuel Trade and Subsidy Change in Energy Expenditures by Entity[electricity suppliers]\
		=
	Change in Fuel Import Expenditures[electricity] ~~|
Fuel Trade and Subsidy Change in Energy Expenditures by Entity[coal suppliers]=
	SUM(Change in Fuel Import Expenditures[coal mining industry fuel within all fuels!])\
		 ~~|
Fuel Trade and Subsidy Change in Energy Expenditures by Entity[natural gas and petroleum suppliers\
		]=
	SUM(Change in Fuel Import Expenditures[NGPS industry fuel within all fuels!]) ~~|
Fuel Trade and Subsidy Change in Energy Expenditures by Entity[biomass and biofuel suppliers\
		]=
	Change in Fuel Import Expenditures[biomass]
	+ Change in Fuel Import Expenditures[biofuel gasoline]
	+ Change in Fuel Import Expenditures[biofuel diesel] ~~|
Fuel Trade and Subsidy Change in Energy Expenditures by Entity[other energy suppliers\
		]=
	Change in Fuel Import Expenditures[nuclear]
	+ Change in Fuel Import Expenditures[heat]
	+ Change in Fuel Import Expenditures[municipal solid waste]
	+ Change in Fuel Import Expenditures[hydrogen]
	~	$
	~		|

Fuel Trade and Subsidy Change in Revenue by Entity[government]=
	SUM(Change in Tax Paid on Fuel Exports[All Fuels!]) ~~|
Fuel Trade and Subsidy Change in Revenue by Entity[nonenergy industries]=
	0 ~~|
Fuel Trade and Subsidy Change in Revenue by Entity[labor and consumers]=
	0 ~~|
Fuel Trade and Subsidy Change in Revenue by Entity[foreign entities]=
	SUM(Change in Fuel Import Expenditures[All Fuels!]) ~~|
Fuel Trade and Subsidy Change in Revenue by Entity[electricity suppliers]=
	Change in Fuel Industry Cash Flow from Fuel Exports[electricity]
	+ Change in Thermal Fuel Subsidies Paid[electricity] ~~|
Fuel Trade and Subsidy Change in Revenue by Entity[coal suppliers]=
	SUM(Change in Fuel Industry Cash Flow from Fuel Exports[coal mining industry fuel within all fuels\
		!])
	+ SUM(Change in Thermal Fuel Subsidies Paid[coal mining industry fuel within all fuels\
		!]) ~~|
Fuel Trade and Subsidy Change in Revenue by Entity[natural gas and petroleum suppliers\
		]=
	SUM(Change in Fuel Industry Cash Flow from Fuel Exports[NGPS industry fuel within all fuels\
		!])
	+ SUM(Change in Thermal Fuel Subsidies Paid[NGPS industry fuel within all fuels!]) ~~|
Fuel Trade and Subsidy Change in Revenue by Entity[biomass and biofuel suppliers]=
	Change in Fuel Industry Cash Flow from Fuel Exports[biomass]
	+ Change in Fuel Industry Cash Flow from Fuel Exports[biofuel gasoline]
	+ Change in Fuel Industry Cash Flow from Fuel Exports[biofuel diesel]
	
	+ Change in Thermal Fuel Subsidies Paid[biomass]
	+ Change in Thermal Fuel Subsidies Paid[biofuel gasoline]
	+ Change in Thermal Fuel Subsidies Paid[biofuel diesel] ~~|
Fuel Trade and Subsidy Change in Revenue by Entity[other energy suppliers]=
	Change in Fuel Industry Cash Flow from Fuel Exports[nuclear]
	+ Change in Fuel Industry Cash Flow from Fuel Exports[heat]
	+ Change in Fuel Industry Cash Flow from Fuel Exports[municipal solid waste]
	+ Change in Fuel Industry Cash Flow from Fuel Exports[hydrogen]
	
	+ Change in Thermal Fuel Subsidies Paid[nuclear]
	+ Change in Thermal Fuel Subsidies Paid[heat]
	+ Change in Thermal Fuel Subsidies Paid[municipal solid waste]
	+ Change in Thermal Fuel Subsidies Paid[hydrogen]
	~	$
	~		|

Fuel Use for Green Hydrogen Production[Industrial Fuel] :EXCEPT:  [biomass if]=
	0 ~~|
Fuel Use for Green Hydrogen Production[biomass if]=
	Off Grid Electricity Demand for Green Hydrogen by Power Plant Type[biomass es]
	* Weighted Average Heat Rate by Electricity Fuel[biomass es]
	
	+ Off Grid Electricity Demand for Green Hydrogen by Power Plant Type[municipal solid waste es\
		]
	* Weighted Average Heat Rate by Electricity Fuel[municipal solid waste es]
	~	BTU
	~	This variable is set to 0 for all fossil resources and hydrogen power \
		plants, as they cannot qualify for the green hydrogen production pathway. \
		There will also be 0 fuel use associated with wind, solar, hydro, and \
		geothermal resources. Therefore, we only calculate biomass values as the \
		sum of the biomass and municipal solid waste plant types, if applicable.
	|

Fuel Used for CCS by Hydrogen Sector[Industrial Fuel]=
