Adjusted Load Factors for Commercial Buildings Sector[Building Component,Electricity Timeslice\
		,Hour]=
	Mean Load Factors for Commercial Buildings Sector[Building Component,Electricity Timeslice\
		]
	+ LFHVM Load Factor Hourly Variance Multiplier[Electricity Timeslice,commercial buildings sector\
		]
	  * (
	      SHELF Seasonal Hourly Equipment Load Factors for Commercial Buildings Sector[Building Component\
		,Electricity Timeslice,Hour]
	      - Mean Load Factors for Commercial Buildings Sector[Building Component,Electricity Timeslice\
		]
	    )
	~	Dmnl
	~		|

Adjusted Load Factors for Data Centers[Electricity Timeslice,Hour]=
	Mean Load Factors for Data Centers[Electricity Timeslice]
	+ LFHVM Load Factor Hourly Variance Multiplier[Electricity Timeslice,commercial buildings sector\
		]
	  * (
	      SHELF Seasonal Hourly Equipment Load Factors for Data Centers[Electricity Timeslice\
		,Hour]
	      - Mean Load Factors for Data Centers[Electricity Timeslice]
	    )
	~	Dmnl
	~		|

Adjusted Load Factors for District Heat and Hydrogen Sectors[Electricity Timeslice,Hour\
		]=
	Mean Load Factors for District Heat and Hydrogen Sectors[Electricity Timeslice]
	+ LFHVM Load Factor Hourly Variance Multiplier[Electricity Timeslice,district heat and hydrogen sector\
		]
	  * (
	      SHELF Seasonal Hourly Equipment Load Factors for District Heat and Hydrogen Sectors\
		[Electricity Timeslice,Hour]
	      - Mean Load Factors for District Heat and Hydrogen Sectors[Electricity Timeslice\
		]
	    )
	~	Dmnl
	~		|

Adjusted Load Factors for Geoengineering Sector[Electricity Timeslice,Hour]=
	Mean Load Factors for Geoengineering Sector[Electricity Timeslice]
	+ LFHVM Load Factor Hourly Variance Multiplier[Electricity Timeslice,geoengineering sector\
		]
	  * (
	      SHELF Seasonal Hourly Equipment Load Factors for Geoengineering Sector[Electricity Timeslice\
		,Hour]
	      - Mean Load Factors for Geoengineering Sector[Electricity Timeslice]
	    )
	~	Dmnl
	~		|

Adjusted Load Factors for Industrial CCS[Electricity Timeslice,Hour]=
	Mean Load Factors for Industrial CCS[Electricity Timeslice]
	+ LFHVM Load Factor Hourly Variance Multiplier[Electricity Timeslice,industry sector\
		]
	  * (
	      SHELF Seasonal Hourly Equipment Load Factors for Industrial CCS[Electricity Timeslice\
		,Hour]
	      - Mean Load Factors for Industrial CCS[Electricity Timeslice]
	    )
	~	Dmnl
	~		|

Adjusted Load Factors for Industrial Processes[Electricity Timeslice,Hour,Industrial Process\
		]=
	Mean Load Factors for Industrial Processes[Electricity Timeslice,Industrial Process]
	+ LFHVM Load Factor Hourly Variance Multiplier[Electricity Timeslice,industry sector\
		]
	
	* 
	
	(
	  SHELF Seasonal Hourly Equipment Load Factors for Industrial Sector by Process[Electricity Timeslice\
		,Industrial Process,Hour]
	  - Mean Load Factors for Industrial Processes[Electricity Timeslice,Industrial Process\
		]
	)
	~	Dmnl
	~		|

Adjusted Load Factors for Industry Categories[Electricity Timeslice,Hour,Industry Cat w Industry wide Load Factor\
		]=
	Mean Load Factors for Industry Categories[Electricity Timeslice,Industry Cat w Industry wide Load Factor\
		]
	+ LFHVM Load Factor Hourly Variance Multiplier[Electricity Timeslice,industry sector\
		]
	
	* 
	
	(
	  SHELF Seasonal Hourly Equipment Load Factors for Industrial Sector by Category[Electricity Timeslice\
		,Industry Cat w Industry wide Load Factor,Hour]
	  - Mean Load Factors for Industry Categories[Electricity Timeslice,Industry Cat w Industry wide Load Factor\
		]
	)
	~	Dmnl
	~		|

