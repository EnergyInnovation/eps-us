	  0,
	
	  LOOKUP INVERT(
	    CSCCCMvSoECBtY Capacity Cost Multiplier vs Share of Existing Capacity Built This Year\
		[summer],
	    MAX(0,
	  BAU Total Energy Market and Capacity Market Revenue for Seasonal Clean Disatchable Reliability CCUS Retrofits\
		[Clean Dispatchable Electricity Source,Optimization Pass]
	
	  -(
	     BAU Cost per MW for CCUS Retrofits Excluding Subsidies[Clean Dispatchable Electricity Source\
		]
	     * SoCtMbCtbDP Share of Costs that Must be Covered to Be Deemed Profitable[Clean Dispatchable Electricity Source\
		]
	  )
	)
	  )
	)
	= :NA:,
	
	  0,
	
	 IF THEN ELSE(
	  MAX(0,
	  BAU Total Energy Market and Capacity Market Revenue for Seasonal Clean Disatchable Reliability CCUS Retrofits\
		[Clean Dispatchable Electricity Source,Optimization Pass]
	
	  -(
	     BAU Cost per MW for CCUS Retrofits Excluding Subsidies[Clean Dispatchable Electricity Source\
		]
	     * SoCtMbCtbDP Share of Costs that Must be Covered to Be Deemed Profitable[Clean Dispatchable Electricity Source\
		]
	  )
	) <= 0,
	
	  0,
	
	  LOOKUP INVERT(
	    CSCCCMvSoECBtY Capacity Cost Multiplier vs Share of Existing Capacity Built This Year\
		[summer],
	    MAX(0,
	  BAU Total Energy Market and Capacity Market Revenue for Seasonal Clean Disatchable Reliability CCUS Retrofits\
		[Clean Dispatchable Electricity Source,Optimization Pass]
	
	  -(
	    BAU Cost per MW for CCUS Retrofits Excluding Subsidies[Clean Dispatchable Electricity Source\
		]
	     * SoCtMbCtbDP Share of Costs that Must be Covered to Be Deemed Profitable[Clean Dispatchable Electricity Source\
		]
	  )
	)
	  )
	)
	
	  * MAX(
	      BAU Minimum Buildable Capacity for Plants,
	      BAU Last Year Electricity Generation Capacity[Clean Dispatchable Electricity Source\
		]
	    )
	)
	~	MW
	~		|

BAU Profitable Capacity for Seasonal Dispatchable Reliability Additions[Electricity Source\
		,Optimization Pass]=
	IF THEN ELSE(
	 IF THEN ELSE(
	  MAX(0,
	  BAU Total Energy Market and Capacity Market Revenue for Seasonal Dispatchable Reliability\
		[Electricity Source,
	Optimization Pass]
	
	  -(
	     BAU Annualized Fixed Costs per Unit New Capacity[Electricity Source]
	     * SoCtMbCtbDP Share of Costs that Must be Covered to Be Deemed Profitable[Electricity Source
	]
	  )
	) <= 0,
	
	  0,
	
	  LOOKUP INVERT(
	    CSCCCMvSoECBtY Capacity Cost Multiplier vs Share of Existing Capacity Built This Year\
		[summer],
	    MAX(0,
	  BAU Total Energy Market and Capacity Market Revenue for Seasonal Dispatchable Reliability\
		[Electricity Source,Optimization Pass]
	
	  -(
	     BAU Annualized Fixed Costs per Unit New Capacity[Electricity Source]
	     * SoCtMbCtbDP Share of Costs that Must be Covered to Be Deemed Profitable[Electricity Source
	]
	  )
	)
	  )
	)
	= :NA:,
	
	  0,
	
	 IF THEN ELSE(
	  MAX(0,
	  BAU Total Energy Market and Capacity Market Revenue for Seasonal Dispatchable Reliability\
		[Electricity Source,Optimization Pass]
	
	  -(
	     BAU Annualized Fixed Costs per Unit New Capacity[Electricity Source]
	     * SoCtMbCtbDP Share of Costs that Must be Covered to Be Deemed Profitable[Electricity Source
	]
	  )
	) <= 0,
	
	  0,
	
	  LOOKUP INVERT(
	    CSCCCMvSoECBtY Capacity Cost Multiplier vs Share of Existing Capacity Built This Year\
		[summer],
	    MAX(0,
	  BAU Total Energy Market and Capacity Market Revenue for Seasonal Dispatchable Reliability\
		[Electricity Source,Optimization Pass]
	  -(
	     BAU Annualized Fixed Costs per Unit New Capacity[Electricity Source]
	     * SoCtMbCtbDP Share of Costs that Must be Covered to Be Deemed Profitable[Electricity Source
	]
	  )
	)
	  )
	)
	
	  * MAX(
	      BAU Minimum Buildable Capacity for Plants,
	      BAU Last Year Electricity Generation Capacity[Electricity Source]
	    )
	)
	~	MW
	~	If we do not test for :NA: (no number), then an out-of-bounds lookup in \
		the prior variable can produce a large random number here, which can throw \
		off the model. It may be better to output zero for an out-of-bounds lookup.
	|

BAU Quantity Carbon Free Energy May be Increased by Fuel by Regulated Vehicle Type[Vehicle Type\
		,Cargo Type,Transportation Fuel] :EXCEPT:  [Vehicle Type,Cargo Type,electricity tf]\
		,[Vehicle Type,Cargo Type,biofuel gasoline tf],[Vehicle Type,Cargo Type
,biofuel diesel tf]=
	0 ~~|
BAU Quantity Carbon Free Energy May be Increased by Fuel by Regulated Vehicle Type[Vehicle Type\
		,Cargo Type,electricity tf]=
	SUM(BAU Quantity Each Fuel May be Increased in Regulated Vehicle Types with Elec Eff Adj\
		[Vehicle Type,Cargo Type,Vehicle Technology
	!,electricity tf])
	* (1 - Carbon Intensity Ratios by Transportation Fuel[electricity tf]) ~~|
BAU Quantity Carbon Free Energy May be Increased by Fuel by Regulated Vehicle Type[Vehicle Type\
		,Cargo Type,biofuel gasoline tf]=
	(SUM(BAU Quantity Each Fuel May be Increased in Regulated Vehicle Types with Elec Eff Adj\
		[Vehicle Type,Cargo Type,Vehicle Technology
	!,biofuel gasoline tf
	])
	  - BAU Quantity Each Fuel May be Increased in Regulated Vehicle Types with Elec Eff Adj\
		[Vehicle Type,Cargo Type,plugin hybrid vehicle
	,biofuel gasoline tf
	])
	* (1 - Carbon Intensity Ratios by Transportation Fuel[biofuel gasoline tf]) ~~|
BAU Quantity Carbon Free Energy May be Increased by Fuel by Regulated Vehicle Type[Vehicle Type\
		,Cargo Type,biofuel diesel tf]=
	(SUM(BAU Quantity Each Fuel May be Increased in Regulated Vehicle Types with Elec Eff Adj\
		[Vehicle Type,Cargo Type,Vehicle Technology
	!,biofuel diesel tf
	])
	  - BAU Quantity Each Fuel May be Increased in Regulated Vehicle Types with Elec Eff Adj\
		[Vehicle Type,Cargo Type,plugin hybrid vehicle
	,biofuel diesel tf
	])
	* (1 - Carbon Intensity Ratios by Transportation Fuel[biofuel diesel tf])
	~	BTU
	~	Plug-in hybrids can shift to either electricity or biofuels.  To model \
		this explicitly would be very difficult, as we'd need to account for three \
		possible shifts (petroleum gasoline to biofuel gasoline, petroleum \
		gasoline to electricity, and biofuel gasoline to electricity).  In \
		practice, biofuel gasoline is hardly used by plug-in hybrids, and \
		electricity will always be the more economical choice for satisfying an \
		LCFS via generation of carbon-free energy.  Therefore, we only allow for \
		one of these three types of shifts in plug-in hybrids: petroleum gasoline \
		to electricity.  Accordingly, we must subtract out the (small) quantity by \
		which biofuels could be increased in plug-in hybrids when calculating the \
		total amount of potential increase in biofuels, to avoid exceeding the \
		maximum allowable shift in gasoline or diesel vehicles (when the shift is \
		assigned to those vehicles, rather than to plug-in hybrids, later in the \
		calculation steps).
	|

BAU Quantity Each Fuel May be Increased in Regulated Vehicle Types[Vehicle Type,Cargo Type\
		,Vehicle Technology,Transportation Fuel]=
	Perc Points Each Transportation Fuel May be Increased[Vehicle Type,Cargo Type,Vehicle Technology\
		,Transportation Fuel]
	* SUM(BAU Transportation Sector Fuel that would be Used in Absence of LCFS by Regulated Vehicle Types\
		[Vehicle Type,Cargo Type
	,Vehicle Technology,Transportation Fuel!])
	~	BTU
	~		|

BAU Quantity Each Fuel May be Increased in Regulated Vehicle Types with Elec Eff Adj[\
		Vehicle Type,Cargo Type,Vehicle Technology
,Transportation Fuel] :EXCEPT:  [Vehicle Type,Cargo Type,Vehicle Technology,electricity tf\
		]=
	BAU Quantity Each Fuel May be Increased in Regulated Vehicle Types[Vehicle Type,Cargo Type\
		,Vehicle Technology,Transportation Fuel
	] ~~|
BAU Quantity Each Fuel May be Increased in Regulated Vehicle Types with Elec Eff Adj[\
		Vehicle Type,Cargo Type,Vehicle Technology
,electricity tf]=
	BAU Quantity Each Fuel May be Increased in Regulated Vehicle Types[Vehicle Type,Cargo Type\
		,Vehicle Technology,electricity tf
	]
	/ (1 - PTFURfE Percentage Transportation Fuel Use Reduction for Electricity[Vehicle Type\
		,Cargo Type])
	~	BTU
	~		|

BAU Quantization Size for Hourly Dispatch=
	SUM(BAU Electricity Generation by Type[Electricity Source!])
	* 2.5e-07
	~	MW*hr
	~		|

BAU Reduction in CO2 Emissions due to LCFS[Vehicle Type,Cargo Type,Vehicle Technology\
		,Transportation Fuel]=
	BAU Change in Fuel Use by Fuel and Technology due to LCFS with Elec Eff Adj[Vehicle Type\
		,Cargo Type,Vehicle Technology,Transportation Fuel]
	* Reduction in Carbon Intensity of This Fuel Relative to Reference Fuel[Vehicle Type\
		,Transportation Fuel]
	~	g pollutant
	~		|

BAU Remaining CES Required Generation after Guaranteed Dispatch and RPS Dispatch=
	MAX(0,
	  SUM(BAU Total Electricity Demand by Hour After Demand Altering Technologies[Electricity Timeslice
	!,Hour!]*BAU Elec Portfolio Percentage to Seek This Year[CES]
	*SHELF Days per Electricity Timeslice  [Electricity Timeslice!])
	  
	   -SUM(BAU Electricity Dispatched by Guaranteed Dispatch by Hour[Electricity Source\
		!,Electricity Timeslice!,Hour!]*Elec Portfolio Qualifying Sources
	[Electricity Source!,CES]*SHELF Days per Electricity Timeslice[Electricity Timeslice\
		!])
	  
	   -SUM(BAU Zero and Negative Cost Electricity Dispatched to Meet RPS[Electricity Timeslice\
		!,Hour!,Electricity Source!]*Elec Portfolio Qualifying Sources
	[Electricity Source!,CES]*SHELF Days per Electricity Timeslice
	[Electricity Timeslice!])
	
	-SUM(BAU Positive Cost Electricity Dispatched to Meet RPS[Electricity Timeslice!,Hour\
		!,Electricity Source!]*Elec Portfolio Qualifying Sources
	[Electricity Source!,CES]*SHELF Days per Electricity Timeslice
	[Electricity Timeslice!])
	
	- SUM(BAU Zero and Negative Cost Electricity Dispatched to Meet CES[Electricity Source\
		!,Electricity Timeslice!,Hour!]*Elec Portfolio Qualifying Sources[Electricity Source\
		!,CES]*SHELF Days per Electricity Timeslice[Electricity Timeslice!])
	)
	~	MW*hour
	~		|

BAU Remaining Electricity Exports by Electricity Timeslice by Optimization Pass[Electricity Timeslice\
		,Optimization Pass]=
	IF THEN ELSE(BAU Daily Net Imported Electricity>=0,0,
	  -BAU Daily Net Imported Electricity-SUM(BAU Electricity Exports by Hour[Electricity Timeslice\
		,Hour!,Optimization Pass])
	 )
	~	MW*hour
	~		|

BAU Remaining Electricity Imports by Electricity Timeslice and Optimization Pass[Electricity Timeslice\
		, Optimization Pass]=
	IF THEN ELSE(BAU Daily Net Imported Electricity<=0,0,
	  BAU Daily Net Imported Electricity-SUM(BAU Electricity Imports by Hour[Electricity Timeslice\
		,Hour!,Optimization Pass])
	)
	~	MW*hour
	~		|

BAU Remaining RPS Required Generation after Guaranteed Dispatch and Zero and Negative Cost Electricity Dispatched to Meet RPS\
		=
	MAX(0,
	  SUM(BAU Total Electricity Demand by Hour After Demand Altering Technologies[Electricity Timeslice
	!,Hour!]*BAU Elec Portfolio Percentage to Seek This Year[RPS]
	*SHELF Days per Electricity Timeslice  [Electricity Timeslice!])
	  
	   -SUM(BAU Electricity Dispatched by Guaranteed Dispatch by Hour[Electricity Source\
		!,Electricity Timeslice!,Hour!]*Elec Portfolio Qualifying Sources
	[Electricity Source!,RPS]*SHELF Days per Electricity Timeslice[Electricity Timeslice\
		!])
	  
	   -SUM(BAU Zero and Negative Cost Electricity Dispatched to Meet RPS[Electricity Timeslice\
		!,Hour!,Electricity Source!]*Elec Portfolio Qualifying Sources[Electricity Source!,\
		RPS]*SHELF Days per Electricity Timeslice
	[Electricity Timeslice!])
	)
	~	MW*hr
	~		|

BAU Renewable Electricity Generation Converted to Primary Energy[hydro es]=
	BAU Electricity Generation by Type Including Distributed Generation[hydro es]
	/ MWh per BTU ~~|
BAU Renewable Electricity Generation Converted to Primary Energy[onshore wind es]=
	BAU Electricity Generation by Type Including Distributed Generation[onshore wind es]
	/ MWh per BTU ~~|
BAU Renewable Electricity Generation Converted to Primary Energy[solar PV es]=
	BAU Electricity Generation by Type Including Distributed Generation[solar PV es]
	/ MWh per BTU ~~|
BAU Renewable Electricity Generation Converted to Primary Energy[solar thermal es]=
	BAU Electricity Generation by Type Including Distributed Generation[solar thermal es\
		]
	/ MWh per BTU ~~|
BAU Renewable Electricity Generation Converted to Primary Energy[geothermal es]=
	BAU Electricity Generation by Type Including Distributed Generation[geothermal es]
	/ MWh per BTU ~~|
BAU Renewable Electricity Generation Converted to Primary Energy[offshore wind es]=
	BAU Electricity Generation by Type Including Distributed Generation[offshore wind es\
		]
	/ MWh per BTU
	~	BTU
	~		|

BAU Repayment for Buildings Sector Financed Capital Expenses Expiring After Financing Period\
		[Building Type]= DELAY FIXED (
	BAU Annual Repayment for Financed Buildings Sector Capital Expenses[Building Type],RPfFBSCC Repayment Period for Financed Buildings Sector Capital Costs\
		, 0)
	~	$
	~		|

BAU Repayment of Financing for Change in Electricity Sector Capital Expenditures including Construction Subsidies\
		=
	DEPRECIATE STRAIGHTLINE(
	
	 BAU Annual Repayment for This Year Electricty Transmission Distribution and Storage Expenses
	  * RPfFESCC Repayment Period for Financed Electricity Sector Capital Costs / One Year\
		,
	 
	  RPfFESCC Repayment Period for Financed Electricity Sector Capital Costs,
	
	  1,
	
	  0
	)
	~	$
	~		|

BAU Required Increase in Carbon Free Energy=
	MAX(
	  0,
	
	  SUM(BAU Fuel that would be Used by Regulated Vehicle Types in Absence of LCFS with Elec Eff Adj\
		[Vehicle Type!,Cargo Type!,Vehicle Technology!,Transportation Fuel!])
	  * BAU Required LCFS Percentage
	  - SUM(BAU Carbon Free Energy in Absence of LCFS by Vehicle Type[Vehicle Type!,Cargo Type\
		!,Vehicle Technology!,Transportation Fuel!])
	)
	~	BTU
	~		|

BAU Required Increase in Carbon Free Energy Assigned to Vehicle and Fuel Types[Vehicle Type\
		,Cargo Type,Transportation Fuel]=
	BAU Quantity Carbon Free Energy May be Increased by Fuel by Regulated Vehicle Type[Vehicle Type\
		,Cargo Type,Transportation Fuel]
	* MIN(
	    1,
	
	    ZIDZ(
	      BAU Required Increase in Carbon Free Energy,
	      SUM(BAU Quantity Carbon Free Energy May be Increased by Fuel by Regulated Vehicle Type\
		[Vehicle Type!,Cargo Type!,Transportation Fuel!])
	    )
	  )
	~	BTU
	~		|

BAU Required LCFS Percentage=
	BLP BAU LCFS Percentage
	~	Dmnl
	~		|

BAU Required Share of Peak Demand from Clean Firm Resources=
	(1-exp(-((BAU Elec Portfolio Percentage to Seek This Year[CES])/CDRDfRCP Clean Dispatchable Resource Demand for Reliability Curve Parameter B\
		)^CDRDfRCP Clean Dispatchable Resource Demand for Reliability Curve Parameter A))*CDRDfRCP Required Share of Peak Demand from Clean Dispatchable Resources at 100 Percent CES
	~	Dmnl
	~		|

BAU Required ZEV Sales Percentage by Subregion[Subregion,Vehicle Type,Cargo Type]=
	MAX(
	
	  BRZSPbMR BAU Required ZEV Sales Percentage by Model Region[Vehicle Type,Cargo Type\
		],
	
	  BRZSPbS BAU Required ZEV Sales Percentage by Subregion[Subregion,Vehicle Type,Cargo Type\
		]
	)
	~	Dmnl
	~		|

BAU Retirable Vintages by Year[Modeled Vintage]=
	IF THEN ELSE(
	  Time - Modeled Vintage to Year Mapping[Modeled Vintage]*One Year
	  <= MLfPPR Minimum Lifetime for Power Plant Retirements,
	
	  0,
	
	  1
	)
	~	Dmnl
	~		|

BAU Retired Vehicles Contribution to Percentage Change to Fleet Avg Fuel Economy[Vehicle Type\
		,Cargo Type,Vehicle Technology]=
	MAX(
	  0,
	
	  - BAU Percentage of Vehicle Stock Retired This Year[Vehicle Type,Cargo Type,Vehicle Technology\
		]
	  * BAU Percentage Difference in Retired Vehicle vs Fleet Avg Fuel Economy[Vehicle Type\
		,Cargo Type,Vehicle Technology]
	)
	~	Dmnl
	~	We do not allow retiring vehicles to cause fleet average fuel economy to \
		worsen, because the less-efficient vehicles are the ones that should \
		retire first, and not including this check can cause discontinuities in \
		output when the number of vehicles of a certain type and technology \
		approaches zero during the model run (for example, in a scenario with a \
		100% EV sales mandate fully ramped in by 2030, so we run out of gasoline \
		LDVs in the 2040s).
	|

BAU Retiring Components Energy Use[Building Type,Building Fuel,Building Component]=
	MAX(
	  0,
	
	  MIN(
	    BAU Last Year Components Energy Use[Building Type,Building Fuel,Building Component\
		]
	    / One Year,
	
	    IF THEN ELSE(
	      Time < INITIAL TIME + CL Component Lifetime[Building Type,Building Component],
	
	      ZIDZ(
	        SYCEU Start Year Components Energy Use[Building Type,Building Fuel,Building Component\
		],
	        CL Component Lifetime[Building Type,Building Component]
	      ),
	
	      BAU New Components Energy Use after Envelope Effects after Lifetime[Building Type\
		,Building Fuel,Building Component]
	    )
	  )
	)
	~	BTU/Year
	~		|

BAU Retiring Generation Capacity[Electricity Source]=
	MAX(
	    0,
	    MIN(
	      SUM(BAU Retiring Generation Capacity Including Economic and Mandated Retirements\
		[Electricity Source,last pass!]),
	      BAU Last Year Electricity Generation Capacity[Electricity Source]
	     )
	  )
	~	MW
	~		|

BAU Retiring Generation Capacity Excluding Capacity Payment[Electricity Source]=
	MAX(
	    0,
	    MIN(
	      BAU Retiring Generation Capacity Including Economic and Policy Mandated Retirements Excluding Capacity Payment\
		[Electricity Source],
	      BAU Last Year Electricity Generation Capacity[Electricity Source]
	     )
	  )
	~	MW
	~		|

BAU Retiring Generation Capacity Including Economic and Mandated Retirements[Electricity Source\
		,Optimization Pass]=
	BAU Economic Capacity Retirements by Optimization Pass[Electricity Source,Optimization Pass\
		]
	+ BCRbQ BAU Capacity Retirements before Quantization[Electricity Source]
	+SUM(BAU Capacity Retirements Based on Economic Lifetime[Electricity Source,Modeled Vintage\
		!])
	~	MW
	~		|

BAU Retiring Generation Capacity Including Economic and Policy Mandated Retirements Excluding Capacity Payment\
		[Electricity Source]=
	BAU Economic Capacity Retirements Excluding Capacity Payment[Electricity Source]
	+ BCRbQ BAU Capacity Retirements before Quantization[Electricity Source]
	+ SUM(BAU Capacity Retirements Based on Economic Lifetime[Electricity Source,Modeled Vintage\
		!])
	~	MW
	~		|

BAU Retiring Hydrogen Production Capacity Installed During Model Run by Vintage[Hydrogen Production Pathway\
		,Model Run Vintage]=
	BAU Last Year Hydrogen Production Capacity Installed During Model Run by Vintage[Hydrogen Production Pathway\
		,Model Run Vintage]
	* Fraction of Hydrogen Production Equipment Retired by Age[Model Run Vintage]
	/ One Year
	~	BTU/Year
	~		|

BAU Retiring Preexisting Hydrogen Production Capacity[Hydrogen Production Pathway]=
	BAU Last Year Preexisting Hydrogen Production Capacity[Hydrogen Production Pathway]
	* PHERP Preexisting Hydrogen Equipment Retirement Profile
	/ One Year
	~	BTU/Year
	~		|

BAU Retiring Vehicle Fuel Economy[Vehicle Type,Cargo Type,Vehicle Technology]=
	IF THEN ELSE(
	  Time - INITIAL TIME <= AVL Avg Vehicle Lifetime[Cargo Type,Vehicle Type] - 1,
	
	  BHNVFEAL BAU Historical New Vehicle Fuel Economy After Lifetime[Vehicle Type,Cargo Type\
		,Vehicle Technology],
	
	  BAU New Vehicle Fuel Economy After Lifetime[Vehicle Type,Cargo Type,Vehicle Technology\
		]
	)
	~	thing*miles/BTU
	~		|

BAU Retiring Vehicles[Vehicle Type,Cargo Type,Vehicle Technology]=
	IF THEN ELSE(
	  Time - INITIAL TIME <
	  MODULO(
	      SYVbT Start Year Vehicles by Technology[Vehicle Type,Cargo Type,Vehicle Technology\
		] / One Vehicle * One Year,
	      AVL Avg Vehicle Lifetime[Cargo Type,Vehicle Type]
	  ),
	  
	  INTEGER(
	    ZIDZ(
	      SYVbT Start Year Vehicles by Technology[Vehicle Type,Cargo Type,Vehicle Technology\
		],
	      AVL Avg Vehicle Lifetime[Cargo Type,Vehicle Type]
	    )
	  )
	  + 1,
	  
	  IF THEN ELSE(
	    Time - INITIAL TIME <= AVL Avg Vehicle Lifetime[Cargo Type,Vehicle Type] - 1,
		
		INTEGER(
	      ZIDZ(
	        SYVbT Start Year Vehicles by Technology[Vehicle Type,Cargo Type,Vehicle Technology\
		],
	        AVL Avg Vehicle Lifetime[Cargo Type,Vehicle Type]
	      )
	    ),
		
		INTEGER(
	      MIN(
	        BAU New Vehicles After Lifetime[Vehicle Type,Cargo Type,Vehicle Technology],
	        BAU Last Year Vehicles[Vehicle Type,Cargo Type,Vehicle Technology] / One Year
	      )
	    )
	  )
	)
	~	vehicles/Year
	~	Let X be the lifetime of a given type of vehicle (in years).  In the first \
		X years of the model run, we want to retire 1/X of the starting number of \
		vehicles.  Since we only work with whole numbers of vehicles (integers), \
		this may leave us with a remainder.  We deal with this by retiring the \
		remainder (if any) in the first year of the model run, in addition to the \
		1/X vehicles that are retired in each of the first X years.  After X years \
		have elapsed, we simply retire the vehicles we added to the fleet X years \
		ago.
	|

BAU Retiring Vehicles Summed Across Technologies[Vehicle Type,Cargo Type]=
	SUM(BAU Retiring Vehicles[Vehicle Type,Cargo Type,Vehicle Technology!])
	~	vehicles/Year
	~		~	:SUPPLEMENTARY 
	|

BAU Retrofit Capacity after Quantization[Electricity Source]=
	BAU New Policy Mandated Retrofits[Electricity Source] 
	+ BAU Retrofit Capacity Desired due to Cost Effectiveness[Electricity Source,CES]
	+ BAU Retrofit Capacity for Clean Dispatchable Reliability[Electricity Source]
	~	MW
	~		|

BAU Retrofit Capacity Desired due to Cost Effectiveness[Electricity Source,Clean Elec Requirement\
		] :EXCEPT:      [CCUS Electricity Source,Clean Elec Requirement]=
	0 ~~|
BAU Retrofit Capacity Desired due to Cost Effectiveness[CCUS Electricity Source,RPS]=
	QUANTUM(
	  MAX(0,
	    SUM(BAU Retrofitted Capacity Desired due to Cost Effectiveness by Optimization Pass\
		[CCUS Electricity Source,last pass!,RPS])
	    -BAU Retrofit Capacity for Clean Dispatchable Reliability[CCUS Electricity Source\
		]),
	  MPPC Minimum Power Plant Capacity[CCUS Electricity Source]
	) ~~|
BAU Retrofit Capacity Desired due to Cost Effectiveness[CCUS Electricity Source,CES]=
	QUANTUM(
	  MAX(0,
	    SUM(BAU Retrofitted Capacity Desired due to Cost Effectiveness by Optimization Pass\
		[CCUS Electricity Source,last pass!,CES])
	    -BAU Retrofit Capacity for Clean Dispatchable Reliability[CCUS Electricity Source\
		]),
	  MPPC Minimum Power Plant Capacity[CCUS Electricity Source]
	)
	~	MW
	~		|

BAU Retrofit Capacity for Clean Dispatchable Reliability[Electricity Source] :EXCEPT:\
		   [CCUS Electricity Source]=
	0 ~~|
BAU Retrofit Capacity for Clean Dispatchable Reliability[CCUS Electricity Source]=
	SUM(BAU Retrofitted Capacity Desired for Seasonal Clean Dispatchable Reliability by Optimization Pass\
		[CCUS Electricity Source,last pass!])
	~	MW
	~		|

BAU Retrofitted Capacity Desired due to Cost Effectiveness by Optimization Pass[Electricity Source\
		, Optimization Pass,Clean Elec Requirement] :EXCEPT:    [CCUS Electricity Source, Optimization Pass\
		,Clean Elec Requirement]=
	0 ~~|
BAU Retrofitted Capacity Desired due to Cost Effectiveness by Optimization Pass[CCUS Electricity Source\
		,Optimization Pass,RPS]=
	QUANTUM(
	  MIN(
	    BAU Max Capacity Available for CCUS Retrofit after CES Clean Firm Reliability Additions\
		[CCUS Electricity Source],
	
	    BAU Profitable Capacity for CCUS Retrofits[CCUS Electricity Source,Optimization Pass\
		,RPS]
	    * CSCSoCECBiaSY Share of Cost Effective Capacity Built in a Single Year[CCUS Electricity Source\
		]
	  ),
	  MPPC Minimum Power Plant Capacity[CCUS Electricity Source]
	) ~~|
BAU Retrofitted Capacity Desired due to Cost Effectiveness by Optimization Pass[CCUS Electricity Source\
		,Optimization Pass,CES]=
	QUANTUM(
	  MIN(
	    BAU Max Capacity Available for CCUS Retrofit after CES Clean Firm Reliability Additions\
		[CCUS Electricity Source],
	
	    BAU Profitable Capacity for CCUS Retrofits[CCUS Electricity Source,Optimization Pass\
		,CES]
	    * CSCSoCECBiaSY Share of Cost Effective Capacity Built in a Single Year[CCUS Electricity Source\
		]
	  ),
	  MPPC Minimum Power Plant Capacity[CCUS Electricity Source]
	)
	~	MW
	~		|

BAU Retrofitted Capacity Desired due to Cost Effectiveness without CES[Electricity Source\
		] :EXCEPT:   [CCUS Electricity Source
]=
	0 ~~|
BAU Retrofitted Capacity Desired due to Cost Effectiveness without CES[CCUS Electricity Source\
		]=
	QUANTUM(
	  MIN(
	    BAU Max Capacity Available for CCUS Retrofit after CES Clean Firm Reliability Additions\
		[CCUS Electricity Source],
	
	    BAU Profitable Capacity for CCUS Retrofits without CES[CCUS Electricity Source]
	    * CSCSoCECBiaSY Share of Cost Effective Capacity Built in a Single Year[CCUS Electricity Source\
		]
	  ),
	 MPPC Minimum Power Plant Capacity[CCUS Electricity Source]
	)
	~	MW
	~		|

BAU Retrofitted Capacity Desired for Seasonal Clean Dispatchable Reliability by Optimization Pass\
		[Clean Dispatchable Electricity Source,Optimization Pass]=
	QUANTUM(
	  MAX(0,MIN(
	    BAU Max Capacity Available for CCUS Retrofits after Mandated Retrofits[Clean Dispatchable Electricity Source\
		],
	
	    (
	      BAU Profitable Capacity for Seasonal Dispatchable Clean Reliability CCUS Retrofits\
		[Clean Dispatchable Electricity Source,Optimization Pass]
	      * CSCSoCECBiaSY Share of Cost Effective Capacity Built in a Single Year[Clean Dispatchable Electricity Source\
		]
	    )
	  )
	  ),
	  MPPC Minimum Power Plant Capacity[Clean Dispatchable Electricity Source]
	)
	~	MW
	~		|

BAU Revenue from CES Credits per Unit Electricity Output by Plant Type[Electricity Source\
		]=
	BAU Optimized RPS Credit Price
	* Elec Portfolio Qualifying Sources[Electricity Source,RPS]
	
	+ 
	
	(
	  BAU Optimized CES Credit Price
	  + BZECfNP BAU Zero Emissions Credit for Nuclear Plants[Electricity Source]
	)
	  * Elec Portfolio Qualifying Sources[Electricity Source,CES]
	~	$/(MW*hr)
	~		|

BAU RPS and CES Revenue at Marginal Capacity Factor[Electricity Source]=
	SUM(BAU RPS Revenue at Marginal Capacity Factor by Optimization Pass[last pass!,Electricity Source\
		])
	+ SUM(BAU CES Revenue at Marginal Capacity Factor by Optimization Pass[last pass!,Electricity Source\
		])
	~	$/MW
	~		|

BAU RPS Credit Price by Optimization Pass[pass1]=
	BAU Initial Guess at RPS Price ~~|
BAU RPS Credit Price by Optimization Pass[current pass]=
	MIN(IF THEN ELSE(
	  BAU RPS Credit Price by Optimization Pass[preceeding pass] = 0,
	
	  0,
	
	  MAX(
	    0,
	
	    IF THEN ELSE(
	      BAU Expected Achievable Annual RPS by Optimization Pass[preceeding pass]
	      < BAU Elec Portfolio Percentage to Seek This Year[RPS],
	  
	      BAU RPS Credit Price by Optimization Pass[preceeding pass]
	      + BAU RPS Optimization Step Size[current pass],
	
	      BAU RPS Credit Price by Optimization Pass[preceeding pass]
	      - BAU RPS Optimization Step Size[current pass]
	    )
	  )
	), BRACP BAU RPS Alternative Compliance Payment)
	~	$/(MW*hour)
	~		|

BAU RPS Optimization Step Size[pass1]=
	ABS(BAU RPS Credit Price by Optimization Pass[pass1])
	/ 2 ~~|
BAU RPS Optimization Step Size[current pass]=
	IF THEN ELSE(
	  BAU RPS Steps in Same Direction[preceeding pass]
	  > Steps Allowed in Same Direction Without Increasing Step Size,
	
	  BAU RPS Optimization Step Size[preceeding pass] * 1.5,
	
	  IF THEN ELSE(
	    BAU RPS Steps in Same Direction[preceeding pass]
	    > Steps Allowed in Same Direction With Declining Step Size,
	
	    BAU RPS Optimization Step Size[preceeding pass],
	
	    BAU RPS Optimization Step Size[preceeding pass]
	    / 2
	  )
	)
	~	$/(MW*hour)
	~		|

BAU RPS Qualifying Guaranteed Dispatch Amount[Electricity Source,Electricity Timeslice\
		,Hour,Clean Elec Requirement]=
	BAU Expected Capacity by Hour[Electricity Source,Electricity Timeslice,Hour]
	 * BGDPbES BAU Guaranteed Dispatch Percentage by Electricity Source[Electricity Source\
		]
	 * Elec Portfolio Qualifying Sources[Electricity Source,Clean Elec Requirement]
	 * One Hour
	~	MW*hr
	~		|

BAU RPS Revenue at Expected Capacity Factor by Optimization Pass[Electricity Source, \
		Optimization Pass]=
	BAU RPS Credit Price by Optimization Pass[Optimization Pass]
	    * BAU Expected Capacity Factor x Hours per Year for Plants Built This Year[Electricity Source
	]
	    * Elec Portfolio Qualifying Sources[Electricity Source,RPS]
	~	$/MW
	~		|

BAU RPS Revenue at Marginal Capacity Factor by Optimization Pass[Optimization Pass, Electricity Source\
		]=
	BAU RPS Credit Price by Optimization Pass[Optimization Pass]
	* BAU Marginal Capacity Factor x Hours per Year[Electricity Source,RPS]
	* Elec Portfolio Qualifying Sources[Electricity Source,RPS]
	~	$/MW
	~		|

BAU RPS Steps in Negative Direction[pass1]=
	0 ~~|
BAU RPS Steps in Negative Direction[current pass]=
	IF THEN ELSE(
	  BAU Expected Achievable Annual RPS by Optimization Pass[preceeding pass]
	  > BAU Elec Portfolio Percentage to Seek This Year[RPS],
	
	  BAU RPS Steps in Negative Direction[preceeding pass] + 1,
	
	  0
	)
	~	Dmnl
	~		|

BAU RPS Steps in Positive Direction[pass1]=
	0 ~~|
BAU RPS Steps in Positive Direction[current pass]=
	IF THEN ELSE(
	  BAU Expected Achievable Annual RPS by Optimization Pass[preceeding pass]
	  < BAU Elec Portfolio Percentage to Seek This Year[RPS],
	
	  BAU RPS Steps in Positive Direction[preceeding pass] + 1,
	
	  0
	)
	~	Dmnl
	~		|

BAU RPS Steps in Same Direction[Optimization Pass]=
	MAX(
	  BAU RPS Steps in Positive Direction[Optimization Pass],
	  BAU RPS Steps in Negative Direction[Optimization Pass]
	)
	~	Dmnl
	~		|

BAU Salvageable Curtailed Capacity by Hour for Hybrid Power Plants[Electricity Source\
		,Electricity Timeslice,Hour]=
	MIN(
	  BAU Expected Curtailed Capacity by Hour for Plants Built This Year[Electricity Source\
		,Electricity Timeslice,Hour],
	  HESBCpUEC Hybrid Electricity Source Battery Capacity per Unit Electricity Capacity
	)
	~	Dmnl
	~		|

BAU Second Tier Guaranteed Dispatch Amount[Electricity Source,Electricity Timeslice,Hour\
		]=
	BAU Guaranteed Dispatch Amount[Electricity Source,Electricity Timeslice,Hour]
	- BAU First Tier Guaranteed Dispatch Amount[Electricity Source,Electricity Timeslice\
		,Hour]
	~	MW*hour
	~		|

BAU Share of Annual Expected Output that Can be Shifted[Electricity Source]=
	SUM(BAU Share of Daily Expected Output that Can be Shifted by Electricity Timeslice[\
		Electricity Source,Electricity Timeslice
	!]*SHELF Days per Electricity Timeslice[Electricity Timeslice!])
	/SUM(SHELF Days per Electricity Timeslice[Electricity Timeslice!])
	~	Dmnl
	~		|

BAU Share of Available Capacity Actually Dispatched by Hour[Electricity Timeslice, Hour\
		]=
	ZIDZ(
	  BAU Total Electricity Dispatched by Hour[Electricity Timeslice,Hour],
	
	  SUM(BAU Available Capacity by Hour[Electricity Source!,Electricity Timeslice,Hour]\
		)*One Hour
	)
	~	Dmnl
	~		~	:SUPPLEMENTARY 
	|

BAU Share of Daily Expected Output that Can be Shifted by Electricity Timeslice[Electricity Source\
		, Electricity Timeslice]=
	MIN(1,
	      ZIDZ((HESBCpUEC Hybrid Electricity Source Battery Capacity per Unit Electricity Capacity
	*GBSC Diurnal Grid Battery Daily Storage Duration),
	      BAU Expected Daily Electricity Output by Electricity Timeslice[Electricity Source
	,Electricity Timeslice]
	     ))
	~	Dmnl
	~		|

BAU Share of Electricity Generation Capacity Built This Year[Electricity Source]=
	ZIDZ(
	
	  SUM((BAU Electricity Generation Capacity by Vintage[Electricity Source,Modeled Vintage\
		!]*This Year Modeled Vintage Flag[Modeled Vintage!])),
	
	  BAU Electricity Generation Capacity[Electricity Source]
	
	)
	~	Dmnl
	~		|

BAU Share of Exports by Hour by Optimization Pass[Electricity Timeslice,Hour,Optimization Pass\
		]=
	ZIDZ(BAU Inverted Spare Potential Output from Surviving Capacity by Hour by Optimization Pass\
		[Electricity Timeslice,Hour,Optimization Pass],
	SUM(BAU Inverted Spare Potential Output from Surviving Capacity by Hour by Optimization Pass\
		[Electricity Timeslice,Hour!,Optimization Pass]))
	~	Dmnl
	~		|

BAU Share of Imports by Hour by Optimization Pass[Electricity Timeslice,Hour,Optimization Pass\
		]=
	ZIDZ(BAU Spare Potential Output from Surviving Capacity by Hour by Optimization Pass\
		[Electricity Timeslice,Hour,Optimization Pass],SUM(BAU Spare Potential Output from Surviving Capacity by Hour by Optimization Pass\
		[Electricity Timeslice,Hour!,Optimization Pass]))
	~	Dmnl
	~		|

BAU Share of Max Hourly Exports Met[Electricity Timeslice,Hour,Optimization Pass]=
	ZIDZ(BAU Electricity Exports by Hour[Electricity Timeslice,Hour,Optimization Pass],
	  MaMHEIaE Maximum Hourly Exports)
	~	Dmnl
	~		|

BAU Share of Max Hourly Imports Met[Electricity Timeslice,Hour,Optimization Pass]=
	ZIDZ(BAU Electricity Imports by Hour[Electricity Timeslice,Hour,Optimization Pass],
	  MaMHEIaE Maximum Hourly Imports)
	~	Dmnl
	~		|

BAU Share of Maximum Annual Decrease in Demand from Diurnal Grid Batteries=
	ZIDZ(
	  BAU Maximum Annual Decrease in Demand from Diurnal Grid Batteries,
	
	  (BAU Maximum Annual Decrease in Demand from Diurnal Grid Batteries
	  + BAU Maximum Annual Decrease in Demand from EVs
	  + BAU Maximum Annual Decrease in Demand from Pumped Hydro
	  + BAU Maximum Annual Decrease in Demand from Seasonal Electricity Storage
	  )
	)
	~	Dmnl
	~		|

BAU Share of New Industrial Equipment Allocated by Fuel Type in Electricity Equivalent\
		[Industry Category,Industrial Fuel
,Industrial Process]=
	ZIDZ(
	  10000
	  * IES Industrial Equipment Shareweights[Industry Category,Industrial Fuel,Industrial Process\
		]
	  * exp(BAU Industrial Equipment Annual Costs and Annual Financing Repayment per Unit Industrial Output in Electricity Equivalent\
		[Industry Category,Industrial Fuel,Industrial Process]
	    * IELC Industrial Equipment Logit Coefficient),
	  10000*
	  SUM(
	    IES Industrial Equipment Shareweights[Industry Category,Industrial Fuel!,Industrial Process\
		]
	    * exp(BAU Industrial Equipment Annual Costs and Annual Financing Repayment per Unit Industrial Output in Electricity Equivalent\
		[Industry Category,Industrial Fuel!,Industrial Process]
	      * IELC Industrial Equipment Logit Coefficient)
	  )
	)
	~	Dmnl
	~	Using standard "Logit" function as described at \
		https://jgcri.github.io/gcam-doc/choice.html
	|

BAU Share of New Industrial Equipment by Fuel Type in Electricity Equivalent[Industry Category\
		,Industrial Fuel]=
	ZIDZ(
	  SUM(BAU Output from New Industrial Equipment by Fuel Type and Industrial Process[Industry Category\
		,Industrial Fuel,Industrial Process!]),
	
	  SUM(BAU Output from New Industrial Equipment by Industrial Process[Industry Category\
		,Industrial Process!])
	)
	~	Dmnl
	~		|

BAU Share of Off Grid Electricity Demand That is New This Year Met by Power Plant Type\
		[Electricity Source]=
	ZIDZ(
	
	  (
	    GHESS Green Hydrogen Electricity Supply Shareweights[Electricity Source]
	    * exp(MAX(1, BAU Cost per Unit New Elec Output Using Expected Capacity Factors[Electricity Source\
		]/Cost per Unit New Elec Output Unit Correction Factor)/10^4*GHESLE Green Hydrogen Electricity Supply Logit Exponent
	  )
	  ),
	
	  (
	    SUM(GHESS Green Hydrogen Electricity Supply Shareweights[Electricity Source!]
	    * exp(MAX(1, BAU Cost per Unit New Elec Output Using Expected Capacity Factors[Electricity Source\
		!]/Cost per Unit New Elec Output Unit Correction Factor)/10^4*GHESLE Green Hydrogen Electricity Supply Logit Exponent
	  )
	  )
	)
	)
	~	Dmnl
	~		|

BAU Share of Total Electricity Dispatched by Hour by Plant Type[Electricity Timeslice\
		,Hour,Electricity Source]=
	BAU Total Electricity Dispatched by Hour by Plant Type[Electricity Timeslice,Hour,Electricity Source\
		]
	/ SUM(BAU Total Electricity Dispatched by Hour by Plant Type[Electricity Timeslice,Hour\
		,Electricity Source!])
	~	Dmnl
	~		|

BAU Shortfall in Electricity vs Daily Average by Hour after Seasonal Net Peak Load Reduction\
		[Electricity Timeslice,Hour]=
	MAX(
	  0,
	
	  BAU Daily Average Hourly Spare Potential Output from Surviving Capacity[Electricity Timeslice\
		]
	  - BAU Spare Potential Output from Surviving Capacity by Hour after Seasonal Net Peak Load Reduction\
		[Electricity Timeslice,Hour]
	)
	~	MW*hr
	~		|

BAU Shortfall in Potenial Output from Surviving Capacity vs Annual Average by Hour[Electricity Timeslice\
		,Hour]=
	MAX(
	  0,
	
	  BAU Annual Average Hourly Spare Potential Output from Surviving Capacity
	  - BAU Spare Potential Output from Surviving Capacity by Hour[Electricity Timeslice\
		,Hour]
	)
	~	MW*hr
	~		|

BAU Slope of Line Approaching Future Elec Portfolio Percentages by Year[Future Year,Clean Elec Requirement\
		]=
	IF THEN ELSE(
	  Time > Numerical Future Year Definitions[Future Year]
	  :OR:
	  FINAL TIME < Numerical Future Year Definitions[Future Year],
	
	  -9999,
	
	
	    (BAU Weighted Average Elec Portfolio Percentage by Year[Future Year,Clean Elec Requirement\
		]
	      - BAU Elec Portfolio Percentage that Would be Achieved with Only Surviving Plants\
		[Clean Elec Requirement])
	    / (Numerical Future Year Definitions[Future Year] - Time + 1) * One Year
	
	  
	)
	~	Dmnl
	~	We use -9999 for slopes of lines approaching points that are not in the \
		future, because we are going to choose the highest slope to any future \
		point, and we don't want any slopes that are not to future points to be \
		selected.  Note that we haven't built for the current model year yet in \
		the calculation flow, so the current model year counts as being in the \
		future.  Also note that in order to prevent the policy case line from \
		diverging from the BAU line in years prior to the first year policies take \
		effect (which is often a year in the past), we only give electricity \
		producers foresignt to BAU RPS values in years when the additional RPS \
		policy is not in effect (thus mirroring BAU case foresight).
	|

BAU Smoothed Green Hydrogen Cost=
	IF THEN ELSE(
	  Time = INITIAL TIME,
	
	  BAU This Year Green Hydrogen Cost,
	
	  BAU Two Year Average Green Hydrogen Cost
	)
	~	$/BTU
	~		|

BAU Smoothed Low Carbon Hydrogen Cost=
	IF THEN ELSE(
	  Time = INITIAL TIME,
	
	  BAU This Year Low Carbon Hydrogen Cost,
	
	  BAU Two Year Average Low Carbon Hydrogen Cost
	)
	~	$/BTU
	~		|

BAU Smoothed Other Hydrogen Cost=
	IF THEN ELSE(
	  Time = INITIAL TIME,
	
	  BAU This Year Other Hydrogen Cost,
	
	  BAU Two Year Average Other Hydrogen Cost
	)
	~	$/BTU
	~		|

BAU Spare Potential Output from Surviving Capacity by Hour[Electricity Timeslice,Hour\
		]=
	BAU Potential Output from Surviving Capacity by Hour[Electricity Timeslice,Hour]
	- BAU Total Electricity Demand by Hour Before Demand Altering Technologies[Electricity Timeslice\
		,Hour]
	~	MW*hr
	~	This variable must be allowed to become negative to reflect the \
		possibility of a shortfall in a given hour.
	|

BAU Spare Potential Output from Surviving Capacity by Hour after Seasonal Net Peak Load Reduction\
		[Electricity Timeslice,Hour]=
	BAU Potential Output from Surviving Capacity by Hour[Electricity Timeslice,Hour]
	- BAU Total Electricity Demand by Hour after Seasonal Net Peak Load Reduction[Electricity Timeslice\
		,Hour]
	~	MW*hr
	~		|

BAU Spare Potential Output from Surviving Capacity by Hour by Optimization Pass[Electricity Timeslice\
		,Hour,pass1]=
	BAU Total Electricity Demand by Hour before Net Imports[Electricity Timeslice,Hour] ~~|
BAU Spare Potential Output from Surviving Capacity by Hour by Optimization Pass[Electricity Timeslice\
		,Hour,current pass]=
	BAU Total Electricity Demand by Hour before Net Imports[Electricity Timeslice,Hour]
	  *IF THEN ELSE(BAU Share of Max Hourly Imports Met[Electricity Timeslice,Hour,preceeding pass\
		]=1,0,1)
	~	(MW*hr)
	~		|

BAU Spur Line Construction Costs[Electricity Source]=
	BAU New Generation Capacity[Electricity Source]
	* CCaMC Spur Line Construction Cost per Unit Capacity[Electricity Source]
	~	$
	~		|

BAU Start Year Electricity Generation Capacity Summed Across Vintages[Electricity Source\
		]= INITIAL(
	SUM(BHRaSYC Start Year Electricity Generation Capacity by Vintage[Electricity Source\
		,Modeled Vintage!]))
	~	MW
	~		|

BAU Start Year Low Carbon Hydrogen Production Shares by Pathway[Hydrogen Production Pathway\
		]=
	IF THEN ELSE(
	  SUM(
	    Hydrogen Production Pathways Qualifying as Low Carbon[Hydrogen Production Pathway\
		!]
	    * SYAHPC Start Year Annual Hydrogen Production Capacity[Hydrogen Production Pathway\
		!]
	  )
	  = 0,
	
	  ZIDZ(
	    Hydrogen Production Pathways Qualifying as Low Carbon[Hydrogen Production Pathway\
		],
	    SUM(
	      Hydrogen Production Pathways Qualifying as Low Carbon[Hydrogen Production Pathway\
		!]
	    )
	  ),
	
	  ZIDZ(
	     SYAHPC Start Year Annual Hydrogen Production Capacity[Hydrogen Production Pathway\
		]
	    * Hydrogen Production Pathways Qualifying as Low Carbon[Hydrogen Production Pathway\
		],
	    SUM(
	      Hydrogen Production Pathways Qualifying as Low Carbon[Hydrogen Production Pathway\
		!]
	      * SYAHPC Start Year Annual Hydrogen Production Capacity[Hydrogen Production Pathway\
		!]
	    )
	  )
	)
	~	Dmnl
	~		|

BAU Start Year Other Hydrogen Production Shares by Pathway[Hydrogen Production Pathway\
		]=
	IF THEN ELSE(
	  SUM(SYAHPC Start Year Annual Hydrogen Production Capacity[Hydrogen Production Pathway\
		!]) = 0,
	
	  ZIDZ(1, ELMCOUNT(Hydrogen Production Pathway)),
	
	  ZIDZ(SYAHPC Start Year Annual Hydrogen Production Capacity[Hydrogen Production Pathway\
		],
	  SUM(SYAHPC Start Year Annual Hydrogen Production Capacity[Hydrogen Production Pathway\
		!]))
	)
	~	Dmnl
	~		|

BAU Subsidies for Elec Production for Existing Plants Paid This Year[Electricity Source\
		]=
	BS BAU Subsidy per Unit Electricity Output for Existing Plants[Electricity Source]
	* BAU Electricity Generation by Type[Electricity Source]
	~	$
	~		|

BAU Subsidies Paid for Grid Battery Production Not Passed Through to Consumers=
	(BAU New Grid Battery Capacity + BPMGBSA BAU Policy Mandated Grid Battery Storage Additions
	  + SUM(BAU New Hybrid Grid Battery Storage Capacity[Electricity Source!]))
	
	* BAU Subsidy for Grid Battery Production Not Passed Through to Consumers
	~	$
	~		|

BAU Subsidies Paid for Grid Battery Production Passed Through to Consumers=
	BAU Subsidy for Grid Battery Production Passed Through to Consumers
	
	*
	
	(BAU New Grid Battery Capacity + BPMGBSA BAU Policy Mandated Grid Battery Storage Additions
	  + SUM(BAU New Hybrid Grid Battery Storage Capacity[Electricity Source!]))
	~	$
	~		|

BAU Subsidies Paid for New Grid Battery Construction=
	(BAU New Grid Battery Capacity+BPMGBSA BAU Policy Mandated Grid Battery Storage Additions\
		)
	* BAU Subsidy per Unit Grid Battery Capacity Deployed
	~	$
	~		|

BAU Subsidies Paid per Unit Electricity Output for Newly Eligible Generation Capacity\
		[Electricity Source]=
	BAU New Generation Capacity[Electricity Source]
	* BAU Expected Capacity Factor x Hours per Year for Plants Built This Year[Electricity Source\
		]
	* BS BAU Subsidy per Unit Electricity Output[Electricity Source]
	~	$
	~		|

BAU Subsidy for Grid Battery Production=
	BSfGBP BAU Subsidy for Grid Battery Production
	* FoGBPD Fraction of Grid Batteries Produced Domestically
	~	$/(MW*hr)
	~		|

BAU Subsidy for Grid Battery Production Not Passed Through to Consumers=
	BAU Subsidy for Grid Battery Production
	- BAU Subsidy for Grid Battery Production Passed Through to Consumers
	~	$/(MW*hr)
	~		|

BAU Subsidy for Grid Battery Production Passed Through to Consumers=
	BAU Subsidy for Grid Battery Production
	* FoSfBPPTtC Fraction of Subsidy for Battery Production Passed Through to Consumers
	~	$/(MW*hr)
	~		|

BAU Subsidy for Vehicle Battery Production=
	BSfVBP BAU Subsidy for Vehicle Battery Production
	* FoVBPD Fraction of Vehicle Batteries Produced Domestically
	~	$/(kW*hr)
	~		|

BAU Subsidy for Vehicle Battery Production Passed Through to Consumers=
	BAU Subsidy for Vehicle Battery Production
	* FoSfBPPTtC Fraction of Subsidy for Battery Production Passed Through to Consumers
	~	$/(kW*hr)
	~		|

BAU Subsidy Paid on Distributed Solar Capacity[Building Type]=
	BAU This Year Increase in Distributed Electricity Source Capacity[Building Type,solar PV es\
		]
	* BAU Cost per Unit Distributed Solar Capacity
	* BPSfDSPC BAU Perc Subsidy for Distributed Solar PV Capacity[Building Type]
	~	$
	~		|

BAU Subsidy Payments per Unit Electricity Output Expiring After Subsidy Duration Period\
		[Electricity Source]= DELAY FIXED (
	BAU Subsidies Paid per Unit Electricity Output for Newly Eligible Generation Capacity\
		[Electricity Source], BS Duration of Subsidies per Unit Electricity Output[Electricity Source\
		], 0)
	~	$
	~		|

BAU Subsidy per Unit Electricity Capacity Built[Electricity Source]=
	BS BAU Subsidy per Unit Electricity Capacity Built[Electricity Source]
	*BAU Construction Cost per Unit Capacity before Construction Subsidies[Electricity Source\
		]
	~	$/MW
	~		|

BAU Subsidy per Unit Electricity Output Adjusted for Subsidy Duration[Electricity Source\
		]=
	BS BAU Subsidy per Unit Electricity Output[Electricity Source]
	*BAU Duration Multiplier for Subsidies per Unit Electricity Output[Electricity Source\
		]
	~	$/(MW*hour)
	~		|

BAU Subsidy per Unit Electricity Output for Dispatch[Electricity Source]=
	IF THEN ELSE(
	  BAU Last Year Electricity Generation Capacity[Electricity Source]=0,
	                 
	  BS BAU Subsidy per Unit Electricity Output[Electricity Source],
	
	  ZIDZ(
	
	    SUM(BAU Last Year Electricity Generation Capacity by Vintage[Electricity Source,\
		Modeled Vintage!]
	    * BAU Subsidy per Unit Electricity Output for Dispatch by Vintage[Electricity Source\
		,Modeled Vintage!]),
	
	    BAU Last Year Electricity Generation Capacity[Electricity Source]
	  )
	)
	~	$/(MW*hr)
	~		|

BAU Subsidy per Unit Electricity Output for Dispatch by Vintage[Electricity Source,Modeled Vintage\
		]=
	DEPRECIATE STRAIGHTLINE(
	
	  BS BAU Subsidy per Unit Electricity Output[Electricity Source]
	  * BS Duration of Subsidies per Unit Electricity Output[Electricity Source] / One Year
	  * This Year Modeled Vintage Flag[Modeled Vintage],
	 
	  BS Duration of Subsidies per Unit Electricity Output[Electricity Source],
	
	  1,
	
	  0
	)
	~	$/(MW*hr)
	~		|

BAU Subsidy per Unit Grid Battery Capacity Deployed=
	(BPSpUGBCD BAU Percent Subsidy per Unit Grid Battery Capacity Deployed
	  * BAU Total Battery Cost per Unit Capacity)
	~	$/(MW*hr)
	~		|

BAU Sum of Shareweights by Vehicle and Cargo Type[Vehicle Type,Cargo Type]=
	SUM(
	  TTS Transportation Technology Shareweights[Vehicle Type,Cargo Type,Vehicle Technology\
		!]
	  * BAU Vehicle Technologies Qualifying as ZEVs[Vehicle Type,Vehicle Technology!]
	)
	~	Dmnl
	~		|

BAU Surviving Capacity Available After Green Hydrogen Demand[Hydrogen Production Pathway\
		] :EXCEPT:  [electrolysis with guaranteed clean electricity
]=
	BAU Surviving Hydrogen Production Capacity[Hydrogen Production Pathway] ~~|
BAU Surviving Capacity Available After Green Hydrogen Demand[electrolysis with guaranteed clean electricity\
		]=
	BAU Surviving Hydrogen Production Capacity[electrolysis with guaranteed clean electricity\
		]
	- BAU Surviving Capacity Used for Green Hydrogen Production
	~	BTU
	~		|

BAU Surviving Capacity Available After Low Carbon Hydrogen Demand[Hydrogen Production Pathway\
		]=
	BAU Surviving Capacity Available After Green Hydrogen Demand[Hydrogen Production Pathway\
		]
	- BAU Surviving Capacity Used for Low Carbon Hydrogen Production[Hydrogen Production Pathway\
		]
	~	BTU
	~		|

BAU Surviving Capacity Available for Low Carbon Hydrogen Demand[Hydrogen Production Pathway\
		]=
	BAU Surviving Capacity Available After Green Hydrogen Demand[Hydrogen Production Pathway\
		]
	* Hydrogen Production Pathways Qualifying as Low Carbon[Hydrogen Production Pathway]
	~	BTU
	~		|

BAU Surviving Capacity Used for Green Hydrogen Production=
	MIN(
	  BAU Green Hydrogen Demand,
	  BAU Surviving Green Hydrogen Production Capacity
	)
	~	BTU
	~		|

BAU Surviving Capacity Used for Hydrogen Production[Hydrogen Production Pathway] :EXCEPT:\
		  [electrolysis with guaranteed clean electricity
]=
	BAU Surviving Capacity Used for Low Carbon Hydrogen Production[Hydrogen Production Pathway\
		]
	+ BAU Surviving Capacity Used for Other Hydrogen Production[Hydrogen Production Pathway\
		] ~~|
BAU Surviving Capacity Used for Hydrogen Production[electrolysis with guaranteed clean electricity\
		]=
	BAU Surviving Capacity Used for Green Hydrogen Production
	+ BAU Surviving Capacity Used for Low Carbon Hydrogen Production[electrolysis with guaranteed clean electricity\
		]
	+ BAU Surviving Capacity Used for Other Hydrogen Production[electrolysis with guaranteed clean electricity\
		]
	~	BTU
	~		|

BAU Surviving Capacity Used for Low Carbon Hydrogen Production[Hydrogen Production Pathway\
		]=
	ALLOCATE AVAILABLE(
	  BAU Surviving Capacity Available for Low Carbon Hydrogen Demand[Hydrogen Production Pathway\
		],
	  BAU Hydrogen Production Dispatch Cost Parameters as Vector[Hydrogen Production Pathway\
		,ptype],
	  BAU Total Surviving Capacity Used for Low Carbon Hydrogen Production
	)
	~	BTU
	~		|

BAU Surviving Capacity Used for Other Hydrogen Production[Hydrogen Production Pathway\
		]=
	ALLOCATE AVAILABLE(
	  BAU Surviving Capacity Available After Low Carbon Hydrogen Demand[Hydrogen Production Pathway\
		],
	  BAU Hydrogen Production Dispatch Cost Parameters as Vector[Hydrogen Production Pathway\
		,ptype],
	  BAU Total Surviving Capacity Used for Other Hydrogen Demand
	)
	~	BTU
	~		|

BAU Surviving Electricity Generation Capacity[Electricity Source]=
	BAU Surviving Electricity Generation Capacity before Economic Retirements[Electricity Source\
		]
	- BAU Economic Capacity Retirements by Optimization Pass[Electricity Source,pass20]
	~	MW
	~		|

BAU Surviving Electricity Generation Capacity before Economic Retirements[Electricity Source\
		]=
	MAX(
	  0,
	
	  BAU Last Year Electricity Generation Capacity[Electricity Source]
	  - BCRbQ BAU Capacity Retirements before Quantization[Electricity Source]
	)
	~	MW
	~		|

BAU Surviving Green Hydrogen Production Capacity=
	BAU Surviving Hydrogen Production Capacity[electrolysis with guaranteed clean electricity\
		]
	~	BTU
	~		|

BAU Surviving Hydrogen Production Capacity[Hydrogen Production Pathway]=
	BAU Surviving Preexisting Hydrogen Production Capacity[Hydrogen Production Pathway]
	+ BAU Surviving Hydrogen Production Capacity Installed During Model Run[Hydrogen Production Pathway\
		]
	~	BTU
	~		|

BAU Surviving Hydrogen Production Capacity Installed During Model Run[Hydrogen Production Pathway\
		]=
	SUM(
	  BAU Last Year Hydrogen Production Capacity Installed During Model Run by Vintage[Hydrogen Production Pathway\
		,Model Run Vintage!]
	  - BAU Retiring Hydrogen Production Capacity Installed During Model Run by Vintage[\
		Hydrogen Production Pathway,Model Run Vintage!] * One Year
	)
	~	BTU
	~		|

BAU Surviving Potential Elec Portfolio Qualifying Output[Clean Elec Requirement]=
	SUM(
	  BAU Surviving Potential Elec Portfolio Qualifying Output by Hour[Electricity Timeslice\
		!,Hour!,Clean Elec Requirement]
	  * SHELF Days per Electricity Timeslice[Electricity Timeslice!]
	)
	~	MW*hr
	~		|

BAU Surviving Potential Elec Portfolio Qualifying Output by Hour[Electricity Timeslice\
		,Hour,Clean Elec Requirement]=
	MIN(
	  SUM(
	    BAU Surviving Electricity Generation Capacity before Economic Retirements[Electricity Source\
		!]
	    * BAU Last Year Achieved Capacity Factors by Hour[Electricity Timeslice,Hour,Electricity Source\
		!]
	    * Elec Portfolio Qualifying Sources[Electricity Source!,Clean Elec Requirement]
	    * One Hour
	  ),
	
	  BAU Total Electricity Demand by Hour After Demand Altering Technologies Excluding New Hybrid Batteries\
		[Electricity Timeslice
	,Hour]
	)
	~	MW*hr
	~		|

BAU Surviving Preexisting Hydrogen Production Capacity[Hydrogen Production Pathway]=
	BAU Last Year Preexisting Hydrogen Production Capacity[Hydrogen Production Pathway]
	- BAU Retiring Preexisting Hydrogen Production Capacity[Hydrogen Production Pathway]\
		 * One Year
	~	BTU
	~		|

BAU Taxes Paid by Fuel[All Fuels]=
	BAU Taxes Paid on Buildings Fuels Mapped to All Fuels Subscript[All Fuels]
	+ BAU Taxes Paid on District Heating Fuels Mapped to All Fuels Subscript[All Fuels]
	+ BAU Taxes Paid on Electricity Fuels Mapped to All Fuels Subscript[All Fuels]
	+ BAU Taxes Paid on Hydrogen Sector Fuels Mapped to All Fuels Subscript[All Fuels]
	+ BAU Taxes Paid on Industry Fuels Mapped to All Fuels Subscript[All Fuels]
	+ BAU Taxes Paid on Transportation Fuels Mapped to All Fuels Subscript[All Fuels]
	~	$
	~		|

BAU Taxes Paid on Buildings Fuels Mapped to All Fuels Subscript[All Fuels] :EXCEPT:  \
		[building fuel within all fuels]=
	0 ~~|
BAU Taxes Paid on Buildings Fuels Mapped to All Fuels Subscript[building fuel within all fuels\
		]=
	SUM(BAU Total Tax Paid on Buildings Fuels[Building Type!,Building Fuel])
	~	$
	~		|

BAU Taxes Paid on District Heating Fuels Mapped to All Fuels Subscript[All Fuels] :EXCEPT:\
		  [industrial fuel within all fuels]=
	0 ~~|
BAU Taxes Paid on District Heating Fuels Mapped to All Fuels Subscript[industrial fuel within all fuels\
		] :EXCEPT: [hydrogen]=
	BAU Total Tax Paid on Fuels to Generate Heat[Industrial Fuel] ~~|
BAU Taxes Paid on District Heating Fuels Mapped to All Fuels Subscript[hydrogen]=
	BAU Total Tax Paid on Fuels to Generate Heat[hydrogen if]
	+ BAU Total Tax Paid on Fuels to Generate Heat[green hydrogen if]
	+ BAU Total Tax Paid on Fuels to Generate Heat[low carbon hydrogen if]
	~	$
	~		|

BAU Taxes Paid on Electricity Fuels Mapped to All Fuels Subscript[All Fuels] :EXCEPT:\
		  [electricity source within all fuels]=
	0 ~~|
BAU Taxes Paid on Electricity Fuels Mapped to All Fuels Subscript[electricity source within all fuels\
		] :EXCEPT:    [solar],[wind],[natural gas],[hard coal],[biomass],[lignite],[nuclear\
		],[hydrogen]=
	BAU Total Tax Paid on Electricity Fuels[Electricity Source] ~~|
BAU Taxes Paid on Electricity Fuels Mapped to All Fuels Subscript[solar]=
	BAU Total Tax Paid on Electricity Fuels[solar PV es]
	+ BAU Total Tax Paid on Electricity Fuels[solar thermal es] ~~|
BAU Taxes Paid on Electricity Fuels Mapped to All Fuels Subscript[wind]=
	BAU Total Tax Paid on Electricity Fuels[onshore wind es]
	+ BAU Total Tax Paid on Electricity Fuels[offshore wind es] ~~|
BAU Taxes Paid on Electricity Fuels Mapped to All Fuels Subscript[natural gas]=
	BAU Total Tax Paid on Electricity Fuels[natural gas steam turbine es]
	+ BAU Total Tax Paid on Electricity Fuels[natural gas combined cycle es]
	+ BAU Total Tax Paid on Electricity Fuels[natural gas peaker es]
	+ BAU Total Tax Paid on Electricity Fuels[natural gas combined cycle w CCS es] ~~|
BAU Taxes Paid on Electricity Fuels Mapped to All Fuels Subscript[hard coal]=
	BAU Total Tax Paid on Electricity Fuels[hard coal es]
	+ BAU Total Tax Paid on Electricity Fuels[hard coal w CCS es] ~~|
BAU Taxes Paid on Electricity Fuels Mapped to All Fuels Subscript[biomass]=
	BAU Total Tax Paid on Electricity Fuels[biomass es]
	+ BAU Total Tax Paid on Electricity Fuels[biomass w CCS es] ~~|
BAU Taxes Paid on Electricity Fuels Mapped to All Fuels Subscript[lignite]=
	BAU Total Tax Paid on Electricity Fuels[lignite es]
	+ BAU Total Tax Paid on Electricity Fuels[lignite w CCS es] ~~|
BAU Taxes Paid on Electricity Fuels Mapped to All Fuels Subscript[nuclear]=
	BAU Total Tax Paid on Electricity Fuels[nuclear es]
	+ BAU Total Tax Paid on Electricity Fuels[small modular reactor es] ~~|
BAU Taxes Paid on Electricity Fuels Mapped to All Fuels Subscript[hydrogen]=
	BAU Total Tax Paid on Electricity Fuels[hydrogen combustion turbine es]
	+ BAU Total Tax Paid on Electricity Fuels[hydrogen combined cycle es]
	~	$
	~		|

BAU Taxes Paid on Geoengineering Fuels[Industrial Fuel]=
	QUANTUM(
	  BAU Geoengineering Sector Energy Use[Industrial Fuel]
	  * BAU Geoengineering Fuel Total Tax or Subsidy Amount per Unit Energy[Industrial Fuel\
		],
	
	  QSfCF Quantization Size for Cash Flows
	)
	~	$
	~		|

BAU Taxes Paid on Hydrogen Sector Fuels Mapped to All Fuels Subscript[All Fuels] :EXCEPT:\
		 [industrial fuel within all fuels]=
	0 ~~|
BAU Taxes Paid on Hydrogen Sector Fuels Mapped to All Fuels Subscript[industrial fuel within all fuels\
		] :EXCEPT: [hydrogen]=
	BAU Total Tax Paid on Hydrogen Sector Fuels[Industrial Fuel] ~~|
BAU Taxes Paid on Hydrogen Sector Fuels Mapped to All Fuels Subscript[hydrogen]=
	BAU Total Tax Paid on Hydrogen Sector Fuels[hydrogen if]
	+ BAU Total Tax Paid on Hydrogen Sector Fuels[green hydrogen if]
	+ BAU Total Tax Paid on Hydrogen Sector Fuels[low carbon hydrogen if]
	~	$
	~		|

BAU Taxes Paid on Industry Fuels[Industry Category,Industrial Fuel]=
	BAU Industrial Fuel Use for Energy Purposes[Industry Category,Industrial Fuel]
	  * BAU Industrial Fuel Total Tax or Subsidy Amount per Unit Energy[Industry Category\
		,Industrial Fuel]
	  * (1 - SoFCTiBoSFbI Share of Fuel Consumption That is Byproduct or Secondary Fuels by Industry\
		[Industry Category,Industrial Fuel])
	
	+ BAU Industrial Feedstock Use after Adjustments[Industry Category,Industrial Fuel]
	  * (
	      BAU Industrial Fuel Total Tax or Subsidy Amount per Unit Energy[Industry Category\
		,Industrial Fuel]
	      - BAU Industrial Fuel Carbon Tax Amount per Unit Energy[Industry Category,Industrial Fuel\
		]
	    )
	~	$
	~		|

BAU Taxes Paid on Industry Fuels Mapped to All Fuels Subscript[All Fuels] :EXCEPT:  [\
		industrial fuel within all fuels]=
	0 ~~|
BAU Taxes Paid on Industry Fuels Mapped to All Fuels Subscript[industrial fuel within all fuels\
		] :EXCEPT: [hydrogen]=
	SUM(BAU Taxes Paid on Industry Fuels[Industry Category!,Industrial Fuel]) ~~|
BAU Taxes Paid on Industry Fuels Mapped to All Fuels Subscript[hydrogen]=
	SUM(BAU Taxes Paid on Industry Fuels[Industry Category!,hydrogen if])
	+ SUM(BAU Taxes Paid on Industry Fuels[Industry Category!,green hydrogen if])
	+ SUM(BAU Taxes Paid on Industry Fuels[Industry Category!,low carbon hydrogen if])
	~	$
	~		|

BAU Taxes Paid on Transportation Fuels Mapped to All Fuels Subscript[All Fuels] :EXCEPT:\
		  [transportation fuel within all fuels]=
	0 ~~|
BAU Taxes Paid on Transportation Fuels Mapped to All Fuels Subscript[transportation fuel within all fuels\
		]=
	SUM(BAU Total Tax Paid on Transportation Fuels[Transportation Fuel,Vehicle Type!,Cargo Type\
		!,Vehicle Technology!])
	~	$
	~		|

BAU Thermal Fuel Subsidies Paid[All Fuels,Sectors]=
	(BAU Fuel Production Imports and Exports[All Fuels,production]
	 * ZIDZ(
	     BAU Total Energy Use by Sector[Sectors,All Fuels],
	
	     SUM(BAU Total Energy Use by Sector[Sectors!,All Fuels])
	   )
	)
	* BS BAU Subsidy for Thermal Fuels per Energy Unit Produced[All Fuels,Sectors]
	~	$
	~		|

BAU This Year Battery Capacity Affecting Learning=
	Battery Storage Capacity Outside Modeled Region Affecting Learning
	+ BAU Cumulative Battery Capacity Deployed
	~	MW*hr
	~		|

BAU This Year Battery Cost as Fraction of Last Year Battery Cost=
	(1 - PDiBCpDoC Perc Decline in Battery Cost per Doubling of Capacity)
	^ ( LN(
	        BAU This Year Battery Capacity Affecting Learning
	        / BAU Last Year Battery Storage Affecting Learning
	      )
	    / LN(2)
	  )
	~	Dmnl
	~		|

BAU This Year Battery Manufacturing Price After Subsidies=
	BAU This Year Battery Manufacturing Price Before Subsidies
	- BAU Subsidy for Vehicle Battery Production Passed Through to Consumers
	~	$/(kW*hr)
	~		|

BAU This Year Battery Manufacturing Price Before Subsidies=
	IF THEN ELSE(BPP Battery Pack Price > 0,
	
	  BPP Battery Pack Price,
	
	  IF THEN ELSE(BPP Battery Pack Price With One Year Delay > 0,
	
	    BPP Battery Pack Price With One Year Delay
	     * BAU This Year Battery Cost as Fraction of Last Year Battery Cost,
	
	    BAU Last Year Battery Manufacturing Price
	     * BAU This Year Battery Cost as Fraction of Last Year Battery Cost
	  )
	)
	~	$/(kW*hr)
	~		|

BAU This Year Battery Portion of Vehicle Price[Cargo Type,Vehicle Type,Vehicle Technology\
		]=
	BAU This Year Battery Manufacturing Price After Subsidies
	* This Year Battery Capacity by Vehicle Type[Cargo Type,Vehicle Type,Vehicle Technology\
		]
	~	$/vehicle
	~		|

BAU This Year Battery Subsidy Passed Through to Consumers by Vehicle Type[Cargo Type,\
		Vehicle Type,Vehicle Technology]=
	BAU Subsidy for Vehicle Battery Production Passed Through to Consumers
	* This Year Battery Capacity by Vehicle Type[Cargo Type,Vehicle Type,Vehicle Technology\
		]
	~	$/vehicle
	~		|

BAU This Year Capacity Market Repayment=
	DEPRECIATE STRAIGHTLINE(
	
	  BAU Total Capacity Market Costs
	  / One Year,
	 
	  Repayment Period for Capacity Market Charges,
	
	  1,
	
	  0
	)
	~	$/Year
	~		|

BAU This Year CCS Cost as Fraction of Last Year CCS Cost=
	(1 - PDiCECpDoC Perc Decline in CCS Eqpt Cost per Doubling of Capacity)
	^ ( LN(
	        BAU This Year CO2 Sequestered Affecting Learning
	        / BAU Last Year CO2 Sequestered Affecting Learning
	      )
	    / LN(2)
	  )
	~	Dmnl
	~	In the event we have no CCS in the base year, we do not decline CCS costs \
		based on installed capacity, because we cannot calculate the doublings of \
		capacity from the base year.  Also, we disallow increases in CCS cost, \
		which could otherwise happen if CCS capacity declines in any year relative \
		to the prior year.
	|

BAU This Year CCS Subsidies Paid[Electricity Source]=
	BAU CCS Subsidies Paid per Unit Electricity Output for Newly Eligible CCS Capacity[Electricity Source\
		]
	
	+BAU Last Year CCS Subsidies Paid per Unit Electricity Output for Newly Eligible CCS Capacity\
		[Electricity Source]
	
	- BAU CCS Subsidy Payments per Unit Electricity Output Expiring After CCS Subsidy Duration Period\
		[Electricity Source]
	~	$
	~		|

BAU This Year Change in Hydrogen Produced by Pathway[Hydrogen Production Pathway]=
	BAU Hydrogen Production by Pathway[Hydrogen Production Pathway]
	- BAU Last Year Hydrogen Produced by Pathway[Hydrogen Production Pathway]
	~	BTU
	~		|

BAU This Year CO2 Sequestered[electricity sector]=
	SUM(BAU This Year Pollutants Sequestered by Electricity Sector[CO2,Electricity Source\
		!])
	/ Grams per Metric Ton CO2e
	/ Grams Pollutant per Gram CO2e Unit Converter ~~|
BAU This Year CO2 Sequestered[industry sector]=
	SUM(BAU This Year Pollutants Sequestered by Industry Sector[Industry Category!,CO2,Emissions Type\
		!])
	/ Grams per Metric Ton CO2e
	/ Grams Pollutant per Gram CO2e Unit Converter ~~|
BAU This Year CO2 Sequestered[district heat and hydrogen sector]=
	BAU This Year Pollutants Sequestered by Hydrogen Sector[CO2]
	/ Grams per Metric Ton CO2e
	/ Grams Pollutant per Gram CO2e Unit Converter
	~	metric tons CO2e
	~		|

BAU This Year CO2 Sequestered Affecting Learning=
	This Year CO2 Sequestered Outside Modeled Region Affecting Learning
	+ SUM(BAU Last Year CO2 Sequestered[CCS Sectors!])
	~	metric tons CO2e
	~		|

BAU This Year Cumulative Policy Mandated Grid Battery Storage=
	BAU Last Year Cumulative Policy Mandated Grid Battery Storage
	+ BPMGBSA BAU Policy Mandated Grid Battery Storage Additions
	~	MW*hour
	~		|

BAU This Year Demand Response Capacity=
	DRC BAU Demand Response Capacity
	+ BAU Demand Responsive Electricity Capacity for Electrolyzers
	~	MW
	~		|

BAU This Year DR Capacity by Provider[Cash Flow Entity] :EXCEPT:  [nonenergy industries\
		]=
	DRC BAU Demand Response Capacity
	* DRCo Share of DR by Provider[Cash Flow Entity] ~~|
BAU This Year DR Capacity by Provider[nonenergy industries]=
	DRC BAU Demand Response Capacity
	* DRCo Share of DR by Provider[nonenergy industries]
	+ BAU Demand Responsive Electricity Capacity for Electrolyzers
	~	MW
	~		|

BAU This Year Electricity Generation Affecting Learning[Electricity Source]=
	This Year Global Solar and Wind Capacities Affecting Learning[Electricity Source]
	+ BAU Last Year Electricity Generation Capacity by Type Including Distributed Generation\
		[Electricity Source]
	~	MW
	~		|

BAU This Year Energy Related Pollutants Sequestered by Industry Sector[Industry Category\
		,Pollutant] :EXCEPT: [Industry Category,CO2]=
	0 ~~|
BAU This Year Energy Related Pollutants Sequestered by Industry Sector[Industry Category\
		,CO2]=
	SUM(BAU Industrial Sector Energy Related Emissions before CCS[Industrial Fuel!,Industry Category\
		,CO2])
	* BAU Fraction of CO2 Captured by Industry[Industry Category,energy related emissions\
		]
	~	g pollutant
	~		|

BAU This Year Financing Repayments for Hydrogen Production Eqpt[Hydrogen Production Pathway\
		]=
	BAU Annual Financing Repayments for Newly Purchased Hydrogen Production Eqpt[Hydrogen Production Pathway\
		] * One Year
	+ BAU Last Year Financing Repayments for Hydrogen Production Eqpt[Hydrogen Production Pathway\
		]
	- BAU Annual Financing Repayments for Hydrogen Production Eqpt Expiring This Year[Hydrogen Production Pathway\
		] * One Year
	~	$
	~		|

BAU This Year Financing Repayments for Industrial CCS Equipment[Industry Category]=
	BAU Last Year Financing Repayments for Industrial CCS Equipment[Industry Category]
	+ BAU Annual Financing Repayment for Newly Purchased Industrial CCS Equipment[Industry Category\
		]
	- BAU Annual Industrial CCS Equipment Financing Repayments Expiring After Repayment Period\
		[Industry Category]
	~	$
	~		|

BAU This Year Financing Repayments for Industrial Equipment[Industry Category]=
	SUM(
	  BAU Annual Financing Repayment for Newly Purchased Industrial Equipment[Industry Category\
		,Industrial Process!]
	  + BAU Last Year Financing Repayments for Industrial Equipment[Industry Category,Industrial Process\
		!]
	  - BAU Annual Industrial Equipment Financing Repayments Expiring After Repayment Period\
		[Industry Category,Industrial Process!]
	)
	~	$
	~		|

BAU This Year Fraction of Initial Industrial Equipment Retired[Industry Category,Industrial Process\
		]=
	BAU Fraction of All Preexisting Equipment Retired[Industry Category,Industrial Process\
		]
	- BAU Last Year Fraction of All Preexisting Equipment Retired[Industry Category,Industrial Process\
		]
	~	Dmnl
	~		|

BAU This Year Green Hydrogen Cost=
	BAU Cost per Unit New Hydrogen Production[electrolysis with guaranteed clean electricity\
		]
	~	$/BTU
	~		|

BAU This Year Grid Battery Storage Capacity excluding Hybrid Batteries=
	BAU Last Year Grid Battery Storage Capacity excluding Hybrid Batteries
	+ BAU New Grid Battery Capacity
	~	MW*hour
	~		|

BAU This Year Grid Battery Storage Capacity excluding Hybrid Batteries in MW=
	BAU This Year Total Grid Battery Storage Capacity excluding Hybrid Batteries
	/ GBSC Diurnal Grid Battery Daily Storage Duration
	~	MW
	~		|

BAU This Year Grid Battery Storage Capacity in MW=
	(BAU This Year Total Grid Battery Storage Capacity excluding Hybrid Batteries + SUM(\
		BAU This Year Hybrid Grid Battery Storage Capacity
	[Electricity Source!]))
	/ GBSC Diurnal Grid Battery Daily Storage Duration
	~	MW
	~		|

BAU This Year Hybrid Grid Battery Storage Capacity[Electricity Source]=
	BAU Last Year Hybrid Grid Battery Storage Capacity[Electricity Source]
	+ BAU New Hybrid Grid Battery Storage Capacity[Electricity Source]
	~	MW*hour
	~		|

BAU This Year Hybrid Grid Battery Storage Capacity in MW=
	SUM(BAU This Year Hybrid Grid Battery Storage Capacity[Electricity Source!])
	/ GBSC Diurnal Grid Battery Daily Storage Duration
	~	MW
	~		|

BAU This Year Increase in Distributed Electricity Source Capacity[Building Type,Electricity Source\
		]=
	MAX(
	  0,
	
	  BAU Distributed Electricity Source Capacity[Building Type,Electricity Source]
	  - Last Year BAU Distributed Electricity Source Capacity[Building Type,Electricity Source\
		]
	)
	~	MW
	~		|

BAU This Year Increase in Pollutants Sequestered by Hydrogen Sector[Pollutant]=
	IF THEN ELSE(
	  Time = INITIAL TIME,
	
	  0,
	
	  MAX(
	    0,
	
	    BAU This Year Pollutants Sequestered by Hydrogen Sector[Pollutant]
	    - BAU Last Year Pollutants Sequestered by Hydrogen Sector[Pollutant]
	  )
	)
	~	g pollutant
	~		|

BAU This Year Increase in Pollutants Sequestered by Industry Sector[Industry Category\
		,Pollutant,Emissions Type]=
	IF THEN ELSE(
	  Time = INITIAL TIME,
	
	  0,
	
	  MAX(
	    0,
	
	    BAU This Year Pollutants Sequestered by Industry Sector[Industry Category,Pollutant\
		,Emissions Type]
	    - BAU Last Year Pollutants Sequestered by Industry Sector[Industry Category,Pollutant\
		,Emissions Type]
	  )
	)
	~	g pollutant
	~		|

BAU This Year Low Carbon Hydrogen Cost=
	ZIDZ(
	  SUM(
	    BAU Cost per Unit New Hydrogen Production[Hydrogen Production Pathway!]
	    * BAU Last Year Low Carbon Hydrogen Production Shares by Pathway[Hydrogen Production Pathway\
		!]
	  ),
	
	  SUM(BAU Last Year Low Carbon Hydrogen Production Shares by Pathway[Hydrogen Production Pathway\
		!])
	)
	~	$/BTU
	~		|

BAU This Year Ongoing CES Costs=
	SUM(BAU CES Costs for Incremental Capacity Additions[Clean Elec Requirement!])
	+SUM(BAU Last Year Ongoing CES Costs[Clean Elec Requirement!])
	+SUM(BAU CES Costs for ACP Compliance[Clean Elec Requirement!])
	-SUM(BAU CES Costs for Incremental Capacity Additions after Financial Lifetime[Clean Elec Requirement\
		!])
	~	$
	~		|

BAU This Year Ongoing Repayment for Buildings Sector Financed Capital Expenses[Building Type\
		]=
	BAU Annual Repayment for Financed Buildings Sector Capital Expenses[Building Type]
	
	+BAU Last Year Repayment for Financed Buildings Sector Capital Expenses[Building Type\
		]
	~	$
	~		|

BAU This Year Ongoing Subsidies Paid per Unit Electricity Output[Electricity Source]=
	BAU Subsidies Paid per Unit Electricity Output for Newly Eligible Generation Capacity\
		[Electricity Source]
	
	+BAU Last Year Subsidies Paid per Unit Electricity Output for Newly Eligible Generation Capacity\
		[Electricity Source]
	
	- BAU Subsidy Payments per Unit Electricity Output Expiring After Subsidy Duration Period\
		[Electricity Source]
	~	$
	~		|

BAU This Year Other Hydrogen Cost=
	ZIDZ(
	  SUM(
	    BAU Last Year Other Hydrogen Production Shares by Pathway[Hydrogen Production Pathway\
		!]
	    * BAU Cost per Unit New Hydrogen Production[Hydrogen Production Pathway!]
	  ),
	
	  SUM(BAU Last Year Other Hydrogen Production Shares by Pathway[Hydrogen Production Pathway\
		!])
	)
	~	$/BTU
	~		|

BAU This Year Pollutants Sequestered by Electricity Sector[Pollutant,Electricity Source\
		] :EXCEPT:   [CO2,Electricity Source
]=
	0 ~~|
BAU This Year Pollutants Sequestered by Electricity Sector[CO2,Electricity Source]=
	BAU Electricity Generation by Type[Electricity Source]
	* BAU Metric Tons CO2 Stored per MWh[Electricity Source]
	* Grams per Metric Ton CO2e
	* Grams Pollutant per Gram CO2e Unit Converter
	~	g pollutant
	~		|

BAU This Year Pollutants Sequestered by Hydrogen Sector[Pollutant] :EXCEPT: [CO2]=
	0 ~~|
BAU This Year Pollutants Sequestered by Hydrogen Sector[CO2]=
	SUM(BAU Hydrogen Sector Fuel Use by Pathway[natural gas reforming with CCS,Industrial Fuel\
		!]
	* Industrial Fuel Pollutant Emissions Intensities This Year[cement and other nonmetallic minerals 239\
		,CO2,Industrial Fuel!])
	* CCP CO2 Capture Potential by Hydrogen Sector
	~	g pollutant
	~	We use the cement sector as a representative sector from which to source \
		pollutant emissions intensities for this variable.
	|

BAU This Year Pollutants Sequestered by Industry Sector[Industry Category,Pollutant,energy related emissions\
		]=
	BAU This Year Energy Related Pollutants Sequestered by Industry Sector[Industry Category\
		,Pollutant] ~~|
BAU This Year Pollutants Sequestered by Industry Sector[Industry Category,Pollutant,process emissions\
		]=
	BAU This Year Process Pollutants Sequestered by Industry Sector[Industry Category,Pollutant\
		]
	~	g pollutant
	~		|

BAU This Year Pretax Electricity Price by Sector[Sectors]=
	MAX(0,
	  
	 IF THEN ELSE(
	  
	  Time=INITIAL TIME,
	  
	  Start Year Electricity Prices by Sector[Sectors],
	
	  BAU Last Year Electricity Supplier Expenditures after Subsidies per Unit Electricity Produced
	  + Last Year Additional Retail Electricity Costs per Unit Electricity Produced[Sectors\
		]
	  
	 )
	)
	~	$/BTU
	~		|

BAU This Year Process Pollutants Sequestered by Industry Sector[Industry Category,Pollutant\
		] :EXCEPT: [Industry Category,CO2]=
	0 ~~|
BAU This Year Process Pollutants Sequestered by Industry Sector[Industry Category,CO2\
		]=
	BAU Process Emissions before CCS[Industry Category,CO2]
	* BAU Fraction of CO2 Captured by Industry[Industry Category,process emissions]
	~	g pollutant
	~		|

BAU This Year Solar and Wind Hard Costs as Fraction of Last Year Hard Costs[Electricity Source\
		] :EXCEPT:    [onshore wind es
],[solar PV es],[offshore wind es]=
	0 ~~|
BAU This Year Solar and Wind Hard Costs as Fraction of Last Year Hard Costs[onshore wind es\
		]=
	(1 - PDiCCpDoC Perc Decline in Capacity Cost per Doubling of Capacity[onshore wind es\
		])
	^ ( LN(
	        BAU This Year Electricity Generation Affecting Learning[onshore wind es]
	        / BAU Last Year Electricity Generation Affecting Learning[onshore wind es]
	      )
	    / LN(2)
	  ) ~~|
BAU This Year Solar and Wind Hard Costs as Fraction of Last Year Hard Costs[solar PV es\
		]=
	(1 - PDiCCpDoC Perc Decline in Capacity Cost per Doubling of Capacity[solar PV es])
	^ ( LN(
	        BAU This Year Electricity Generation Affecting Learning[solar PV es]
	        / BAU Last Year Electricity Generation Affecting Learning[solar PV es]
	      )
	    / LN(2)
	  ) ~~|
BAU This Year Solar and Wind Hard Costs as Fraction of Last Year Hard Costs[offshore wind es\
		]=
	(1 - PDiCCpDoC Perc Decline in Capacity Cost per Doubling of Capacity[offshore wind es\
		])
	^ ( LN(
	        BAU This Year Electricity Generation Affecting Learning[offshore wind es]
	        / BAU Last Year Electricity Generation Affecting Learning[offshore wind es]
	      )
	    / LN(2)
	  )
	~	Dmnl
	~		|

BAU This Year Total Grid Battery Storage Capacity excluding Hybrid Batteries=
	BAU This Year Grid Battery Storage Capacity excluding Hybrid Batteries
	+ BAU This Year Cumulative Policy Mandated Grid Battery Storage
	~	MW*hour
	~		|

BAU This Year Total Grid Battery Storage Capacity excluding Hybrid Batteries in MW=
	BAU This Year Total Grid Battery Storage Capacity excluding Hybrid Batteries
	/ GBSC Diurnal Grid Battery Daily Storage Duration
	~	MW
	~		|

BAU Three Year Average Net Energy Market Revenue by Plant Type Excluding Subsidies for Hybrid Power Plants\
		[Hybrid Electricity Source]=
	DEPRECIATE STRAIGHTLINE(
	 BAU One Year Average Net Energy Market Revenue by Plant Type Excluding Subsidies for Hybrid Power Plants\
		[Hybrid Electricity Source],
	 3,
	 1,
	 0
	)
	~	$/MW
	~		|

BAU Three Year Average Total Predicted Net Energy Market Revenue per MW[Electricity Source\
		]=
	DEPRECIATE STRAIGHTLINE(
	 BAU Last Year Total Five Year Average Net Energy Market Revenue per MW[Electricity Source\
		], 
	 3, 
	 1, 
	 0
	)
	~	$/MW
	~		|

BAU Three Year Average Wholesale Energy Market Costs=
	DEPRECIATE STRAIGHTLINE(
	 BAU One Year Average Wholesale Energy Market Costs,
	 3,
	 1,
	 0
	)
	~	$
	~		|

BAU Three Year Weighted Average Hypothetical Electricity Capacity Factor[Electricity Timeslice\
		,Hour,Electricity Source]=
	(BAU Last Year Hypothetical Hourly Electricity Capacity Factor[Electricity Timeslice\
		,Hour,Electricity Source]
	+ BAU Two Years Prior Hypothetical Hourly Electricity Capacity Factor[Electricity Timeslice\
		,Hour,Electricity Source]
	+ BAU Three Years Prior Hypothetical Hourly Electricity Capacity Factor[Electricity Timeslice\
		,Hour,Electricity Source]
	)
	/3
	~	Dmnl
	~		|

BAU Three Years Prior Hypothetical Hourly Electricity Capacity Factor[Electricity Timeslice\
		,Hour,Electricity Source]= DELAY FIXED (
	BAU Two Years Prior Hypothetical Hourly Electricity Capacity Factor[Electricity Timeslice\
		,Hour,Electricity Source],
	1,
	SYSHECF Start Year Seasonal Expected Hourly Electricity Capacity Factors[Electricity Source\
		,Electricity Timeslice,Hour]
	* RAF Regional Availability Factor for Generation[Electricity Source])
	~	Dmnl
	~		|

BAU Total Annual Recoverable Costs for Cost of Service Rates=
	QUANTUM(
	  BAU Total Cost of Power Generation
	  +BAU Annual Cost Recovery for Capacity Construction and Retrofits
	  +BAU Annual Cost to Keep Generation Capacity Online Past Repayment Period
	  +BAU Total Cost of Transmission Distribution Storage and Other,
	
	  Quantization Size for Dollars
	)
	~	$
	~		|

BAU Total Annual Vehicle Costs[Vehicle Type,Cargo Type,Vehicle Technology]=
	BAU Annual Fuel Expenditures for a Vehicle Sold This Year[Vehicle Type,Cargo Type,Vehicle Technology\
		]
	+ AVMC Annual Vehicle Maintenance Cost[Vehicle Type,Cargo Type,Vehicle Technology]
	+ AVIC Annual Vehicle Insurance Cost[Vehicle Type,Cargo Type]
	+ AVPC Annual Vehicle Parking Cost[Vehicle Type,Cargo Type]
	+ AVLRaPTC Annual Vehicle Licensing Registration and Property Tax Costs[Vehicle Type\
		,Cargo Type]
	~	$/vehicle
	~		|

BAU Total Battery Cost per Unit Capacity=
	BAU Battery Energy Cost per Unit Capacity
	+ BAU Battery Power Cost per Unit Capacity
	  / GBSC Diurnal Grid Battery Daily Storage Duration
	~	$/(MW*hour)
	~		|

BAU Total Capacity Market Costs=
	(SUM(BAU Annual Capacity Market Costs for Seasonal Dispatchable Reliability[Electricity Source\
		!])
	   + BAU Capacity Market Costs for Diurnal Storage
	)
	~	$
	~		|

BAU Total Carbon Tax Revenue=
	SUM(BAU Transportation Sector Carbon Tax Revenue[Vehicle Type!,Cargo Type!])
	+ BAU Electricity Sector Carbon Tax Revenue
	+ BAU Buildings Sector Carbon Tax Revenue
	+ SUM(BAU Industry Sector Carbon Tax Revenue[Industry Category!])
	+ BAU District Heat Sector Carbon Tax Revenue
	+ BAU Hydrogen Sector Carbon Tax Revenue
	+ BAU Geoengineering Sector Carbon Tax Revenue
	~	$
	~		|

BAU Total Change in Energy Market and CES Revenue for CCUS Retrofits[CCUS Electricity Source\
		, Optimization Pass,RPS]=
	BAU Predicted Change in Energy Market Revenue for CCUS Retrofits[CCUS Electricity Source\
		]
	+ BAU RPS Revenue at Marginal Capacity Factor by Optimization Pass[Optimization Pass\
		,CCUS Electricity Source]
	- BAU RPS Revenue at Marginal Capacity Factor by Optimization Pass[Optimization Pass\
		,CCUS Source Electricity Source] ~~|
BAU Total Change in Energy Market and CES Revenue for CCUS Retrofits[CCUS Electricity Source\
		,Optimization Pass,CES]=
	BAU Predicted Change in Energy Market Revenue for CCUS Retrofits[CCUS Electricity Source\
		]
	+ SUM(BAU RPS Revenue at Marginal Capacity Factor by Optimization Pass[last pass!,CCUS Electricity Source\
		])
	+ BAU CES Revenue at Marginal Capacity Factor by Optimization Pass[Optimization Pass\
		,CCUS Electricity Source]
	- SUM(BAU RPS Revenue at Marginal Capacity Factor by Optimization Pass[last pass!,CCUS Source Electricity Source\
		])
	- BAU CES Revenue at Marginal Capacity Factor by Optimization Pass[Optimization Pass\
		,CCUS Source Electricity Source]
	~	$/MW
	~		|

BAU Total CO2e Emissions=
	SUM(
	  BAU Total Pollutant Emissions[Pollutant!]
	  * GWP by Pollutant[Pollutant!])
	~	g CO2e
	~		|

BAU Total CO2e Emissions by Sector[Sectors]=
	SUM(
	  BAU Total Pollutant Emissions by Sector[Sectors,Pollutant!]
	  * GWP by Pollutant[Pollutant!]
	)
	~	g CO2e
	~		~	:SUPPLEMENTARY 
	|

BAU Total Cost of Power Generation=
	BAU Generation Costs
	+BAU Interregional Electricity Trade Costs
	+SUM(BAU Electricity Sector CCS Transportation and Storage Costs[Electricity Source!\
		])
	+BAU This Year Ongoing CES Costs
	-SUM(BAU Electricity Sector Carbon Tax Rebate due to CCS[Electricity Source!])
	-SUM(BAU This Year CCS Subsidies Paid[Electricity Source!])
	-SUM(BAU This Year Ongoing Subsidies Paid per Unit Electricity Output[Electricity Source\
		!])
	~	$
	~		|

BAU Total Cost of Transmission Distribution Storage and Other=
	QUANTUM(
	  BAU Repayment of Financing for Change in Electricity Sector Capital Expenditures including Construction Subsidies
	  +BAU Electricity Transmission and Distribution OM Expenditures
	  +BAU Electricity Supplier Other Expenditures
	  +SYTaDC Start Year Transmission Capital Costs
	  +SYTaDC Start Year Distribution Capital Costs,
	
	  Quantization Size for Dollars
	)
	~	$
	~		|

BAU Total Demand Shifting Capacity in MW[Electricity Timeslice,Hour]=
	BAU This Year Demand Response Capacity
	+ BAU Last Year Grid and Hybrid Battery Storage Available in MW[Electricity Timeslice\
		]
	+ BPHC BAU Pumped Hydro Capacity * SYSHECF Start Year Seasonal Expected Capacity Factor for Pumped Hydro\
		[Electricity Timeslice
	,Hour]
	+ BAU Total EV Battery Capacity Available in MW
	~	MW
	~		|

BAU Total Deployed and Under Construction CCS[Industry Category,Emissions Type]=
	BAU Last Year Total Deployed and Under Construction CCS[Industry Category,Emissions Type\
		]
	+ BAU CCS Retrofit Capacity Construction Started This Year[Industry Category,Emissions Type\
		]
	~	Dmnl
	~		|

BAU Total District Heat Use=
	(
	  SUM(BAU Building Components Energy Use[Building Type!,heat bf,Building Component!]\
		)
	  + SUM(BAU Industrial Fuel Use[heat if,Industry Category!])
	)
	/ (1 - HDL Heat Distribution Losses)
	~	BTU
	~		|

BAU Total District Heat Use by Fuel before CHP[Industrial Fuel]=
	BAU Total District Heat Use
	* BFoHPbF BAU Fraction of Heat Provided by Fuel[Industrial Fuel]
	~	BTU
	~		|

BAU Total Electricity Demand=
	SUM(BAU Transportation Sector Electricity Demand[Vehicle Type!,Cargo Type!])
	+ SUM(BAU Buildings Sector Electricity Demand[Building Type!,Building Component!])
	+ BAU Industrial Sector Electricity Demand
	+ BAU District Heat Electricity Demand
	+ BAU Hydrogen Sector Grid Electricity Demand
	+ BAU Data Center Load
	+ BAU Geoengineering Sector Electricity Demand
	~	MW*hour
	~		|

BAU Total Electricity Demand after TnD Losses and Own Use=
	BAU Total Electricity Demand
	+(BAU Total Electricity Demand*BTaDLP BAU Transmission and Distribution Loss Percentage\
		)
	+(BAU Total Electricity Demand*BPPEOUP BAU Power Plant Electricity Own Use Percentage\
		)
	~	MW*hr
	~		|

BAU Total Electricity Demand by Hour After Demand Altering Technologies[Electricity Timeslice
,Hour]=
	BAU Total Electricity Demand by Hour After Demand Altering Technologies Excluding New Hybrid Batteries\
		[Electricity Timeslice,Hour]
	~	MW*hr
	~		|

BAU Total Electricity Demand by Hour After Demand Altering Technologies Excluding New Hybrid Batteries\
		[Electricity Timeslice,Hour]=
	BAU Total Electricity Demand by Hour Before Demand Altering Technologies[Electricity Timeslice\
		,Hour]
	+ BAU Change in Electricity Demand from Demand Altering Technologies for Net Peak Load Reduction exlcuding Hybrid Batteries\
		[Electricity Timeslice,Hour]
	~	MW*hr
	~		|

BAU Total Electricity Demand by Hour after Seasonal Net Peak Load Reduction[Electricity Timeslice\
		,Hour]=
	MAX(
	  0,
	
	  BAU Total Electricity Demand by Hour Before Demand Altering Technologies[Electricity Timeslice\
		,Hour]
	  + BAU Increase in Demand by Hour for Seasonal Net Peak Load Reduction[Electricity Timeslice\
		,Hour]
	  - BAU Decrease in Demand by Hour for Seasonal Net Peak Load Reduction[Electricity Timeslice\
		,Hour]
	)
	~	MW*hr
	~		|

BAU Total Electricity Demand by Hour Before Demand Altering Technologies[Electricity Timeslice\
		,Hour]=
	MAX(
	  0,
	
	  BAU Total Electricity Demand by Hour before Net Imports[Electricity Timeslice,Hour\
		]
	  + SUM(BAU Electricity Exports by Hour[Electricity Timeslice,Hour,last pass!])
	  - SUM(BAU Electricity Imports by Hour[Electricity Timeslice,Hour,last pass!])
	)
	~	MW*hr
	~		|

BAU Total Electricity Demand by Hour Before Demand Altering Technologies Plus Reserve Margin\
		[Electricity Timeslice,Hour]=
	MAX(0,
	BAU Total Electricity Demand by Hour Before Demand Altering Technologies[Electricity Timeslice\
		,Hour]
	  -SUM(BAU Electricity Exports by Hour[Electricity Timeslice,Hour,last pass!]))
	*(1+RM Reserve Margin)
	+BAU Change in Electricity Demand from Demand Altering Technologies for Net Peak Load Reduction exlcuding Hybrid Batteries\
		[Electricity Timeslice,Hour]
	~	MW*hr
	~		|

BAU Total Electricity Demand by Hour Before Demand Altering Technologies Plus Reserve Margin Required from Clean Dispatchable Resource\
		[Electricity Timeslice,Hour]=
	BAU Required Share of Peak Demand from Clean Firm Resources*BAU Total Electricity Demand by Hour Before Demand Altering Technologies Plus Reserve Margin\
		[Electricity Timeslice,Hour]
	~	MW*hr
	~		|

BAU Total Electricity Demand by Hour before Distributed Generation[Electricity Timeslice\
		,Hour]=
	(SUM(
	  (BAU Buildings Sector Electricity Demand[urban residential,Building Component!]
	    + BAU Buildings Sector Electricity Demand[rural residential,Building Component!]\
		)
	  * Adjusted Load Factors for Residential Buildings Sector[Building Component!,Electricity Timeslice\
		,Hour]
	)
	
	+ SUM(
	    BAU Buildings Sector Electricity Demand[commercial,Building Component!]
	    * Adjusted Load Factors for Commercial Buildings Sector[Building Component!,Electricity Timeslice\
		,Hour]
	  )
	
	+ SUM(
	    BAU Transportation Sector Electricity Demand[Vehicle Type!,Cargo Type!]
	    * Adjusted Load Factors for Transporation Sector[Vehicle Type!,Electricity Timeslice\
		,Hour]
	  )
	
	+ SUM(BAU Total Industrial Electricity Demand by Hour Before CCS[Electricity Timeslice\
		,Hour,Industry Category!])
	
	+ SUM(BAU Fuel Used for CCS by Industry Sector[electricity if,Industry Category!]
	    * Adjusted Load Factors for Industrial CCS[Electricity Timeslice,Hour]
	  ) * MWh per BTU
	
	+ (BAU District Heat Electricity Demand
	    + BAU Hydrogen Sector Grid Electricity Demand)
	  * Adjusted Load Factors for District Heat and Hydrogen Sectors[Electricity Timeslice\
		,Hour]
	
	+ BAU Data Center Load
	  * Adjusted Load Factors for Data Centers[Electricity Timeslice,Hour]
	
	+ BAU Geoengineering Sector Electricity Demand
	  * Adjusted Load Factors for Geoengineering Sector[Electricity Timeslice,Hour]
	
	)
	
	*(BAU Total Electricity Demand after TnD Losses and Own Use
	  /BAU Total Electricity Demand)
	~	MW*hr
	~		|

BAU Total Electricity Demand by Hour before Net Imports[Electricity Timeslice,Hour]=
	BAU Total Electricity Demand by Hour before Distributed Generation[Electricity Timeslice\
		,Hour]
	-SUM(BAU Hourly Output from Distributed Electricity Capacity[Electricity Source!,Electricity Timeslice\
		,Hour])
	~	MW*hr
	~		|

BAU Total Electricity Demand in BTU=
	BAU Total Electricity Demand
	/MWh per BTU
	~	BTU
	~		|

BAU Total Electricity Demand Including TnD Losses=
	SUM(BAU Total Electricity Demand by Hour After Demand Altering Technologies[Electricity Timeslice\
		!,Hour!]
	* SHELF Days per Electricity Timeslice[Electricity Timeslice!])
	~	MW*hr
	~		~	:SUPPLEMENTARY 
	|

BAU Total Electricity Demand Plus Exports in BTU=
	(BAU Total Electricity Demand + EIaE BAU Exported Electricity)
	/ MWh per BTU
	~	BTU
	~		|

BAU Total Electricity Dispatched by Hour[Electricity Timeslice,Hour]=
	SUM(BAU Total Electricity Dispatched by Hour by Plant Type[Electricity Timeslice,Hour\
		,Electricity Source!])
	~	MW*hr
	~		|

BAU Total Electricity Dispatched by Hour by Plant Type[Electricity Timeslice,Hour,Electricity Source\
		]=
	MAX(0,
	  BAU Electricity Dispatched by Guaranteed Dispatch by Hour[Electricity Source,Electricity Timeslice\
		,Hour]
	  + BAU Electricity Dispatched to Meet Elec Portfolio Stds[Electricity Timeslice,Hour\
		,Electricity Source]
	  + BAU Electricity Dispatched by Least Cost by Hour[Electricity Timeslice,Hour,Electricity Source\
		]
	 )
	~	MW*hr
	~		|

BAU Total Electricity Dispatched by Hour by Plant Type Using Five Year Averages[Electricity Timeslice\
		,Hour,Electricity Source]=
	MAX(0,
	  BAU Electricity Dispatched by Guaranteed Dispatch by Hour[Electricity Source,Electricity Timeslice\
		,Hour]
	  + BAU Electricity Dispatched to Meet Elec Portfolio Stds[Electricity Timeslice,Hour\
		,Electricity Source]
	  + BAU Five Year Average Electricity Dispatched by Least Cost by Hour[Electricity Timeslice\
		,Hour,Electricity Source]
	 )
	~	MW*hr
	~		|

BAU Total Electricity Generation Capacity by Optimization Pass for Seasonal Clean Dispatchable Reliability\
		[Electricity Source
,Optimization Pass] :EXCEPT:            [Clean Dispatchable Electricity Source,Optimization Pass\
		]=
	BAU Electricity Generation Capacity before Dispatchable CES Additions[Electricity Source\
		] ~~|
BAU Total Electricity Generation Capacity by Optimization Pass for Seasonal Clean Dispatchable Reliability\
		[Clean Dispatchable Electricity Source,Optimization Pass]=
	BAU Electricity Generation Capacity before Dispatchable CES Additions[Clean Dispatchable Electricity Source\
		]
	+BAU New Capacity Desired for Seasonal Clean Dispatchable Reliability by Optimization Pass\
		[Clean Dispatchable Electricity Source,Optimization Pass]
	+BAU Retrofitted Capacity Desired for Seasonal Clean Dispatchable Reliability by Optimization Pass\
		[Clean Dispatchable Electricity Source,Optimization Pass]
	~	MW
	~		|

BAU Total Electricity Generation Capacity by Optimization Pass for Seasonal Dispatchable Reliability\
		[Electricity Source,
Optimization Pass]=
	BAU Electricity Generation Capacity before Reliability Additions[Electricity Source]
	-BAU Economic Capacity Retirements by Optimization Pass[Electricity Source,Optimization Pass\
		]
	+BAU New Capacity Desired for Seasonal Dispatchable Reliability by Optimization Pass\
		[Electricity Source,Optimization Pass
	]
	~	MW
	~		|

BAU Total Energy Market and Capacity Market Revenue for Seasonal Clean Disatchable Reliability CCUS Retrofits\
		[Clean Dispatchable Electricity Source,Optimization Pass] :EXCEPT:             [CCUS Electricity Source\
		,Optimization Pass]=
	0 ~~|
BAU Total Energy Market and Capacity Market Revenue for Seasonal Clean Disatchable Reliability CCUS Retrofits\
		[CCUS Electricity Source,Optimization Pass]=
	BAU Predicted Change in Energy Market Revenue for CCUS Retrofits[CCUS Electricity Source\
		]
	+ (
	BAU Capacity Market Price for Seasonal Clean Dispatchable Reliability by Optimization Pass\
		[Optimization Pass]
	  * BAU Last Year Hourly Bid Electricity Capacity Factors for Clean Firm Reliability in Binding Hour by Plant Type\
		[CCUS Electricity Source]
	  * Days per Year
	  * One Day
	  )
	*Elec Portfolio Qualifying Sources[CCUS Electricity Source,CES]
	~	$/MW
	~		|

BAU Total Energy Market and Capacity Market Revenue for Seasonal Clean Dispatchable Reliability\
		[Clean Dispatchable Electricity Source,Optimization Pass]=
	BAU Average Four Year Prior Total Predicted Net Energy Market Revenue per MW[Clean Dispatchable Electricity Source\
		]
	+ (
	BAU Capacity Market Price for Seasonal Clean Dispatchable Reliability by Optimization Pass\
		[Optimization Pass]
	  * BAU Last Year Hourly Bid Electricity Capacity Factors for Clean Firm Reliability in Binding Hour by Plant Type\
		[Clean Dispatchable Electricity Source
	]
	  * Days per Year
	  * One Day
	  )
	*Elec Portfolio Qualifying Sources[Clean Dispatchable Electricity Source,CES]
	~	$/MW
	~		|

BAU Total Energy Market and Capacity Market Revenue for Seasonal Dispatchable Reliability\
		[Electricity Source,Optimization Pass]=
	BAU Total Energy Market and CES Revenue and Variable Subsidies[Electricity Source
	]
	-BAU RPS and CES Revenue at Marginal Capacity Factor[Electricity Source]
	+ (
	BAU Capacity Market Price for Seasonal Dispatchable Reliability by Optimization Pass\
		[Optimization Pass
	]
	  * BAU Last Year Hourly Bid Electricity Capacity Factors for Reliability in Binding Hour by Plant Type\
		[Electricity Source
	]
	  * Days per Year
	  * One Day)
	~	$/MW
	~		|

BAU Total Energy Market and CES Revenue and Variable Subsidies[Electricity Source]=
	SUM(BAU Total Energy Market and CES Revenue and Variable Subsidies by Optimization Pass\
		[Electricity Source,last pass!,CES])
	~	$/MW
	~		|

BAU Total Energy Market and CES Revenue and Variable Subsidies by Optimization Pass[Electricity Source\
		, Optimization Pass
,RPS]=
	BAU Average Four Year Prior Total Predicted Net Energy Market Revenue per MW[Electricity Source\
		]
	+BAU RPS Revenue at Marginal Capacity Factor by Optimization Pass[Optimization Pass,\
		Electricity Source] ~~|
BAU Total Energy Market and CES Revenue and Variable Subsidies by Optimization Pass[Electricity Source\
		,Optimization Pass
,CES]=
	BAU Average Four Year Prior Total Predicted Net Energy Market Revenue per MW[Electricity Source\
		]
	+ SUM(BAU RPS Revenue at Marginal Capacity Factor by Optimization Pass[last pass!,Electricity Source\
		])
	+BAU CES Revenue at Marginal Capacity Factor by Optimization Pass[Optimization Pass,\
		Electricity Source]
	~	$/MW
	~		|

BAU Total Energy Market and CES Revenue and Variable Subsidies by Optimization Pass for Hybrid Power Plants\
		[Hybrid Electricity Source
,Optimization Pass,RPS]=
	BAU Average Four Year Prior Net Energy Market Revenue by Plant Type Excluding Subsidies for Hybrid Power Plants\
		[Hybrid Electricity Source
	]
	+ BAU RPS Revenue at Marginal Capacity Factor by Optimization Pass[Optimization Pass\
		,Hybrid Electricity Source]*(1-BAU Share of Annual Expected Output that Can be Shifted
	[Hybrid Electricity Source])
	+BAU RPS Revenue at Expected Capacity Factor by Optimization Pass[Hybrid Electricity Source\
		,Optimization Pass]*(BAU Share of Annual Expected Output that Can be Shifted
	[Hybrid Electricity Source]) ~~|
BAU Total Energy Market and CES Revenue and Variable Subsidies by Optimization Pass for Hybrid Power Plants\
		[Hybrid Electricity Source
,Optimization Pass,CES]=
	BAU Average Four Year Prior Net Energy Market Revenue by Plant Type Excluding Subsidies for Hybrid Power Plants\
		[Hybrid Electricity Source
	]
	+ (BAU CES Revenue at Marginal Capacity Factor by Optimization Pass[Optimization Pass\
		,Hybrid Electricity Source]+ SUM(BAU RPS Revenue at Marginal Capacity Factor by Optimization Pass
	[last pass!,Hybrid Electricity Source]))*(1-BAU Share of Annual Expected Output that Can be Shifted\
		[Hybrid Electricity Source
	])
	+(BAU CES Revenue at Expected Capacity Factor by Optimization Pass[Hybrid Electricity Source\
		,Optimization Pass]+ SUM(BAU RPS Revenue at Expected Capacity Factor by Optimization Pass
	[Hybrid Electricity Source,last pass!]))*(BAU Share of Annual Expected Output that Can be Shifted\
		[Hybrid Electricity Source
])
	~	$/MW
	~		|

BAU Total Energy Related Emissions[Sectors,Pollutant] :EXCEPT:      [industry sector,\
		Pollutant],[LULUCF sector,Pollutant],[geoengineering sector,Pollutant]=
	BAU Total Pollutant Emissions by Sector[Sectors,Pollutant] ~~|
BAU Total Energy Related Emissions[industry sector,Pollutant]=
	BAU Total Pollutant Emissions by Sector[industry sector,Pollutant]
	- SUM(BAU Process Emissions after CCS[Industry Category!,Pollutant]) ~~|
BAU Total Energy Related Emissions[LULUCF sector,Pollutant]=
	BAU Total Pollutant Emissions by Sector[LULUCF sector,Pollutant]
	- BLAPE BAU LULUCF Anthropogenic Pollutant Emissions[Pollutant] ~~|
BAU Total Energy Related Emissions[geoengineering sector,Pollutant]=
	SUM(BAU Geoengineering Sector Pollutant Emissions Excluding Captured CO2[Pollutant,Industrial Fuel\
		!])
	~	g pollutant
	~		|

BAU Total Energy Related Emissions in CO2e[Sectors]=
	SUM(
	  BAU Total Energy Related Emissions[Sectors,Pollutant!]
	  * GWP by Pollutant[Pollutant!]
	)
	~	g CO2e
	~		~	:SUPPLEMENTARY 
	|

BAU Total Energy Use[All Fuels]=
	SUM(BAU Total Energy Use by Sector[Sectors!,All Fuels])
	~	BTU
	~		|

BAU Total Energy Use by Sector[transportation sector,transportation fuel within all fuels\
		]=
	SUM(BAU Transportation Sector Fuel Used[Vehicle Type!,Cargo Type!,Vehicle Technology\
		!,Transportation Fuel]) ~~|
BAU Total Energy Use by Sector[electricity sector,electricity source within all fuels\
		] :EXCEPT:        [electricity sector
,natural gas
],[electricity sector,wind],[electricity sector,solar],[electricity sector,hard coal]\
		,[electricity sector,biomass],[electricity sector
,lignite],[electricity sector,nuclear],[electricity sector,hydrogen]=
	BAU Electricity Fuel Use[Electricity Source] ~~|
BAU Total Energy Use by Sector[industry sector,industrial fuel within all fuels] :EXCEPT:\
		    [industry sector,hydrogen]=
	SUM(BAU Industrial Fuel Use[Industrial Fuel,Industry Category!]) ~~|
BAU Total Energy Use by Sector[residential buildings sector,building fuel within all fuels\
		]=
	SUM(BAU Building Components Energy Use[urban residential,Building Fuel,Building Component\
		!])
	+ SUM(BAU Building Components Energy Use[rural residential,Building Fuel,Building Component\
		!]) ~~|
BAU Total Energy Use by Sector[commercial buildings sector,building fuel within all fuels\
		]=
	SUM(BAU Building Components Energy Use[commercial,Building Fuel,Building Component!]\
		) ~~|
BAU Total Energy Use by Sector[district heat and hydrogen sector,industrial fuel within all fuels\
		] :EXCEPT:        [district heat and hydrogen sector
,hydrogen]=
	BAU Fuel Used to Generate Heat[Industrial Fuel]
	+ BAU Hydrogen Sector Fuel Use[Industrial Fuel] ~~|
BAU Total Energy Use by Sector[geoengineering sector,industrial fuel within all fuels\
		] :EXCEPT:     [geoengineering sector,hydrogen
]=
	BAU Geoengineering Sector Energy Use[Industrial Fuel] ~~|
BAU Total Energy Use by Sector[electricity sector,natural gas]=
	BAU Electricity Fuel Use[natural gas steam turbine es]
	+ BAU Electricity Fuel Use[natural gas combined cycle es]
	+ BAU Electricity Fuel Use[natural gas peaker es]
	+ BAU Electricity Fuel Use[natural gas combined cycle w CCS es] ~~|
BAU Total Energy Use by Sector[electricity sector,wind]=
	BAU Electricity Fuel Use[onshore wind es]
	+ BAU Electricity Fuel Use[offshore wind es] ~~|
BAU Total Energy Use by Sector[electricity sector,solar]=
	BAU Electricity Fuel Use[solar PV es]
	+ BAU Electricity Fuel Use[solar thermal es] ~~|
BAU Total Energy Use by Sector[transportation sector,All Fuels] :EXCEPT:       [transportation sector\
		,transportation fuel within all fuels
]=
	0 ~~|
BAU Total Energy Use by Sector[electricity sector,All Fuels] :EXCEPT:       [electricity sector\
		,electricity source within all fuels
]=
	0 ~~|
BAU Total Energy Use by Sector[industry sector,All Fuels] :EXCEPT:       [industry sector\
		,industrial fuel within all fuels
]=
	0 ~~|
BAU Total Energy Use by Sector[residential buildings sector,All Fuels] :EXCEPT:       \
		[residential buildings sector,building fuel within all fuels
]=
	0 ~~|
BAU Total Energy Use by Sector[commercial buildings sector,All Fuels] :EXCEPT:       \
		[commercial buildings sector,building fuel within all fuels
]=
	0 ~~|
BAU Total Energy Use by Sector[district heat and hydrogen sector,All Fuels] :EXCEPT:       \
		[district heat and hydrogen sector
,
industrial fuel within all fuels]=
	0 ~~|
BAU Total Energy Use by Sector[geoengineering sector,All Fuels] :EXCEPT:       [geoengineering sector\
		,industrial fuel within all fuels
]=
	0 ~~|
BAU Total Energy Use by Sector[LULUCF sector,All Fuels]=
	0 ~~|
BAU Total Energy Use by Sector[electricity sector,hard coal]=
	BAU Electricity Fuel Use[hard coal es]
	+ BAU Electricity Fuel Use[hard coal w CCS es] ~~|
BAU Total Energy Use by Sector[electricity sector,biomass]=
	BAU Electricity Fuel Use[biomass es]
	+ BAU Electricity Fuel Use[biomass w CCS es] ~~|
BAU Total Energy Use by Sector[electricity sector,lignite]=
	BAU Electricity Fuel Use[lignite es]
	+ BAU Electricity Fuel Use[lignite w CCS es] ~~|
BAU Total Energy Use by Sector[electricity sector,nuclear]=
	BAU Electricity Fuel Use[nuclear es]
	+ BAU Electricity Fuel Use[small modular reactor es] ~~|
BAU Total Energy Use by Sector[electricity sector,hydrogen]=
	BAU Electricity Fuel Use[hydrogen combustion turbine es]
	+ BAU Electricity Fuel Use[hydrogen combined cycle es] ~~|
BAU Total Energy Use by Sector[industry sector,hydrogen]=
	SUM(BAU Industrial Fuel Use[hydrogen if,Industry Category!])
	+ SUM(BAU Industrial Fuel Use[green hydrogen if,Industry Category!])
	+ SUM(BAU Industrial Fuel Use[low carbon hydrogen if,Industry Category!]) ~~|
BAU Total Energy Use by Sector[district heat and hydrogen sector,hydrogen]=
	BAU Fuel Used to Generate Heat[hydrogen if]
	+ BAU Hydrogen Sector Fuel Use[hydrogen if]
	
	+ BAU Fuel Used to Generate Heat[green hydrogen if]
	+ BAU Hydrogen Sector Fuel Use[green hydrogen if]
	
	+ BAU Fuel Used to Generate Heat[low carbon hydrogen if]
	+ BAU Hydrogen Sector Fuel Use[low carbon hydrogen if] ~~|
BAU Total Energy Use by Sector[geoengineering sector,hydrogen]=
	BAU Geoengineering Sector Energy Use[hydrogen if]
	+ BAU Geoengineering Sector Energy Use[green hydrogen if]
	+ BAU Geoengineering Sector Energy Use[low carbon hydrogen if]
	~	BTU
	~		|

BAU Total EV Battery Capacity=
	SUM(
	  BAU Vehicles[Vehicle Type!,Cargo Type!,Vehicle Technology!]
	  * This Year Battery Capacity by Vehicle Type[Cargo Type!,Vehicle Type!,Vehicle Technology\
		!]
	)
	/ kWh per MWh
	~	MW*hr
	~		|

BAU Total EV Battery Capacity Available in MW=
	SUM(
	    BAU Vehicles[Vehicle Type!,Cargo Type!,battery electric vehicle]
	   *AVCC Average Vehicle Charger Capacity[Vehicle Type!,Cargo Type!]
	   *BEVGB BAU Fraction of EVs Used for Grid Balancing on Average Day
	)
	~	MW
	~		|

BAU Total EV Subsidy Amount Paid[Vehicle Type,Cargo Type,Vehicle Technology]=
	BAU New Vehicles[Vehicle Type,Cargo Type,Vehicle Technology]
	* BVS BAU Vehicle Subsidy[Cargo Type,Vehicle Type,Vehicle Technology]
	* One Year
	~	$
	~		|

BAU Total Final Energy Use by Sector[Sectors,All Fuels] :EXCEPT:        [electricity sector\
		,All Fuels],[industry sector,All Fuels],[district heat and hydrogen sector,All Fuels\
		]=
	BAU Total Energy Use by Sector[Sectors,All Fuels] ~~|
BAU Total Final Energy Use by Sector[electricity sector,All Fuels]=
	0 ~~|
BAU Total Final Energy Use by Sector[industry sector, All Fuels]=
	SUM(BAU Industry Sector Final Energy Use by Industry[All Fuels,Industry Category!]) ~~|
BAU Total Final Energy Use by Sector[district heat and hydrogen sector,All Fuels]=
	0
	~	BTU
	~		~	:SUPPLEMENTARY 
