	~	$
	~		|

Cost of Capital by Industry Fuel and Process[Industry Category,Industrial Fuel,Industrial Process\
		]=
	BCoISC Weighted Average Cost of Capital by Industry[Industry Category]
	* 
	(
	  1 - (Perc Decrease in Cost of Capital for Clean Industrial Equipment This Year[Industrial Process\
		,Industry Category]
	    * IFTQfS Industrial Fuel Types Qualifying for Loans[Industrial Fuel]
	  )
	)
	~	Dmnl
	~		|

Cost of CHP Conversion for Heat=
	Heat Shifted to CHP Facilities This Year
	* CECpUES CHP Equipment Cost per Unit Energy Shifted
	~	$
	~		|

Cost of Electricity Sector Capital for Power Plants[Electricity Source]=
	BCoESC BAU Cost of Electricity Sector Capital for Power Plants[Electricity Source]
	* (1 - Percentage Decrease in Cost of Capital for Power Plants This Year[Electricity Source\
		])
	~	Dmnl
	~		|

Cost of Green Hydrogen Electricity Capacity Construction[Electricity Source]=
	New Off Grid Capacity for Green Hydrogen Demand[Electricity Source]
	* Construction Cost per Unit Capacity before Construction Subsidies[Electricity Source\
		]
	~	$
	~		|

Cost of Implementing Land Use Policies[Land Use Policy]=
	Land Area Newly Affected by Policy[Land Use Policy] * One Year
	* ICoLUPpUA Implementation Cost of Land Use Policies per Unit Area[Land Use Policy]
	~	$
	~		|

Cost of Maintaining Area Previously Affected by Land Use Policies[Land Use Policy]=
	Cumulative Total Land Area Affected by Policy[Land Use Policy]
	* AOCoLUPpUA Annual Ongoing Cost of Land Use Policies per Unit Area[Land Use Policy]
	~	$
	~		|

