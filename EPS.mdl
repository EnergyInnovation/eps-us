		=
	Electricity Sector CCS Transportation and Storage Costs[Electricity Source]
	- BAU Electricity Sector CCS Transportation and Storage Costs[Electricity Source]
	~	$
	~		|

Change in Electricity Sector CCS Transportation and Storage Costs by Recipient ISIC Code\
		[ISIC Code] :EXCEPT:  [ISIC 352T353]=
	0 ~~|
Change in Electricity Sector CCS Transportation and Storage Costs by Recipient ISIC Code\
		[ISIC 352T353]=
	SUM(Change in Electricity Sector CCS Transportation and Storage Costs[Electricity Source\
		!])
	~	$
	~		|

Change in Electricity Sector CCS Transportation and Storage Subsidies[Electricity Source\
		]=
	Electricity Sector CCS Transportation and Storage Subsidies[Electricity Source]
	- BAU Electricity Sector CCS Transportation and Storage Subsidies[Electricity Source\
		]
	~	$
	~		|

Change in Electricity Sector Fixed OM Costs[Electricity Source]=
	Elec Supplier Fixed OM Costs[Electricity Source]
	- BAU Elec Supplier Fixed OM Costs[Electricity Source]
	~	$
	~		|

Change in Electricity Sector Fixed OM Costs by Recipient ISIC Code[ISIC Code]=
	SUM(
	  Change in Electricity Sector Fixed OM Costs[Electricity Source!]
	  * SoESCaOMCbIC Share of Electricity Sector Fixed OM Costs by ISIC Code[Electricity Source\
		!,ISIC Code]
	)
	~	$
	~		|

Change in Electricity Sector OM Costs by Recipient ISIC Code[ISIC Code]=
	Change in Electricity Sector Fixed OM Costs by Recipient ISIC Code[ISIC Code]
	+ Change in Electricity Sector Variable OM Costs by Recipient ISIC Code[ISIC Code]
	+ Change in Transmission OM Costs by Recipient ISIC Code[ISIC Code]
	+ Change in Distribution OM Costs by Recipient ISIC Code[ISIC Code]
	+ Change in Electricity Sector CCS Transportation and Storage Costs by Recipient ISIC Code\
		[ISIC Code]
	~	$
	~		|

Change in Electricity Sector Pollutant Emissions[Pollutant]=
	SUM(Electricity Sector Pollutant Emissions[Pollutant,Electricity Source!])
	- SUM(BAU Electricity Sector Pollutant Emissions[Pollutant,Electricity Source!])
	~	g pollutant
	~		~	:SUPPLEMENTARY 
	|

Change in Electricity Sector Variable OM Costs[Electricity Source]=
	Elec Supplier Variable OM Costs[Electricity Source]
	- BAU Elec Supplier Variable OM Costs[Electricity Source]
	~	$
	~		|

Change in Electricity Sector Variable OM Costs by Recipient ISIC Code[ISIC Code]=
	SUM(
	  Change in Electricity Sector Variable OM Costs[Electricity Source!]
	  * SoESCaOMCbIC Share of Electricity Sector Variable OM Costs by ISIC Code[Electricity Source\
		!,ISIC Code]
	)
	~	$
	~		|

Change in Electricity Supplier Costs Recovered through Electricity Rates per Unit Electricity Delivered for Cost of Service Rates\
		=
	Electricity Supplier Costs Recovered through Electricity Rates per Unit Electricity Delivered for Cost of Service Rates
	-BAU Electricity Supplier Costs Recovered through Electricity Rates per Unit Electricity Delivered for Cost of Service Rates
	~	$/BTU
	~		|

Change in Electricity Supplier Other Expenditures=
	Electricity Supplier Other Expenditures
	-BAU Electricity Supplier Other Expenditures
	~	$
	~		|

Change in Electricity Transmission and Distribution OM Expenditures=
