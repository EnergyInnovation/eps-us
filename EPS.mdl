	 One Year Average Wholesale Energy Market Costs,
	 2,
	 1,
	 0
	)
	~	$
	~		|

Two Years Prior Hypothetical Hourly Electricity Capacity Factor[Electricity Timeslice\
		,Hour,Electricity Source]= DELAY FIXED (
	  Last Year Hypothetical Hourly Electricity Capacity Factor[Electricity Timeslice,Hour\
		,Electricity Source],
	  1,
	  SYSHECF Start Year Seasonal Expected Hourly Electricity Capacity Factors[Electricity Source\
		,Electricity Timeslice,Hour
	] * RAF Regional Availability Factor for Generation[Electricity Source])
	~	Dmnl
	~		|

Two Years Prior Net Loss per Unit Capacity[Electricity Source,Optimization Pass]= DELAY FIXED\
		 (
	Last Year Net Loss per Unit Capacity[Electricity Source,Optimization Pass],
	1,
	0)
	~	$/MW
	~		|

Two Years Prior Net Loss per Unit Capacity Excluding Capacity Payment[Electricity Source\
		]= DELAY FIXED (
	Last Year Net Loss per Unit Capacity Excluding Predicted Capacity Payment[Electricity Source\
		],
	1,
	0)
	~	$/MW
	~		|

UFDfGBS Usage Factor Discount for Grid Battery Storage[Electricity Timeslice]:=
	GET DIRECT DATA(
	   'InputData/elec/UFDfGBS/UFDfGBS.csv',
	   ',',
	   '1',
	   'B2'
	)
	~	Dmnl
	~		|

Union Status:
	union,
	nonunion
	~	
	~		|

Unmet Electricity Demand After Elec Portfolio Std Dispatch[Electricity Timeslice,Hour\
		]=
	MAX(
	  0,
	
	  Unmet Electricity Demand After Guaranteed Dispatch[Electricity Timeslice,Hour]
	  - SUM(Electricity Dispatched to Meet Elec Portfolio Stds[Electricity Timeslice,Hour\
		,Electricity Source!])
	)
	~	MW*hr
	~		|

Unmet Electricity Demand After Guaranteed Dispatch[Electricity Timeslice,Hour]=
	MAX(
	  0,
	
	  Total Electricity Demand by Hour After Demand Altering Technologies[Electricity Timeslice\
		,
	Hour]
	  - SUM(Electricity Dispatched by Guaranteed Dispatch by Hour[Electricity Source!,Electricity Timeslice\
		,Hour])
	)
	~	MW*hr
	~		|

Unmet Electricity Demand after RPS Allocation Steps[Electricity Timeslice,Hour]=
	Unmet Electricity Demand After Zero and Negative Cost RPS Dispatch[Electricity Timeslice\
		,Hour]
	- SUM(Positive Cost Electricity Dispatched to Meet RPS[Electricity Timeslice,Hour,Electricity Source\
		!])
	~	MW*hour
	~		|

Unmet Electricity Demand After RPS and Zero and Negative Cost CES Allocation Steps[Electricity Timeslice\
		,Hour]=
	Unmet Electricity Demand after RPS Allocation Steps[Electricity Timeslice,Hour]
	- SUM(Zero and Negative Cost Electricity Dispatched to Meet CES[Electricity Source!,\
		Electricity Timeslice,Hour])
	~	MW*hour
	~		|

Unmet Electricity Demand After Zero and Negative Cost RPS Dispatch[Electricity Timeslice\
		,Hour]=
	MAX(0,
	  Unmet Electricity Demand After Guaranteed Dispatch[Electricity Timeslice,Hour]
	  -SUM(Zero and Negative Cost Electricity Dispatched to Meet RPS[Electricity Timeslice\
		,Hour,Electricity Source!])
	 )
	~	MW*hr
	~		|

Unmet Electricity Demand by Hour[Electricity Timeslice,Hour]=
	QUANTUM(
	  MAX(
	    0,
	
	    Total Electricity Demand by Hour After Demand Altering Technologies[Electricity Timeslice
	,Hour]
	    - Total Electricity Dispatched by Hour[Electricity Timeslice,Hour]
	  ),
	
	  Quantization Size for Hourly Dispatch
	)
	~	MW*hr
	~		|

Unmet Electricity Demand Summed Across Hours[Electricity Timeslice]=
	SUM(Unmet Electricity Demand by Hour[Electricity Timeslice,Hour!])
	~	MW*hr
	~		~	:SUPPLEMENTARY 
	|

