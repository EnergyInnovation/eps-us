	~	vehicles
	~		|

BAU Last Year Weighted Average Annual Capital Cost per Unit Capacity[Electricity Source\
		]=
	DELAY FIXED(BAU Weighted Average Annual Capital Costs per Unit Capacity[Electricity Source\
		],
	  1,
	  0
	)
	~	$/MW
	~		|

BAU Last Year Weighted Average Annual Fixed OM Costs per Unit Capacity[Electricity Source\
		]=
	DELAY FIXED(BAU Weighted Average Annual Fixed OM Cost per Unit Capacity[Electricity Source\
		],
	  1,
	  0
	)
	~	$/MW
	~		|

BAU Last Year Weighted Average Expected Capacity Factors by Hour[Electricity Source,Electricity Timeslice\
		,Hour]= DELAY FIXED (
	  BAU Weighted Average Expected Capacity Factors by Hour Without Hypothetical Adjustments\
		[Electricity Source,Electricity Timeslice
	,Hour],
	  1,
	  Start Year Seasonal Expected Hourly Electricity Capacity Factors after RAF[Electricity Source\
		,Electricity Timeslice
	,Hour])
	~	Dmnl
	~		|

BAU LCFS Credit Price=
	MIN(
	  LCPC LCFS Credit Price Cap,
	
	  ZIDZ(
	    BAU Incremental Costs from Substitute Fuel Production due to LCFS,
	    BAU LCFS Credits Generated
	  )
	)
	~	$/LCFS credit
	~	Although some substitute fuels have no incremental cost to produce, they \
		still create LCFS credits and thus reduce the market price for LCFS \
		credits, so we divide total costs by total credits, rather than \
		subscripting by fuel type.
	~	:SUPPLEMENTARY 
	|

BAU LCFS Credits Generated=
	SUM(BAU Reduction in CO2 Emissions due to LCFS[Vehicle Type!,Cargo Type!,Vehicle Technology\
		!,Transportation Fuel!])
	/ GCApLC Grams CO2e Avoided per LCFS Credit
	~	LCFS credits
	~		|

BAU Legally Required Elec Portfolio Percentage[Clean Elec Requirement]=
	SUM(
	  BAU Weighted Average Elec Portfolio Percentage by Year[Future Year!,Clean Elec Requirement\
		]
	  * This Year Flag[Future Year!]
	)
	~	Dmnl
	~		|

BAU Legally Required Electricity Dispatch to Satisfy Elec Portfolio Stds[Clean Elec Requirement\
		]=
	SUM(
	  BAU Electricity Dispatch Required to Satisfy Elec Portfolio Stds[Electricity Timeslice\
		!,Hour!,Clean Elec Requirement]
	  * SHELF Days per Electricity Timeslice[Electricity Timeslice!]
	)
	~	MW*hour
	~		~	:SUPPLEMENTARY 
	|

BAU Low Carbon Hydrogen Demand=
	SUM(BAU Low Carbon Hydrogen Demand by Sector[Sectors!])
	~	BTU
	~		|

BAU Low Carbon Hydrogen Demand by Sector[Sectors] :EXCEPT:          [industry sector]\
		,[geoengineering sector],[district heat and hydrogen sector]=
	BAU Hydrogen Demand by Sector[Sectors]
	* SoHDTiGaLCbS Share of Hydrogen Demand That is Low Carbon by Sector[Sectors] ~~|
BAU Low Carbon Hydrogen Demand by Sector[industry sector]=
	SUM(BAU Industrial Fuel Use[low carbon hydrogen if,Industry Category!]) ~~|
BAU Low Carbon Hydrogen Demand by Sector[geoengineering sector]=
	BAU Geoengineering Sector Energy Use[low carbon hydrogen if] ~~|
BAU Low Carbon Hydrogen Demand by Sector[district heat and hydrogen sector]=
	BAU Fuel Used to Generate Heat[low carbon hydrogen if]
	~	BTU
	~		|

BAU Low Carbon Hydrogen Production by Pathway[Hydrogen Production Pathway]=
	ZIDZ(
	  BAU New Low Carbon Hydrogen Production Capacity This Year[Hydrogen Production Pathway\
		]
	  + BAU Surviving Capacity Used for Low Carbon Hydrogen Production[Hydrogen Production Pathway\
		],
	
	  SUM(
	    BAU New Low Carbon Hydrogen Production Capacity This Year[Hydrogen Production Pathway\
		!]
	    + BAU Surviving Capacity Used for Low Carbon Hydrogen Production[Hydrogen Production Pathway\
		!]
	  )
	)
	~	Dmnl
	~		|

BAU Low Carbon Hydrogen Production Shares with Fallback[Hydrogen Production Pathway]=
	IF THEN ELSE(
	  SUM(BAU Low Carbon Hydrogen Production by Pathway[Hydrogen Production Pathway!]) =\
		 0,
	
	  IF THEN ELSE(
	    SUM(BAU New Low Carbon Hydrogen Production Capacity Shares This Year[Hydrogen Production Pathway\
		!]) = 0,
	
	    BAU Start Year Low Carbon Hydrogen Production Shares by Pathway[Hydrogen Production Pathway\
		],
	
	    BAU New Low Carbon Hydrogen Production Capacity Shares This Year[Hydrogen Production Pathway\
		]
	  ),
	
	  ZIDZ( 
	    BAU Low Carbon Hydrogen Production by Pathway[Hydrogen Production Pathway],
	    SUM(BAU Low Carbon Hydrogen Production by Pathway[Hydrogen Production Pathway!])
	  )
	)
	~	Dmnl
	~		|

BAU Marginal Capacity Factor by Hour[Electricity Source,Electricity Timeslice,Hour,Clean Elec Requirement\
		]=
	IF THEN ELSE(
	  Time = INITIAL TIME
	
	  :OR:
	
	   ABS(BAU Last Year Electricity Generation Capacity[Electricity Source])*MW Tolerance Unit Correction Factor\
		 < Tolerance,
	
	  BAU Last Year Weighted Average Expected Capacity Factors by Hour[Electricity Source\
		,Electricity Timeslice,Hour]
	  *  IF THEN ELSE(
	    SUM(
	      BAU Last Year Weighted Average Expected Capacity Factors by Hour[Electricity Source\
		!,Electricity Timeslice,Hour]
	      * BAU Last Year Electricity Generation Capacity[Electricity Source!]
	      * Elec Portfolio Qualifying Sources[Electricity Source!,Clean Elec Requirement\
		]
	    )
	    < BAU Last Year Total Electricity Demand by Hour After Demand Altering Technologies\
		[Electricity Timeslice,Hour]/One Hour
	,
	
	    1,
	
	    0),
	         
	
	  IF THEN ELSE(
	    SUM(
	      BAU Last Year Weighted Average Expected Capacity Factors by Hour[Electricity Source\
		!,Electricity Timeslice,Hour]
	      * BAU Last Year Electricity Generation Capacity[Electricity Source!]
	      * Elec Portfolio Qualifying Sources[Electricity Source!,Clean Elec Requirement\
		]
	    )
	    < BAU Last Year Total Electricity Demand by Hour After Demand Altering Technologies\
		[Electricity Timeslice,Hour]/One Hour
	,
	
	BAU Last Year Weighted Average Expected Capacity Factors by Hour[Electricity Source,\
		Electricity Timeslice,Hour]
	    ,
	
	    0
	  )
	)
	~	Dmnl
	~		|

BAU Marginal Capacity Factor x Hours per Year[Electricity Source,Clean Elec Requirement\
		]=
	SUM(
	  BAU Marginal Capacity Factor by Hour[Electricity Source,Electricity Timeslice!,Hour\
		!,Clean Elec Requirement]
	  * SHELF Days per Electricity Timeslice[Electricity Timeslice!]
	  * One Hour
	)
	~	hours
	~		|

BAU Marginal Dispatch Cost by Hour[Electricity Timeslice,Hour]=
	IF THEN ELSE(ABS(SUM(BAU Total Electricity Dispatched by Hour by Plant Type[Electricity Timeslice\
		,Hour,Electricity Source
	!]
	))*MWhr Tolerance Unit Correction Factor < Tolerance,EIaE Imported Electricity Price\
		,
	  IF THEN ELSE(
	    ABS(BAU Electricity Market Price Adjusted for Zero Least Cost Dispatch Hours[Electricity Timeslice\
		,Hour])*Dollar per MWhr Tolerance Unit Correction Factor
	 < Tolerance
	    :OR: ABS(SUM(BAU Electricity Dispatched by Least Cost by Hour[Electricity Timeslice\
		,Hour,Electricity Source!]))*MWhr Tolerance Unit Correction Factor
	 < Tolerance
	,
	
	    SUM(BAU Dispatch Cost per Unit Electricity Output[Electricity Source!]*BAU Share of Total Electricity Dispatched by Hour by Plant Type\
		[Electricity Timeslice,Hour,Electricity Source!]),
	
	    BAU Electricity Market Price Adjusted for Zero Least Cost Dispatch Hours[Electricity Timeslice\
		,Hour]
	  )
	)
	~	$/(MW*hour)
	~		|

BAU Max Additional Potential Capacity by Source[Electricity Source]=
	MAX(
	  0,
	
	  MPCbS Max Potential Capacity by Source[Electricity Source]
	  - BAU Surviving Electricity Generation Capacity before Economic Retirements[Electricity Source\
		]
	)
	~	MW
	~		|

BAU Max Capacity Available for CCUS Retrofit[Electricity Source] :EXCEPT:      [hard coal w CCS es\
		],[natural gas combined cycle w CCS es
],[biomass w CCS es],[lignite w CCS es]=
	0 ~~|
BAU Max Capacity Available for CCUS Retrofit[hard coal w CCS es]=
	BAU Surviving Electricity Generation Capacity before Economic Retirements[hard coal w CCS es\
		] ~~|
BAU Max Capacity Available for CCUS Retrofit[natural gas combined cycle w CCS es]=
	BAU Surviving Electricity Generation Capacity before Economic Retirements[natural gas combined cycle w CCS es\
		] ~~|
BAU Max Capacity Available for CCUS Retrofit[biomass w CCS es]=
	BAU Surviving Electricity Generation Capacity before Economic Retirements[biomass w CCS es\
		] ~~|
BAU Max Capacity Available for CCUS Retrofit[lignite w CCS es]=
	BAU Surviving Electricity Generation Capacity before Economic Retirements[lignite w CCS es\
		]
	~	MW
	~		|

BAU Max Capacity Available for CCUS Retrofit after CES Clean Firm Reliability Additions\
		[Electricity Source]=
	MAX(0,
	  BAU Max Capacity Available for CCUS Retrofits after Mandated Retrofits[Electricity Source\
		]-BAU Retrofit Capacity for Clean Dispatchable Reliability
	[Electricity Source])
	~	MW
	~		|

BAU Max Capacity Available for CCUS Retrofits after Mandated Retrofits[Electricity Source\
		] :EXCEPT:    [CCUS Electricity Source]=
	0 ~~|
BAU Max Capacity Available for CCUS Retrofits after Mandated Retrofits[CCUS Electricity Source\
		]=
	MAX(0,(BAU Max Capacity Available for CCUS Retrofit[CCUS Electricity Source]
	-BAU New Policy Mandated Retrofits[CCUS Electricity Source]))
	
	* IF THEN ELSE(
	    BBPPRTY BAU Ban Power Plant Retrofits This Year[CCUS Electricity Source]>0,
	    0,
	    1
	  )
	~	MW
	~		|

BAU Max Capacity Buildable after Cost Effective and RPS Additions[Electricity Source,\
		Clean Elec Requirement]=
	MAX(
	  0,
	
	  BAU Max Capacity Buildable after Mandated and Required Clean Dispatchable Additions\
		[Electricity Source]
	  - BAU New Capacity Desired due to Cost Effectiveness[Electricity Source,Clean Elec Requirement\
		]
	  - BAU New Capacity Desired due to Cost Effectiveness for Hybrid Power Plants[Electricity Source\
		,Clean Elec Requirement]
	)
	~	MW
	~		|

BAU Max Capacity Buildable after Mandated Additions[Electricity Source]=
	MAX(
	  0,
	
	  BAU Max Capacity Buildable This Year[Electricity Source]
	  - BAU New Policy Mandated Capacity[Electricity Source]
	)
	~	MW
	~		|

BAU Max Capacity Buildable after Mandated and Required Clean Dispatchable Additions[Electricity Source\
		]=
	MAX(0,
	  BAU Max Capacity Buildable after Mandated Additions[Electricity Source]
	  - BAU New Dispatchable Only Clean Capacity Desired for Seasonal Reliability[Electricity Source\
		]
	 )
	~	MW
	~		|

BAU Max Capacity Buildable This Year[Electricity Source]=
	IF THEN ELSE(
	  BAU Boolean Plant Types that May Not be Built due to Having Been Retired to Zero[Electricity Source\
		] > 0
	  :OR:
	  BBNPPTY BAU Ban New Power Plants This Year[Electricity Source] > 0,
	
	  0,
	
	  BAU Max Additional Potential Capacity by Source[Electricity Source]
	)
	~	MW
	~		|

BAU Max Capacity that Can be Retired Economically by Plant Type[Electricity Source]=
	SUM(
	  BAU Last Year Electricity Generation Capacity by Vintage[Electricity Source,Modeled Vintage\
		!]
	  * BAU Retirable Vintages by Year[Modeled Vintage!]
	)
	~	MW
	~		|

BAU Maximum Annual Decrease in Demand from Diurnal Grid Batteries=
	SUM(
	  BAU Last Year Grid and Hybrid Battery Storage Available for Load Shifting[Electricity Timeslice\
		!]
	  * SHELF Days per Electricity Timeslice[Electricity Timeslice!]
	  * ESTRTE Grid Battery Round Trip Efficiency
	)
	~	MW*hour
	~		|

BAU Maximum Annual Decrease in Demand from EVs=
	BAU Maximum Daily Quantity of Electricity Charged by EVs for Diurnal Balancing
	* ESTRTE Grid Battery Round Trip Efficiency
	* Days per Year
	~	MW*hour
	~		|

BAU Maximum Annual Decrease in Demand from Pumped Hydro=
	SUM(BAU Maximum Daily Quantity of Electricity Charged by Pumped Hydro[Electricity Timeslice\
		!]
	  * SHELF Days per Electricity Timeslice[Electricity Timeslice!]
	  )
	* ESTRTE Pumped Hydro Round Trip Efficiency
	~	MW*hour
	~		|

BAU Maximum Annual Decrease in Demand from Seasonal Electricity Storage=
	BAU Maximum Annual Quantity of Electricity Charged by Seasonal Electricity Storage
	* SES Seasonal Electricity Storage Round Trip Efficiency
	~	MW*hour
	~		|

BAU Maximum Annual Quantity of Electricity Absorbed for Seasonal Balancing=
	BAU Maximum Annual Quantity of Electricity Charged by Seasonal Electricity Storage
	* RAF Regional Availability Factor for Demand Altering Technologies
	~	MW*hr
	~		|

BAU Maximum Annual Quantity of Electricity Absorbed for Seasonal Net Peak Load Reduction\
		=
	BAU Maximum Annual Quantity of Electricity Absorbed for Seasonal Balancing
	~	MW*hr
	~		|

BAU Maximum Annual Quantity of Electricity Charged by Seasonal Electricity Storage=
	SES Seasonal Electricity Storage Capacity
	* SES Seasonal Electricity Storage Annual Charge and Discharge Cycles
	~	MW*hr
	~		|

BAU Maximum Capacity Factor after RAF[Electricity Source]=
	MCF Maximum Capacity Factor[Electricity Source]
	* RAF Regional Availability Factor for Generation[Electricity Source]
	~	Dmnl
	~		|

BAU Maximum Daily Quantity of Electricity Absorbed for Diurnal Balancing[Electricity Timeslice\
		]=
	(
	  BAU Last Year Grid and Hybrid Battery Storage Available for Load Shifting[Electricity Timeslice\
		]
	  + BAU Maximum Daily Quantity of Electricity Charged by EVs for Diurnal Balancing
	  + BAU Maximum Daily Quantity of Electricity Charged by Pumped Hydro[Electricity Timeslice\
		]
	)
	* RAF Regional Availability Factor for Demand Altering Technologies
	~	MW*hr
	~		|

BAU Maximum Daily Quantity of Electricity Absorbed for Diurnal Net Peak Load Reduction Excluding Hybrid Batteries\
		[Electricity Timeslice]=
	BAU Maximum Daily Quantity of Electricity Absorbed for Diurnal Balancing[Electricity Timeslice\
		]
	~	MW*hr
	~		|

BAU Maximum Daily Quantity of Electricity Charged by EVs for Diurnal Balancing=
	BAU Total EV Battery Capacity
	* BEVGB BAU Fraction of EVs Used for Grid Balancing on Average Day
	* BEVGB Fraction of EV Battery Capacity Used for Grid Balancing when EV is Used for Grid Balancing
	~	MW*hr
	~		|

BAU Maximum Daily Quantity of Electricity Charged by Pumped Hydro[Electricity Timeslice\
		]=
	BPHC BAU Pumped Hydro Capacity
	* SUM(SYSHECF Start Year Seasonal Expected Capacity Factor for Pumped Hydro[Electricity Timeslice\
		,Hour!])
	* One Hour
	~	MW*hr
	~		|

BAU Maximum Daily Quantity of Electricity Reduced by Demand Response Programs[peak day electricity timeslice\
		]=
	BAU This Year Demand Response Capacity
	* DRC Average DR Hours per Day on Which DR is Called Upon ~~|
BAU Maximum Daily Quantity of Electricity Reduced by Demand Response Programs[average day electricity timeslice\
		]=
	0
	~	MW*hr
	~	We assume that DR can be called upon for every peak day (i.e. at least the \
		five peak summer and five peak winter days).  In the U.S., an average \
		number of DR days per year is 24, more than enough to be used on all peak \
		days.
	|

BAU Maximum Daily Quantity of Electricity Reduced by Demand Response Programs for Net Peak Load Reduction\
		[Electricity Timeslice]=
	BAU Maximum Daily Quantity of Electricity Reduced by Demand Response Programs[Electricity Timeslice\
		]
	~	MW*hr
	~		|

BAU Maximum Possible LCFS Percentage=
	ZIDZ(
	  SUM(BAU Carbon Free Energy in Absence of LCFS by Vehicle Type[Vehicle Type!,Cargo Type\
		!,Vehicle Technology!,Transportation Fuel!])
	   + SUM(BAU Quantity Carbon Free Energy May be Increased by Fuel by Regulated Vehicle Type\
		[Vehicle Type!,Cargo Type!,Transportation Fuel!]),
	
	  SUM(BAU Fuel that would be Used by Regulated Vehicle Types in Absence of LCFS with Elec Eff Adj\
		[Vehicle Type!,Cargo Type!,Vehicle Technology!,Transportation Fuel!])
	)
	~	Dmnl
	~		~	:SUPPLEMENTARY 
	|

BAU Maximum Potential Binding Hour Electricity Output by Hour for Dispatchable Reliability\
		[Optimization Pass]=
	(SUM(
	 BAU Total Electricity Generation Capacity by Optimization Pass for Seasonal Dispatchable Reliability\
		[Electricity Source
	!,Optimization Pass]
	  * BAU Last Year Hourly Bid Electricity Capacity Factors for Reliability in Binding Hour by Plant Type\
		[Electricity Source
	!]
	 )
	
	+(BAU New Grid Battery Capacity Deployed for Seasonal Dispatchable Reliability by Optimization Pass\
		[Optimization Pass]
	  *ESTRTE Grid Battery Round Trip Efficiency
	  /GBSC Diurnal Grid Battery Daily Storage Duration)
	)
	* One Hour
	~	MW*hour
	~		|

BAU Maximum Potential Binding Hour Peak Seasonal Day Electricity Output by Optimization Pass for Dispatchable Reliability Under CES\
		[Optimization Pass]=
	SUM(
	BAU Total Electricity Generation Capacity by Optimization Pass for Seasonal Clean Dispatchable Reliability\
		[Clean Dispatchable Electricity Source
	!,Optimization Pass]
	  *BAU Last Year Hourly Bid Electricity Capacity Factors for Clean Firm Reliability in Binding Hour by Plant Type\
		[Clean Dispatchable Electricity Source!]
	)
	* One Hour
	~	MW*hr
	~		|

BAU Metric Tons CO2 Stored per MWh[Electricity Source] :EXCEPT:    [biomass w CCS es]\
		=
	BAU Heat Rate by Electricity Fuel for Plants Built This Year[Electricity Source]
	* Electricity Fuel Pollutant Emissions Intensities This Year[CO2,Electricity Source]
	* CCP CO2 Capture Potential by Electricity Source[Electricity Source]
	/ Grams per Metric Ton CO2e
	/ Grams Pollutant per Gram CO2e Unit Converter ~~|
BAU Metric Tons CO2 Stored per MWh[biomass w CCS es]=
	BwCCSSpM Biomass with CCS Storage per MWh
	~	metric ton CO2e/(MW*hour)
	~		|

BAU Minimum Buildable Capacity for Plants=
	CSCMBCfPTwNEC Minimum Buildable Capacity for Plant Types with No Existing Capacity
	*SUM(BAU Last Year Electricity Generation Capacity[Electricity Source!])
	~	MW
	~		|

BAU Net Electricity Clean Firm Demand Relative to Available Clean Firm Supply by Hour before Additions\
		[Hour,peak day electricity timeslice]=
	QUANTUM(
	    BAU Total Electricity Demand by Hour Before Demand Altering Technologies Plus Reserve Margin Required from Clean Dispatchable Resource
	[peak day electricity timeslice,Hour]
	    
	      - SUM(
	    
	          BAU Electricity Generation Capacity before Dispatchable CES Additions[Clean Dispatchable Electricity Source\
		!]
	          * BAU Last Year Hourly Bid Electricity Capacity Factors by Plant Type[peak day electricity timeslice\
		,Hour,Clean Dispatchable Electricity Source
	!])
	          * One Hour
	
	      - BAU Total Demand Shifting Capacity in MW[peak day electricity timeslice,Hour\
		],
	     
	    Minimum Incremental Clean Firm Demand Requirement)
	~	MW*hr
	~		|

BAU Net Electricity Clean Firm Demand Relative to Available Clean Firm Supply by Hour by Optimization Pass for Seasonal Dispatchable Reliability under CES\
		[Optimization Pass]=
	QUANTUM(
	    SUM(BAU Total Electricity Demand by Hour Before Demand Altering Technologies Plus Reserve Margin Required from Clean Dispatchable Resource\
		[peak day electricity timeslice!,Hour!]*BAU Binding Peak Hour for Clean Dispatchable Reliability\
		[peak day electricity timeslice!,Hour!])
	           - BAU Maximum Potential Binding Hour Peak Seasonal Day Electricity Output by Optimization Pass for Dispatchable Reliability Under CES\
		[Optimization Pass],
	
	  Minimum Incremental Clean Firm Demand Requirement)
	~	MW*hr
	~		|

BAU Net Electricity Demand Relative to Available Supply by Hour before Reliability Additions\
		[peak day electricity timeslice,Hour]=
	BAU Total Electricity Demand by Hour Before Demand Altering Technologies Plus Reserve Margin\
		[peak day electricity timeslice
	,Hour]
	
	  - SUM(BAU Electricity Generation Capacity before Reliability Additions[Electricity Source\
		!]*BAU Last Year Hourly Bid Electricity Capacity Factors by Plant Type
	[peak day electricity timeslice,Hour,Electricity Source!])* One Hour
	~	MW*hour
	~		|

BAU Net Electricity Demand Relative to Available Supply in Binding Hour by Optimization Pass\
		[Optimization Pass]=
	SUM(BAU Total Electricity Demand by Hour Before Demand Altering Technologies Plus Reserve Margin\
		[peak day electricity timeslice!,
	Hour!]*BAU Binding Peak Hour for Reliability Additions[peak day electricity timeslice\
		!,Hour!])
	- BAU Maximum Potential Binding Hour Electricity Output by Hour for Dispatchable Reliability\
		[Optimization Pass]
	~	MW*hour
	~		|

BAU Net Imports of Electricity=
	(
	  BAU Imported Electricity
	  - EIaE BAU Exported Electricity
	)
	* (1 + Perc Change in Sectoral Energy Use due to Exogenous GDP Adjustment[electricity sector\
		])
	~	MW*hour
	~		|

BAU Net Loss per Unit Capacity[Electricity Source,Optimization Pass]=
	MAX(
	  0,
	
	  BAU Last Year Annual Recurring Costs by Plant Type[Electricity Source]
	  * SoFCtMbCtPR Share of Forward Costs that Must Be Covered to Prevent Retirement[Electricity Source\
		]
	  - BAU Expected Total Revenue per Unit Capacity by Plant Type Excluding Subsidies[Electricity Source\
		,Optimization Pass]
	)
	~	$/MW
	~		|

BAU Net Loss per Unit Capacity Excluding Predicted Capacity Payment[Electricity Source\
		]=
	MAX(
	  0,
	
	  BAU Last Year Annual Recurring Costs by Plant Type[Electricity Source]
	  * SoFCtMbCtPR Share of Forward Costs that Must Be Covered to Prevent Retirement[Electricity Source\
		]
	  - BAU Expected Total Revenue per Unit Capacity by Plant Type Excluding Subsidies and Predicted Capacity Payment\
		[Electricity Source]
	)
	~	$/MW
	~		|

BAU New Capacity Added due to Elec Portfolio Stds for Hybrid Power Plants[Electricity Source\
		,Clean Elec Requirement]=
	BAU New Capacity Desired due to Cost Effectiveness for Hybrid Power Plants[Electricity Source\
		,Clean Elec Requirement]
	-BAU New Capacity Desired due to Cost Effectivness for Hybrid Power Plants without CES\
		[Electricity Source]
	~	MW
	~		|

BAU New Capacity Added or Retrofitted due to Elec Portfolio Stds[Electricity Source,Clean Elec Requirement\
		]=
	BAU New Capacity Added due to Elec Portfolio Stds for Hybrid Power Plants[Electricity Source\
		,Clean Elec Requirement]
	+ BAU New Capacity Added or Retrofitted due to Elec Portfolio Stds excluding Hybrid Power Plants\
		[Electricity Source,Clean Elec Requirement]
	~	MW
	~		|

BAU New Capacity Added or Retrofitted due to Elec Portfolio Stds excluding Hybrid Power Plants\
		[Electricity Source,Clean Elec Requirement]=
	BAU New Capacity Desired due to Cost Effectiveness[Electricity Source,Clean Elec Requirement\
		]
	+ BAU Retrofit Capacity Desired due to Cost Effectiveness[Electricity Source,Clean Elec Requirement\
		]
	- BAU New Capacity Desired due to Cost Effectivness without CES[Electricity Source]
	- BAU Retrofitted Capacity Desired due to Cost Effectiveness without CES[Electricity Source\
		]
	~	MW
	~		|

BAU New Capacity Desired due to Cost Effectiveness[Electricity Source,RPS]=
	MAX(0,
	
	  
	  SUM(BAU New Capacity Desired due to Cost Effectivness by Optimization Pass[Electricity Source\
		,last pass!,RPS])
	  -BAU New Dispatchable Only Clean Capacity Desired for Seasonal Reliability[Electricity Source\
		]
	
	 ) ~~|
BAU New Capacity Desired due to Cost Effectiveness[Electricity Source,CES]=
	MAX(0,
	
	  
	  SUM(BAU New Capacity Desired due to Cost Effectivness by Optimization Pass[Electricity Source\
		,last pass!,CES])
	  -BAU New Dispatchable Only Clean Capacity Desired for Seasonal Reliability[Electricity Source\
		]
	
	 )
	~	MW
	~	Although "last pass" is intended to contain a single element, we must sum \
		across it becuase it is technically a subrange.
	|

BAU New Capacity Desired due to Cost Effectiveness for Hybrid Power Plants[Electricity Source\
		,Clean Elec Requirement] :EXCEPT:   [Hybrid Electricity Source,Clean Elec Requirement\
		]=
	0 ~~|
BAU New Capacity Desired due to Cost Effectiveness for Hybrid Power Plants[Hybrid Electricity Source\
		,RPS]=
	SUM(BAU New Capacity Desired due to Cost Effectivness by Optimization Pass for Hybrid Power Plants\
		[Hybrid Electricity Source,last pass!,RPS]) ~~|
BAU New Capacity Desired due to Cost Effectiveness for Hybrid Power Plants[Hybrid Electricity Source\
		,CES]=
	SUM(BAU New Capacity Desired due to Cost Effectivness by Optimization Pass for Hybrid Power Plants\
		[Hybrid Electricity Source,last pass!,CES])
	~	MW
	~	Although "last pass" is intended to contain a single element, we must sum \
		across it becuase it is technically a subrange.
	|

BAU New Capacity Desired due to Cost Effectivness by Optimization Pass[Electricity Source\
		, Optimization Pass,RPS]=
	QUANTUM(
	  MIN(
	    BAU Max Capacity Buildable after Mandated and Required Clean Dispatchable Additions\
		[Electricity Source],
	
	    BAU Profitable Capacity for Cost Effectiveness Additions[Electricity Source,Optimization Pass\
		,RPS]
	    * CSCSoCECBiaSY Share of Cost Effective Capacity Built in a Single Year[Electricity Source\
		]
	  ),
	  MPPC Minimum Power Plant Capacity[Electricity Source]
	) ~~|
BAU New Capacity Desired due to Cost Effectivness by Optimization Pass[Electricity Source\
		,Optimization Pass,CES]=
	QUANTUM(
	  MIN(
	    BAU Max Capacity Buildable after Mandated and Required Clean Dispatchable Additions\
		[Electricity Source],
	
	    BAU Profitable Capacity for Cost Effectiveness Additions[Electricity Source,Optimization Pass\
		,CES]
	    * CSCSoCECBiaSY Share of Cost Effective Capacity Built in a Single Year[Electricity Source\
		]
	  ),
	  MPPC Minimum Power Plant Capacity[Electricity Source]
	)
	~	MW
	~		|

BAU New Capacity Desired due to Cost Effectivness by Optimization Pass for Hybrid Power Plants\
		[Electricity Source, Optimization Pass,Clean Elec Requirement] :EXCEPT:      [Hybrid Electricity Source\
		, Optimization Pass,Clean Elec Requirement]=
	0 ~~|
BAU New Capacity Desired due to Cost Effectivness by Optimization Pass for Hybrid Power Plants\
		[Hybrid Electricity Source,Optimization Pass,RPS]=
	QUANTUM(
	  MIN(
	    BAU Max Capacity Buildable after Mandated and Required Clean Dispatchable Additions\
		[Hybrid Electricity Source]
	    - BAU New Capacity Desired due to Cost Effectivness by Optimization Pass[Hybrid Electricity Source\
		,Optimization Pass,RPS],
	
	    BAU Profitable Capacity for Cost Effectiveness Additions for Hybrid Power Plants\
		[Hybrid Electricity Source,Optimization Pass,RPS
	]
	    * CSCSoCECBiaSY Share of Cost Effective Capacity Built in a Single Year[Hybrid Electricity Source\
		]
	  ),
	  MPPC Minimum Power Plant Capacity[Hybrid Electricity Source]
	) ~~|
BAU New Capacity Desired due to Cost Effectivness by Optimization Pass for Hybrid Power Plants\
		[Hybrid Electricity Source,Optimization Pass,CES]=
	QUANTUM(
	  MIN(
	    BAU Max Capacity Buildable after Mandated and Required Clean Dispatchable Additions\
		[Hybrid Electricity Source]
	    - BAU New Capacity Desired due to Cost Effectivness by Optimization Pass[Hybrid Electricity Source\
		,Optimization Pass,CES],
	
	    BAU Profitable Capacity for Cost Effectiveness Additions for Hybrid Power Plants\
		[Hybrid Electricity Source,Optimization Pass,CES
	]
	    * CSCSoCECBiaSY Share of Cost Effective Capacity Built in a Single Year[Hybrid Electricity Source\
		]
	  ),
	  MPPC Minimum Power Plant Capacity[Hybrid Electricity Source]
	)
	~	MW
	~		|

BAU New Capacity Desired due to Cost Effectivness for Hybrid Power Plants without CES\
		[Electricity Source] :EXCEPT:      [
Hybrid Electricity Source]=
	0 ~~|
BAU New Capacity Desired due to Cost Effectivness for Hybrid Power Plants without CES\
		[Hybrid Electricity Source]=
	QUANTUM(
	  MIN(
	    BAU Max Capacity Buildable after Mandated and Required Clean Dispatchable Additions\
		[Hybrid Electricity Source]
	    - BAU New Capacity Desired due to Cost Effectivness without CES[Hybrid Electricity Source\
		],
	
	    BAU Profitable Capacity for Cost Effectiveness Additions for Hybrid Power Plants without CES\
		[Hybrid Electricity Source
	  ]
	    * CSCSoCECBiaSY Share of Cost Effective Capacity Built in a Single Year[Hybrid Electricity Source\
		]
	 ),
	 MPPC Minimum Power Plant Capacity[Hybrid Electricity Source]
	)
	~	MW
	~		|

BAU New Capacity Desired due to Cost Effectivness without CES[Electricity Source]=
	QUANTUM(
	  MIN(
	    BAU Max Capacity Buildable after Mandated and Required Clean Dispatchable Additions\
		[Electricity Source],
	
	    BAU Profitable Capacity for Cost Effectiveness Additions without CES[Electricity Source\
		]
	    * CSCSoCECBiaSY Share of Cost Effective Capacity Built in a Single Year[Electricity Source\
		]
	  ),
	 MPPC Minimum Power Plant Capacity[Electricity Source]
	)
	~	MW
	~		|

BAU New Capacity Desired for Seasonal Clean Dispatchable Reliability by Optimization Pass\
		[Clean Dispatchable Electricity Source,Optimization Pass]=
	QUANTUM(
	  MAX(0,MIN(
	    BAU Max Capacity Buildable after Mandated Additions[Clean Dispatchable Electricity Source\
		],
	
	    (
	      BAU Profitable Capacity for Seasonal Dispatchable Clean Reliability Additions[\
		Clean Dispatchable Electricity Source,Optimization Pass]
	      * CSCSoCECBiaSY Share of Cost Effective Capacity Built in a Single Year[Clean Dispatchable Electricity Source\
		]
	    )
	
	  )
	  ),
	  MPPC Minimum Power Plant Capacity[Clean Dispatchable Electricity Source]
	)
	~	MW
	~		|

BAU New Capacity Desired for Seasonal Dispatchable Reliability by Optimization Pass[Electricity Source\
		,Optimization Pass]=
	QUANTUM(
	  MAX(0,MIN(
	    BAU Max Capacity Buildable after Cost Effective and RPS Additions[Electricity Source\
		,CES
	],
	
	    (
	      BAU Profitable Capacity for Seasonal Dispatchable Reliability Additions[Electricity Source\
		,Optimization Pass
	]
	      * CSCSoCECBiaSY Share of Cost Effective Capacity Built in a Single Year[Electricity Source
	]
	    )
	    - BAU Total New Capacity Desired due to Cost Effectiveness[Electricity Source,CES\
		]
	    - BAU New Dispatchable Only Clean Capacity Desired for Seasonal Reliability[Electricity Source\
		]
	  )
	  )
	   * IF THEN ELSE(
	       BAU Five Year Foresight Elec Portfolio Values for Reliability Check[RPS]=1,
	       Elec Portfolio Qualifying Sources[Electricity Source,RPS],
	       IF THEN ELSE(
	         BAU Five Year Foresight Elec Portfolio Values for Reliability Check[CES]=1,
	         Elec Portfolio Qualifying Sources[Electricity Source,CES],
	         1
	       )
	     ),
	  MPPC Minimum Power Plant Capacity[Electricity Source]
	)
	~	MW
	~		|

BAU New Cargo Dist Transported[Vehicle Type,Cargo Type]=
	SUM(BAU New Cargo Dist Transported Allocated by Last Year Vehicle Technologies[Vehicle Type\
		,Cargo Type,Vehicle Technology!])
	~	thing*miles
	~		|

BAU New Cargo Dist Transported Allocated by Last Year Vehicle Technologies[Vehicle Type\
		,Cargo Type,Vehicle Technology]=
	BAU Cargo Dist Transported Allocated by Last Year Vehicle Technologies[Vehicle Type,\
		Cargo Type,Vehicle Technology]
	* SoCDTtiNTY Share of Cargo Dist Transported that is New This Year[Vehicle Type,Cargo Type\
		,Vehicle Technology]
	~	thing*miles
	~		|

BAU New Components Energy Use[Building Type,Building Fuel,Building Component] :EXCEPT:\
		     [Building Type,Building Fuel,envelope
]=
	BCEU BAU Components Energy Use[Building Type,Building Fuel,Building Component]
	* SoCEUtiNTY Share of Components Energy Use that is New This Year[Building Type,Building Component\
		] ~~|
BAU New Components Energy Use[Building Type,Building Fuel,envelope]=
	1
	
	{This is a coefficient that will be modified by policies, then multiplied by heating and by cooling new components potential energy use}
	~	BTU
	~		|

BAU New Components Energy Use after Envelope Effects[Building Type,Building Fuel,heating\
		]=
	BAU New Components Energy Use[Building Type,Building Fuel,heating]
	* BAU New Components Energy Use[Building Type,Building Fuel,envelope]
	* Envelope Multiplier Unit Correction Factor
	/ One Year ~~|
BAU New Components Energy Use after Envelope Effects[Building Type,Building Fuel,cooling and ventilation\
		]=
	BAU New Components Energy Use[Building Type,Building Fuel,cooling and ventilation]
	* BAU New Components Energy Use[Building Type,Building Fuel,envelope]
	* Envelope Multiplier Unit Correction Factor
	/ One Year ~~|
BAU New Components Energy Use after Envelope Effects[Building Type,Building Fuel,envelope\
		]=
	0 ~~|
BAU New Components Energy Use after Envelope Effects[Building Type,Building Fuel,lighting\
		]=
	BAU New Components Energy Use[Building Type,Building Fuel,lighting]
	/ One Year ~~|
BAU New Components Energy Use after Envelope Effects[Building Type,Building Fuel,appliances\
		]=
	BAU New Components Energy Use[Building Type,Building Fuel,appliances]
	/ One Year ~~|
BAU New Components Energy Use after Envelope Effects[Building Type,Building Fuel,other component\
		]=
	BAU New Components Energy Use[Building Type,Building Fuel,other component]
	/ One Year
	~	BTU/Year
	~		|

BAU New Components Energy Use after Envelope Effects after Lifetime[Building Type,Building Fuel\
		,Building Component]= DELAY FIXED (
	BAU New Components Energy Use after Envelope Effects[Building Type,Building Fuel,Building Component\
		],
	CL Component Lifetime[Building Type,Building Component],
	0)
	~	BTU/Year
	~		|

BAU New Dispatchable Only Capacity Desired for Seasonal Reliability[Electricity Source\
		]=
	VMAX(BAU New Capacity Desired for Seasonal Dispatchable Reliability by Optimization Pass\
		[Electricity Source,last pass!])
	~	MW
	~		|

BAU New Dispatchable Only Clean Capacity Desired for Seasonal Reliability[Electricity Source\
		] :EXCEPT:     [Clean Dispatchable Electricity Source]=
	0 ~~|
BAU New Dispatchable Only Clean Capacity Desired for Seasonal Reliability[Clean Dispatchable Electricity Source\
		]=
	SUM(BAU New Capacity Desired for Seasonal Clean Dispatchable Reliability by Optimization Pass\
		[Clean Dispatchable Electricity Source,last pass!])
	~	MW
	~		|

BAU New EV Chargers This Year=
	BNoEVC BAU Number of EV Chargers
	- BAU Last Year Number of EV Chargers
	~	chargers
	~		|

BAU New Generation Capacity[Electricity Source]=
	BAU New Generation Capacity Excluding Retrofit Capacity[Electricity Source]
	+BAU Retrofit Capacity after Quantization[Electricity Source]
	~	MW
	~		|

BAU New Generation Capacity after Dispatchable Only Reliability Additions[Electricity Source\
		]=
	BAU New Generation Capacity before Reliability Additions[Electricity Source]
	+BAU New Dispatchable Only Capacity Desired for Seasonal Reliability[Electricity Source\
		]
	~	MW
	~		|

BAU New Generation Capacity before Cost Effectiveness Additions[Electricity Source]=
	BAU New Policy Mandated Capacity[Electricity Source]
	+BAU New Dispatchable Only Clean Capacity Desired for Seasonal Reliability[Electricity Source\
		]
	~	MW
	~		|

BAU New Generation Capacity before Reliability Additions[Electricity Source]=
	BAU New Generation Capacity before Cost Effectiveness Additions[Electricity Source]
	+BAU Total New Capacity Desired due to Cost Effectiveness[Electricity Source,CES]
	~	MW
	~		|

BAU New Generation Capacity Excluding Retrofit Capacity[Electricity Source]=
	BAU New Generation Capacity after Dispatchable Only Reliability Additions[Electricity Source\
		]
	~	MW
	~		|

BAU New Green Hydrogen Production Capacity This Year=
	MAX( 
	  0,
	  BAU Green Hydrogen Demand
	  - BAU Surviving Green Hydrogen Production Capacity
	)
	~	BTU
	~		|

BAU New Grid Battery Capacity=
	BAU New Grid Battery Capacity Deployed before Capacity Market Revenue
	+SUM(BAU New Grid Battery Capacity Deployed for Seasonal Dispatchable Reliability by Optimization Pass\
		[last pass!])
	~	MW*hour
	~		|

BAU New Grid Battery Capacity Deployed before Capacity Market Revenue=
	MAX(
	 GBCGpUNR Grid Battery Capacity Growth per Unit Net Revenue*BAU Grid Batteries Net Energy Market Revenue per Unit Elec Output
	,
	 0
	)
	~	MW*hr
	~		|

BAU New Grid Battery Capacity Deployed for Seasonal Dispatchable Reliability by Optimization Pass\
		[Optimization Pass]=
	MAX(
	 GBCGpUNR Grid Battery Capacity Growth per Unit Net Revenue*
	 (BAU Grid Batteries Net Energy Market Revenue per Unit Elec Output
	  +BAU Grid Batteries Capacity Market Revenue for Seasonal Dispatchable Reliability per Unit Elec Output\
		[Optimization Pass
	]
	)
	,
	 0
	)
	-BAU New Grid Battery Capacity Deployed before Capacity Market Revenue
	~	MW*hr
	~		|

BAU New Hybrid Grid Battery Storage Capacity[Electricity Source]=
	BAU New Capacity Desired due to Cost Effectivness by Optimization Pass for Hybrid Power Plants\
		[Electricity Source,pass20,CES]
	   *HESBCpUEC Hybrid Electricity Source Battery Capacity per Unit Electricity Capacity
	   *GBSC Diurnal Grid Battery Daily Storage Duration
	~	MW*hour
	~		|

BAU New Hydrogen Production Capacity[Hydrogen Production Pathway] :EXCEPT:  [electrolysis with guaranteed clean electricity\
		]=
	(BAU New Low Carbon Hydrogen Production Capacity This Year[Hydrogen Production Pathway\
		]
	+ BAU New Other Hydrogen Production Capacity This Year[Hydrogen Production Pathway])
	/ One Year ~~|
BAU New Hydrogen Production Capacity[electrolysis with guaranteed clean electricity]=
	(BAU New Green Hydrogen Production Capacity This Year
	+ BAU New Low Carbon Hydrogen Production Capacity This Year[electrolysis with guaranteed clean electricity\
		]
	+ BAU New Other Hydrogen Production Capacity This Year[electrolysis with guaranteed clean electricity\
		])
	/ One Year
	~	BTU/Year
	~		|

BAU New Industrial Equipment Capital Cost[Industry Category]=
	SUM(
	  BAU New Industrial Equipment Energy Use by Fuel Type and Process[Industry Category\
		,Industrial Fuel!,Industrial Process
	!]
	  * BAU Industrial Equipment Capital Cost per Unit Energy Before Subsidy[Industry Category\
		,Industrial Fuel!,Industrial Process!]
	)
	~	$
	~		|

BAU New Industrial Equipment Energy Intensity[Industry Category,Industrial Fuel,Industrial Process\
		]=
	MAX(
	
	 BAU Last Year New Equipment Energy Intensity[Industry Category,Industrial Fuel,Industrial Process\
		]
	 / (1 + BIEEI BAU Industrial Equipment Efficiency Improvement[Industrial Process,Industrial Fuel\
		]),
	 
	 IEMUEF Industrial Equipment Minimum Unit Energy Factor[Industrial Fuel,Industrial Process\
		]
	)
	~	Dmnl
	~		|

BAU New Industrial Equipment Energy Intensity in Electricity Equivalent[Industry Category\
		,Industrial Fuel,Industrial Process]=
	BAU New Industrial Equipment Energy Intensity[Industry Category,Industrial Fuel,Industrial Process\
		]
	* (1 - PIFURfE Percentage Industry Fuel Use Reduction for Electricity[Industry Category\
		,Industrial Process])
	~	Dmnl
	~		|

BAU New Industrial Equipment Energy Use by Fuel Type and Process[Industry Category,Industrial Fuel\
		,Industrial Process] :EXCEPT:  [Industry Category,electricity if,Industrial Process\
		]=
	BAU New Industrial Equipment Energy Use by Fuel Type and Process in Electricity Equivalent\
		[Industry Category,Industrial Fuel,Industrial Process]
	/ (1 - PIFURfE Percentage Industry Fuel Use Reduction for Electricity[Industry Category\
		,Industrial Process]) ~~|
BAU New Industrial Equipment Energy Use by Fuel Type and Process[Industry Category,electricity if\
		,Industrial Process]=
	BAU New Industrial Equipment Energy Use by Fuel Type and Process in Electricity Equivalent\
		[Industry Category,electricity if,Industrial Process]
	~	BTU
	~		|

BAU New Industrial Equipment Energy Use by Fuel Type and Process in Electricity Equivalent\
		[Industry Category,Industrial Fuel
,Industrial Process]=
	BAU Output from New Industrial Equipment by Fuel Type and Industrial Process[Industry Category\
		,Industrial Fuel,Industrial Process
	]
	* BAU Energy Intensity of Industrial Production by Fuel for New Equipment in Electricity Equivalent\
		[Industry Category,Industrial Fuel]
	~	BTU
	~		|

BAU New Low Carbon Hydrogen Production Capacity Shares This Year[Hydrogen Production Pathway\
		]=
	ZIDZ(
	  HPS Hydrogen Production Shareweights[Hydrogen Production Pathway]
	  * exp(MAX(10^-8, BAU Cost per Unit New Hydrogen Production[Hydrogen Production Pathway\
		] / One Dollar * One BTU)*10^4
	  * HPLC Hydrogen Production Logit Coefficient)
	  * Hydrogen Production Pathways Qualifying as Low Carbon[Hydrogen Production Pathway\
		]
	
	  ,
	
	  SUM(
	    HPS Hydrogen Production Shareweights[Hydrogen Production Pathway!]
	    * exp(MAX(10^-8, BAU Cost per Unit New Hydrogen Production[Hydrogen Production Pathway\
		!] / One Dollar * One BTU)*10^4
	    * HPLC Hydrogen Production Logit Coefficient)
	    * Hydrogen Production Pathways Qualifying as Low Carbon[Hydrogen Production Pathway\
		!]
	  )
	)
	~	Dmnl
	~		|

BAU New Low Carbon Hydrogen Production Capacity This Year[Hydrogen Production Pathway\
		]=
	BAU New Low Carbon Hydrogen Production Capacity Shares This Year[Hydrogen Production Pathway\
		]
	
	* BAU Total New Low Carbon Hydrogen Production Capacity This Year
	~	BTU
	~		|

BAU New Off Grid Capacity for Green Hydrogen Demand[Electricity Source]=
	QUANTUM(
	  ZIDZ(
	    BAU Off Grid Electricity Demand for Green Hydrogen That is New This Year by Power Plant Type\
		[Electricity Source],
	    BAU Expected Capacity Factor x Hours per Year for Plants Built This Year Without Hypothetical Calculations\
		[Electricity Source]
	  ),
	
	  MPPC Minimum Power Plant Capacity[Electricity Source]
	)
	~	MW
	~		|

BAU New Other Hydrogen Production Capacity Shares This Year[Hydrogen Production Pathway\
		]=
	ZIDZ(
	  HPS Hydrogen Production Shareweights[Hydrogen Production Pathway]
	  * exp(MAX(10^-8, BAU Cost per Unit New Hydrogen Production[Hydrogen Production Pathway\
		] / One Dollar * One BTU)*10^4
	  * HPLC Hydrogen Production Logit Coefficient)
	
	  ,
	
	  SUM(
	    HPS Hydrogen Production Shareweights[Hydrogen Production Pathway!]
	    * exp(MAX(10^-8, BAU Cost per Unit New Hydrogen Production[Hydrogen Production Pathway\
		!] / One Dollar * One BTU)*10^4
	    * HPLC Hydrogen Production Logit Coefficient)
	  )
	)
	~	Dmnl
	~		|

BAU New Other Hydrogen Production Capacity This Year[Hydrogen Production Pathway]=
	BAU New Other Hydrogen Production Capacity Shares This Year[Hydrogen Production Pathway\
		]
	
	* BAU Total New Other Hydrogen Production Capacity This Year
	~	BTU
	~		|

BAU New Policy Mandated Capacity[Electricity Source]=
	BPMCCS BAU Policy Mandated Capacity Construction Schedule[Electricity Source]
	~	MW
	~		|

BAU New Policy Mandated Retrofits[Electricity Source]=
	MIN(
	  BAU Max Capacity Available for CCUS Retrofit[Electricity Source],
	
	  BPMCRS BAU Policy Mandated Capacity Retrofit Schedule[Electricity Source]
	
	 )
	~	MW
	~		|

BAU New Vehicle Distance Traveled[Vehicle Type,Cargo Type]=
	ZIDZ(
	  BAU New Cargo Dist Transported[Vehicle Type,Cargo Type],
	  AVLo Average Vehicle Loading[Vehicle Type,Cargo Type]
	)
	~	miles
	~		|

BAU New Vehicle Fuel Cost per Unit Cargo Dist[Vehicle Type,Cargo Type,Vehicle Technology\
		]=
	ZIDZ(
	  BAU Weighted Avg Fuel Cost per Unit Energy by Vehicle Technology[Vehicle Type,Cargo Type\
		,Vehicle Technology],
	  BAU New Vehicle Fuel Economy[Vehicle Type,Cargo Type,Vehicle Technology]
	)
	~	$/(thing*mile)
	~		|

BAU New Vehicle Fuel Cost per Unit Vehicle Distance[Vehicle Type,Cargo Type,Vehicle Technology\
		]=
	BAU New Vehicle Fuel Cost per Unit Cargo Dist[Vehicle Type,Cargo Type,Vehicle Technology\
		]
	* AVLo Average Vehicle Loading[Vehicle Type,Cargo Type]
	~	$/mile
	~		|

BAU New Vehicle Fuel Economy[Vehicle Type,Cargo Type,Vehicle Technology]=
	BNVFE BAU New Vehicle Fuel Economy[Vehicle Type,Cargo Type,Vehicle Technology]
	~	thing*miles/BTU
	~		|

BAU New Vehicle Fuel Economy After Lifetime[Vehicle Type,Cargo Type,Vehicle Technology\
		]= DELAY FIXED (
	BAU New Vehicle Fuel Economy[Vehicle Type,Cargo Type,Vehicle Technology],
	AVL Avg Vehicle Lifetime[Cargo Type,Vehicle Type],
	0)
	~	thing*miles/BTU
	~		|

BAU New Vehicle Price[Vehicle Type,Cargo Type,Vehicle Technology]=
	MAX(BAU New Vehicle Price after Endogenous Vehicle Learning[Vehicle Type,Cargo Type,\
		Vehicle Technology]
	     - BAU Vehicle Subsidy Perc[Cargo Type,Vehicle Type,Vehicle Technology],
	
	   0
	)
	~	$/vehicle
	~		|

BAU New Vehicle Price after Endogenous Vehicle Learning[Vehicle Type,Cargo Type,Vehicle Technology\
		]=
	BAU This Year Battery Portion of Vehicle Price[Cargo Type,Vehicle Type,Vehicle Technology\
		]
	  + NBPoNVP Non Battery Portion of New Vehicle Price[Vehicle Type,Cargo Type,Vehicle Technology\
		]
	~	$/vehicle
	~		|

BAU New Vehicle Price Including EV Shadow Cost[Vehicle Type,Cargo Type,Vehicle Technology\
		] :EXCEPT:  [LDVs,passenger,battery electric vehicle
]=
	BAU New Vehicle Price[Vehicle Type,Cargo Type,Vehicle Technology] ~~|
BAU New Vehicle Price Including EV Shadow Cost[LDVs,passenger,battery electric vehicle\
		]=
	BAU New Vehicle Price[LDVs,passenger,battery electric vehicle]
	+ BAU BRAaCTSC BAU Range Anxiety Shadow Cost
	+ BAU Charging Availability Shadow Cost
	~	$/vehicle
	~		|

BAU New Vehicle Price Without Subsidies[Vehicle Type,Cargo Type,Vehicle Technology]=
	BAU New Vehicle Price after Endogenous Vehicle Learning[Vehicle Type,Cargo Type,Vehicle Technology\
		]
	+ BAU This Year Battery Subsidy Passed Through to Consumers by Vehicle Type[Cargo Type\
		,Vehicle Type,Vehicle Technology]
	~	$/vehicle
	~		|

BAU New Vehicles[Vehicle Type,Cargo Type,Vehicle Technology]=
	QUANTUM(
	  SUM(BAU New Vehicles by Subregion[Subregion!,Vehicle Type,Cargo Type,Vehicle Technology\
		]),
	  QSfV Quantization Size for Vehicles[Vehicle Type,Cargo Type]
	)
	/ One Year
	~	vehicles/Year
	~	If the model wishes to add fewer than +/- VQS vehicles, this is rounding \
		error, and we dampen it to zero.  If we do not, it can throw off the Fleet \
		Average Fuel Economy if the erroneously introduced vehicle (or negative \
		vehicle) is the only vehicle of its type and technology in the model.
	|

BAU New Vehicles After Lifetime[Vehicle Type,Cargo Type,Vehicle Technology]= DELAY FIXED\
		 (
	BAU New Vehicles[Vehicle Type,Cargo Type,Vehicle Technology],
	AVL Avg Vehicle Lifetime[Cargo Type,Vehicle Type],
	0)
	~	vehicles/Year
	~		|

BAU New Vehicles Allocated before ZEV Standards[Vehicle Type,Cargo Type,Vehicle Technology\
		]=
	(
	  TTS Transportation Technology Shareweights[Vehicle Type,Cargo Type,Vehicle Technology\
		]
	  *exp(MAX(1, BAU NPV of Lifetime Vehicle Cost[Vehicle Type,Cargo Type,Vehicle Technology\
		]*Vehicle Allocation Unit Correction)/1e+06*TTLE Transportation Technology Logit Exponents\
		[Vehicle Type,Cargo Type])
	)
	/
	(
	  SUM(TTS Transportation Technology Shareweights[Vehicle Type,Cargo Type,Vehicle Technology\
		!]
	  * exp(MAX(1, BAU NPV of Lifetime Vehicle Cost[Vehicle Type,Cargo Type,Vehicle Technology\
		!]*Vehicle Allocation Unit Correction)/1e+06*TTLE Transportation Technology Logit Exponents\
		[Vehicle Type,Cargo Type])
	))
	* BAU New Vehicles Demanded[Vehicle Type,Cargo Type]
	~	vehicles
	~	Using standard Logit function as described at \
		https://jgcri.github.io/gcam-doc/choice.html
	|

BAU New Vehicles before ZEV Standards by Subregion[Subregion,Vehicle Type,Cargo Type,\
		Vehicle Technology]=
	BAU New Vehicles Allocated before ZEV Standards[Vehicle Type,Cargo Type,Vehicle Technology\
		]
	* VSbS Vehicle Shares by Subregion[Subregion,Vehicle Type,Cargo Type]
	~	vehicles
	~		|

BAU New Vehicles by Subregion[Subregion,Vehicle Type,Cargo Type,Vehicle Technology]=
	BAU New Vehicles by Subregion for Vehicle Types with BAU Qualifying Technologies[Subregion\
		,Vehicle Type,Cargo Type,Vehicle Technology]
	+ BAU New Vehicles by Subregion for Vehicle Types without BAU Qualifying Technologies\
		[Subregion,Vehicle Type,Cargo Type,Vehicle Technology]
	~	vehicles
	~	If the ZEV standard is met naturally, we keep the pre-ZEV standard \
		allocation. Otherwise, we scale up ZEVs sales such that the standard is \
		hit and scale down non-ZEV sales so as to avoid changing the total number \
		of vehicles sold.
	|

BAU New Vehicles by Subregion for Vehicle Types with BAU Qualifying Technologies[Subregion\
		,Vehicle Type,Cargo Type,Vehicle Technology]=
	IF THEN ELSE(BAU Sum of Shareweights by Vehicle and Cargo Type[Vehicle Type,Cargo Type\
		] = 0,
	
	0,
	
	IF THEN ELSE(
	
	  BAU ZEV Sales Share Without ZEV Standard[Subregion,Vehicle Type,Cargo Type]
	  > BAU Required ZEV Sales Percentage by Subregion[Subregion,Vehicle Type,Cargo Type\
		],
	
	
	  BAU New Vehicles before ZEV Standards by Subregion[Subregion,Vehicle Type,Cargo Type\
		,Vehicle Technology],
	
	
	  BAU New Vehicles before ZEV Standards by Subregion[Subregion,Vehicle Type,Cargo Type\
		,Vehicle Technology]
	    * BAU Vehicle Technologies Qualifying as ZEVs[Vehicle Type,Vehicle Technology]
	    * ZIDZ(
	        BAU Required ZEV Sales Percentage by Subregion[Subregion,Vehicle Type,Cargo Type\
		],
	        BAU ZEV Sales Share Without ZEV Standard[Subregion,Vehicle Type,Cargo Type]
	      )
	  + BAU New Vehicles before ZEV Standards by Subregion[Subregion,Vehicle Type,Cargo Type\
		,Vehicle Technology]
	    * (1 - BAU Vehicle Technologies Qualifying as ZEVs[Vehicle Type,Vehicle Technology\
		])
	    * ZIDZ(
	        (1 - BAU Required ZEV Sales Percentage by Subregion[Subregion,Vehicle Type,Cargo Type\
		]),
	        (1 - BAU ZEV Sales Share Without ZEV Standard[Subregion,Vehicle Type,Cargo Type\
		])
	      )
	)
	)
	~	vehicles
	~	If the ZEV standard is met naturally, we keep the pre-ZEV standard \
		allocation. Otherwise, we scale up ZEVs sales such that the standard is \
		hit and scale down non-ZEV sales so as to avoid changing the total number \
		of vehicles sold.
	|

BAU New Vehicles by Subregion for Vehicle Types without BAU Qualifying Technologies[Subregion\
		,Vehicle Type,Cargo Type,Vehicle Technology]=
	IF THEN ELSE(BAU Sum of Shareweights by Vehicle and Cargo Type[Vehicle Type,Cargo Type\
		] = 0,
	
	
	IF THEN ELSE(
	  
	  BAU ZEV Sales Share Without ZEV Standard[Subregion,Vehicle Type,Cargo Type]
	  > BAU Required ZEV Sales Percentage by Subregion[Subregion,Vehicle Type,Cargo Type\
		],
	
	
	  BAU New Vehicles before ZEV Standards by Subregion[Subregion,Vehicle Type,Cargo Type\
		,Vehicle Technology],
	
	
	  (BAU New Vehicles before ZEV Standards by Subregion[Subregion,Vehicle Type,Cargo Type\
		,Vehicle Technology]
	  * (1 - BAU Required ZEV Sales Percentage by Subregion[Subregion,Vehicle Type,Cargo Type\
		]))
	
	  + 
	
	  SUM(BAU New Vehicles before ZEV Standards by Subregion[Subregion,Vehicle Type,Cargo Type\
		,Vehicle Technology!])
	  * BAU Required ZEV Sales Percentage by Subregion[Subregion,Vehicle Type,Cargo Type\
		]
	  * 
	
	  ((BAU Vehicle Technologies Qualifying as ZEVs[Vehicle Type,Vehicle Technology]
	  * exp(MAX(1, BAU NPV of Lifetime Vehicle Cost[Vehicle Type,Cargo Type,Vehicle Technology\
		]* Vehicle Allocation Unit Correction
	)/1e+06*TTLE Transportation Technology Logit Exponents[Vehicle Type,Cargo Type])
	)
	/
	(
	  SUM(BAU Vehicle Technologies Qualifying as ZEVs[Vehicle Type,Vehicle Technology!]
	  * exp(MAX(1, BAU NPV of Lifetime Vehicle Cost[Vehicle Type,Cargo Type,Vehicle Technology\
		!]* Vehicle Allocation Unit Correction
	)/1e+06*TTLE Transportation Technology Logit Exponents[Vehicle Type,Cargo Type])
	  )
	))
	
	
	)
	
	,0)
	~	vehicles
	~		|

BAU New Vehicles Contribution to Percentage Change to Fleet Avg Fuel Economy[Vehicle Type\
		,Cargo Type,Vehicle Technology]=
	BAU Percentage of Vehicle Stock New This Year[Vehicle Type,Cargo Type,Vehicle Technology\
		]
	* BAU Percentage Difference in New Vehicle vs Fleet Avg Fuel Economy[Vehicle Type,Cargo Type\
		,Vehicle Technology]
	~	Dmnl
	~		|

BAU New Vehicles Demanded[Vehicle Type,Cargo Type]=
	INTEGER(
	 ZIDZ(
	   BAU New Vehicle Distance Traveled[Vehicle Type,Cargo Type],
	   BAADTbVT BAU Average Annual Dist Traveled by Vehicle Type[Vehicle Type,Cargo Type\
		]
	 )
	 +0.999999
	)
	~	vehicles
	~		|

BAU New Vehicles Last Year[Vehicle Type,Cargo Type,Vehicle Technology]= DELAY FIXED (
	BAU New Vehicles[Vehicle Type,Cargo Type,Vehicle Technology],
	1,
	0)
	~	vehicles/Year
	~		|

BAU Non RPS Qualifying Guaranteed Dispatch Amount[Electricity Source,Electricity Timeslice\
		,Hour,Clean Elec Requirement]=
	BAU Expected Capacity by Hour[Electricity Source,Electricity Timeslice,Hour]
	 * BGDPbES BAU Guaranteed Dispatch Percentage by Electricity Source[Electricity Source\
		]
	 * (1 - Elec Portfolio Qualifying Sources[Electricity Source,Clean Elec Requirement]\
		)
	 * One Hour
	~	MW*hr
	~		|

BAU Non RPS Qualifying Guaranteed Dispatch Amount after RPS Policy[Electricity Source\
		,Electricity Timeslice,Hour,Clean Elec Requirement]=
	MIN(
	
	  BAU Non RPS Qualifying Guaranteed Dispatch Amount[Electricity Source,Electricity Timeslice\
		,Hour,Clean Elec Requirement]
	    * MIN(
	    1,
	
	    ZIDZ(
	      BAU Total Electricity Demand by Hour After Demand Altering Technologies[Electricity Timeslice\
		,Hour]
	      * (1 - BAU Legally Required Elec Portfolio Percentage[Clean Elec Requirement])\
		,      
	
	      BAU Non RPS Qualifying Guaranteed Dispatch Amount[Electricity Source,Electricity Timeslice\
		,Hour,Clean Elec Requirement]
	    )
	  ),
	
	BAU Non RPS Qualifying Guaranteed Dispatch Amount[Electricity Source,Electricity Timeslice\
		,Hour,Clean Elec Requirement]
	    * MIN(
	    1,
	
	    ZIDZ(
	      BAU Total Electricity Demand by Hour After Demand Altering Technologies[Electricity Timeslice\
		,Hour]
	      * (1 - BAU Legally Required Elec Portfolio Percentage[Clean Elec Requirement])\
		,      
	
	      BAU Non RPS Qualifying Guaranteed Dispatch Amount[Electricity Source,Electricity Timeslice\
		,Hour,Clean Elec Requirement]
	    )
	  )
	)
	~	MW*hr
	~		|

BAU Normalized Standard Deviation of Dispatch Costs Mapped to Hydrogen Production Pathways\
		[electrolysis]=
	SUM(
	  NSDoDC Normalized Standard Deviation of Dispatch Costs[Electricity Source!]
	  * BAU Last Year Electricity Generation by Type[Electricity Source!]
	)
	/
	SUM(BAU Last Year Electricity Generation by Type[Electricity Source!]) ~~|
BAU Normalized Standard Deviation of Dispatch Costs Mapped to Hydrogen Production Pathways\
		[natural gas reforming]=
	NSDoDC Normalized Standard Deviation of Dispatch Costs[natural gas combined cycle es\
		] ~~|
BAU Normalized Standard Deviation of Dispatch Costs Mapped to Hydrogen Production Pathways\
		[coal gasification]=
	NSDoDC Normalized Standard Deviation of Dispatch Costs[hard coal es] ~~|
BAU Normalized Standard Deviation of Dispatch Costs Mapped to Hydrogen Production Pathways\
		[biomass gasification]=
	NSDoDC Normalized Standard Deviation of Dispatch Costs[biomass es] ~~|
BAU Normalized Standard Deviation of Dispatch Costs Mapped to Hydrogen Production Pathways\
		[hydrocarbon partial oxidation
]=
	NSDoDC Normalized Standard Deviation of Dispatch Costs[heavy or residual fuel oil es\
		] ~~|
BAU Normalized Standard Deviation of Dispatch Costs Mapped to Hydrogen Production Pathways\
		[electrolysis with guaranteed clean electricity
]=
	SUM(NSDoDC Normalized Standard Deviation of Dispatch Costs[Electricity Source!]*BAU Share of Off Grid Electricity Demand That is New This Year Met by Power Plant Type
	[Electricity Source!]) ~~|
BAU Normalized Standard Deviation of Dispatch Costs Mapped to Hydrogen Production Pathways\
		[natural gas reforming with CCS
]=
	BAU Normalized Standard Deviation of Dispatch Costs Mapped to Hydrogen Production Pathways\
		[natural gas reforming]
	~	Dmnl
	~		|

BAU NPV of Lifetime Fuel Expenditures for a Vehicle Sold This Year[Vehicle Type,Cargo Type\
		,Vehicle Technology]=
	BAU Total Annual Vehicle Costs[Vehicle Type,Cargo Type,Vehicle Technology]
	* (
	    (1 - (1 + VBDR Vehicle Buyer Discount Rate[Vehicle Type]) ^ (- AVOP Average Vehicle Ownership Period\
		[Vehicle Type,Cargo Type]/One Year
	))
	    / VBDR Vehicle Buyer Discount Rate[Vehicle Type]
	  )
	~	$/vehicle
	~		|

BAU NPV of Lifetime Vehicle Cost[Vehicle Type,Cargo Type,Vehicle Technology]=
	BAU New Vehicle Price Including EV Shadow Cost[Vehicle Type,Cargo Type,Vehicle Technology\
		]
	+ BAU NPV of Lifetime Fuel Expenditures for a Vehicle Sold This Year[Vehicle Type,Cargo Type\
		,Vehicle Technology]
	~	$/vehicle
	~		|

BAU Off Grid Capacity for Green Hydrogen Demand[Electricity Source]=
	BAU New Off Grid Capacity for Green Hydrogen Demand[Electricity Source]
	+ BAU Last Year Cumulative Off Grid Capacity for Green Hydrogen Demand[Electricity Source\
		]
	~	MW
	~		|

BAU Off Grid Electricity Demand for Green Hydrogen by Power Plant Type[Electricity Source\
		]=
	BAU Off Grid Electricity Demand for Green Hydrogen That is New This Year by Power Plant Type With Quantization\
		[Electricity Source]
	+ BAU Last Year Cumulative Off Grid Electricity Demand for Green Hydrogen by Power Plant Type\
		[Electricity Source]
	~	MW*hr
	~		|

BAU Off Grid Electricity Demand for Green Hydrogen That is New This Year by Power Plant Type\
		[Electricity Source]=
	BAU Share of Off Grid Electricity Demand That is New This Year Met by Power Plant Type\
		[Electricity Source]
	* BAU Hydrogen Sector Off Grid Electricity Demand for Green Hydrogen That is New This Year
	~	MW*hr
	~		|

BAU Off Grid Electricity Demand for Green Hydrogen That is New This Year by Power Plant Type With Quantization\
		[Electricity Source]=
	BAU New Off Grid Capacity for Green Hydrogen Demand[Electricity Source]
	* BAU Expected Capacity Factor x Hours per Year for Plants Built This Year Without Hypothetical Calculations\
		[Electricity Source]
	~	MW*hr
	~		|

BAU One Year Average Net Energy Market Revenue by Plant Type Excluding Subsidies for Hybrid Power Plants\
		[Hybrid Electricity Source]=
	SUM(BAU Expected Capacity Factors by Hour for Hybrid Plants Built This Year[Hybrid Electricity Source\
		,Electricity Timeslice
	!,Hour!]
	*BAU Last Year Five Year Average Marginal Dispatch Cost by Hour[Electricity Timeslice\
		!,Hour!]
	*SHELF Days per Electricity Timeslice[Electricity Timeslice!]
	* One Hour)
	-BAU Last Year Five Year Average Annual Expected Dispatch Costs by Power Plant Type[\
		Hybrid Electricity Source]
	~	$/MW
	~		|

BAU One Year Average Wholesale Energy Market Costs=
	SUM(
	 (BAU Total Electricity Dispatched by Hour[Electricity Timeslice!,Hour!])
	 *BAU Marginal Dispatch Cost by Hour[Electricity Timeslice!,Hour!]
	 *SHELF Days per Electricity Timeslice[Electricity Timeslice!])
	~	$
	~		|

BAU Ongoing Capital Costs for Green Hydrogen Electricity[Electricity Source]=
	BAU Off Grid Capacity for Green Hydrogen Demand[Electricity Source]
	* Weighted Average Annual Capital Costs per Unit Capacity[Electricity Source]
	~	$
	~		|

BAU Optimized CES Credit Price=
	MAX(
	  0,
	
	  SUM(BAU CES Credit Price by Optimization Pass[last pass!])
	)
	~	$/(MW*hour)
	~	Although "last pass" is intended to contain a single element, we must sum \
		across it becuase it is technically a subrange.
	|

BAU Optimized RPS Credit Price=
	MAX(
	  0,
	
	  SUM(BAU RPS Credit Price by Optimization Pass[last pass!])
	)
	~	$/(MW*hour)
	~	Although "last pass" is intended to contain a single element, we must sum \
		across it becuase it is technically a subrange.
	|

BAU Other Hydrogen Demand=
	BAU Total Hydrogen Demand
	- BAU Green Hydrogen Demand
	- BAU Low Carbon Hydrogen Demand
	~	BTU
	~		|

BAU Other Hydrogen Production by Pathway[Hydrogen Production Pathway]=
	ZIDZ(
	  BAU New Other Hydrogen Production Capacity This Year[Hydrogen Production Pathway]
	  + BAU Surviving Capacity Used for Other Hydrogen Production[Hydrogen Production Pathway\
		],
	
	  SUM(
	    BAU New Other Hydrogen Production Capacity This Year[Hydrogen Production Pathway\
		!]
	    + BAU Surviving Capacity Used for Other Hydrogen Production[Hydrogen Production Pathway\
		!]
	  )
	)
	~	Dmnl
	~		|

BAU Other Hydrogen Production Shares with Fallback[Hydrogen Production Pathway]=
	IF THEN ELSE(
	  SUM(BAU Other Hydrogen Production by Pathway[Hydrogen Production Pathway!]) = 0,
	
	  IF THEN ELSE(
	    SUM(BAU New Other Hydrogen Production Capacity Shares This Year[Hydrogen Production Pathway\
		!]) = 0,
	    BAU Start Year Other Hydrogen Production Shares by Pathway[Hydrogen Production Pathway\
		],
	    BAU New Other Hydrogen Production Capacity Shares This Year[Hydrogen Production Pathway\
		]
	  ),
	
	  ZIDZ( 
	    BAU Other Hydrogen Production by Pathway[Hydrogen Production Pathway],
	    SUM(BAU Other Hydrogen Production by Pathway[Hydrogen Production Pathway!])
	  )
	)
	~	1
	~		|

BAU Output by ISIC Code by Year[ISIC Code]=
	BAU Domestic Energy Revenue by Producing ISIC Code[ISIC Code]
	* FoPTaFbIC Fractions of Products That are Fuels by ISIC Code[ISIC Code]
	
	+ BAU Output by ISIC Code by Year from Exogenous Data[ISIC Code]
	  * (1 - FoPTaFbIC Fractions of Products That are Fuels by ISIC Code[ISIC Code])
	~	$
	~	Insofar as each ISIC code's revenues are from energy products, we use \
		endogenously-calculated values, and insofar as each ISIC code's revenues \
		are from non-energy products, we use exogenous values.
	|

BAU Output by ISIC Code by Year from Exogenous Data[ISIC Code]=
	BObIC BAU Output by ISIC Code[ISIC Code]
	* (1 + BPCiObIC BAU Percent Change in Output by ISIC Code[ISIC Code])
	~	$
	~		|

BAU Output Cost per Unit New Hydrogen Production[Hydrogen Production Pathway]=
	BAU Cost per Unit New Hydrogen Production[Hydrogen Production Pathway]
	* BpMMTH BTU per MMT Hydrogen
	/ Kilogram per Million Metric Ton
	/ OCCF Dollars per Small Output Currency Unit
	~	output currency unit/kg
	~		|

BAU Output from Industrial Equipment Installed During Model Run[Industry Category,Industrial Process\
		,Model Run Vintage]=
	BAU Potential Output from Industrial Equipment Installed During Model Run[Industry Category\
		,Industrial Process,Model Run Vintage
	]
	* MIN(
	    1,
	
	    ZIDZ(
	      BAU Last Year Output by ISIC Code with Fuels Based on Energy Content[Industry Category ISIC Code\
		],
	      SUM(BAU Potential Output from Industrial Equipment Installed During Model Run[\
		Industry Category,Industrial Process
	,Model Run Vintage!])
	      + BAU Potential Output from Preexisting Industrial Equipment[Industry Category\
		,Industrial Process]
	    )
	  )
	~	$
	~		|

BAU Output from New Industrial Equipment[Industry Category,Industrial Process]=
	MAX(
	  0,
	
	  BAU Last Year Output by ISIC Code with Fuels Based on Energy Content[Industry Category ISIC Code\
		]
	  * 
	  ZIDZ(Total BAU Fuel Use for Energy Purposes by Industrial Process in Electricity Equivalent\
		[Industry Category,Industrial Process],
	    SUM(Total BAU Fuel Use for Energy Purposes by Industrial Process in Electricity Equivalent\
		[Industry Category,Industrial Process!])
	  )
	  - SUM(
	      BAU Last Year Potential Output from Industrial Equipment Installed During Model Run\
		[Industry Category,Industrial Process
	,Model Run Vintage!]
	      - BAU Potential Output from Retiring Industrial Equipment Installed During Model Run\
		[Industry Category,Industrial Process
	,Model Run Vintage!] * One Year)
	  - BAU Potential Output from Preexisting Industrial Equipment[Industry Category,Industrial Process\
		]
	)
	~	$
	~		|

BAU Output from New Industrial Equipment by Fuel Type and Industrial Process[Industry Category\
		,Industrial Fuel,Industrial Process]=
	BAU Share of New Industrial Equipment Allocated by Fuel Type in Electricity Equivalent\
		[Industry Category,Industrial Fuel,Industrial Process]
	* BAU Output from New Industrial Equipment by Industrial Process[Industry Category,Industrial Process\
		]
	~	$
	~		|

BAU Output from New Industrial Equipment by Industrial Process[Industry Category,Industrial Process\
		]=
	BAU Output from New Industrial Equipment[Industry Category,Industrial Process]
	~	$
	~		|

BAU Output from Preexisting Industrial Equipment[Industry Category,Industrial Process\
		]=
	BAU Potential Output from Preexisting Industrial Equipment[Industry Category,Industrial Process\
		]
	* MIN(
	    1,
	
	    ZIDZ(
	      BAU Last Year Output by ISIC Code with Fuels Based on Energy Content[Industry Category ISIC Code\
		],
	      SUM(BAU Potential Output from Industrial Equipment Installed During Model Run[\
		Industry Category,Industrial Process,Model Run Vintage!])
	      + BAU Potential Output from Preexisting Industrial Equipment[Industry Category\
		,Industrial Process]
	    )
	  )
	~	$
	~		|

BAU Peak Electricity Load=
	VMAX(BAU Total Electricity Demand by Hour before Net Imports[Electricity Timeslice
	!,Hour!])/One Hour
	~	MW
	~		|

BAU Peak Electricity Load Growth Relative to Start Year=
	BAU Peak Electricity Load
	/ SYPEL Start Year Peak Electricity Load
	~	Dmnl
	~		|

BAU Perc Change in In Scope Emissions due to Electricity Exports=
	IF THEN ELSE(
	  BIEfEE Boolean Include Emissions from Exported Electricity > 0,
	
	  0,
	
	  -BAU Percentage of Generated Electricity that is Exported
	)
	~	Dmnl
	~		|

BAU Percent Change in Domestically Produced Energy by Producing ISIC Code Relative to Initial Time\
		[ISIC Code]=
	ZIDZ(
	  BAU Domestically Produced Energy by Producing ISIC Code[ISIC Code]
	  - BAU Initial Domestically Produced Energy by Producing ISIC Code[ISIC Code],
	
	  BAU Initial Domestically Produced Energy by Producing ISIC Code[ISIC Code]
	)
	~	Dmnl
	~		|

BAU Percent Change in Employment and EE Compensation by ISIC Code[ISIC Code]=
	Percent Change in BAU Energy Production and Imports vs Initial Year by ISIC Code[ISIC Code\
		]
	* FoPTaFbIC Fractions of Products That are Fuels by ISIC Code[ISIC Code]
	
	+ BAU Percent Change in Output by ISIC Code Using Endogenous Energy Revenues[ISIC Code\
		]
	  * (1 - FoPTaFbIC Fractions of Products That are Fuels by ISIC Code[ISIC Code])
	~	Dmnl
	~	Insofar as each ISIC code's revenues are from energy products, we use \
		changes in production (physical quanitty of energy produced) to estimate \
		change in employment and EE compensation.  Insofar as each ISIC code's \
		revenues are from non-energy products, we use changes in economic output, \
		since non-energy products are heterogenous and are presently only tracked \
		in financial terms, not as physical quantities of machines, furniture, etc.
	|

BAU Percent Change in Fuel Production from Calculated Fuel Demand[Industry Category] \
		:EXCEPT:       [energy industries within industry category
]=
	0 ~~|
BAU Percent Change in Fuel Production from Calculated Fuel Demand[coal mining 05]=
	ZIDZ(SUM(BAU Fuel Production Imports and Exports[coal mining industry fuel within all fuels\
		!,production]),
	  SUM(BFPIaE BAU Fuel Production Imports and Exports[coal mining industry fuel within all fuels\
		!,production]))
	 -1 ~~|
BAU Percent Change in Fuel Production from Calculated Fuel Demand[oil and gas extraction 06\
		]=
	ZIDZ(BAU Fuel Production Imports and Exports[natural gas,production]+BAU Fuel Production Imports and Exports\
		[crude oil,
production],
	  BFPIaE BAU Fuel Production Imports and Exports[natural gas,production]+BFPIaE BAU Fuel Production Imports and Exports
[crude oil,production])
	 -1 ~~|
BAU Percent Change in Fuel Production from Calculated Fuel Demand[refined petroleum and coke 19\
		]=
	ZIDZ(SUM(BAU Fuel Production Imports and Exports[secondary petroleum product within all fuels\
		!,production]),
	  SUM(BFPIaE BAU Fuel Production Imports and Exports[secondary petroleum product within all fuels\
		!,production]))
	 -1 ~~|
BAU Percent Change in Fuel Production from Calculated Fuel Demand[energy pipelines and gas processing 352T353\
		]=
	ZIDZ(BAU Fuel Production Imports and Exports[natural gas,production]+BAU Fuel Production Imports and Exports\
		[heat,production
]
	     +BAU Fuel Production Imports and Exports[natural gas,imports]
	     -BAU Fuel Production Imports and Exports[natural gas,exports],
	
	     BFPIaE BAU Fuel Production Imports and Exports[natural gas,production]
	    +BFPIaE BAU Fuel Production Imports and Exports[natural gas,imports]
	    -BAU Fuel Production Imports and Exports[natural gas,exports])
	 -1
	~	Dmnl
	~		|

BAU Percent Change in Output by ISIC Code Using Endogenous Energy Revenues[ISIC Code]\
		=
	ZIDZ(
	  BAU Output by ISIC Code by Year[ISIC Code]
	  - BObIC BAU Output by ISIC Code[ISIC Code],
	
	  BObIC BAU Output by ISIC Code[ISIC Code]
	)
	~	Dmnl
	~		|

BAU Percentage Change in Fleet Avg Fuel Economy[Vehicle Type,Cargo Type,Vehicle Technology\
		]=
	BAU New Vehicles Contribution to Percentage Change to Fleet Avg Fuel Economy[Vehicle Type\
		,Cargo Type,Vehicle Technology]
	+ BAU Retired Vehicles Contribution to Percentage Change to Fleet Avg Fuel Economy[Vehicle Type\
		,Cargo Type,Vehicle Technology]
	~	Dmnl
	~		|

BAU Percentage Curtailment by Power Plant Type[Electricity Source]=
	ZIDZ(
	  BAU Curtailed Electricity Output[Electricity Source],
	
	  BAU Annual Maximum Potential Electricity Output[Electricity Source]
	)
	~	Dmnl
	~		~	:SUPPLEMENTARY 
	|

BAU Percentage Difference in New Vehicle vs Fleet Avg Fuel Economy[Vehicle Type,Cargo Type\
		,Vehicle Technology]=
	ZIDZ(
	  BAU New Vehicle Fuel Economy[Vehicle Type,Cargo Type,Vehicle Technology],
	
	  BAU Last Year Fleet Avg Fuel Economy[Vehicle Type,Cargo Type,Vehicle Technology]
	)
	- 1
	~	Dmnl
	~		|

BAU Percentage Difference in Retired Vehicle vs Fleet Avg Fuel Economy[Vehicle Type,Cargo Type\
		,Vehicle Technology]=
	ZIDZ(
	  BAU Retiring Vehicle Fuel Economy[Vehicle Type,Cargo Type,Vehicle Technology],
	
	  BAU Last Year Fleet Avg Fuel Economy[Vehicle Type,Cargo Type,Vehicle Technology]
	)
	- 1
	~	Dmnl
	~		|

BAU Percentage Electricity Generation by Source[Electricity Source]=
	BAU Electricity Generation by Type Including Distributed Generation[Electricity Source\
		]
	/ SUM(BAU Electricity Generation by Type Including Distributed Generation[Electricity Source\
		!])
	~	Dmnl
	~		~	:SUPPLEMENTARY 
	|

BAU Percentage Fuel Use by Industrial Process with Fallback Data[Industry Category,Industrial Fuel\
		,Industrial Process]=
	IF THEN ELSE(
	  SUM(BPFUbIP BAU Percentage Fuel Use by Industrial Process[Industry Category,Industrial Process\
		!,Industrial Fuel])
	  = 0,
	
	  BPFUbIP Fallback Fuel Use Shares by Process for Missing Data[Industrial Fuel,Industrial Process\
		],
	
	  BPFUbIP BAU Percentage Fuel Use by Industrial Process[Industry Category,Industrial Process\
		,Industrial Fuel]
	)
	~	Dmnl
	~	In case no data are provided for how to divide up a given fuel type \
		amongst industrial processes in BPFUbIP and in case there is a non-zero \
		quantity of that fuel use specified in BIFU, we rely on the fallback \
		apportionment of that fuel by industrial process, so we avoid losing \
		(zeroing out) fuel use that is specified in BIFU.
	|

BAU Percentage of Generated Electricity that is Exported=
	ZIDZ(
	  EIaE BAU Exported Electricity,
	
	  SUM(BAU Electricity Generation by Type[Electricity Source!])
	)
	~	Dmnl
	~		|

BAU Percentage of Vehicle Stock New This Year[Vehicle Type,Cargo Type,Vehicle Technology\
		]=
	ZIDZ(
	  BAU New Vehicles[Vehicle Type,Cargo Type,Vehicle Technology] * One Year,
	
	  BAU Vehicles[Vehicle Type,Cargo Type,Vehicle Technology]
	)
	~	Dmnl
	~		|

BAU Percentage of Vehicle Stock Retired This Year[Vehicle Type,Cargo Type,Vehicle Technology\
		]=
	ZIDZ(
	  BAU Retiring Vehicles[Vehicle Type,Cargo Type,Vehicle Technology] * One Year,
	
	  BAU Vehicles[Vehicle Type,Cargo Type,Vehicle Technology]
	)
	~	Dmnl
	~		|

BAU Plant Types with Positive Dispatch Cost After Subsidies[Electricity Source]=
	IF THEN ELSE( 
	  BAU Plant Types with Zero or Negative Dispatch Cost After Subsidies[Electricity Source\
		]=1,
	  0,
	  1
	 )
	~	Dmnl
	~		|

BAU Plant Types with Zero or Negative Dispatch Cost After Subsidies[Electricity Source\
		]=
	IF THEN ELSE(
	  BAU Dispatch or Opportunity Cost per Unit Electricity Output[Electricity Source] <=\
		 0,
	
	  1,
	
	  0
	)
	~	Dmnl
	~		|

BAU Pollutant Emissions from Imported Electricity[Pollutant,Electricity Source]=
	EIaE BAU Imported Electricity by Electricity Source[Electricity Source]
	* BAU Electricity Fuel Pollutant Emissions Intensity per MWh[Electricity Source,Pollutant\
		]
	~	g pollutant
	~		|

BAU Positive Cost Electricity Dispatched to Meet CES[Electricity Timeslice,Hour,Electricity Source\
		]=
	MIN(
	
	BAU Expected CES Qualifying Output After Guaranteed and RPS Dispatch[Electricity Source\
		,Electricity Timeslice,Hour],
	
	IF THEN ELSE(
	 
	       BAU Remaining CES Required Generation after Guaranteed Dispatch and RPS Dispatch
	= 0,
	 
	       0,
	
	 
	       IF THEN ELSE(
	          SUM(
	            BAU Expected CES Qualifying Output After Guaranteed and RPS Dispatch[Electricity Source\
		!,Electricity Timeslice
	,Hour] 
	          )
	          > BAU Unmet Electricity Demand After RPS and Zero and Negative Cost CES Allocation Steps\
		[Electricity Timeslice,Hour],
	 
	          MIN(
	            BAU Unmet Electricity Demand After RPS and Zero and Negative Cost CES Allocation Steps\
		[Electricity Timeslice,Hour]
	            * ZIDZ(
	                BAU Expected CES Qualifying Output After Guaranteed and RPS Dispatch\
		[Electricity Source,Electricity Timeslice
	,Hour],
	                SUM(BAU Expected CES Qualifying Output After Guaranteed and RPS Dispatch\
		[Electricity Source!,Electricity Timeslice
	,Hour])
	              ),
	
	            ZIDZ(
	              BAU Remaining CES Required Generation after Guaranteed Dispatch and RPS Dispatch\
		,
	   
	              SUM(
	                BAU Expected CES Qualifying Output After Guaranteed and RPS Dispatch\
		[Electricity Source!,Electricity Timeslice
	!,Hour!]
	                *BAU Plant Types with Positive Dispatch Cost After Subsidies[Electricity Source\
		!]
	              )
	            )
	 
	            * BAU Expected CES Qualifying Output After Guaranteed and RPS Dispatch[Electricity Source\
		,Electricity Timeslice
	,Hour]
	            *BAU Plant Types with Positive Dispatch Cost After Subsidies[Electricity Source\
		]
	          ),
	 
	          BAU Expected CES Qualifying Output After Guaranteed and RPS Dispatch[Electricity Source\
		,Electricity Timeslice,Hour
	]
	          * BAU Plant Types with Positive Dispatch Cost After Subsidies[Electricity Source\
		]
	          * ZIDZ(
	              BAU Remaining CES Required Generation after Guaranteed Dispatch and RPS Dispatch\
		,
	              SUM(
	                BAU Expected CES Qualifying Output After Guaranteed and RPS Dispatch\
		[Electricity Source!,Electricity Timeslice
	!,Hour!]
	                *SHELF Days per Electricity Timeslice[Electricity Timeslice!]
	              )
	            )
	     )
	)
	)
	~	MW*hour
	~		|

BAU Positive Cost Electricity Dispatched to Meet RPS[Electricity Timeslice,Hour,Electricity Source\
		]=
	MIN(
	
	BAU Expected RPS Qualifying Capacity After Zero and Negative Cost RPS Dispatch[Electricity Timeslice\
		,Hour,Electricity Source]*One Hour,
	
	IF THEN ELSE(
	 
	       BAU Remaining RPS Required Generation after Guaranteed Dispatch and Zero and Negative Cost Electricity Dispatched to Meet RPS
	= 0,
	 
	       0,
	
	 
	       IF THEN ELSE(
	          SUM(
	            BAU Expected RPS Qualifying Capacity After Zero and Negative Cost RPS Dispatch\
		[Electricity Timeslice,Hour,Electricity Source!] 
	            *One Hour
	          )
	          > BAU Unmet Electricity Demand After Zero and Negative Cost RPS Dispatch[Electricity Timeslice\
		,Hour],
	 
	          MIN(
	            BAU Unmet Electricity Demand After Zero and Negative Cost RPS Dispatch[Electricity Timeslice\
		,Hour]
	            * ZIDZ(
	                BAU Expected RPS Qualifying Capacity After Zero and Negative Cost RPS Dispatch\
		[Electricity Timeslice,Hour,Electricity Source],
	                SUM(BAU Expected RPS Qualifying Capacity After Zero and Negative Cost RPS Dispatch\
		[Electricity Timeslice,Hour,Electricity Source!])
	              ),
	
	            ZIDZ(
	              BAU Remaining RPS Required Generation after Guaranteed Dispatch and Zero and Negative Cost Electricity Dispatched to Meet RPS\
		,
	   
	              SUM(
	                BAU Expected RPS Qualifying Capacity After Zero and Negative Cost RPS Dispatch\
		[Electricity Timeslice!,Hour!,Electricity Source!]
	                *BAU Plant Types with Positive Dispatch Cost After Subsidies[Electricity Source\
		!]
	              )
	              * One Hour 
	            )
	 
	            * BAU Expected RPS Qualifying Capacity After Zero and Negative Cost RPS Dispatch\
		[Electricity Timeslice,Hour,Electricity Source]
	            *BAU Plant Types with Positive Dispatch Cost After Subsidies[Electricity Source\
		]
	            * One Hour
	          ),
	 
	          BAU Expected RPS Qualifying Capacity After Zero and Negative Cost RPS Dispatch\
		[Electricity Timeslice,Hour,Electricity Source]
	          * BAU Plant Types with Positive Dispatch Cost After Subsidies[Electricity Source\
		]
	          * ZIDZ(
	              BAU Remaining RPS Required Generation after Guaranteed Dispatch and Zero and Negative Cost Electricity Dispatched to Meet RPS\
		,
	              SUM(
	                BAU Expected RPS Qualifying Capacity After Zero and Negative Cost RPS Dispatch\
		[Electricity Timeslice!,Hour!,Electricity Source!]
	                *SHELF Days per Electricity Timeslice[Electricity Timeslice!]
	              )
	            )
	     )
	)
	)
	~	MW*hr
	~		|

BAU Potential Capacity by Hour[Electricity Source,Electricity Timeslice,Hour]=
	BAU Electricity Generation Capacity[Electricity Source]
	*BAU Weighted Average Expected Capacity Factors by Hour without RAF[Electricity Source\
		,Electricity Timeslice,Hour]
	~	MW
	~		|

BAU Potential Output from Industrial Equipment Installed During Model Run[Industry Category\
		,Industrial Process,Model Run Vintage]=
	BAU Last Year Potential Output from Industrial Equipment Installed During Model Run[\
		Industry Category,Industrial Process
	,Model Run Vintage]
	+
	IF THEN ELSE(
	  This Year Model Run Vintage Flag[Model Run Vintage] = 1,
	  BAU Output from New Industrial Equipment[Industry Category,Industrial Process],
	  0
	)
	  - BAU Potential Output from Retiring Industrial Equipment Installed During Model Run\
		[Industry Category,Industrial Process
	,Model Run Vintage] * One Year
	~	$
	~		|

BAU Potential Output from Preexisting Industrial Equipment[Industry Category,Industrial Process\
		]=
	BAU Last Year Potential Output from Preexisting Industrial Equipment[Industry Category\
		,Industrial Process]
	- BAU Potential Output from Retiring Preexisting Industrial Equipment[Industry Category\
		,Industrial Process]
	~	$
	~		|

BAU Potential Output from Retiring Industrial Equipment Installed During Model Run[Industry Category\
		,Industrial Process,
Model Run Vintage]=
	BAU Last Year Potential Output from Industrial Equipment Installed During Model Run[\
		Industry Category,Industrial Process
	,Model Run Vintage]
	* 
	Retiring Share of Industrial Equipment Desired Due to Equipment Age[Industrial Process\
		,Model Run Vintage] / One Year
	~	$/Year
	~		|

BAU Potential Output from Retiring Preexisting Industrial Equipment[Industry Category\
		,Industrial Process]=
	BAU Initial Output by Industry Category and Process[Industry Category,Industrial Process\
		]
	* 
	BAU This Year Fraction of Initial Industrial Equipment Retired[Industry Category,Industrial Process\
		]
	~	$
	~		|

BAU Potential Output from Surviving Capacity by Hour[Electricity Timeslice,Hour]=
	SUM(
	  BAU Surviving Electricity Generation Capacity before Economic Retirements[Electricity Source\
		!]
	  * BAU Last Year Hourly Bid Electricity Capacity Factors by Plant Type[Electricity Timeslice\
		,Hour,Electricity Source!]
	)
	* One Hour
	~	MW*hr
	~		|

BAU Power Plant Least Cost Dispatch Parameters as Vector[Electricity Source,ptype]=
	3 ~~|
BAU Power Plant Least Cost Dispatch Parameters as Vector[Electricity Source,ppriority\
		]=
	BAU Dispatch or Opportunity Cost per Unit Electricity Output[Electricity Source
	] ~~|
BAU Power Plant Least Cost Dispatch Parameters as Vector[Electricity Source,pwidth]=
	MAX(
	  ABS(MAX(NSDoDC Normalized Standard Deviation of Dispatch Costs[Electricity Source]\
		,0.01)
	  *(BAU Dispatch or Opportunity Cost per Unit Electricity Output[Electricity Source]
	  + BAU Variable Subsidies per Unit Electricity Output[Electricity Source])
	  ),
	
	  0.01
	) ~~|
BAU Power Plant Least Cost Dispatch Parameters as Vector[Electricity Source,pextra]=
	0
	~	$/(MW*hr)
	~	We require pwidth to be a minimum of 0.01 so that the dispatch allocations \
		do not result in an error due to 0 dispatch costs for some power plant \
		types
	|

BAU Predicted Capacity Payment by Plant Type for Existing Plants[Electricity Source,Optimization Pass\
		]=
	BAU Capacity Market Price for Seasonal Dispatchable Reliability by Optimization Pass\
		[Optimization Pass]
	  * BAU Last Year Hourly Bid Electricity Capacity Factors for Reliability in Binding Hour by Plant Type\
		[Electricity Source
	]
	  * Days per Year
	  * One Day
	~	$/MW
	~		|

BAU Predicted Change in Energy Market Revenue for CCUS Retrofits[hard coal w CCS es]=
	BAU Average Four Year Prior Total Predicted Net Energy Market Revenue per MW[hard coal w CCS es\
		]
	
	-BAU Average Four Year Prior Total Predicted Net Energy Market Revenue per MW[hard coal es\
		] ~~|
BAU Predicted Change in Energy Market Revenue for CCUS Retrofits[natural gas combined cycle w CCS es\
		]=
	BAU Average Four Year Prior Total Predicted Net Energy Market Revenue per MW[natural gas combined cycle w CCS es
	]
	
	-BAU Average Four Year Prior Total Predicted Net Energy Market Revenue per MW[natural gas combined cycle es
	] ~~|
BAU Predicted Change in Energy Market Revenue for CCUS Retrofits[biomass w CCS es]=
	BAU Average Four Year Prior Total Predicted Net Energy Market Revenue per MW[biomass w CCS es\
		]
	
	-BAU Average Four Year Prior Total Predicted Net Energy Market Revenue per MW[biomass es\
		] ~~|
BAU Predicted Change in Energy Market Revenue for CCUS Retrofits[lignite w CCS es]=
	BAU Average Four Year Prior Total Predicted Net Energy Market Revenue per MW[lignite w CCS es\
		]
	
	-BAU Average Four Year Prior Total Predicted Net Energy Market Revenue per MW[lignite es\
		]
	~	$/MW
	~		|

BAU Present Value of Clean Industrial Heat Subsidy[Industry Category,Industrial Fuel,\
		industrial heating process]=
	SUM(
	  ZIDZ(
	    BAU Clean Industrial Heat Subsidy Rate by Fuel Type in Future Years[Industrial Fuel\
		,industrial heating process,Future Year!],
	    (1 + BCoISC Weighted Average Cost of Capital by Industry[Industry Category])
	    ^ ((Numerical Future Year Definitions[Future Year!] - Time) / One Year)
	  )    
	)
	~	$/BTU
	~		|

BAU Present Value of Industrial Equipment Annual Financing Repayments[Industry Category\
		,Industrial Fuel,Industrial Process]=
	SUM(
	  ZIDZ(
	    BAU Industrial Equipment Annual Financing Repayment per Unit Energy in Future Years\
		[Industry Category,Industrial Fuel,Industrial Process
	,Future Year!],
	    (1 + BCoISC Weighted Average Cost of Capital by Industry[Industry Category])
	    ^ ((Numerical Future Year Definitions[Future Year!] - Time) / One Year)
	  )    
	)
	~	$/BTU
	~		|

BAU Present Value of Industrial Equipment Costs per Unit Energy[Industry Category,Industrial Fuel\
		,Industrial Process]=
	BAU Present Value of Industrial Equipment Annual Financing Repayments[Industry Category\
		,Industrial Fuel,Industrial Process]
	+ BAU Present Value of Industrial Equipment Costs per Unit Energy including Clean Heat Subsidy\
		[Industry Category,Industrial Fuel,Industrial Process]
	~	$/BTU
	~		|

BAU Present Value of Industrial Equipment Costs per Unit Energy including Clean Heat Subsidy\
		[Industry Category,Industrial Fuel
,Industrial Process] :EXCEPT:                   [Industry Category,Industrial Fuel,industrial heating process\
		]=
	(BAU Present Value of Pretax Industrial Fuel Price in Future Years[Industry Category\
		,Industrial Fuel,Industrial Process]
	 + BAU Present Value of Industrial Fuel Tax or Subsidy Rate by Fuel in Future Years[\
		Industry Category,Industrial Fuel,Industrial Process])
	
	* (1 - SoFCTiBoSFbI Share of Fuel Consumption That is Byproduct or Secondary Fuels by Industry\
		[Industry Category,Industrial Fuel
	])
	
	+ BAU Present Value of Industrial Fuel Carbon Tax per Unit Energy in Future Years[Industry Category\
		,Industrial Fuel,Industrial Process] ~~|
BAU Present Value of Industrial Equipment Costs per Unit Energy including Clean Heat Subsidy\
		[Industry Category,Industrial Fuel
,industrial heating process]=
	(BAU Present Value of Pretax Industrial Fuel Price in Future Years[Industry Category\
		,Industrial Fuel,industrial heating process]
	 + BAU Present Value of Industrial Fuel Tax or Subsidy Rate by Fuel in Future Years[\
		Industry Category,Industrial Fuel,industrial heating process])
	
	* (1 - SoFCTiBoSFbI Share of Fuel Consumption That is Byproduct or Secondary Fuels by Industry\
		[Industry Category,Industrial Fuel])
	
	+ BAU Present Value of Industrial Fuel Carbon Tax per Unit Energy in Future Years[Industry Category\
		,Industrial Fuel,industrial heating process]
	
	- BAU Present Value of Clean Industrial Heat Subsidy[Industry Category,Industrial Fuel\
		,industrial heating process]
	~	$/BTU
	~		|

BAU Present Value of Industrial Fuel Carbon Tax per Unit Energy in Future Years[Industry Category\
		,Industrial Fuel,Industrial Process]=
	SUM(
	  ZIDZ(
	    BAU Industrial Fuel Carbon Tax Amount per Unit Energy in Future Years[Industry Category\
		,Industrial Fuel,Future Year
	!],
	    (1 + BCoISC Weighted Average Cost of Capital by Industry[Industry Category])
	    ^ ((Numerical Future Year Definitions[Future Year!] - Time) / One Year)
	
	  * IF THEN ELSE(Numerical Future Year Definitions[Future Year!] - Time >= IESD Average Age at Which Equipment Retires\
		[Industrial Process],
	      0,
	      IF THEN ELSE(Numerical Future Year Definitions[Future Year!] < Time,
	        0,
	        1
	      )
	    )
	  )    
	)
	~	$/BTU
	~		|

BAU Present Value of Industrial Fuel Tax or Subsidy Rate by Fuel in Future Years[Industry Category\
		,Industrial Fuel,Industrial Process]=
	SUM(
	  ZIDZ(
	    BFPaT BAU Fuel Tax by Sector[industrial fuel within all fuels,industry sector,Future Year\
		!]
	,
	    (1 + BCoISC Weighted Average Cost of Capital by Industry[Industry Category])
	    ^ ((Numerical Future Year Definitions[Future Year!] - Time) / One Year)
	
	  * IF THEN ELSE(Numerical Future Year Definitions[Future Year!] - Time >= IESD Average Age at Which Equipment Retires\
		[Industrial Process],
	      0,
	      IF THEN ELSE(Numerical Future Year Definitions[Future Year!] < Time,
	        0,
	        1
	      )
	    )
	  )    
	)
	~	$/BTU
	~		|

BAU Present Value of Pretax Industrial Fuel Price in Future Years[Industry Category,Industrial Fuel\
		,Industrial Process] :EXCEPT: [Industry Category,hydrogen if,Industrial Process],[Industry Category\
		,green hydrogen if,Industrial Process],[Industry Category,low carbon hydrogen if,Industrial Process\
		]=
	SUM(
	  ZIDZ(
	    BAU Pretax Fuel Price by Sector in Future Years[industrial fuel within all fuels\
		,industry sector,Future Year!],
	    (1 + BCoISC Weighted Average Cost of Capital by Industry[Industry Category])
	    ^ ((Numerical Future Year Definitions[Future Year!] - Time) / One Year)
	
	  * IF THEN ELSE(Numerical Future Year Definitions[Future Year!] - Time >= IESD Average Age at Which Equipment Retires\
		[
	Industrial Process],
	      0,
	      IF THEN ELSE(Numerical Future Year Definitions[Future Year!] < Time,
	        0,
	        1
	      )
	    )
	  )    
	) ~~|
BAU Present Value of Pretax Industrial Fuel Price in Future Years[Industry Category,hydrogen if\
		,Industrial Process]=
	SUM(
	  ZIDZ(
	    BAU Smoothed Other Hydrogen Cost,
	    (1 + BCoISC Weighted Average Cost of Capital by Industry[Industry Category])
	    ^ ((Numerical Future Year Definitions[Future Year!] - Time) / One Year)
	
	  * IF THEN ELSE(Numerical Future Year Definitions[Future Year!] - Time >= IESD Average Age at Which Equipment Retires\
		[
	Industrial Process],
	      0,
	      IF THEN ELSE(Numerical Future Year Definitions[Future Year!] < Time,
	        0,
	        1
	      )
	    )
	  )    
	) ~~|
BAU Present Value of Pretax Industrial Fuel Price in Future Years[Industry Category,green hydrogen if\
		,Industrial Process]=
	SUM(
	  ZIDZ(
	    BAU Smoothed Green Hydrogen Cost,
	    (1 + BCoISC Weighted Average Cost of Capital by Industry[Industry Category])
	    ^ ((Numerical Future Year Definitions[Future Year!] - Time) / One Year)
	
	  * IF THEN ELSE(Numerical Future Year Definitions[Future Year!] - Time >= IESD Average Age at Which Equipment Retires\
		[
	Industrial Process],
	      0,
	      IF THEN ELSE(Numerical Future Year Definitions[Future Year!] < Time,
	        0,
	        1
	      )
	    )
	  )    
	) ~~|
BAU Present Value of Pretax Industrial Fuel Price in Future Years[Industry Category,low carbon hydrogen if\
		,Industrial Process]=
	SUM(
	  ZIDZ(
	    BAU Smoothed Low Carbon Hydrogen Cost,
	    (1 + BCoISC Weighted Average Cost of Capital by Industry[Industry Category])
	    ^ ((Numerical Future Year Definitions[Future Year!] - Time) / One Year)
	
	  * IF THEN ELSE(Numerical Future Year Definitions[Future Year!] - Time >= IESD Average Age at Which Equipment Retires\
		[
	Industrial Process],
	      0,
	      IF THEN ELSE(Numerical Future Year Definitions[Future Year!] < Time,
	        0,
	        1
	      )
	    )
	  )    
	)
	~	$/BTU
	~		|

BAU Pretax Fuel Cost per Unit Energy by Sector with Sensitivity Analysis Adjustment[All Fuels\
		,Sectors] :EXCEPT:  [electricity
,Sectors]=
	BAU Pretax Fuel Price by Sector[All Fuels,Sectors]
	* Fuel Price Multiplier for Sensitivity Analysis Runs[All Fuels] ~~|
BAU Pretax Fuel Cost per Unit Energy by Sector with Sensitivity Analysis Adjustment[electricity\
		,Sectors]=
	This Year Pretax Electricity Price by Sector[Sectors]
	* Fuel Price Multiplier for Sensitivity Analysis Runs[electricity]
	~	$/BTU
	~		|

BAU Pretax Fuel Price by Sector[All Fuels, Sectors]=
	SUM(BFPAT BAU Pretax Fuel Price by Sector[All Fuels,Sectors,Future Year!]*Future Year to Year Mapping\
		[Future Year!])
	~	$/BTU
	~		|

BAU Pretax Fuel Price by Sector in Future Years[All Fuels,Sectors,Future Year] :EXCEPT:\
		       
[electricity,Sectors,Future Year]=
	BFPAT BAU Pretax Fuel Price by Sector[All Fuels,Sectors,Future Year] ~~|
BAU Pretax Fuel Price by Sector in Future Years[electricity,Sectors,Future Year]=
	BAU Average Five Year Prior Pretax Electricity Price by Sector[Sectors]
	~	$/BTU
	~		|

BAU Pretax Fuel Price by Sector Including Endogenous Electricity Prices[All Fuels,Sectors\
		] :EXCEPT:  [electricity,Sectors
]=
	BAU Pretax Fuel Price by Sector[All Fuels,Sectors] ~~|
BAU Pretax Fuel Price by Sector Including Endogenous Electricity Prices[electricity,Sectors\
		]=
	BAU This Year Pretax Electricity Price by Sector[Sectors]
	~	$/BTU
	~		|

BAU Process Emissions after CCS[Industry Category,Pollutant]=
	BAU Process Emissions before CCS[Industry Category,Pollutant]
	- BAU This Year Process Pollutants Sequestered by Industry Sector[Industry Category,\
		Pollutant]
	~	g pollutant
	~		|

BAU Process Emissions after GDP and Fuel Production Adjustment[Industry Category,Pollutant\
		] :EXCEPT:      [energy industries within industry category
,Pollutant]=
	BPE BAU Process Emissions[Industry Category,Pollutant]
	* (1 + Perc Change in Sectoral Energy Use due to Exogenous GDP Adjustment[industry sector\
		]) ~~|
BAU Process Emissions after GDP and Fuel Production Adjustment[energy industries within industry category\
		,Pollutant]=
	BPE BAU Process Emissions[energy industries within industry category
	,Pollutant]
	* (1 + Last Year BAU Percent Change in Fuel Production from Calculated Fuel Demand[energy industries within industry category\
		])
	~	g pollutant
	~		|

BAU Process Emissions before CCS[Industry Category,Pollutant]=
	BAU Process Emissions after GDP and Fuel Production Adjustment[Industry Category,Pollutant\
		]
	~	g pollutant
	~	This variable does no math operations.  It changes the name of "BAU \
		Process Emissions after GDP Adjustment" to "BAU Process Emissions before \
		CCS" to as to be parallel with the variable named "Process Emissions \
		before CCS".
	|

BAU Process Emissions in CO2e[Industry Category,Pollutant]=
	BAU Process Emissions after GDP and Fuel Production Adjustment[Industry Category,Pollutant\
		]
	* GbPbT GWP by Pollutant by Timeframe[Pollutant,one hundred years]
	~	g CO2e
	~	We use one-hundred year GWP values here (rather than the user-selected \
		20-year or 100-year GWP values) because we must use the same timeframe as \
		our PERAC source document when converting from pollutant to CO2e.
	|

BAU Process Emissions in CO2e after CCS[Industry Category,Pollutant]=
	BAU Process Emissions after CCS[Industry Category,Pollutant]
	* GWP by Pollutant[Pollutant]
	~	g CO2e
	~		|

BAU Process Emissions in CO2e in Metric Tons[Industry Category,Pollutant]=
	BAU Process Emissions in CO2e after CCS[Industry Category,Pollutant]
	/ Grams per Metric Ton CO2e
	~	metric tons CO2e
	~		|

BAU Profitable Capacity as Share of Existing Capacity for Cost Effective CCUS Retrofits\
		[CCUS Electricity Source, Optimization Pass,RPS]=
	IF THEN ELSE(
	  BAU Incremental Revenue for Cost Effective CCUS Retrofits[CCUS Electricity Source,\
		Optimization Pass,RPS
	] < 1,
	
	  0,
	
	  LOOKUP INVERT(
	    CSCCCMvSoECBtY Capacity Cost Multiplier vs Share of Existing Capacity Built This Year\
		[summer],
	    BAU Incremental Revenue for Cost Effective CCUS Retrofits[CCUS Electricity Source\
		,Optimization Pass,RPS
	]
	  )
	) ~~|
BAU Profitable Capacity as Share of Existing Capacity for Cost Effective CCUS Retrofits\
		[CCUS Electricity Source,Optimization Pass,CES]=
	IF THEN ELSE(
	  BAU Incremental Revenue for Cost Effective CCUS Retrofits[CCUS Electricity Source,\
		Optimization Pass,CES
	] < 1,
	
	  0,
	
	  LOOKUP INVERT(
	    CSCCCMvSoECBtY Capacity Cost Multiplier vs Share of Existing Capacity Built This Year\
		[summer],
	    BAU Incremental Revenue for Cost Effective CCUS Retrofits[CCUS Electricity Source\
		,Optimization Pass,CES
	]
	  )
	)
	~	Dmnl
	~		|

BAU Profitable Capacity as Share of Existing Capacity for Cost Effective CCUS Retrofits without CES\
		[CCUS Electricity Source]=
	IF THEN ELSE(
	  BAU Incremental Revenue for Cost Effective CCUS Retrofits without CES[CCUS Electricity Source
	] < 1,
	
	  0,
	
	  LOOKUP INVERT(
	    CSCCCMvSoECBtY Capacity Cost Multiplier vs Share of Existing Capacity Built This Year\
		[summer],
	    BAU Incremental Revenue for Cost Effective CCUS Retrofits without CES[CCUS Electricity Source\
		]
	  )
	)
	~	Dmnl
	~		|

BAU Profitable Capacity as Share of Existing Capacity for Cost Effectiveness Additions\
		[Electricity Source, Optimization Pass,RPS]=
	IF THEN ELSE(
	  BAU Incremental Revenue for Cost Effectiveness Additions[Electricity Source,Optimization Pass\
		,RPS] < 1,
	
	  0,
	
	  LOOKUP INVERT(
	    CSCCCMvSoECBtY Capacity Cost Multiplier vs Share of Existing Capacity Built This Year\
		[summer],
	    BAU Incremental Revenue for Cost Effectiveness Additions[Electricity Source,Optimization Pass\
		,RPS]
	  )
	) ~~|
BAU Profitable Capacity as Share of Existing Capacity for Cost Effectiveness Additions\
		[Electricity Source,Optimization Pass,CES]=
	IF THEN ELSE(
	  BAU Incremental Revenue for Cost Effectiveness Additions[Electricity Source,Optimization Pass\
		,CES] < 1,
	
	  0,
	
	  LOOKUP INVERT(
	    CSCCCMvSoECBtY Capacity Cost Multiplier vs Share of Existing Capacity Built This Year\
		[summer],
	    BAU Incremental Revenue for Cost Effectiveness Additions[Electricity Source,Optimization Pass\
		,CES]
	  )
	)
	~	Dmnl
	~		|

BAU Profitable Capacity as Share of Existing Capacity for Cost Effectiveness Additions for Hybrid Power Plants\
		[Hybrid Electricity Source,Optimization Pass,RPS]=
	IF THEN ELSE(
	  BAU Incremental Revenue for Cost Effectiveness Additions for Hybrid Power Plants[Hybrid Electricity Source
	,Optimization Pass,RPS] < 1,
	
	  0,
	
	  LOOKUP INVERT(
	    CSCCCMvSoECBtY Capacity Cost Multiplier vs Share of Existing Capacity Built This Year\
		[summer],
	    BAU Incremental Revenue for Cost Effectiveness Additions for Hybrid Power Plants\
		[Hybrid Electricity Source
	,Optimization Pass,RPS]
	  )
	) ~~|
BAU Profitable Capacity as Share of Existing Capacity for Cost Effectiveness Additions for Hybrid Power Plants\
		[Hybrid Electricity Source,Optimization Pass,CES]=
	IF THEN ELSE(
	  BAU Incremental Revenue for Cost Effectiveness Additions for Hybrid Power Plants[Hybrid Electricity Source
	,Optimization Pass,CES] < 1,
	
	  0,
	
	  LOOKUP INVERT(
	    CSCCCMvSoECBtY Capacity Cost Multiplier vs Share of Existing Capacity Built This Year\
		[summer],
	    BAU Incremental Revenue for Cost Effectiveness Additions for Hybrid Power Plants\
		[Hybrid Electricity Source
	,Optimization Pass,CES]
	  )
	)
	~	Dmnl
	~		|

BAU Profitable Capacity as Share of Existing Capacity for Cost Effectiveness Additions for Hybrid Power Plants without CES\
		[Hybrid Electricity Source]=
	IF THEN ELSE(
	  BAU Incremental Revenue for Cost Effectiveness Additions for Hybrid Power Plants without CES
	[Hybrid Electricity Source] < 1,
	
	  0,
	
	  LOOKUP INVERT(
	    CSCCCMvSoECBtY Capacity Cost Multiplier vs Share of Existing Capacity Built This Year\
		[summer],
	    BAU Incremental Revenue for Cost Effectiveness Additions for Hybrid Power Plants without CES
	[Hybrid Electricity Source]  )
	)
	~	Dmnl
	~		|

BAU Profitable Capacity as Share of Existing Capacity for Cost Effectiveness Additions without CES\
		[Electricity Source]=
	IF THEN ELSE(
	  BAU Incremental Revenue for Cost Effectiveness Additions without CES[Electricity Source\
		] < 1
	,
	
	  0,
	
	  LOOKUP INVERT(
	    CSCCCMvSoECBtY Capacity Cost Multiplier vs Share of Existing Capacity Built This Year\
		[summer],
	    BAU Incremental Revenue for Cost Effectiveness Additions without CES[Electricity Source\
		])
	)
	~	Dmnl
	~		|

BAU Profitable Capacity for CCUS Retrofits[CCUS Electricity Source, Optimization Pass\
		,RPS]=
	IF THEN ELSE(
	  BAU Profitable Capacity as Share of Existing Capacity for Cost Effective CCUS Retrofits\
		[CCUS Electricity Source,Optimization Pass,RPS
	] = :NA:,
	
	  0,
	
	  BAU Profitable Capacity as Share of Existing Capacity for Cost Effective CCUS Retrofits\
		[CCUS Electricity Source,Optimization Pass,RPS
	]
	  * MAX(
	      BAU Minimum Buildable Capacity for Plants,
	      BAU Last Year Electricity Generation Capacity[CCUS Electricity Source]
	    )
	) ~~|
BAU Profitable Capacity for CCUS Retrofits[CCUS Electricity Source,Optimization Pass,\
		CES]=
	IF THEN ELSE(
	  BAU Profitable Capacity as Share of Existing Capacity for Cost Effective CCUS Retrofits\
		[CCUS Electricity Source,Optimization Pass,CES
	] = :NA:,
	
	  0,
	
	  BAU Profitable Capacity as Share of Existing Capacity for Cost Effective CCUS Retrofits\
		[CCUS Electricity Source,Optimization Pass,CES
	]
	  * MAX(
	      BAU Minimum Buildable Capacity for Plants,
	      BAU Last Year Electricity Generation Capacity[CCUS Electricity Source]
	    )
	)
	~	MW
	~	If we do not test for :NA: (no number), then an out-of-bounds lookup in \
		the prior variable can produce a large random number here, which can throw \
		off the model. It may be better to output zero for an out-of-bounds lookup.
	|

BAU Profitable Capacity for CCUS Retrofits without CES[CCUS Electricity Source]=
	IF THEN ELSE(
	  BAU Profitable Capacity as Share of Existing Capacity for Cost Effective CCUS Retrofits without CES\
		[CCUS Electricity Source
	] = :NA:,
	
	  0,
	
	  BAU Profitable Capacity as Share of Existing Capacity for Cost Effective CCUS Retrofits without CES\
		[CCUS Electricity Source
	]
	  * MAX(
	      BAU Minimum Buildable Capacity for Plants,
	      BAU Last Year Electricity Generation Capacity[CCUS Electricity Source]
	    )
	)
	~	MW
