Process Emissions after CCS[Industry Category,Pollutant]=
	Process Emissions before CCS[Industry Category,Pollutant]
	- This Year Process Pollutants Sequestered by Industry Sector[Industry Category,Pollutant\
		]
	~	g pollutant
	~		|

Process Emissions before CCS[Industry Category,Pollutant]=
	MAX((BAU Process Emissions before CCS[Industry Category,Pollutant]
	     + SUM(Decrease in Process Emissions at BAU Production Levels[Industry Category,\
		Industry Process Emissions Policy!,Pollutant
	])
	     + SUM(Non BAU Process Emissions Additions at BAU Production Levels[Industry Category\
		,Industry Process Emissions Policy!,Pollutant])
	     + Change in Process Emissions from Feedstock Shifting[Industry Category,Pollutant\
		]
	    )
	    * (1 + Percent Change in Production due to Policies[Industry Category])
	  ,0
	  )
	~	g pollutant
	~		|

Process Emissions Cost Parameters as Vector[Marginal Abatement Cost,ptype]=
	1 ~~|
Process Emissions Cost Parameters as Vector[Marginal Abatement Cost,ppriority]=
	Allocation Priority for Marginal Cost Buckets[Marginal Abatement Cost] * One Metric Ton CO2e\
		 / One Dollar ~~|
Process Emissions Cost Parameters as Vector[Marginal Abatement Cost,pwidth]=
	1 ~~|
Process Emissions Cost Parameters as Vector[Marginal Abatement Cost,pextra]=
	0
	~	Dmnl
	~		|

Process Emissions in CO2e after CCS[Industry Category,Pollutant]=
	Process Emissions after CCS[Industry Category,Pollutant]
	* GWP by Pollutant[Pollutant]
	~	g CO2e
	~		|

Process Emissions in CO2e in Metric Tons[Industry Category,Pollutant]=
	Process Emissions in CO2e after CCS[Industry Category,Pollutant]
	/ Grams per Metric Ton CO2e
	~	metric tons CO2e
	~		|

Production Exceeding Both Caps[All Fuels]=
	Production Exceeding Cap[All Fuels]
	- Production Shifted to Imports due to Production Cap[All Fuels]
	~	BTU
	~		|

Production Exceeding Cap[All Fuels]=
	MAX(
	  0,
	
	  Change in Fuel Production before Cap[All Fuels]
	  - Maximum Absolute Increase in Fuel Production[All Fuels]
	)
	~	BTU
	~		|

Production Shifted to Imports due to Production Cap[All Fuels]=
	MIN(
	  Production Exceeding Cap[All Fuels],
	
	  Spare Capacity under Imports Cap[All Fuels]
	)
	~	BTU
	~		|

Profitable Capacity as Share of Existing Capacity for Cost Effective CCUS Retrofits[CCUS Electricity Source\
		, Optimization Pass,RPS]=
	IF THEN ELSE(
	  Incremental Revenue for Cost Effective CCUS Retrofits[CCUS Electricity Source,Optimization Pass\
		,RPS] < 1,
	
	  0,
	
	  LOOKUP INVERT(
	    CSCCCMvSoECBtY Capacity Cost Multiplier vs Share of Existing Capacity Built This Year\
		[summer],
	    Incremental Revenue for Cost Effective CCUS Retrofits[CCUS Electricity Source,Optimization Pass\
		,RPS]
	  )
	) ~~|
Profitable Capacity as Share of Existing Capacity for Cost Effective CCUS Retrofits[CCUS Electricity Source\
		,Optimization Pass,CES]=
	IF THEN ELSE(
	  Incremental Revenue for Cost Effective CCUS Retrofits[CCUS Electricity Source,Optimization Pass\
		,CES] < 1,
	
