Output from Industrial Equipment Installed During Model Run[Industry Category,Industrial Process\
		,Model Run Vintage]=
	Potential Output from Industrial Equipment Installed During Model Run[Industry Category\
		,Industrial Process,Model Run Vintage]
	* MIN(
	    1,
	
	    ZIDZ(
	      Last Year Output by ISIC Code with Fuels Based on Energy Content[Industry Category ISIC Code\
		],
	      SUM(Potential Output from Industrial Equipment Installed During Model Run[Industry Category\
		,Industrial Process,Model Run Vintage!])
	      + Potential Output from Preexisting Industrial Equipment[Industry Category,Industrial Process\
		]
	    )
	  )
	~	$
	~		|

Output from New Industrial Equipment[Industry Category,Industrial Process]=
	MAX(
	  0,
	
	  Last Year Output by ISIC Code with Fuels Based on Energy Content[Industry Category ISIC Code\
		]
	  * 
	  ZIDZ(Total BAU Fuel Use for Energy Purposes by Industrial Process in Electricity Equivalent\
		[Industry Category,Industrial Process],
	    SUM(Total BAU Fuel Use for Energy Purposes by Industrial Process in Electricity Equivalent\
		[Industry Category,Industrial Process!])
	  )
	  - SUM(
	      Last Year Potential Output from Industrial Equipment Installed During Model Run\
		[Industry Category,Industrial Process,Model Run Vintage!]
	      - Potential Output from Retiring Industrial Equipment Installed During Model Run\
		[Industry Category,Industrial Process,Model Run Vintage!] * One Year)
	  - Potential Output from Preexisting Industrial Equipment[Industry Category,Industrial Process\
		]
	)
	~	$
	~		|

Output from New Industrial Equipment by Fuel Type and Industrial Process[Industry Category\
		,Industrial Fuel,Industrial Process]=
