	* CO2 Emissions Intensity by Fuel for All Fuels[All Fuels]
	~	g pollutant
	~		|

Change in Energy Export Revenue including Electricity[All Fuels] :EXCEPT: [electricity\
		]=
	QUANTUM(
	  Change in Fuel Export Revenue[All Fuels],
	  QSfCF Quantization Size for Cash Flows
	) ~~|
Change in Energy Export Revenue including Electricity[electricity]=
	Change in Amount Received from Exporting Electricity
	~	$
	~		|

Change in Energy Exports including Electricity[All Fuels] :EXCEPT:  [electricity]=
	QUANTUM(
	  Change in Fuel Exports[All Fuels],
	  QSfE Quantization Size for Energy
	) ~~|
Change in Energy Exports including Electricity[electricity]=
	Change in Electricity Exports
	/ MWh per BTU
	~	BTU
	~		|

Change in Energy Import Expenditures including Electricity[All Fuels] :EXCEPT:  [electricity\
		]=
	QUANTUM(
	  Change in Fuel Import Expenditures[All Fuels],
	  QSfCF Quantization Size for Cash Flows
	) ~~|
Change in Energy Import Expenditures including Electricity[electricity]=
	Change in Amount Spent on Importing Electricity
	~	$
	~		|

Change in Energy Imports Including Electricity[All Fuels] :EXCEPT: [electricity]=
	QUANTUM(
	  Change in Fuel Imports[All Fuels],
	  QSfE Quantization Size for Energy
	) ~~|
Change in Energy Imports Including Electricity[electricity]=
	Change in Electricity Imports
	/ MWh per BTU
	~	BTU
	~		|

Change in Energy Production including Energy Carriers[All Fuels] :EXCEPT:  [electricity\
		],[heat],[hydrogen]=
	QUANTUM(
	  Change in Fuel Production[All Fuels],
	  QSfE Quantization Size for Energy
	) ~~|
Change in Energy Production including Energy Carriers[electricity]=
	SUM(Change in Electricity Generation by Type[Electricity Source!])
	/ MWh per BTU ~~|
Change in Energy Production including Energy Carriers[heat]=
	QUANTUM(
	  Change in Total Heat Use,
	  QSfE Quantization Size for Energy
	) ~~|
Change in Energy Production including Energy Carriers[hydrogen]=
	QUANTUM(
	  SUM(Change in Hydrogen Produced by Pathway[Hydrogen Production Pathway!]),
	  QSfE Quantization Size for Energy
	)
	~	BTU
	~		|

Change in Energy Spending per Household=
	Direct Change in Energy Expenditures by Entity[labor and consumers]
	/ NoH Number of Households
	~	$/households
	~		|

Change in Expenditures on Nonenergy Imports and Exports by Entity[Cash Flow Entity] :EXCEPT:\
		  [foreign entities]=
	SUM(Change in Expenditures on Nonenergy Imports by Entity[Industry Category!,Cash Flow Entity\
		]) ~~|
Change in Expenditures on Nonenergy Imports and Exports by Entity[foreign entities]=
	SUM(Change in Exports of Nonenergy Products[Industry Category!])
	~	$
	~		|

Change in Expenditures on Nonenergy Imports by Entity[Industry Category,Cash Flow Entity\
		] :EXCEPT:  [Industry Category,foreign entities
]=
	Change in Imports of Nonenergy Products[Industry Category]
	
	* ZIDZ(
	
	  FoGPbEaIC Fraction of Goods Purchased by Entity[Industry Category,Cash Flow Entity\
		],
	
	  (1 - FoGPbEaIC Fraction of Goods Purchased by Entity[Industry Category,foreign entities\
		])
	) ~~|
Change in Expenditures on Nonenergy Imports by Entity[Industry Category,foreign entities\
		]=
	0
	~	$
	~	In this variable, "Industry Category" is the foreign industry producting \
		the goods being imported.  "Cash Flow Entity" is the domestic buyer of \
		those imported goods.
	|

Change in Exports of Nonenergy Products[Industry Category]=
	BAU Exports[Industry Category ISIC Code]
	* Percent Change in Exports of Nonenergy Products[Industry Category]
	~	$
	~		|

Change in Fare Revenue by Transport Supplier[Cash Flow Entity]=
	SUM(
	  Change in Transport Fares Paid[Vehicle Type!,Cargo Type!]
	  * FoVObE Fraction of Vehicles Owned by Entity[Vehicle Type!,Cash Flow Entity,Cargo Type\
		!]
	)
	~	$
	~		|

Change in Financing Repayments for Hydrogen Production Eqpt[Hydrogen Production Pathway\
		]=
	This Year Financing Repayments for Hydrogen Production Eqpt[Hydrogen Production Pathway\
		]
	- BAU This Year Financing Repayments for Hydrogen Production Eqpt[Hydrogen Production Pathway\
		]
	~	$
	~		|

Change in Financing Repayments for Industrial CCS Equipment[Industry Category]=
	This Year Financing Repayments for Industrial CCS Equipment[Industry Category]
	- BAU This Year Financing Repayments for Industrial CCS Equipment[Industry Category]
	~	$
	~		|

Change in Financing Repayments for Industrial Equipment[Industry Category]=
	This Year Financing Repayments for Industrial Equipment[Industry Category]
	- BAU This Year Financing Repayments for Industrial Equipment[Industry Category]
	~	$
	~		|

Change in Forest Expenses by Entity[Cash Flow Entity]=
	(
	  SUM(Cost of Implementing Land Use Policies[Land Use Policy!])
	    + SUM(Cost of Maintaining Area Previously Affected by Land Use Policies[Land Use Policy\
		!])
	)
	* FoFObE Fraction of Forests Owned by Entity[Cash Flow Entity]
	~	$
	~		|

Change in Fuel Export Revenue[All Fuels]=
	Change in Fuel Exports[All Fuels]
	* IMFPbFT International Market Fuel Price by Fuel Type[All Fuels]
	~	$
	~		|

Change in Fuel Exports[All Fuels]=
	MAX(
	  -BAU Fuel Production Imports and Exports[All Fuels,exports],
	
	  Change in Fuel Exports due to Changes in Fuel Use[All Fuels]
	  + Change in Fuel Exports due to Export Reduction Policy[All Fuels]
	)
	~	BTU
	~		|

Change in Fuel Exports before Cap[Target Fuel]=
	MAX(
	  -SUM(
	     Change in Total Fuel Use Less Secondary and Byproduct Fuels[Source Fuel!]
	    * PoFDCtAE Percentage of Fuel Demand Change that Alters Exports[Source Fuel!,Target Fuel\
		]
	  ),
	
	  -BAU Fuel Production Imports and Exports[Target Fuel,exports]
	)
	~	BTU
	~		|

Change in Fuel Exports due to Changes in Fuel Use[All Fuels]=
	MIN(
	  Change in Fuel Exports before Cap[All Fuels],
	
	  Maximum Absolute Increase in Fuel Exports[All Fuels]
	)
	~	BTU
	~		|

Change in Fuel Exports due to Export Reduction Policy[All Fuels]=
	(BAU Fuel Production Imports and Exports[All Fuels,exports]
	  + Change in Fuel Exports due to Changes in Fuel Use[All Fuels]
	)
	* -Percent Reduction in Fossil Fuel Exports This Year[All Fuels]
	~	BTU
	~		|

Change in Fuel Import Expenditures[All Fuels]=
	Change in Fuel Imports[All Fuels]
	* IMFPbFT International Market Fuel Price by Fuel Type[All Fuels]
	~	$
	~		|

Change in Fuel Imports[All Fuels]=
	MAX(
	  -BAU Fuel Production Imports and Exports[All Fuels,imports],
	
	  MIN(
	    Change in Fuel Imports before Cap[All Fuels],
	    Maximum Absolute Increase in Fuel Imports[All Fuels]
	  )
	  + Production Shifted to Imports due to Production Cap[All Fuels]
	  + Excess Changes in Fuel Use Assigned to Imports[All Fuels]
	)
	~	BTU
	~		|

Change in Fuel Imports before Cap[All Fuels]=
	Change in Fuel Use Remaining after Change in Exports[All Fuels]
	* ZIDZ(
	    BAU Fuel Production Imports and Exports[All Fuels,imports],
	
	    BAU Fuel Production Imports and Exports[All Fuels,imports]
	    + BAU Fuel Production Imports and Exports[All Fuels,production]
	  )
	~	BTU
	~		|

Change in Fuel Industry Cash Flow from Fuel Exports[All Fuels]=
	Change in Fuel Export Revenue[All Fuels]
	* (1 - ETRbF Export Tax Rate by Fuel[All Fuels])
	~	$
	~		|

Change in Fuel Industry Revenue by Fuel[All Fuels] :EXCEPT:  [electricity]=
	Transportation Sector Change in Fuel Industry Cash Flow Mapped to All Fuels Subscript\
		[All Fuels]
	+ Electricity Sector Change in Fuel Industry Cash Flow Mapped to All Fuels Subscript\
		[All Fuels]
	+ Buildings Sector Change in Fuel Industry Cash Flow Mapped to All Fuels Subscript[All Fuels\
		]
	+ Industry Sector Change in Fuel Industry Cash Flow Mapped to All Fuels Subscript[All Fuels\
		]
	+ District Heating Change in Fuel Industry Cash Flow Mapped to All Fuels Subscript[All Fuels\
		]
	+ Hydrogen Sector Change in Fuel Industry Cash Flow Mapped to All Fuels Subscript[All Fuels\
		]
	+ Geoengineering Sector Change in Fuel Industry Cash Flow Mapped to All Fuels Subscript\
		[All Fuels]
	+ Change in Fuel Industry Cash Flow from Fuel Exports[All Fuels] ~~|
Change in Fuel Industry Revenue by Fuel[electricity]=
	Transportation Sector Change in Fuel Industry Cash Flow Mapped to All Fuels Subscript\
		[electricity]
	+ Electricity Sector Change in Fuel Industry Cash Flow Mapped to All Fuels Subscript\
		[electricity]
	+ Buildings Sector Change in Fuel Industry Cash Flow Mapped to All Fuels Subscript[electricity\
		]
	+ Industry Sector Change in Fuel Industry Cash Flow Mapped to All Fuels Subscript[electricity\
		]
	+ District Heating Change in Fuel Industry Cash Flow Mapped to All Fuels Subscript[electricity\
		]
	+ Hydrogen Sector Change in Fuel Industry Cash Flow Mapped to All Fuels Subscript[electricity\
		]
	+ Geoengineering Sector Change in Fuel Industry Cash Flow Mapped to All Fuels Subscript\
		[electricity]
	+ Change in Fuel Industry Cash Flow from Fuel Exports[electricity]
	~	$
	~		|

Change in Fuel Industry Revenue by Fuel Including Subsidies and Rebates[All Fuels] :EXCEPT:\
		    [electricity]=
	Transportation Sector Change in Fuel Industry Cash Flow Including Subsidies Mapped to All Fuels Subscript\
		[All Fuels]
	+ Electricity Sector Change in Fuel Industry Cash Flow Including Subsidies Mapped to All Fuels Subscript\
		[All Fuels]
	+ Buildings Sector Change in Fuel Industry Cash Flow Including Subsidies Mapped to All Fuels Subscript\
		[All Fuels]
	+ Industry Sector Change in Fuel Industry Cash Flow Including Subsidies Mapped to All Fuels Subscript\
		[All Fuels]
	+ District Heating Change in Fuel Industry Cash Flow Mapped to All Fuels Subscript[All Fuels\
		]
	+ Hydrogen Sector Change in Fuel Industry Cash Flow Mapped to All Fuels Subscript[All Fuels\
		]
	+ Geoengineering Sector Change in Fuel Industry Cash Flow Mapped to All Fuels Subscript\
		[All Fuels]
	+ Change in Fuel Industry Cash Flow from Fuel Exports[All Fuels]
	+ Change in Thermal Fuel Subsidies Paid[All Fuels] ~~|
Change in Fuel Industry Revenue by Fuel Including Subsidies and Rebates[electricity]=
	Transportation Sector Change in Fuel Industry Cash Flow Including Subsidies Mapped to All Fuels Subscript\
		[electricity]
	+ Electricity Sector Change in Fuel Industry Cash Flow Including Subsidies Mapped to All Fuels Subscript\
		[electricity]
	+ Buildings Sector Change in Fuel Industry Cash Flow Including Subsidies Mapped to All Fuels Subscript\
		[electricity]
	+ Industry Sector Change in Fuel Industry Cash Flow Including Subsidies Mapped to All Fuels Subscript\
		[electricity]
	+ District Heating Change in Fuel Industry Cash Flow Mapped to All Fuels Subscript[electricity\
		]
	+ Hydrogen Sector Change in Fuel Industry Cash Flow Mapped to All Fuels Subscript[electricity\
		]
	+ Geoengineering Sector Change in Fuel Industry Cash Flow Mapped to All Fuels Subscript\
		[electricity]
	+ Change in Fuel Industry Cash Flow from Fuel Exports[electricity]
	+ Change in Thermal Fuel Subsidies Paid[electricity]
	+ Electricity Sector Change in Subsidies for Grid Batteries
	~	$
	~		|

Change in Fuel Production[All Fuels]=
	MAX(
	  -BAU Fuel Production Imports and Exports[All Fuels,production],
	
	  Change in Fuel Exports due to Export Reduction Policy[All Fuels]
	  + MIN(
	      Change in Fuel Production before Cap[All Fuels],
	      Maximum Absolute Increase in Fuel Production[All Fuels]
	    )
	  + Imports Shifted to Production due to Imports Cap[All Fuels]
	  + Excess Changes in Fuel Use Assigned to Production[All Fuels]
	)
	~	BTU
	~		|

Change in Fuel Production before Cap[All Fuels]=
	Change in Fuel Use Remaining after Change in Exports[All Fuels]
	* ZIDZ(
	    BAU Fuel Production Imports and Exports[All Fuels,production],
	
	    BAU Fuel Production Imports and Exports[All Fuels,imports]
	    + BAU Fuel Production Imports and Exports[All Fuels,production]
	  )
	~	BTU
	~		|

Change in Fuel Production Mapped to ISIC Codes[ISIC Code] :EXCEPT:          [Fossil and Energy Utility ISIC Code\
		]=
	0 ~~|
Change in Fuel Production Mapped to ISIC Codes[ISIC 05]=
	SUM(Change in Fuel Production[coal mining industry fuel within all fuels!]) ~~|
Change in Fuel Production Mapped to ISIC Codes[ISIC 06]=
	Change in Fuel Production[natural gas]
	  +  Change in Fuel Production[crude oil] ~~|
Change in Fuel Production Mapped to ISIC Codes[ISIC 19]=
	SUM(Change in Fuel Production[secondary petroleum product within all fuels!]) ~~|
Change in Fuel Production Mapped to ISIC Codes[ISIC 352T353]=
	Change in Fuel Production[natural gas]
	  + Change in Fuel Production[heat]
	  + Change in Fuel Imports[natural gas] ~~|
Change in Fuel Production Mapped to ISIC Codes[ISIC 351]=
	(SUM(Electricity Generation by Type[Electricity Source!])
	  - SUM(BAU Electricity Generation by Type[Electricity Source!]))
	/ MWh per BTU
	~	BTU
	~		|

Change in Fuel Supplier Expenditures per Unit Fuel Produced[All Fuels] :EXCEPT:  [coal mining industry fuel within all fuels
],[NGPS industry fuel within all fuels],[biomass and biofuel within all fuels]=
	0 ~~|
Change in Fuel Supplier Expenditures per Unit Fuel Produced[coal mining industry fuel within all fuels\
		]=
	(Industry Sector Change in Energy Expenditures by Entity[coal suppliers]
	  + Industry Sector Change in Nonenergy Expenditures by Entity[coal suppliers]
	)
	* ZIDZ(
	    Fuel Production[coal mining industry fuel within all fuels],
	
	    SUM(Fuel Production[coal mining industry fuel within all fuels!])
	    * Fuel Production[coal mining industry fuel within all fuels]
	  ) ~~|
Change in Fuel Supplier Expenditures per Unit Fuel Produced[NGPS industry fuel within all fuels\
		] :EXCEPT: [natural gas]=
	ZIDZ(
	
	  (Industry Sector Change in Energy Expenditures by Entity[natural gas and petroleum suppliers\
		]
	    - Industry Sector Change in Energy Expenditures for Natural Gas Production
	  )
	  * ZIDZ(
	      Fuel Production[NGPS industry fuel within all fuels],
	
	      (SUM(Fuel Production[NGPS industry fuel within all fuels!])
	        - Fuel Production[natural gas]
	      )
	    )
	  + Industry Sector Change in Nonenergy Expenditures by Entity[natural gas and petroleum suppliers\
		]
	  * ZIDZ(
	      Fuel Production[NGPS industry fuel within all fuels],
	
	      SUM(Fuel Production[NGPS industry fuel within all fuels!])
	    ),
	
	  Fuel Production[NGPS industry fuel within all fuels]
	) ~~|
Change in Fuel Supplier Expenditures per Unit Fuel Produced[biomass and biofuel within all fuels\
		]=
	(Industry Sector Change in Energy Expenditures by Entity[biomass and biofuel suppliers\
		]
	  + Industry Sector Change in Nonenergy Expenditures by Entity[biomass and biofuel suppliers\
		]
	)
	* ZIDZ(
	    Fuel Production[biomass and biofuel within all fuels],
	
	    SUM(Fuel Production[biomass and biofuel within all fuels!])
	    * Fuel Production[biomass and biofuel within all fuels]
	  ) ~~|
Change in Fuel Supplier Expenditures per Unit Fuel Produced[natural gas]=
	ZIDZ(
	  Industry Sector Change in Energy Expenditures for Natural Gas Production
	  + Industry Sector Change in Nonenergy Expenditures by Entity[natural gas and petroleum suppliers\
		]
	    * ZIDZ(
	      Fuel Production[natural gas],
	
	      SUM(Fuel Production[NGPS industry fuel within all fuels!])
	    ),
	
	  Fuel Production[natural gas]
	)
	~	$/BTU
	~	We already separated out energy expenditures on natural gas production, so \
		we divide the NGPS industry's energy expenditures among non-natural gas \
		NGPS products proportinately to the quantity produced.  We did not already \
		separate out non-energy expenditures on natural gas production, so we \
		divide the NGPS industry's non-energy expenditures among all NGPS products \
		(including natural gas) proportionately to the quantity produced.
	|

Change in Fuel Use by Fuel and Technology due to LCFS[Vehicle Type,Cargo Type,Vehicle Technology\
		,Transportation Fuel] :EXCEPT: [Vehicle Type,Cargo Type,Vehicle Technology,electricity tf\
		]=
	Change in Fuel Use by Fuel and Technology due to LCFS with Elec Eff Adj[Vehicle Type\
		,Cargo Type,Vehicle Technology,Transportation Fuel] ~~|
Change in Fuel Use by Fuel and Technology due to LCFS[Vehicle Type,Cargo Type,Vehicle Technology\
		,electricity tf]=
	Change in Fuel Use by Fuel and Technology due to LCFS with Elec Eff Adj[Vehicle Type\
		,Cargo Type,Vehicle Technology,electricity tf]
	* (1 - PTFURfE Percentage Transportation Fuel Use Reduction for Electricity[Vehicle Type\
		,Cargo Type])
	~	BTU
	~		|

Change in Fuel Use by Fuel and Technology due to LCFS with Elec Eff Adj[Vehicle Type,\
		Cargo Type,Vehicle Technology,Transportation Fuel] :EXCEPT:     [Vehicle Type,Cargo Type\
		,gasoline vehicle,petroleum gasoline tf],[Vehicle Type,Cargo Type,diesel vehicle,petroleum diesel tf
],[Vehicle Type,Cargo Type,plugin hybrid vehicle,Transportation Fuel],[aircraft,Cargo Type\
		,diesel vehicle,jet fuel tf],[Vehicle Type,Cargo Type,diesel vehicle,heavy or residual fuel oil tf
]=
	Additional Fuel Use by Fuel and Technology due to LCFS with Elec Eff Adj[Vehicle Type\
		,Cargo Type,Vehicle Technology,Transportation Fuel
	] ~~|
Change in Fuel Use by Fuel and Technology due to LCFS with Elec Eff Adj[Vehicle Type,\
		Cargo Type,gasoline vehicle,petroleum gasoline tf]=
	- Additional Fuel Use by Fuel and Technology due to LCFS with Elec Eff Adj[Vehicle Type\
		,Cargo Type,gasoline vehicle,biofuel gasoline tf
	] ~~|
Change in Fuel Use by Fuel and Technology due to LCFS with Elec Eff Adj[Vehicle Type,\
		Cargo Type,diesel vehicle,petroleum diesel tf] :EXCEPT:     [aircraft,Cargo Type,diesel vehicle\
		,petroleum diesel tf]=
	- Additional Fuel Use by Fuel and Technology due to LCFS with Elec Eff Adj[Vehicle Type\
		,Cargo Type,diesel vehicle,biofuel diesel tf
	]
	
	* 
	
	ZIDZ(
	  Transportation Sector Fuel that would be Used in Absence of LCFS[Vehicle Type,Cargo Type\
		,diesel vehicle,petroleum diesel tf],
	  Transportation Sector Fuel that would be Used in Absence of LCFS[Vehicle Type,Cargo Type\
		,diesel vehicle,petroleum diesel tf]
	  + Transportation Sector Fuel that would be Used in Absence of LCFS[Vehicle Type,Cargo Type\
		,diesel vehicle,heavy or residual fuel oil tf]
	) ~~|
Change in Fuel Use by Fuel and Technology due to LCFS with Elec Eff Adj[Vehicle Type,\
		Cargo Type,plugin hybrid vehicle,Transportation Fuel] :EXCEPT:   [LDVs,Cargo Type,plugin hybrid vehicle\
		,petroleum gasoline tf],[HDVs,Cargo Type,plugin hybrid vehicle,petroleum diesel tf
]=
	Additional Fuel Use by Fuel and Technology due to LCFS with Elec Eff Adj[Vehicle Type\
		,Cargo Type,plugin hybrid vehicle,
	Transportation Fuel] ~~|
Change in Fuel Use by Fuel and Technology due to LCFS with Elec Eff Adj[LDVs,Cargo Type\
		,plugin hybrid vehicle,petroleum gasoline tf]=
	- Additional Fuel Use by Fuel and Technology due to LCFS with Elec Eff Adj[LDVs,Cargo Type\
		,plugin hybrid vehicle,electricity tf
	] ~~|
Change in Fuel Use by Fuel and Technology due to LCFS with Elec Eff Adj[HDVs,Cargo Type\
		,plugin hybrid vehicle,petroleum diesel tf
]=
	- Additional Fuel Use by Fuel and Technology due to LCFS with Elec Eff Adj[HDVs,Cargo Type\
		,plugin hybrid vehicle,electricity tf
] ~~|
Change in Fuel Use by Fuel and Technology due to LCFS with Elec Eff Adj[aircraft,Cargo Type\
		,diesel vehicle,jet fuel tf]=
	- Additional Fuel Use by Fuel and Technology due to LCFS with Elec Eff Adj[aircraft,\
		Cargo Type,diesel vehicle,biofuel diesel tf
] ~~|
Change in Fuel Use by Fuel and Technology due to LCFS with Elec Eff Adj[aircraft,Cargo Type\
		,diesel vehicle,petroleum diesel tf
]=
	0 ~~|
Change in Fuel Use by Fuel and Technology due to LCFS with Elec Eff Adj[Vehicle Type,\
		Cargo Type,diesel vehicle,heavy or residual fuel oil tf]=
	- Additional Fuel Use by Fuel and Technology due to LCFS with Elec Eff Adj[Vehicle Type\
		,Cargo Type,diesel vehicle,biofuel diesel tf]
	
	* 
	
	ZIDZ(
	  Transportation Sector Fuel that would be Used in Absence of LCFS[Vehicle Type,Cargo Type\
		,diesel vehicle,heavy or residual fuel oil tf],
	  Transportation Sector Fuel that would be Used in Absence of LCFS[Vehicle Type,Cargo Type\
		,diesel vehicle,heavy or residual fuel oil tf]
	  + Transportation Sector Fuel that would be Used in Absence of LCFS[Vehicle Type,Cargo Type\
		,diesel vehicle,petroleum diesel tf]
	)
	~	BTU
	~		|

Change in Fuel Use Remaining after Change in Exports[All Fuels] :EXCEPT:   [crude oil\
		]=
	Change in Total Fuel Use Less Secondary and Byproduct Fuels[All Fuels]
	+ Change in Fuel Exports[All Fuels]
	- Change in Fuel Exports due to Export Reduction Policy[All Fuels] ~~|
Change in Fuel Use Remaining after Change in Exports[crude oil]=
	Change in Total Fuel Use Less Secondary and Byproduct Fuels[crude oil]
	+ Change in Fuel Exports[crude oil]
	- Change in Fuel Exports due to Export Reduction Policy[crude oil]
	- Change in Crude Exports due to Changes in Secondary Petroleum Product Use
	~	BTU
	~		|

Change in Geoengineering CapEx and OM Spending This Year=
	Geoengineering CapEx and OM Spending This Year
	- BAU Geoengineering CapEx and OM Spending This Year
	~	$
	~		|

Change in Government Cash Flow by Cash Flow Type[carbon tax revenue]=
	Change in Carbon Tax Revenue ~~|
Change in Government Cash Flow by Cash Flow Type[fuel tax revenue]=
	Change in Other Fuel Tax Revenue ~~|
Change in Government Cash Flow by Cash Flow Type[EV subsidy]=
	- SUM(Change in Total Vehicle Subsidy Amount Paid[Vehicle Type!,Cargo Type!,Vehicle Technology\
		!]) ~~|
Change in Government Cash Flow by Cash Flow Type[elec gen subsidy]=
	- SUM(Change in Electricity Generation Subsidies Paid[Electricity Source!])
	- SUM(Change in ZEC Subsidies[Electricity Source!]) ~~|
Change in Government Cash Flow by Cash Flow Type[elec cap construction subsidy]=
	- SUM(Change in Capacity Construction Subsidies Paid[Electricity Source!])
	- Change in Subsidies Paid for New Grid Battery Construction ~~|
Change in Government Cash Flow by Cash Flow Type[distributed solar subsidy]=
	- SUM(Change in Subsidy Paid on Distributed Solar Capacity[Building Type!]) ~~|
Change in Government Cash Flow by Cash Flow Type[fuel subsidy]=
	- SUM(Change in Thermal Fuel Subsidies Paid[All Fuels!]) ~~|
Change in Government Cash Flow by Cash Flow Type[national debt interest]=
	- SUM(Last Year Change in National Debt Interest Received by Cash Flow Entity[Cash Flow Entity\
		!]) ~~|
Change in Government Cash Flow by Cash Flow Type[remainder]=
	Change in Cash Flow by Entity From IO Outputs[government]
	
	- Change in Government Cash Flow by Cash Flow Type[carbon tax revenue]
	- Change in Government Cash Flow by Cash Flow Type[fuel tax revenue]
	- Change in Government Cash Flow by Cash Flow Type[EV subsidy]
	- Change in Government Cash Flow by Cash Flow Type[battery production subsidy]
	- Change in Government Cash Flow by Cash Flow Type[elec gen subsidy]
	- Change in Government Cash Flow by Cash Flow Type[elec cap construction subsidy]
	- Change in Government Cash Flow by Cash Flow Type[distributed solar subsidy]
	- Change in Government Cash Flow by Cash Flow Type[fuel subsidy]
	- Change in Government Cash Flow by Cash Flow Type[CCS subsidy]
	- Change in Government Cash Flow by Cash Flow Type[indst clean heat subsidy]
	- Change in Government Cash Flow by Cash Flow Type[indst proc emis subsidy]
	- Change in Government Cash Flow by Cash Flow Type[hydgn production subsidy]
	- Change in Government Cash Flow by Cash Flow Type[national debt interest] ~~|
Change in Government Cash Flow by Cash Flow Type[CCS subsidy]=
	- SUM(Electricity Sector Change in CCS Subsidy Amount Paid[Electricity Source!])
	- SUM(Industry Sector Change in CCS Subsidy Amount Paid[Industry Category!])
	- Change in CCS Subsidy Amount Paid to Hydrogen Sector
	- SUM(Change in Electricity Sector CCS Transportation and Storage Subsidies[Electricity Source\
		!])
	- SUM(Industry Sector Change in CCS Transportation and Storage Subsidies[Industry Category\
		!])
	- Change in Hydrogen Sector CCS Transportation and Storage Subsidies ~~|
Change in Government Cash Flow by Cash Flow Type[battery production subsidy]=
	- SUM(Change in Total Vehicle Battery Production Subsidy Amount Paid[Vehicle Type!,Cargo Type\
		!,Vehicle Technology!])
	- Change in Subsidies Paid for Grid Battery Production ~~|
Change in Government Cash Flow by Cash Flow Type[indst clean heat subsidy]=
	- SUM(Change in Industrial Clean Heat Investment Subsidies Paid[Industry Category!])
	- SUM(Change in Industrial Clean Heat Production Subsidies Paid[Industry Category!])\
		 ~~|
Change in Government Cash Flow by Cash Flow Type[indst proc emis subsidy]=
	- SUM(Government Incentives for Process Emissions Policies Paid to Abating Industries\
		[Industry Category!,Industry Process Emissions Policy
	!]) ~~|
Change in Government Cash Flow by Cash Flow Type[hydgn production subsidy]=
	- SUM(Change in Hydrogen Production Subsidy Payments[Hydrogen Production Pathway!])
	~	$
	~		|

Change in Green Hydrogen Electricity Capacity Construction Costs[Electricity Source]=
	DEPRECIATE STRAIGHTLINE(
	
	  Cost of Green Hydrogen Electricity Capacity Construction[Electricity Source]
	  - BAU Cost of Green Hydrogen Electricity Capacity Construction[Electricity Source]\
		,
	 
	  STfESCE Smoothing Time for Electricity Sector Capital Expenditures,
	
	  1,
	
	  0
	)
	~	$
	~		|

Change in Green Hydrogen Electricity Capacity Construction Subsidies Paid[Electricity Source\
		]=
	Green Hydrogen Electricity Capacity Construction Subsidies Paid[Electricity Source]
	- BAU Green Hydrogen Electricity Capacity Construction Subsidies Paid[Electricity Source\
		]
	~	$
	~		|

Change in Green Hydrogen Electricity Fixed OM Costs[Electricity Source]=
	Green Hydrogen Electricity Fixed OM Costs[Electricity Source]
	- BAU Green Hydrogen Electricity Fixed OM Costs[Electricity Source]
	~	$
	~		|

Change in Green Hydrogen Electricity Generation Subsidies Paid[Electricity Source]=
	Green Hydrogen Electricity Generation Subsidies Paid[Electricity Source]
	- BAU Green Hydrogen Electricity Generation Subsidies Paid[Electricity Source]
	~	$
	~		|

Change in Green Hydrogen Electricity Variable OM Costs[Electricity Source]=
	Green Hydrogen Electricity Variable OM Costs[Electricity Source]
	- BAU Green Hydrogen Electricity Variable OM Costs[Electricity Source]
	~	$
	~		|

Change in Household Cash Flow before Household Savings=
	Change in Cash Flow by Entity From IO Outputs[labor and consumers]
	  + Government Revenue Change Allocated by Mechanism[household taxes]
	~	$
	~		|

Change in Household Savings=
	(Change in Household Cash Flow before Household Savings
	  - Change in Household Spending
	) / One Year
	~	$/Year
	~		|

Change in Household Spending=
	Change in Household Cash Flow before Household Savings
	* (1 - HSR Household Savings Rate)
	~	$
	~		|

Change in Hydrogen Produced by Pathway[Hydrogen Production Pathway]=
	Hydrogen Production by Pathway[Hydrogen Production Pathway]
	- BAU Hydrogen Production by Pathway[Hydrogen Production Pathway]
	~	BTU
	~		|

Change in Hydrogen Production Subsidy Payments[Hydrogen Production Pathway]=
	Hydrogen Production Subsidy Payments[Hydrogen Production Pathway]
	- BAU Hydrogen Production Subsidy Payments[Hydrogen Production Pathway]
	~	$
	~		|

Change in Hydrogen Sector Carbon Tax Rebate due to CCS=
	Hydrogen Sector Carbon Tax Rebate due to CCS-BAU Hydrogen Sector Carbon Tax Rebate due to CCS
	~	$
	~		|

Change in Hydrogen Sector CCS Transportation and Storage Costs=
	Hydrogen Sector CCS Transportation and Storage Costs
	- BAU Hydrogen Sector CCS Transportation and Storage Costs
	~	$
	~		|

Change in Hydrogen Sector CCS Transportation and Storage Subsidies=
	Hydrogen Sector CCS Transportation and Storage Subsidies
	- BAU Hydrogen Sector CCS Transportation and Storage Subsidies
	~	$
	~		|

Change in Hydrogen Supplier Expenditures per Unit Hydrogen Produced=
	ZIDZ(
	  Hydrogen Sector Change in Energy Expenditures by Entity[other energy suppliers]
	  + Hydrogen Sector Change in Nonenergy Expenditures by Entity[other energy suppliers\
		],
	
	  SUM(Hydrogen Demand by Sector[Sectors!])
	)
	~	$/BTU
	~		|

Change in Imports of Nonenergy Products[Industry Category]=
	Last Year Output by ISIC Code[Industry Category ISIC Code]
	* Change in Nonenergy Industry Product Imports as Share of Domestic Production[Industry Category\
		]
	~	$
	~		|

Change in Industrial Clean Heat Investment Subsidies Paid[Industry Category]=
	Clean Industrial Heat Investment Subsidy Amount Paid[Industry Category]
	- BAU Clean Industrial Heat Investment Subsidy Amount Paid[Industry Category]
	~	$
	~		|

Change in Industrial Clean Heat Production Subsidies Paid[Industry Category]=
	Industrial Clean Heat Production Subsidy Amount Paid[Industry Category]
	- BAU Industrial Clean Heat Production Subsidy Amount Paid[Industry Category]
	~	$
	~		|

Change in Industrial Fuel Use for Non Energy Purposes due to Feedstock Shifting[Industry Category\
		,Industrial Fuel]=
	Industrial Fuel Use for Non Energy Purposes[Industry Category,Industrial Fuel]
	- Industrial Fuel Use for Non Energy Purposes Before Feedstock Shifting[Industry Category\
		,Industrial Fuel]
	~	BTU
	~		|

Change in Industry Sector Carbon Tax Rebate due to CCS[Industry Category]=
	Industry Sector Carbon Tax Rebate due to CCS[Industry Category]
	- BAU Industry Sector Carbon Tax Rebate due to CCS[Industry Category]
	~	$
	~		|

Change in Industry Sector Fuel Supplier Revenue by Entity[Cash Flow Entity] :EXCEPT:  \
		[electricity suppliers],[coal suppliers],[natural gas and petroleum suppliers],[biomass and biofuel suppliers\
		],[other energy suppliers]=
	0 ~~|
Change in Industry Sector Fuel Supplier Revenue by Entity[electricity suppliers]=
	SUM(Cash Flow Change for Fuel Industry from Industry Fuel Use[Industry Category!,electricity if\
		]) ~~|
Change in Industry Sector Fuel Supplier Revenue by Entity[coal suppliers]=
	SUM(Cash Flow Change for Fuel Industry from Industry Fuel Use[Industry Category!,hard coal if\
		]) ~~|
Change in Industry Sector Fuel Supplier Revenue by Entity[natural gas and petroleum suppliers\
		]=
	SUM(Cash Flow Change for Fuel Industry from Industry Fuel Use[Industry Category!,natural gas if\
		])
	+ SUM(Cash Flow Change for Fuel Industry from Industry Fuel Use[Industry Category!,petroleum diesel if\
		])
	+ SUM(Cash Flow Change for Fuel Industry from Industry Fuel Use[Industry Category!,crude oil if\
		])
	+ SUM(Cash Flow Change for Fuel Industry from Industry Fuel Use[Industry Category!,heavy or residual fuel oil if\
		])
	+ SUM(Cash Flow Change for Fuel Industry from Industry Fuel Use[Industry Category!,LPG propane or butane if\
		]) ~~|
Change in Industry Sector Fuel Supplier Revenue by Entity[biomass and biofuel suppliers\
		]=
	SUM(Cash Flow Change for Fuel Industry from Industry Fuel Use[Industry Category!,biomass if\
		]) ~~|
Change in Industry Sector Fuel Supplier Revenue by Entity[other energy suppliers]=
	SUM(Cash Flow Change for Fuel Industry from Industry Fuel Use[Industry Category!,heat if\
		])
	+ SUM(Cash Flow Change for Fuel Industry from Industry Fuel Use[Industry Category!,hydrogen if\
		])
	~	$
	~		|

Change in Industry Sector Pollutant Emissions[Pollutant]=
	SUM(Industrial Sector Pollutant Emissions[Industry Category!,Pollutant])
	- SUM(BAU Industrial Sector Pollutant Emissions[Industry Category!,Pollutant])
	~	g pollutant
	~		~	:SUPPLEMENTARY 
	|

Change in Interest Paid on National Debt=
	Cumulative Change in National Debt
	* IRoND Interest Rate on National Debt
	~	$
	~		|

Change in Labor and Consumers Earnings After Income Taxes=
	SUM(Change in Domestic Employee Compensation by ISIC Code[ISIC Code!])
	- SUM(Change in Domestic Individual Income Tax Revenue by ISIC Code[ISIC Code!])
	~	$
	~		|

Change in LULUCF Emissions[Pollutant] :EXCEPT: [CO2]=
	SUM(CO2 Abated by Land Use Policy This Year[Land Use Policy!])
	* RPEpUACE Rebound Pollutant Emissions per Unit Avoided CO2 Emissions[Pollutant] ~~|
Change in LULUCF Emissions[CO2]=
	-SUM(CO2 Abated by Land Use Policy This Year[Land Use Policy!])
	~	g pollutant
	~		|

Change in LULUCF Pollutant Emissions[Pollutant]=
	LULUCF Anthropogenic Pollutant Emissions[Pollutant]
	- BLAPE BAU LULUCF Anthropogenic Pollutant Emissions[Pollutant]
	~	g pollutant
	~		~	:SUPPLEMENTARY 
	|

Change in Methane Captured by Industry[Industry Category]=
	- Total Change in Process Emissions[Industry Category,indst methane capture,CH4]
	* MHV Methane Heating Value
	~	BTU
	~		|

Change in Miscellaneous Expenditures by Industry[Industry Category]=
	Change in Carbon Tax on Process Emissions by Industry[Industry Category]
	+ SUM(Cost of Process Emissions Policies[Industry Category,Industry Process Emissions Policy\
		!])
	+ Industry Sector Change in CCS OM Cost[Industry Category]
	+ Industry Sector Change in CCS Transportation and Storage Costs[Industry Category]
	+ Change in Financing Repayments for Industrial Equipment[Industry Category]
	+ Financing Repayments for Waste Heat Recovery Equipment[Industry Category]
	+ Change in Financing Repayments for Industrial CCS Equipment[Industry Category]
	~	$
	~		|

Change in National Debt Interest Received by Cash Flow Entity[Cash Flow Entity]=
	Change in Interest Paid on National Debt
	* PoNDHbE Percent of National Debt Held by Entity[Cash Flow Entity]
	~	$
	~		|

Change in Net Imports of Electricity=
	Net Imports of Electricity
	- BAU Net Imports of Electricity
	~	MW*hr
	~		|

Change in Nonenergy Expenditures by Entity due to Expense Passthrough[Cash Flow Entity\
		]=
	SUM(Nonenergy Industry Expense Passthrough by Purchasing Entity[Industry Category!,Cash Flow Entity\
		])
	~	$
	~		|

Change in Nonenergy Expenditures by Entity due to Production Changes[Cash Flow Entity\
		]=
	SUM(Change in Nonenergy Industry Revenues due to Production Changes by Purchasing Entity\
		[Industry Category!,Cash Flow Entity])
	~	$
	~	Every cash flow entity increases or reduces its expenditures by the amount \
		that industry revenue (summed across all industries) changes due to \
		selling more or fewer outputs to that cash flow entity.
	|

Change in Nonenergy Industry Cash Flow by ISIC Code[ISIC Code]=
	Change in Nonenergy ISIC Code Revenue After Relinquishing Collected VAT or Sales Tax by ISIC Code\
		[ISIC Code]
	- Change in Nonenergy Industry Expenditures by ISIC Code[ISIC Code]
	~	$
	~		|

Change in Nonenergy Industry Demand Response Costs by ISIC Code[ISIC Code]=
	Change in Demand Response Costs by Recipient[nonenergy industries]
	* Percent of Nonenergy Industry Electricity Spending by ISIC Code[ISIC Code]
	~	$
	~		|

Change in Nonenergy Industry Expenditures by ISIC Code[ISIC Code]=
	Buildings Sector Change in Nonenergy Industry Expenditures by ISIC Code[ISIC Code]
	+ Electricity Sector Change in Nonenergy Industry Expenditures by ISIC Code[ISIC Code\
		]
	+ Industry Sector Change in Nonenergy Industry Expenditures by ISIC Code[ISIC Code]
	+ LULUCF Change in Nonenergy Industry Expenditures by ISIC Code[ISIC Code]
	+ Transportation Sector Change in Nonenergy Industry Expenditures by ISIC Code[ISIC Code\
		]
	~	$
	~		|

Change in Nonenergy Industry Product Imports and Exports by Entity[Cash Flow Entity] \
		:EXCEPT:  [foreign entities],[nonenergy industries]=
	0 ~~|
Change in Nonenergy Industry Product Imports and Exports by Entity[foreign entities]=
	SUM(Change in Imports of Nonenergy Products[Industry Category!]) ~~|
Change in Nonenergy Industry Product Imports and Exports by Entity[nonenergy industries\
		]=
	SUM(Change in Exports of Nonenergy Products[Industry Category!])
	~	$
	~		|

Change in Nonenergy Industry Product Imports as Share of Domestic Production[Industry Category\
		]=
	(1 - Domestic Content Share of Consumption Before Import Substitution by ISIC Code[Industry Category ISIC Code\
		])
	* Percent Change in Nonenergy Industry Product Demand due to Change in Passthrough Expenses\
		[Industry Category]
	
	+ Percent of Purchases of Domestically Produced Goods Shifted to Purchases of Imports\
		[Industry Category]
	  * (1 + Percent Change in Nonenergy Industry Product Demand due to Change in Passthrough Expenses\
		[Industry Category])
	~	Dmnl
	~	The first term takes the pre-shift imported content share and adjusts it \
		for changes in product demand.  The second term takes the shifted imported \
		content share and adjusts it for changes in product demand.  (The domestic \
		content share, both the pre-shift portion and the shifted portion, are \
		already given as shares of domestic production.  This variable does not \
		alter the denominator used.)  The first term, the pre-shift imported \
		content share, is adjusted up or down depending on the sign of the percent \
		change in nonenergy industry product demand.  The second term, the shifted \
		portion, is simply made slightly larger or smaller based on the change in \
		demand, because it was already calculated earlier with the correct sign \
		and only needs to be adjusted for demand changes.  This is why "(1 +" \
		appears in the second term but not in the first term.
	|

Change in Nonenergy Industry Revenue due to Production Changes[Industry Category] :EXCEPT:\
		   [energy industries within industry category
]=
	BAU Output by ISIC Code by Year[Industry Category ISIC Code]
	* Percent Change in Production due to Policies[Industry Category]
	* (1 + VoSTR VAT or Sales Tax Rate[Industry Category ISIC Code]) ~~|
Change in Nonenergy Industry Revenue due to Production Changes[energy industries within industry category\
		]=
	0
	~	$
	~		|

Change in Nonenergy Industry Revenues due to Production Changes by Purchasing Entity[\
		Industry Category,Cash Flow Entity]=
	Change in Nonenergy Industry Revenue due to Production Changes[Industry Category]
	* FoGPbEaIC Fraction of Goods Purchased by Entity[Industry Category,Cash Flow Entity\
		]
	~	$
	~	In this variable, Industry Category is the industry receiving revenue for \
		selling non-energy outputs (so it is zero for energy industries).  Cash \
		Flow Entity is the entity (government, labor and consumers, etc.) that is \
		buying the non-energy industrial outputs.
	|

Change in Nonenergy Industry Revenues due to Production Changes by Purchasing ISIC Code\
		[Industry Category,ISIC Code]=
	Change in Nonenergy Industry Revenues due to Production Changes by Purchasing Entity\
		[Industry Category,nonenergy industries]
	* FoGPbEaIC Fraction of Goods Purchased by ISIC Code[Industry Category,ISIC Code]
	~	$
	~		|

Change in Nonenergy ISIC Code Revenue After Relinquishing Collected VAT or Sales Tax by ISIC Code\
		[ISIC Code]=
	Direct Change in Revenue for Nonenergy ISIC Codes[ISIC Code]
	- Change in VAT or Sales Tax Collected on Revenue of Nonenergy ISIC Codes[ISIC Code]
	~	$
	~		|

Change in Ongoing Capital Costs[Electricity Source]=
	Surviving Electricity Generation Capacity[Electricity Source]*Weighted Average Annual Capital Costs per Unit Capacity
	[Electricity Source]
	
	-BAU Surviving Electricity Generation Capacity[Electricity Source]*BAU Weighted Average Annual Capital Costs per Unit Capacity
	[Electricity Source]
	~	$
	~		|

Change in Ongoing Capital Costs by Recipient ISIC Code[ISIC Code]=
	SUM(
	  Change in Ongoing Capital Costs[Electricity Source!]
	  * SoESCaOMCbIC Share of Electricity Sector Capital Costs by ISIC Code[Electricity Source\
		!,ISIC Code]
	)
	~	$
	~		|

Change in Ongoing Capital Costs for Green Hydrogen Electricity[Electricity Source]=
	Ongoing Capital Costs for Green Hydrogen Electricity[Electricity Source]
	- BAU Ongoing Capital Costs for Green Hydrogen Electricity[Electricity Source]
	~	$
	~		|

Change in Other Fuel Tax Revenue=
	Total Other Fuel Tax Revenue
	- BAU Total Other Fuel Tax Revenue
	~	$
	~		|

Change in Output from Distributed Sources[Building Type,Electricity Source]=
	(Distributed Electricity Source Capacity[Building Type,Electricity Source]
	  - BAU Distributed Electricity Source Capacity[Building Type,Electricity Source])
	* Distributed Solar Capacity Factor x Hours per Year
	~	MW*hour
	~		|

Change in Passthrough Expenses as Share of Nonenergy Industry Output After Carbon Tax Border Adjustment by Industry Category\
		[Industry Category] :EXCEPT: [energy industries within industry category]=
	Change in Passthrough Expenses as Share of Nonenergy Industry Output by Industry Category\
		[Industry Category] 
	  - Carbon Tax Effects on Expenditures by Nonenergy Industries As Share of Nonenergy Industry Output\
		[Industry Category] ~~|
Change in Passthrough Expenses as Share of Nonenergy Industry Output After Carbon Tax Border Adjustment by Industry Category\
		[energy industries within industry category]=
	0
	~	Dmnl
	~		|

Change in Passthrough Expenses as Share of Nonenergy Industry Output by Industry Category\
		[Industry Category] :EXCEPT:  [energy industries within industry category]=
	Change in Passthrough Expenses as Share of Nonenergy Industry Output by ISIC Code[Industry Category ISIC Code\
		] ~~|
Change in Passthrough Expenses as Share of Nonenergy Industry Output by Industry Category\
		[energy industries within industry category]=
	0
	~	Dmnl
	~		|

Change in Passthrough Expenses as Share of Nonenergy Industry Output by ISIC Code[ISIC Code\
		]=
	ZIDZ(
	
	  Last Year Smoothed Nonenergy Industy Expenses Passed Through to Buyers by Producer ISIC Code with VAT or Sales Tax Removed\
		[ISIC Code],
	
	  Last Year Output by ISIC Code[ISIC Code]
	)
	~	Dmnl
	~		|

Change in Peak Load=
	MAX(0,Peak Electricity Load
	- Last Year Electricity Peak Load)
	~	MW
	~		|

Change in Process Emissions from Feedstock Shifting[Industry Category,Pollutant]=
	SUM(
	  Change in Industrial Fuel Use for Non Energy Purposes due to Feedstock Shifting[Industry Category\
		,Industrial Fuel!]
	  * Industrial Fuel Pollutant Emissions Intensities This Year[Industry Category,Pollutant\
		,Industrial Fuel!]
	)
	~	g pollutant
	~		|

Change in Process Emissions Policy Revenue by Entity[Cash Flow Entity] :EXCEPT:    [nonenergy industries\
		],[labor and consumers]=
	0 ~~|
Change in Process Emissions Policy Revenue by Entity[nonenergy industries]=
	SUM(Cost to Industry from Process Emissions Policies Paid to Industry[Industry Category\
		!,Industry Process Emissions Policy!]) ~~|
Change in Process Emissions Policy Revenue by Entity[labor and consumers]=
	SUM(Cost to Industry from Process Emissions Policies Paid to Labor[Industry Category\
		!,Industry Process Emissions Policy!])
	~	$
	~		|

Change in Repayment for Buildings Sector Financed Capital Expenses[Building Type]=
	This Year Ongoing Repayment for Buildings Sector Financed Capital Expenses[Building Type\
		]
	- BAU This Year Ongoing Repayment for Buildings Sector Financed Capital Expenses[Building Type\
		]
	~	$
	~		|

Change in Repayment of Financing for Electricity Sector Capital Expenditures=
	Repayment of Financing for Electricity Sector Capital Expenditures Including Construction Subsidies
	-BAU Repayment of Financing for Change in Electricity Sector Capital Expenditures including Construction Subsidies
	~	$
	~		|

Change in Revenue from Buildings Sector Subsidies and Rebates by Entity[Cash Flow Entity\
		] :EXCEPT:        [nonenergy industries
]=
	SUM(
	    Building Component Rebate Amount Paid[Building Type!,Building Component!]
	    * Fraction of Buildings Owned by Entity after Allocation to Energy Supplier Entities\
		[Cash Flow Entity,Building Type
	!]
	  ) ~~|
Change in Revenue from Buildings Sector Subsidies and Rebates by Entity[nonenergy industries\
		]=
	SUM(
	    Building Component Rebate Amount Paid[Building Type!,Building Component!]
	    * Fraction of Buildings Owned by Entity after Allocation to Energy Supplier Entities\
		[nonenergy industries,Building Type
	!]
	  )
	+ SUM(Subsidy Paid for Retrofitting Buildings[Building Type!])
	
	+ SUM(Change in Subsidy Paid on Distributed Solar Capacity[Building Type!])
	~	$
	~		|

Change in Revenue from Industry Process Emissions Policies by Recipient ISIC Code[ISIC Code\
		]=
	Cost to Industry from Process Emissions Policies Paid to Industry[cement and other nonmetallic minerals 239\
		,indst cement measures]
	* SoPEASbRIC Share of Process Emissions Abatement Spending by Recipient ISIC Code[cement industry measures\
		,ISIC Code]
	
	+ Cost to Industry from Process Emissions Policies Paid to Industry[oil and gas extraction 06\
		,indst methane capture]
	* SoPEASbRIC Share of Process Emissions Abatement Spending by Recipient ISIC Code[ngp production methane capture\
		,ISIC Code
	]
	
	+ Cost to Industry from Process Emissions Policies Paid to Industry[oil and gas extraction 06\
		,indst methane destruction]
	* SoPEASbRIC Share of Process Emissions Abatement Spending by Recipient ISIC Code[ngp production methane destruction\
		,ISIC Code
	]
	
	+ Cost to Industry from Process Emissions Policies Paid to Industry[energy pipelines and gas processing 352T353\
		,indst methane capture]
	* SoPEASbRIC Share of Process Emissions Abatement Spending by Recipient ISIC Code[ngp processing TnD methane capture\
		,ISIC Code
	]
	
	+ Cost to Industry from Process Emissions Policies Paid to Industry[energy pipelines and gas processing 352T353\
		,indst methane destruction
	]
	* SoPEASbRIC Share of Process Emissions Abatement Spending by Recipient ISIC Code[ngp processing TnD methane destruction
	,ISIC Code]
	
	+ Cost to Industry from Process Emissions Policies Paid to Industry[chemicals 20,indst f gas substitution\
		]
	* SoPEASbRIC Share of Process Emissions Abatement Spending by Recipient ISIC Code[chemicals f gas substitution\
		,ISIC Code
	]
	
	+ Cost to Industry from Process Emissions Policies Paid to Industry[chemicals 20,indst f gas destruction\
		]
	* SoPEASbRIC Share of Process Emissions Abatement Spending by Recipient ISIC Code[chemicals f gas destruction\
		,ISIC Code
	]
	
	+ Cost to Industry from Process Emissions Policies Paid to Industry[chemicals 20,indst f gas recovery\
		]
	* SoPEASbRIC Share of Process Emissions Abatement Spending by Recipient ISIC Code[chemicals f gas recovery\
		,ISIC Code]
	
	+ Cost to Industry from Process Emissions Policies Paid to Industry[chemicals 20,indst f gas inspct maint retrofit\
		]
	* SoPEASbRIC Share of Process Emissions Abatement Spending by Recipient ISIC Code[chemicals inspct maint retrofit\
		,ISIC Code
	]
	
	+ Cost to Industry from Process Emissions Policies Paid to Industry[coal mining 05,indst methane capture\
		]
	* SoPEASbRIC Share of Process Emissions Abatement Spending by Recipient ISIC Code[coal mining methane capture\
		,ISIC Code
	]
	
	+ Cost to Industry from Process Emissions Policies Paid to Industry[coal mining 05,indst methane destruction\
		]
	* SoPEASbRIC Share of Process Emissions Abatement Spending by Recipient ISIC Code[coal mining methane destruction\
		,ISIC Code
	]
	
	+ Cost to Industry from Process Emissions Policies Paid to Industry[water and waste 36T39\
		,indst methane capture]
	* SoPEASbRIC Share of Process Emissions Abatement Spending by Recipient ISIC Code[waste management methane capture\
		,ISIC Code
	]
	
	+ Cost to Industry from Process Emissions Policies Paid to Industry[water and waste 36T39\
		,indst methane destruction]
	* SoPEASbRIC Share of Process Emissions Abatement Spending by Recipient ISIC Code[waste management methane destruction\
		,
	ISIC Code]
	
	+ Cost to Industry from Process Emissions Policies Paid to Industry[agriculture and forestry 01T03\
		,indst cropland and rice measures]
	* SoPEASbRIC Share of Process Emissions Abatement Spending by Recipient ISIC Code[agriculture crop and rice measures\
		,ISIC Code
	]
	
	+ Cost to Industry from Process Emissions Policies Paid to Industry[agriculture and forestry 01T03\
		,indst livestock measures]
	* SoPEASbRIC Share of Process Emissions Abatement Spending by Recipient ISIC Code[agriculture livestock measures\
		,ISIC Code
	]
	
	+ Cost to Industry from Process Emissions Policies Paid to Industry[agriculture and forestry 01T03\
		,indst tillage]
	* SoPEASbRIC Share of Process Emissions Abatement Spending by Recipient ISIC Code[agriculture tillage\
		,ISIC Code]
	
	+ Cost to Industry from Process Emissions Policies Paid to Industry[chemicals 20,indst N2O abatement\
		]
	* SoPEASbRIC Share of Process Emissions Abatement Spending by Recipient ISIC Code[chemicals N2O abatement\
		,ISIC Code]
	
	+ Cost to Industry from Process Emissions Policies Paid to Industry[other metals 242\
		,indst f gas inspct maint retrofit]
	* SoPEASbRIC Share of Process Emissions Abatement Spending by Recipient ISIC Code[other metals inspct maint retrofit\
		,ISIC Code
	]
	~	$
	~	We have to map from the "Industry by Process Emissions Policy" subscript \
		(used by SoPEASbRIC) to industry and policy as separate subscripts, which \
		is used in most parts of the Industry Sector.
	|

Change in Revenue from Vehicle and Battery Subsidies by Entity[Cash Flow Entity]=
	SUM((Change in Total Vehicle Subsidy Amount Paid[Vehicle Type!,Cargo Type!,Vehicle Technology\
		!]
	    + Change in Total Vehicle Battery Production Subsidy Passed Through to Consumers\
		[Vehicle Type!,Cargo Type!,Vehicle Technology!])
	    * Fraction of Vehicles Owned by Entity after Allocation to Energy Supplier Entities\
		[Vehicle Type!,Cash Flow Entity,
	Cargo Type!]
	)
	~	$
	~		|

Change in Secondary and Byproduct Fuel Consumption[Industry Category,Industrial Fuel]\
		=
	(Industrial Fuel Use for Energy Purposes[Industrial Fuel,Industry Category]
	  - BAU Industrial Fuel Use for Energy Purposes[Industry Category,Industrial Fuel])
	* SoFCTiBoSFbI Share of Fuel Consumption That is Byproduct or Secondary Fuels by Industry\
		[Industry Category,Industrial Fuel
	]
	~	BTU
	~		|

Change in Secondary and Byproduct Fuel Consumption Mapped to All Fuels[All Fuels] :EXCEPT:\
		 [industrial fuel within all fuels]=
	0 ~~|
Change in Secondary and Byproduct Fuel Consumption Mapped to All Fuels[industrial fuel within all fuels\
		] :EXCEPT: [hydrogen]=
	SUM(Change in Secondary and Byproduct Fuel Consumption[Industry Category!,Industrial Fuel\
		]) ~~|
Change in Secondary and Byproduct Fuel Consumption Mapped to All Fuels[hydrogen]=
	SUM(Change in Secondary and Byproduct Fuel Consumption[Industry Category!,hydrogen if\
		])
	+ SUM(Change in Secondary and Byproduct Fuel Consumption[Industry Category!,green hydrogen if\
		])
	+ SUM(Change in Secondary and Byproduct Fuel Consumption[Industry Category!,low carbon hydrogen if\
		])
	~	BTU
	~		|

Change in Spur Line Construction Costs[Electricity Source]=
	DEPRECIATE STRAIGHTLINE(
	
	  Spur Line Construction Costs[Electricity Source]
	  - BAU Spur Line Construction Costs[Electricity Source],
	 
	  STfESCE Smoothing Time for Electricity Sector Capital Expenditures,
	
	  1,
	
	  0
	)
	~	$
	~	We use a DEPRECIATE STRAIGHTLINE function to even out price spikes that \
		unrealistically affect the price of electricity, because the costs of \
		construction of new generation assets really would be spread out over a \
		few years.  We use an initial value of zero because prior to the start of \
		the model run, the change in construction costs due to policies is zero \
		(none were in effect).
	|

Change in Spur Line Construction Costs by Recipient ISIC Code[ISIC Code]=
	SUM(Change in Spur Line Construction Costs[Electricity Source!])
	* SoTaCCbIC Share of Transmission and Distribution Capital Costs by ISIC Code[ISIC Code\
		]
	~	$
	~		|

Change in Subsidies Paid for Grid Battery Production=
	Change in Subsidies Paid for Grid Battery Production Retained by Manufacturers
	+ Change in Subsidies Paid for Grid Battery Production Passed Through to Consumers
	~	$
	~		|

Change in Subsidies Paid for Grid Battery Production Passed Through to Consumers=
	Subsidies Paid for Grid Battery Production Passed Through to Consumers
	- BAU Subsidies Paid for Grid Battery Production Passed Through to Consumers
	~	$
	~		|

Change in Subsidies Paid for Grid Battery Production Retained by Manufacturers=
	Subsidies Paid for Grid Battery Production Not Passed Through to Consumers
	- BAU Subsidies Paid for Grid Battery Production Not Passed Through to Consumers
	~	$
	~		|

Change in Subsidies Paid for New Grid Battery Construction=
	Subsidies Paid for New Grid Battery Construction
	- BAU Subsidies Paid for New Grid Battery Construction
	~	$
	~		|

Change in Subsidy Paid on Distributed Solar Capacity[Building Type]=
	Subsidy Paid on Distributed Solar Capacity[Building Type]
	- BAU Subsidy Paid on Distributed Solar Capacity[Building Type]
	~	$
	~		|

Change in Tax Paid on Fuel Exports[All Fuels]=
	Change in Fuel Export Revenue[All Fuels]
	* ETRbF Export Tax Rate by Fuel[All Fuels]
	~	$
	~		|

Change in Taxes Paid on Fuels to Generate Heat[Industrial Fuel]=
	Total Tax Paid on Fuels to Generate Heat[Industrial Fuel]
	- BAU Total Tax Paid on Fuels to Generate Heat[Industrial Fuel]
	~	$
	~		|

Change in Taxes Paid on Geoengineering Fuels[Industrial Fuel]=
	Taxes Paid on Geoengineering Fuels[Industrial Fuel]
	- BAU Taxes Paid on Geoengineering Fuels[Industrial Fuel]
	~	$
	~	We use the tax amount per unit fuel from the cement industry as a model \
		for tax amounts per unit fuel from industry more generally, for use to \
		represent tax amount per unit fuel used by geoengineering.
	|

Change in Taxes Paid on Hydrogen Sector Fuels[Industrial Fuel]=
	Total Tax Paid on Hydrogen Sector Fuels[Industrial Fuel]
	- BAU Total Tax Paid on Hydrogen Sector Fuels[Industrial Fuel]
	~	$
	~		|

Change in Taxes Paid on Industry Fuels[Industry Category,Industrial Fuel]=
	QUANTUM(
	  Taxes Paid on Industry Fuels[Industry Category,Industrial Fuel]
	  - BAU Taxes Paid on Industry Fuels[Industry Category,Industrial Fuel],
	
	  QSfCF Quantization Size for Cash Flows
	)
	~	$
	~		|

Change in Thermal Fuel Subsidies Paid[All Fuels]=
	SUM(Thermal Fuel Subsidies Paid[All Fuels,Sectors!])
	- SUM(BAU Thermal Fuel Subsidies Paid[All Fuels,Sectors!])
	~	$
	~		|

Change in This Year Grid Battery Storage Capacity in MW=
	This Year Grid Battery Storage Capacity in MW
	- BAU This Year Grid Battery Storage Capacity in MW
	~	MW
	~		|

Change in This Year Hybrid Grid Battery Storage Capacity in MW=
	This Year Hybrid Grid Battery Storage Capacity in MW
	- BAU This Year Hybrid Grid Battery Storage Capacity in MW
	~	MW
	~		|

Change in This Year Total Grid Battery Storage excluding Hybrid Batteries in MW=
	This Year Total Grid Battery Storage Capacity excluding Hybrid Batteries in MW
	- BAU This Year Total Grid Battery Storage Capacity excluding Hybrid Batteries in MW
	~	MW
	~		|

Change in Total Annual Recoverable Costs for Cost of Service Rates=
	Total Annual Recoverable Costs for Cost of Service Rates
	-BAU Total Annual Recoverable Costs for Cost of Service Rates
	~	$
	~		|

Change in Total CO2e Emissions=
	Total CO2e Emissions
	- BAU Total CO2e Emissions
	~	g CO2e
	~		|

Change in Total Cost of Power Generation=
	Total Cost of Power Generation
	-BAU Total Cost of Power Generation
	~	$
	~		|

Change in Total Cost of Transmission Distribution Storage and Other=
	Total Cost of Transmission Distribution Storage and Other
	-BAU Total Cost of Transmission Distribution Storage and Other
	~	$
	~		|

Change in Total Fuel Use[All Fuels]=
	QUANTUM(
	  Total Energy Use[All Fuels]
	  - BAU Total Energy Use[All Fuels],
	
	  QSfE Quantization Size for Energy
	)
	~	BTU
	~		|

Change in Total Fuel Use Less Secondary and Byproduct Fuels[All Fuels]=
	Change in Total Fuel Use[All Fuels]
	- Change in Secondary and Byproduct Fuel Consumption Mapped to All Fuels[All Fuels]
	~	BTU
	~		|

Change in Total Generation Costs=
	Generation Costs
	-BAU Generation Costs
	~	$
	~		|

Change in Total Heat Use=
	Total District Heat Use
	- BAU Total District Heat Use
	~	BTU
	~		|

Change in Total Interregional Electricity Trade Costs=
	Interregional Electricity Trade Costs
	-BAU Interregional Electricity Trade Costs
	~	$
	~		|

Change in Total Pollutant Emissions by Sector Excluding Imported Electricity Emissions\
		[Sectors,Pollutant] :EXCEPT:  [electricity sector,Pollutant]=
	Total Pollutant Emissions by Sector[Sectors,Pollutant]
	- BAU Total Pollutant Emissions by Sector[Sectors,Pollutant] ~~|
Change in Total Pollutant Emissions by Sector Excluding Imported Electricity Emissions\
		[electricity sector,Pollutant]=
	(Total Pollutant Emissions by Sector[electricity sector,Pollutant]
	  - SUM(Absolute Change in In Scope Emissions due to Electricity Imports[Pollutant,Electricity Source\
		!])
	)
	- (BAU Total Pollutant Emissions by Sector[electricity sector,Pollutant]
	    - SUM(BAU Absolute Change in In Scope Emissions due to Electricity Imports[Pollutant\
		,Electricity Source!])
	  )
	~	g pollutant
	~	We exclude the change in emissions due to imported electricity from health \
		impact calculations because those emissions occur outside the modeled \
		region boundaries, and we only want health impacts of emissions that occur \
		within the modeled region boundaries.
	|

Change in Total Vehicle Battery Production Subsidy Amount Paid[Vehicle Type,Cargo Type\
		,Vehicle Technology]=
	Total Vehicle Battery Production Subsidy Amount Paid[Vehicle Type,Cargo Type,Vehicle Technology\
		]
	- BAU Total Vehicle Battery Production Subsidy Amount Paid[Vehicle Type,Cargo Type,Vehicle Technology\
		]
	~	$
	~		|

Change in Total Vehicle Battery Production Subsidy Passed Through to Consumers[Vehicle Type\
		,Cargo Type,Vehicle Technology]=
	Change in Total Vehicle Battery Production Subsidy Amount Paid[Vehicle Type,Cargo Type\
		,Vehicle Technology]
	* FoSfBPPTtC Fraction of Subsidy for Battery Production Passed Through to Consumers
	~	$
	~		|

Change in Total Vehicle Battery Production Subsidy Retained by Manufacturers[Vehicle Type\
		,Cargo Type,Vehicle Technology]=
	Change in Total Vehicle Battery Production Subsidy Amount Paid[Vehicle Type,Cargo Type\
		,Vehicle Technology]
	* (1 - FoSfBPPTtC Fraction of Subsidy for Battery Production Passed Through to Consumers\
		)
	~	$
	~		|

Change in Total Vehicle Subsidy Amount Paid[Vehicle Type,Cargo Type,Vehicle Technology\
		]=
	Total Vehicle Subsidy Amount Paid[Vehicle Type,Cargo Type,Vehicle Technology]
	- BAU Total EV Subsidy Amount Paid[Vehicle Type,Cargo Type,Vehicle Technology]
	~	$
	~		|

Change in Transmission Construction Costs=
	DEPRECIATE STRAIGHTLINE(
	
	  Transmission Construction Costs-BAU Transmission Construction Costs,
	 
	  STfESCE Smoothing Time for Electricity Sector Capital Expenditures,
	
	  1,
	
	  0
	)
	~	$
	~	We use a DEPRECIATE STRAIGHTLINE function to even out price spikes that \
		unrealistically affect the price of electricity, because the costs of \
		construction of new generation assets really would be spread out over a \
		few years.  We use an initial value of zero because prior to the start of \
		the model run, the change in construction costs due to policies is zero \
		(none were in effect).
	|

Change in Transmission Construction Costs by Recipient ISIC Code[ISIC Code]=
	Change in Transmission Construction Costs
	* SoTaCCbIC Share of Transmission and Distribution Capital Costs by ISIC Code[ISIC Code\
		]
	~	$
	~		|

Change in Transmission OM Costs=
	Transmission OM Costs
	- BAU Transmission OM Costs
	~	$
	~		|

Change in Transmission OM Costs by Recipient ISIC Code[ISIC Code]=
	Change in Distribution OM Costs
	* SoTaDOMCbIC Share of Transmission and Distribution OM Costs by ISIC Code[ISIC Code\
		]
	~	$
	~		|

Change in Transport Fares Paid[Vehicle Type,Cargo Type]=
	Transport Fares Paid[Vehicle Type,Cargo Type]
	- BAU Transport Fares Paid[Vehicle Type,Cargo Type]
	~	$
	~		|

Change in Transportation Fuel Taxes Paid[Transportation Fuel,Vehicle Type,Cargo Type,\
		Vehicle Technology]=
	Total Tax Paid on Transportation Fuels[Transportation Fuel,Vehicle Type,Cargo Type,Vehicle Technology\
		]
	- BAU Total Tax Paid on Transportation Fuels[Transportation Fuel,Vehicle Type,Cargo Type\
		,Vehicle Technology]
	~	$
	~		|

Change in Transportation Sector Pollutant Emissions[Pollutant]=
	Transportation Sector Pollutant Emissions[Pollutant]
	- BAU Transportation Sector Pollutant Emissions[Pollutant]
	~	g pollutant
	~		~	:SUPPLEMENTARY 
	|

Change in Upfront Capital Expenditures by Industry for Financed Equipment[Industry Category\
		]=
	Change in Upfront Capital Expenditures for New Industrial Equipment That Are Financed\
		[Industry Category]
	+ Industry Sector Change in New CCS Capital Eqpt Costs That Are Financed[Industry Category\
		]
	+ New Waste Heat Recovery Equipment Capital Expenditures That Are Financed[Industry Category\
		]
	~	$
	~		|

Change in Upfront Capital Expenditures by Industry for Non Financed Equipment[Industry Category\
		]=
	Change in Upfront Capital Expenditures for New Industrial Equipment That Are Not Financed\
		[Industry Category]
	+ Industry Sector Change in New CCS Capital Eqpt Costs That Are Not Financed[Industry Category\
		]
	+ New Waste Heat Recovery Equipment Capital Expenditures That Are Not Financed[Industry Category\
		]
	~	$
	~		|

Change in Upfront Capital Expenditures for New Industrial Equipment That Are Financed\
		[Industry Category]=
	Change in Upfront Capital Expenditures on New Industrial Equipment[Industry Category\
		]
	* SoICETAF Share of Industry Capital Expenditures That Are Financed[Industry Category\
		]
	~	$
	~		|

Change in Upfront Capital Expenditures for New Industrial Equipment That Are Not Financed\
		[Industry Category]=
	Change in Upfront Capital Expenditures on New Industrial Equipment[Industry Category\
		]
	* (1 - SoICETAF Share of Industry Capital Expenditures That Are Financed[Industry Category\
		])
	~	$
	~		|

Change in Upfront Capital Expenditures on New Industrial Equipment[Industry Category]\
		=
	New Industrial Equipment Capital Cost[Industry Category]
	- BAU New Industrial Equipment Capital Cost[Industry Category]
	~	$
	~		|

Change in VAT or Sales Tax Collected on Revenue of Nonenergy ISIC Codes[ISIC Code] :EXCEPT:\
		 [Industry Category ISIC Code]=
	(
	  Direct Change in Revenue for Nonenergy ISIC Codes[ISIC Code]
	  + Last Year Indirect and Induced Change in Domestic Output for Non Industry Category ISIC Codes\
		[ISIC Code]
	)
	* VoSTR VAT or Sales Tax Rate[ISIC Code] ~~|
Change in VAT or Sales Tax Collected on Revenue of Nonenergy ISIC Codes[Industry Category ISIC Code\
		]=
	(
	  Direct Change in Revenue for Nonenergy ISIC Codes[Industry Category ISIC Code]
	  - Change in Exports of Nonenergy Products[Industry Category]
	)
	* VoSTR VAT or Sales Tax Rate[Industry Category ISIC Code]
	~	$
	~	We assume only the output of Industry Category ISIC Codes may be exported.  \
		(We don't presently calculate exports of output of non-Industry ISIC \
		codes, such as exported consulting services.)
	|

Change in Wholesale Energy Market Costs=
	Wholesale Energy Market Costs
	-BAU Wholesale Energy Market Costs
	~	$
	~		~	:SUPPLEMENTARY 
	|

Change in ZEC Subsidies[Electricity Source]=
	ZEC Subsidies Paid[Electricity Source]
	- BAU ZEC Subsidies Paid[Electricity Source]
	~	$
	~		|

Changes in Fuel Use Exceeding Both Caps[All Fuels]=
	Production Exceeding Both Caps[All Fuels]
	+ Imports Exceeding Both Caps[All Fuels]
	~	BTU
	~		|

Changes in New Components Energy Use due to Fuel Shifting[Building Type,Building Fuel\
		,Building Component]=
	New Components Potential Energy Use after Fuel Shifting[Building Type,Building Fuel,\
		Building Component]
	- New Components Potential Energy Use after Price Efficiency Feedbacks[Building Type\
		,Building Fuel,Building Component]
	~	BTU
	~		|

Changes in Nonenergy Revenue by Entity due to Expense Passthrough[Cash Flow Entity] :EXCEPT:\
		  [nonenergy industries]=
	0 ~~|
Changes in Nonenergy Revenue by Entity due to Expense Passthrough[nonenergy industries\
		]=
	SUM(Nonenergy Industry Expenses Passed Through to Buyers[Industry Category!])
	~	$
	~		|

Changes in Nonenergy Revenue by Entity due to Production Changes[Cash Flow Entity] :EXCEPT:\
		 [nonenergy industries]=
	0 ~~|
Changes in Nonenergy Revenue by Entity due to Production Changes[nonenergy industries\
		]=
	SUM(Change in Nonenergy Industry Revenues due to Production Changes by Purchasing Entity\
		[Industry Category!,Cash Flow Entity!])
	~	$
	~	Nonenergy industries receive revenue for their sales of nonenergy outputs \
		to all cash flow entities.
	|

Changes in Revenue due to VAT or Sales Tax on Nonenergy ISIC Codes by Cash Flow Entity\
		[Cash Flow Entity] :EXCEPT:  [government],[nonenergy industries]=
	0 ~~|
Changes in Revenue due to VAT or Sales Tax on Nonenergy ISIC Codes by Cash Flow Entity\
		[government]=
	SUM(Change in VAT or Sales Tax Collected on Revenue of Nonenergy ISIC Codes[ISIC Code\
		!]) ~~|
Changes in Revenue due to VAT or Sales Tax on Nonenergy ISIC Codes by Cash Flow Entity\
		[nonenergy industries]=
	-SUM(Change in VAT or Sales Tax Collected on Revenue of Nonenergy ISIC Codes[ISIC Code\
		!])
	~	$
	~		|

Charging Availability Shadow Cost=
	MAX(
	  EVCAP EV Charging Availability Parameter A 
	  * LN(This Year Number of EV Chargers*EV Charger Unit Correction
	     / (BNoGP BAU Number of Gas Pumps*Gas Pump Unit Correction)
	      )
	  + EVCAP EV Charging Availability Parameter B,
	
	  0
	)
	~	$/vehicle
	~		|

Check for Equality of Buildings Sector Nonenergy Industry Expenditures=
	SUM(Buildings Sector Change in Nonenergy Industry Expenditures by ISIC Code[ISIC Code\
		!])
	- Buildings Sector Change in Energy Expenditures by Entity[nonenergy industries]
	- Buildings Sector Change in Nonenergy Expenditures by Entity[nonenergy industries]
	~	$
	~		~	:SUPPLEMENTARY 
	|

Check for Equality of Buildings Sector Nonenergy Industry Revenue=
	SUM(Buildings Sector Change in Nonenergy Industry Revenue by ISIC Code[ISIC Code!])
	- Buildings Sector Change in Revenue by Entity[nonenergy industries]
	~	$
	~		~	:SUPPLEMENTARY 
	|

Check for Equality of District Heating Nonenergy Industry Revenue=
	SUM(District Heating Change in Nonenergy Industry Revenue by ISIC Code[ISIC Code!])
	- District Heating Change in Revenue by Entity[nonenergy industries]
	~	$
	~		~	:SUPPLEMENTARY 
	|

Check for Equality of Electricity Sector Nonenergy Industry Expenditures=
	SUM(Electricity Sector Change in Nonenergy Industry Expenditures by ISIC Code[ISIC Code\
		!])
	- Electricity Sector Change in Energy Expenditures by Entity[nonenergy industries]
	- Electricity Sector Change in Nonenergy Expenditures by Entity[nonenergy industries\
		]
	~	$
	~		~	:SUPPLEMENTARY 
	|

Check for Equality of Electricity Sector Nonenergy Industry Revenue=
	SUM(Electricity Sector Change in Nonenergy Industry Revenue by ISIC Code[ISIC Code!]\
		)
	- Electricity Sector Change in Revenue by Entity[nonenergy industries]
	~	$
	~		~	:SUPPLEMENTARY 
	|

Check for Equality of Geoengineering Sector Nonenergy Industry Revenue=
	SUM(Geoengineering Sector Change in Nonenergy Industry Revenue by ISIC Code[ISIC Code\
		!])
	- Geoengineering Sector Change in Revenue by Entity[nonenergy industries]
	~	$
	~		~	:SUPPLEMENTARY 
	|

Check for Equality of Hydrogen Sector Nonenergy Industry Revenue=
	SUM(Hydrogen Sector Change in Nonenergy Industry Revenue by ISIC Code[ISIC Code!])
	- Hydrogen Sector Change in Revenue by Entity[nonenergy industries]
	~	$
	~		~	:SUPPLEMENTARY 
	|

Check for Equality of Industry Sector Nonenergy Industry Expenditures=
	SUM(Industry Sector Change in Nonenergy Industry Expenditures by ISIC Code[ISIC Code\
		!])
	- Industry Sector Change in Energy Expenditures by Entity[nonenergy industries]
	- Industry Sector Change in Nonenergy Expenditures by Entity[nonenergy industries]
	~	$
	~		~	:SUPPLEMENTARY 
	|

Check for Equality of Industry Sector Nonenergy Industry Revenue=
	SUM(Industry Sector Change in Nonenergy Industry Revenue by ISIC Code[ISIC Code!])
	- Industry Sector Change in Revenue by Entity[nonenergy industries]
	~	$
	~		~	:SUPPLEMENTARY 
	|

Check for Equality of LULUCF Nonenergy Industry Expenditures=
	SUM(LULUCF Change in Nonenergy Industry Expenditures by ISIC Code[ISIC Code!])
	- LULUCF Change in Nonenergy Expenditures by Entity[nonenergy industries]
	~	$
	~		~	:SUPPLEMENTARY 
	|

Check for Equality of LULUCF Nonenergy Industry Revenue=
	SUM(LULUCF Change in Nonenergy Industry Revenue by ISIC Code[ISIC Code!])
	- LULUCF Change in Revenue by Entity[nonenergy industries]
	~	$
	~		~	:SUPPLEMENTARY 
	|

Check for Equality of Nonenergy Industry Cash Flow=
	SUM(Change in Nonenergy Industry Cash Flow by ISIC Code[ISIC Code!])
	- Direct Change in Cash Flow by Entity[nonenergy industries]
	~	$
	~		~	:SUPPLEMENTARY 
	|

Check for Equality of Nonenergy Industry Expenditures=
	SUM(Change in Nonenergy Industry Expenditures by ISIC Code[ISIC Code!])
	- Direct Change in Energy Expenditures by Entity[nonenergy industries]
	- Direct Change in Nonenergy Expenditures by Entity[nonenergy industries]
	~	$
	~		~	:SUPPLEMENTARY 
	|

Check for Equality of Nonenergy Industry Revenue=
	SUM(Change in Nonenergy ISIC Code Revenue After Relinquishing Collected VAT or Sales Tax by ISIC Code\
		[ISIC Code!])
	- Direct Change in Revenue by Entity[nonenergy industries]
	~	$
	~		~	:SUPPLEMENTARY 
	|

Check for Equality of Transportation Sector Nonenergy Industry Expenditures=
	SUM(Transportation Sector Change in Nonenergy Industry Expenditures by ISIC Code[ISIC Code\
		!])
	- Transportation Sector Change in Energy Expenditures by Entity[nonenergy industries\
		]
	- Transportation Sector Change in Nonenergy Expenditures by Entity[nonenergy industries\
		]
	~	$
	~		~	:SUPPLEMENTARY 
	|

Check for Equality of Transportation Sector Nonenergy Industry Revenue=
	SUM(Transportation Sector Change in Nonenergy Industry Revenue by ISIC Code[ISIC Code\
		!])
	- Transportation Sector Change in Revenue by Entity[nonenergy industries]
	~	$
	~		~	:SUPPLEMENTARY 
	|

Child and Adult Deaths by Demographic Trait[demographic trait excluding age bracket]=
	MAX(
	  0,
	
	  BDbDT BAU Child and Adult Deaths by Demographic Trait[demographic trait excluding age bracket\
		]
	  - Reduction in Child and Adult Premature Mortality by Demographic Trait[demographic trait excluding age bracket\
		]
	)
	~	incidents
	~		|

