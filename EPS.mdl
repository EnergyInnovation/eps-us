Percent Change in Nonenergy Industry Domestic Production due to Change in Passthrough Expenses\
		[Industry Category]=
	-Percent of Purchases of Domestically Produced Goods Shifted to Purchases of Imports\
		[Industry Category]
	
	+ (1 - Percent of Purchases of Domestically Produced Goods Shifted to Purchases of Imports\
		[Industry Category])
	  * Percent Change in Nonenergy Industry Product Demand due to Change in Passthrough Expenses\
		[Industry Category]
	~	Dmnl
	~	First, we substract out the share of domestic production that was shifted \
		to imports.  Then, we assume that reductions in demand affect domestic \
		production and imports equally (meaning each is reduced by the same \
		percentage), so we reduce the remaining share of domestic production by \
		the percentage change in demand.
	|

Percent Change in Nonenergy Industry Product Demand due to Change in Passthrough Expenses\
		[Industry Category]=
	Weighted Average Percent Change in Cost of Goods by Industry Category[Industry Category\
		]
	* EoDfIP Elasticities of Demand for Industrial Products[Industry Category]
	~	Dmnl
	~		|

Percent Change in Nonfuel Production due to Policies[Industry Category] :EXCEPT: [energy industries within industry category\
		],[agriculture and forestry 01T03]=
	Percent Change in Production after Macroeconomic Feedbacks[Industry Category]
	- (Percent Reduction in Nonenergy Nonagriculture Industry Product Demand This Year[Industry Category\
		]
	  * (1 + Percent Change in Production after Macroeconomic Feedbacks[Industry Category\
		])
	  ) ~~|
Percent Change in Nonfuel Production due to Policies[energy industries within industry category\
		]=
	0 ~~|
Percent Change in Nonfuel Production due to Policies[agriculture and forestry 01T03]=
	Percent Change in Production after Macroeconomic Feedbacks[agriculture and forestry 01T03\
		]
	+ Percent Change in Agriculture Industry Production due to Nonanimal Product Shifting
	~	Dmnl
	~		|

Percent Change in Production after Macroeconomic Feedbacks[Industry Category]=
	(1 + Last Year Percent Change in Nonenergy Industry Domestic Production due to Passthrough Expenses\
		[Industry Category])
	* (1 + Percent Change in Production Due to Macroeconomic Feedbacks[Industry Category\
		])
	
	- 1
	~	Dmnl
	~		|

Percent Change in Production Due to Macroeconomic Feedbacks[Industry Category]=
	IF THEN ELSE(
	  BDMFL Boolean Disable Macroeconomic Feedback Loops > 0,
	
	  0,
	
	  MAX(
	    -1,
	
	    Last Year Percent Change in Contribution to Gross Domestic Product Excluding Most Direct Impacts by ISIC Code\
		[Industry Category ISIC Code]
	  )
	)
	~	Dmnl
	~		|

Percent Change in Production due to Policies[Industry Category] :EXCEPT:         [energy industries within industry category
]=
	Percent Change in Nonfuel Production due to Policies[Industry Category] ~~|
Percent Change in Production due to Policies[energy industries within industry category\
		] :EXCEPT:         [energy pipelines and gas processing 352T353
]=
	Last Year Percent Change in Domestic Fuel Industry Production[energy industries within industry category\
		] ~~|
Percent Change in Production due to Policies[energy pipelines and gas processing 352T353\
		]=
	Last Year Percent Change in Domestic Plus Exported Natural Gas Demand
	~	Dmnl
	~	For the "energy pipelines and gas processing 352T353" industry, we base \
		change in production on the change in demand for natural gas, not the \
		change in production of natural gas, because there are EPS regions (such \
		as U.S. states) which produce little or no gas, but can still have methane \
		leaks from natural gas transmission systems.  Changes in NG demand better \
		reflects changes in leakage from these transmission systems.
	|

Percent Change in Transport Demand due to Macroeconomic Feedbacks by Cargo Type[passenger\
		]=
	0 ~~|
Percent Change in Transport Demand due to Macroeconomic Feedbacks by Cargo Type[freight\
		]=
	Weighted Average Last Year Percent Change in Industry Contribution to Gross Domestic Product Excluding Most Direct Impacts
	~	Dmnl
	~	Research on the relationship between income and VMT have shown negligible \
		impacts, so we set passenger modes to 0 here.
	|

Percent Change in Weighted Average Pretax Fuel Price by ISIC Code[ISIC Code]=
	IF THEN ELSE(
	  ABS(Weighted Average Pretax Fuel Price by Producing ISIC Code[ISIC Code])*Dollar per BTU Tolerance Unit Correction\
		 < Tolerance
	,
	
	  0,
	
	  ZIDZ(
	    Weighted Average Pretax Fuel Price by Producing ISIC Code[ISIC Code]
	    - Initial BAU Weighted Average Pretax Fuel Price by Producing ISIC Code[ISIC Code\
		],
	
	    Initial BAU Weighted Average Pretax Fuel Price by Producing ISIC Code[ISIC Code]
	  )
	)
	~	Dmnl
	~		|

Percent of Corporate Income Tax Allocation by ISIC Code[ISIC Code] :EXCEPT:   [Private Business ISIC Code\
		]=
	0 ~~|
Percent of Corporate Income Tax Allocation by ISIC Code[Private Business ISIC Code]=
	BAU Value Added by ISIC Code by Year[Private Business ISIC Code]
	/ SUM(BAU Value Added by ISIC Code by Year[Private Business ISIC Code!])
	~	Dmnl
	~		|

Percent of Government Cash Flow Change Allocated by Mechanism[Govt Cash Flow Type,Government Revenue Mechanism\
		]=
	XIDZ(
	  GRA Weights by Government Cash Flow Type by Mechanism[Govt Cash Flow Type,Government Revenue Mechanism\
		],
	
	  SUM(GRA Weights by Government Cash Flow Type by Mechanism[Govt Cash Flow Type,Government Revenue Mechanism\
		!]),
	
	  1 / ELMCOUNT(Government Revenue Mechanism)
	)
	~	Dmnl
	~		|

Percent of Government Expenditures by ISIC Code[ISIC Code]=
	Government Expenditures by ISIC Code by Year[ISIC Code]
	/ SUM(Government Expenditures by ISIC Code by Year[ISIC Code!])
	~	Dmnl
	~		|

Percent of Household Expenditures by ISIC Code[ISIC Code]=
	Household Expenditures by ISIC Code by Year[ISIC Code]
	/ SUM(Household Expenditures by ISIC Code by Year[ISIC Code!])
	~	Dmnl
	~		|

