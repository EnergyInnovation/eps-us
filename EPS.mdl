	~		|

Perc Change in All Components Energy Use due to Price Demand Feedbacks[Building Type,\
		Building Fuel,Building Component]=
	Perc Change in Components Energy Cost if Run at Potential[Building Type,Building Fuel\
		,Building Component]
	* EoBSDwEC Elasticity of Building Service Demand wrt Energy Cost[Building Fuel,Building Type\
		]
	~	Dmnl
	~		|

Perc Change in Avg Annual Dist Traveled by Vehicle Type[Vehicle Type,Cargo Type,Vehicle Technology\
		]=
	Perc Change in Fuel Cost per Unit Cargo Dist[Vehicle Type,Cargo Type,Vehicle Technology\
		]
	* EoDfVUwFC Elasticity of Demand for Vehicle Use wrt Fuel Cost[Vehicle Type]
	~	Dmnl
	~		|

Perc Change in Buildings Fuel Cost per Unit Energy[Building Type,Building Fuel]=
	1 -
	XIDZ(
	  BAU Buildings Fuel Cost per Unit Energy[Building Fuel,Building Type],
	  Buildings Fuel Cost per Unit Energy[Building Fuel,Building Type],
	  1
	)
	~	Dmnl
	~		|

Perc Change in Components Energy Cost if Run at Potential[Building Type,Building Fuel\
		,Building Component]=
	MAX(
	  -1,
	
	  ZIDZ(
	    Potential Buildings Fuel Cost[Building Type,Building Fuel,Building Component]
	      - Hypothetical BAU Potential Buildings Fuel Cost[Building Type,Building Fuel,Building Component\
		],
	
	    Hypothetical BAU Potential Buildings Fuel Cost[Building Type,Building Fuel,Building Component\
		]
	  )
	)
	~	Dmnl
	~		|

Perc Change in Energy Use Due to Quality Level Shifting[Building Type,Building Component\
		]=
	SUM(
	  (Fraction New Components by Quality Level[Building Type,Building Component,Building Component Quality\
		!]
	    - BFoCSbQL BAU Fraction of Components Sold by Quality Level[Building Type,Building Component\
		,Building Component Quality!])
	  * PEUDfSbQL Perc E Use Difference from Std by Quality Level[Building Component,Building Type\
		,Building Component Quality!]
	)
	~	Dmnl
	~	The change in each market share fraction is multiplied by its respective \
		percentage energy use difference from the standard.  These changes are \
		summed across Quality Levels to get the overall percentage change in \
		energy use.
	|

Perc Change in Fuel Cost per Unit Cargo Dist[Vehicle Type,Cargo Type,Vehicle Technology\
		]=
	ZIDZ(
	  (Fuel Cost per Unit Cargo Dist[Vehicle Type,Cargo Type,Vehicle Technology]
	    - BAU Fuel Cost per Unit Cargo Dist[Vehicle Type,Cargo Type,Vehicle Technology])\
		,
	
	  BAU Fuel Cost per Unit Cargo Dist[Vehicle Type,Cargo Type,Vehicle Technology]
	)
	~	Dmnl
	~		|

Perc Change in Fuel Economy due to Fuel Price Effects[Vehicle Type,Vehicle Technology\
		,Transportation Fuel]=
	Perc Change in Transportation Fuel Cost per Unit Energy[Transportation Fuel]
	* EoNVFEwFC Elasticity of New Veh Fuel Economy wrt Fuel Cost[Vehicle Type,Vehicle Technology\
		,Transportation Fuel]
	~	Dmnl
	~		|

Perc Change in Fuel Economy due to Fuel Price Effects Weighted by Fuel Type[Vehicle Type\
		,Vehicle Technology]=
	ZIDZ(
	
	  SUM(
	    Perc Change in Fuel Economy due to Fuel Price Effects[Vehicle Type,Vehicle Technology\
		,Transportation Fuel!]
	    * Last Year Transportation Sector Fuel Used[Vehicle Type,Cargo Type!,Vehicle Technology\
		,Transportation Fuel!]
	  ),
	
	  SUM(Last Year Transportation Sector Fuel Used[Vehicle Type,Cargo Type!,Vehicle Technology\
		,Transportation Fuel!])
	)
	~	Dmnl
	~		|

Perc Change in In Scope Emissions due to Electricity Exports=
	IF THEN ELSE(
	  BIEfEE Boolean Include Emissions from Exported Electricity > 0,
	
	  0,
	
	  -Percentage of Generated Electricity that is Exported
	)
	~	Dmnl
	~		|

Perc Change in New Component Energy Cost per Unit Area[Building Type,Building Fuel,Building Component\
		]=
	( (1 + Perc Change in New Component Energy Use per Unit Floor Area[Building Type,Building Fuel\
		,Building Component])
	  * (1 + Perc Change in Buildings Fuel Cost per Unit Energy[Building Type,Building Fuel\
		])
	)
	- 1
	~	Dmnl
	~	The coefficient for change in energy cost per unit service provided is 1 + \
		the percent change in energy efficiency multiplied by 1 + the percent \
		change in energy cost.  I'm using a percent change for clarity to model \
		viewers, so I add this coefficient to 1.  For example, if energy use per \
		service drops by 20% and energy cost drops by 20%, the change in energy \
		cost per service is (0.8 * 0.8) - 1 = 0.64 - 1 = -0.36.
	|

Perc Change in New Component Energy Use due to Price Efficiency Feedbacks[Building Type\
		,Building Fuel,Building Component] :EXCEPT: [Building Type,Building Fuel,envelope]=
	Perc Change in New Component Energy Cost per Unit Area[Building Type,Building Fuel,Building Component\
		]
	* EoCEDwEC Elasticity of Component Energy Demand wrt Energy Cost[Building Fuel,Building Type\
		] ~~|
Perc Change in New Component Energy Use due to Price Efficiency Feedbacks[Building Type\
		,Building Fuel,envelope]=
	0
	~	Dmnl
	~	This change is due to people buying more efficient components.  People \
		using their component less often is handled later in the model.  Note that \
		envelope here is always zero (unaffected) because our data source provides \
		for overall energy reductions by fuel type (thus incorporating the effects \
		of any envelope improvements), so it would double-count these reductions \
		if we were to reduce heating/cooling as well as the envelope multiplier \
		here.
	|

Perc Change in New Component Energy Use per Unit Floor Area[Building Type,Building Fuel\
		,Building Component]=
	ZIDZ(
	  New Components Potential Energy Use after Quality Level Shifts[Building Type,Building Fuel\
		,Building Component]
	  - BAU New Components Energy Use[Building Type,Building Fuel,Building Component],
	
	  BAU New Components Energy Use[Building Type,Building Fuel,Building Component]
	)
	~	Dmnl
	~		|

Perc Change in New LDV Fuel Economy due to Feebate=
	LDVs Feebate Rate This Year
	* EoFoNVFE Effect of Feebate on New Veh Fuel Economy
	~	Dmnl
	~		|

Perc Change in New Vehicle Fuel Economy[Vehicle Type,Cargo Type,Vehicle Technology]=
	ZIDZ(
	  New Vehicle Fuel Economy[Vehicle Type,Cargo Type,Vehicle Technology]
	  - BNVFE BAU New Vehicle Fuel Economy[Vehicle Type,Cargo Type,Vehicle Technology],
	
	  BNVFE BAU New Vehicle Fuel Economy[Vehicle Type,Cargo Type,Vehicle Technology]
	)
	~	Dmnl
	~		|

Perc Change in Sectoral Energy Use due to Exogenous GDP Adjustment[Sectors]=
	MAX(
	  -1,
	
	  Exogenous GDP Growth Rate Adjustment
	  * EoSEUwGDPiR Elasticity of Sectoral Energy Use with respect to GDP in Recession[Sectors\
		]
	)
	~	Dmnl
	~		|

Perc Change in Transportation Fuel Cost per Unit Energy[Transportation Fuel]=
	QUANTUM(
	  ZIDZ(
	    Transportation Fuel Cost per Unit Energy[Transportation Fuel]
	    - BAU Transportation Fuel Cost per Unit Energy[Transportation Fuel],
	
	    BAU Transportation Fuel Cost per Unit Energy[Transportation Fuel]
	  ),
	
	  Quantization Size for Percentage Changes
	)
	~	Dmnl
	~		|

