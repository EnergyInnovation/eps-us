Non BAU Process Emissions Additions in CO2e at BAU Production Levels[Industry by Process Emissions Policy\
		]=
	IF THEN ELSE(
	
	  Boolean Use Non BAU Process Emissions Additions This Year[Industry by Process Emissions Policy\
		] > 0,
	
	  SUM(PEAAC Mass CO2e Additions and Costs[Industry by Process Emissions Policy,Marginal Abatement Cost\
		!]),
	
	  0
	)
	~	g CO2e
	~		|

Non Fossil Primary Energy=
	Total Primary Energy Use[nuclear]
	+ Total Primary Energy Use[hydro]
	+ Total Primary Energy Use[wind]
	+ Total Primary Energy Use[solar]
	+ Total Primary Energy Use[biomass]
	~	BTU
	~		|

Non RPS Qualifying Guaranteed Dispatch Amount[Electricity Source,Electricity Timeslice\
		,Hour,Clean Elec Requirement]=
	Expected Capacity by Hour[Electricity Source,Electricity Timeslice,Hour]
	 * Guaranteed Dispatch Percentages for Policy Case[Electricity Source]
	 * (1 - Elec Portfolio Qualifying Sources[Electricity Source,Clean Elec Requirement]\
		)
	 *One Hour
	~	MW*hr
	~		|

Non RPS Qualifying Guaranteed Dispatch Amount after RPS Policy[Electricity Source,Electricity Timeslice\
		,Hour,Clean Elec Requirement]=
	MIN(
	
	  Non RPS Qualifying Guaranteed Dispatch Amount[Electricity Source,Electricity Timeslice\
		,Hour,Clean Elec Requirement]
	    * MIN(
	    1,
	
	    ZIDZ(
	      Total Electricity Demand by Hour After Demand Altering Technologies[Electricity Timeslice\
		,Hour]
	      * (1 - Legally Required Elec Portfolio Percentage[Clean Elec Requirement]),      
	
	      Non RPS Qualifying Guaranteed Dispatch Amount[Electricity Source,Electricity Timeslice\
		,Hour,Clean Elec Requirement]
	    )
	  ),
	
	Non RPS Qualifying Guaranteed Dispatch Amount[Electricity Source,Electricity Timeslice\
		,Hour,Clean Elec Requirement]
	    * MIN(
	    1,
	
	    ZIDZ(
	      Total Electricity Demand by Hour After Demand Altering Technologies[Electricity Timeslice\
		,Hour]
	      * (1 - Legally Required Elec Portfolio Percentage[Clean Elec Requirement]),      
	
	      Non RPS Qualifying Guaranteed Dispatch Amount[Electricity Source,Electricity Timeslice\
		,Hour,Clean Elec Requirement]
	    )
	  )
	)
	~	MW*hr
	~		|

