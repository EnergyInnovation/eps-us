	  Profitable Capacity as Share of Existing Capacity for Cost Effectiveness Additions for Hybrid Power Plants\
		[Hybrid Electricity Source
	,Optimization Pass,RPS] = :NA:,
	
	  0,
	
	  MAX(0,Profitable Capacity as Share of Existing Capacity for Cost Effectiveness Additions for Hybrid Power Plants\
		[Hybrid Electricity Source,Optimization Pass,RPS]
	    * MAX(
