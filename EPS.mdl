Additional Fuel Tax or Subsidy Rate by Fuel by Year from Policy Setting[All Fuels,Sectors\
		,Future Year]=
	Additional Fuel Tax or Subsidy Rate by Fuel[All Fuels,Sectors]
	
	* VECTOR ELM MAP(
	    Selected Policy Implementation Schedule for Future Years[cross fuel tax X electricity X transportation sector\
		,Future Year
	],
	
	    ((All Fuels-1)*ELMCOUNT(Sectors) + (Sectors-1))*ELMCOUNT(Future Year)
	  )
	~	Dmnl
	~		|

Additional Fuel Tax or Subsidy Rate by Fuel This Year[All Fuels,Sectors]=
	Additional Fuel Tax or Subsidy Rate by Fuel[All Fuels,Sectors]
	* VECTOR ELM MAP(
	    Selected Policy Implementation Schedule[cross fuel tax X electricity X transportation sector\
		],
	
	    (All Fuels-1)*ELMCOUNT(Sectors) + (Sectors - 1)
	  )
	~	Dmnl
	~		|

Additional Fuel Use by Fuel and Technology due to LCFS with Elec Eff Adj[Vehicle Type\
		,Cargo Type,Vehicle Technology,Transportation Fuel]=
	ZIDZ(
	  Additional Carbon Free Energy Allocated by Fuel and Technology[Vehicle Type,Cargo Type\
		,Vehicle Technology,Transportation Fuel],
	  (1 - Carbon Intensity Ratios by Transportation Fuel[Transportation Fuel])
	)
	~	BTU
	~		|

