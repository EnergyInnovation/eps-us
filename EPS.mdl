Fuel Balancing Mode:
	production,
	imports,
	exports
	~	
	~		|

Fuel Cost per Unit Cargo Dist[Vehicle Type,Cargo Type,Vehicle Technology]=
	ZIDZ(
	  Weighted Avg Fuel Cost per Unit Energy by Vehicle Technology[Vehicle Type,Cargo Type\
		,Vehicle Technology],
	
	  Last Year Fleet Avg Fuel Economy[Vehicle Type,Cargo Type,Vehicle Technology]
	)
	~	$/(thing*mile)
	~		|

Fuel Cost per Unit Output for Plants Built This Year[Electricity Source]=
	Heat Rate by Electricity Fuel for Plants Built This Year[Electricity Source]
	* Electricity Fuel Cost per Unit Energy[Electricity Source]
	~	$/(MW*hour)
	~		|

Fuel Export Revenue[All Fuels]=
	Fuel Exports[All Fuels]
	* IMFPbFT International Market Fuel Price by Fuel Type[All Fuels]
	~	$
	~		|

Fuel Exports[All Fuels]=
	BAU Fuel Production Imports and Exports[All Fuels,exports]
	+ Change in Fuel Exports[All Fuels]
	~	BTU
	~		|

Fuel Imbalance after First Priority Balancing[All Fuels]=
	QUANTUM(
	  BAU Fuel Production Imports and Exports after First Priority Balancing[All Fuels,production\
		]
	    + BAU Fuel Production Imports and Exports after First Priority Balancing[All Fuels\
		,imports]
	    - BAU Fuel Production Imports and Exports after First Priority Balancing[All Fuels\
		,exports]
	    - BAU Total Energy Use[All Fuels],
	
	  QSfE Quantization Size for Energy
	)
	~	BTU
	~	C = P + I - E
		0 = P + I - E - C
	|

Fuel Imbalance after Second Priority Balancing[All Fuels]=
	QUANTUM(
	  BAU Fuel Production Imports and Exports after Second Priority Balancing[All Fuels,\
		production]
	    + BAU Fuel Production Imports and Exports after Second Priority Balancing[All Fuels\
		,imports]
	    - BAU Fuel Production Imports and Exports after Second Priority Balancing[All Fuels\
		,exports]
	    - BAU Total Energy Use[All Fuels],
	
	  QSfE Quantization Size for Energy
	)
	~	BTU
	~		|

Fuel Import Cap[All Fuels]=
	Initial BAU Fuel Production Imports and Exports[All Fuels,imports]
	+ Maximum Absolute Increase in Fuel Imports[All Fuels]
	~	BTU
	~		|

Fuel Import Expenditures[All Fuels]=
	Fuel Imports[All Fuels]
	* IMFPbFT International Market Fuel Price by Fuel Type[All Fuels]
	~	$
	~		|

Fuel Imports[All Fuels]=
	BAU Fuel Production Imports and Exports[All Fuels,imports]
	+ Change in Fuel Imports[All Fuels]
	~	BTU
	~		|

Fuel Price Deregulation[All Fuels]=
	0,	{electricity - NOT USED}
	0,	{hard coal}
	0,	{natural gas}
	0,	{nuclear}
	0,	{hydro - NOT USED}
	0,	{wind - NOT USED}
	0,	{solar - NOT USED}
	0,	{biomass}
	0,	{petroleum gasoline}
	0,	{petroleum diesel}
	0,	{biofuel gasoline}
	0,	{biofuel diesel}
	0,	{jet fuel or kerosene}
	0,	{heat - NOT USED}
	0,	{geothermal - NOT USED}
	0,	{lignite}
	0,	{crude oil}
	0,	{heavy or residual fuel oil}
	0,	{LPG propane or butane}
	0,	{municipal solid waste}
	0	{hydrogen}
	~	Dmnl [0,1]
	~		|

