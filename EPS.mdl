Shortfall in Electricity vs Daily Average by Hour after Seasonal Net Peak Load Reduction\
		[Electricity Timeslice,Hour]=
	MAX(
	  0,
	
	  Daily Average Hourly Spare Potential Output from Surviving Capacity[Electricity Timeslice\
		]
	  - Spare Potential Output from Surviving Capacity by Hour after Seasonal Net Peak Load Reduction\
		[Electricity Timeslice,Hour]
	)
	~	MW*hr
	~		|

Shortfall in Potential Output from Surviving Capacity vs Annual Average by Hour[Electricity Timeslice\
		,Hour]=
	MAX(
	  0,
	
	  Annual Average Hourly Spare Potential Output from Surviving Capacity
	  - Spare Potential Output from Surviving Capacity by Hour[Electricity Timeslice,Hour\
		]
	)
	~	MW*hr
	~		|

Slope of Line Approaching Future Elec Portfolio Percentages by Year[Future Year,Clean Elec Requirement\
		]=
	IF THEN ELSE(
	  Time > Numerical Future Year Definitions[Future Year]
	  :OR:
	  FINAL TIME < Numerical Future Year Definitions[Future Year],
	
	  -9999,
	
	  IF THEN ELSE(
	    Do Producers Have Foresight to Future NonBAU Elec Portfolio Values = 0
	    :OR:
	    Dimensionless Time < FYIbFP First Year Impacted by Future Policies,
	
	    (BAU Weighted Average Elec Portfolio Percentage by Year[Future Year,Clean Elec Requirement\
		]
	      - Elec Portfolio Percentage that Would be Achieved with Only Surviving Plants[\
		Clean Elec Requirement])
	    / (Numerical Future Year Definitions[Future Year] - Time + 1) * One Year,
	
	    (Weighted Average Elec Portfolio Percentage by Year[Future Year,Clean Elec Requirement\
		]
	      - Elec Portfolio Percentage that Would be Achieved with Only Surviving Plants[\
		Clean Elec Requirement])
	    / (Numerical Future Year Definitions[Future Year] - Time + 1) * One Year
	  )
	)
	~	Dmnl
	~	We use -9999 for slopes of lines approaching points that are not in the \
		future, because we are going to choose the highest slope to any future \
		point, and we don't want any slopes that are not to future points to be \
		selected.  Note that we haven't built for the current model year yet in \
		the calculation flow, so the current model year counts as being in the \
		future.  Also note that in order to prevent the policy case line from \
		diverging from the BAU line in years prior to the first year policies take \
		effect (which is often a year in the past), we only give electricity \
		producers foresignt to BAU RPS values in years when the additional RPS \
		policy is not in effect (thus mirroring BAU case foresight).
	|

Smoothed Green Hydrogen Cost=
	IF THEN ELSE(
	  Time = INITIAL TIME,
	
	  This Year Green Hydrogen Cost,
	
	  Two Year Average Green Hydrogen Cost
	)
	~	$/BTU
	~		|

Smoothed Low Carbon Hydrogen Cost=
	IF THEN ELSE(
	  Time = INITIAL TIME,
	
	  This Year Low Carbon Hydrogen Cost,
	
	  Two Year Average Low Carbon Hydrogen Cost
	)
	~	$/BTU
	~		|

Smoothed Nonenergy Industry Expenses Passed Through ro Buyers by Producer ISIC Code with VAT or Sales Tax Removed Helper Variable\
		[ISIC Code]=
	DEPRECIATE STRAIGHTLINE(
	  Nonenergy Industry Expenses Passed Through to Buyers by Producer ISIC Code with VAT or Sales Tax Removed\
		[ISIC Code],
	  Smoothing Time for Passthrough Expense Impacts on Industrial Production,
	  1,
	  0
	)
	~	$
	~		|

Smoothed Nonenergy Industry Expenses Passed Through to Buyers by Producer ISIC Code with VAT or Sales Tax Removed\
		[ISIC Code]=
	Smoothed Nonenergy Industry Expenses Passed Through ro Buyers by Producer ISIC Code with VAT or Sales Tax Removed Helper Variable\
		[ISIC Code
	]
	*
	MAX(
	  ZIDZ(
	    Smoothing Time for Passthrough Expense Impacts on Industrial Production,
	    Time - INITIAL TIME + 1
	  ),
	  1
	)
	~	$
	~		|

Smoothed Other Hydrogen Cost=
	IF THEN ELSE(
	  Time = INITIAL TIME,
	
	  This Year Other Hydrogen Cost,
	
	  Two Year Average Other Hydrogen Cost
	)
	~	$/BTU
	~		|

Smoothing Time for Passthrough Expense Impacts on Industrial Production=
	4
	~	Year [2,5,1]
	~		|

