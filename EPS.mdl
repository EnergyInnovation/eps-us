Marginal Capacity Factor by Hour[Electricity Source,Electricity Timeslice,Hour,Clean Elec Requirement\
		]=
	IF THEN ELSE(
	  Time = INITIAL TIME
	
	  :OR:
	
	   ABS(Last Year Electricity Generation Capacity[Electricity Source])*MW Tolerance Unit Correction Factor\
		 < Tolerance,
	
	  Last Year Weighted Average Expected Capacity Factors by Hour Without Hypothetical Adjustments\
		[Electricity Source,Electricity Timeslice,Hour]
	  *  IF THEN ELSE(
	    SUM(
	      Last Year Weighted Average Expected Capacity Factors by Hour Without Hypothetical Adjustments\
		[Electricity Source!,Electricity Timeslice,Hour]
	      * Last Year Electricity Generation Capacity[Electricity Source!]
	      * Elec Portfolio Qualifying Sources[Electricity Source!,Clean Elec Requirement\
		]
	    )
	    < Last Year Total Electricity Demand by Hour After Demand Altering Technologies[\
		Electricity Timeslice,Hour]/One Hour
	,
	
	    1,
	
	    0),
	         
	
	  IF THEN ELSE(
	    SUM(
	      Last Year Weighted Average Expected Capacity Factors by Hour Without Hypothetical Adjustments\
		[Electricity Source!,Electricity Timeslice,Hour]
	      * Last Year Electricity Generation Capacity[Electricity Source!]
	      * Elec Portfolio Qualifying Sources[Electricity Source!,Clean Elec Requirement\
		]
	    )
	    < Last Year Total Electricity Demand by Hour After Demand Altering Technologies[\
		Electricity Timeslice,Hour]/One Hour
	,
	
	Last Year Weighted Average Expected Capacity Factors by Hour Without Hypothetical Adjustments\
		[Electricity Source,Electricity Timeslice,Hour]
	    ,
	
	    0
	  )
	)
	~	Dmnl
	~		|

Marginal Capacity Factor x Hours per Year[Electricity Source,Clean Elec Requirement]=
	SUM(
	  Marginal Capacity Factor by Hour[Electricity Source,Electricity Timeslice!,Hour!,Clean Elec Requirement\
		]
	  * SHELF Days per Electricity Timeslice[Electricity Timeslice!]
	  * One Hour
	)
	~	hours
	~		|

Marginal Dispatch Cost by Hour[Electricity Timeslice,Hour]=
	IF THEN ELSE(ABS(SUM(Total Electricity Dispatched by Hour by Plant Type[Electricity Timeslice\
		,Hour,Electricity Source!]
	))*MWhr Tolerance Unit Correction Factor < Tolerance,EIaE Imported Electricity Price\
		,
	  IF THEN ELSE(
	    ABS(Electricity Market Price Adjusted for Zero Least Cost Dispatch Hours[Electricity Timeslice\
		,Hour])*Dollar per MWhr Tolerance Unit Correction Factor
	 < Tolerance
	    :OR: ABS(SUM(Electricity Dispatched by Least Cost by Hour[Electricity Timeslice,\
		Hour,Electricity Source!]))*MWhr Tolerance Unit Correction Factor
	 < Tolerance
	,
	
	    SUM(Dispatch Cost per Unit Electricity Output[Electricity Source!]*Share of Total Electricity Dispatched by Hour by Plant Type\
		[Electricity Timeslice,Hour,Electricity Source!]),
	
	    Electricity Market Price Adjusted for Zero Least Cost Dispatch Hours[Electricity Timeslice\
		,Hour]
	  )
	)
	~	$/(MW*hour)
	~		|

