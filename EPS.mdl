	age 55to64,
	age 65plus
	~	
	~		|

Aggregate Decrease in Demand by Timeslice for Seasonal Net Peak Load Reduction[Electricity Timeslice\
		]=
	SUM(Aggregate Increase in Demand by Timeslice for Seasonal Net Peak Load Reduction[Electricity Timeslice\
		!])
	* Weighted Average Round Trip Efficiency for Seasonal Shifting
	* ZIDZ(
	    Aggregate Shortfall in Potential Output from Surviving Capacity vs Average[Electricity Timeslice\
		],
	    SUM(Aggregate Shortfall in Potential Output from Surviving Capacity vs Average[Electricity Timeslice\
		!])
	  )
	~	MW*hr
	~		|

Aggregate Excess Potential Output from Surviving Capacity vs Average[Electricity Timeslice\
		]=
	SUM(Excess Potential Output from Surviving Capacity vs Annual Average by Hour[Electricity Timeslice\
		,Hour!])
	* SHELF Days per Electricity Timeslice[Electricity Timeslice]
	~	MW*hr
	~		|

Aggregate Increase in Demand by Timeslice for Seasonal Net Peak Load Reduction[Electricity Timeslice\
		]=
	MIN(
	  Maximum Annual Quantity of Electricity Absorbed for Seasonal Net Peak Load Reduction
	  * ZIDZ(
	      Aggregate Excess Potential Output from Surviving Capacity vs Average[Electricity Timeslice\
		],
	      SUM(Aggregate Excess Potential Output from Surviving Capacity vs Average[Electricity Timeslice\
		!])
	    ),
	
	  Aggregate Excess Potential Output from Surviving Capacity vs Average[Electricity Timeslice\
		]
	)
	~	MW*hr
	~		|

Aggregate Shortfall in Potential Output from Surviving Capacity vs Average[Electricity Timeslice\
		]=
	SUM(Shortfall in Potential Output from Surviving Capacity vs Annual Average by Hour[\
		Electricity Timeslice,Hour!])
	* SHELF Days per Electricity Timeslice[Electricity Timeslice]
	~	MW*hr
	~		|

Agriculture CO2e Emissions[Pollutant]=
	Industrial Sector Pollutant Emissions[agriculture and forestry 01T03,Pollutant]
	* GWP by Pollutant[Pollutant]
	~	g CO2e
	~		|

Agriculture Pollutant Emissions[Pollutant]=
	Industrial Sector Pollutant Emissions[agriculture and forestry 01T03,Pollutant]
	~	g pollutant
	~		|

AIiBCbVT Annual Improvement in Battery Capacity by Vehicle Type[Cargo Type,Vehicle Type\
		,Vehicle Technology] :EXCEPT:   [Cargo Type
,Vehicle Type,battery electric vehicle],[Cargo Type,Vehicle Type,plugin hybrid vehicle\
		]=
	0 ~~|
AIiBCbVT Annual Improvement in Battery Capacity by Vehicle Type[passenger,Vehicle Type\
		,battery electric vehicle]:=
	GET DIRECT DATA(
	   'InputData/trans/AIiBCbVT/AIiBCbVT-passenger-bev.csv',
	   ',',
	   '1',
	   'B2'
	) ~~|
AIiBCbVT Annual Improvement in Battery Capacity by Vehicle Type[passenger,Vehicle Type\
		,plugin hybrid vehicle]:=
	GET DIRECT DATA(
	   'InputData/trans/AIiBCbVT/AIiBCbVT-passenger-phev.csv',
	   ',',
	   '1',
	   'B2'
	) ~~|
AIiBCbVT Annual Improvement in Battery Capacity by Vehicle Type[freight,Vehicle Type,\
		battery electric vehicle]:=
	GET DIRECT DATA(
	   'InputData/trans/AIiBCbVT/AIiBCbVT-freight-bev.csv',
	   ',',
	   '1',
	   'B2'
	) ~~|
AIiBCbVT Annual Improvement in Battery Capacity by Vehicle Type[freight,Vehicle Type,\
		plugin hybrid vehicle]:=
	GET DIRECT DATA(
	   'InputData/trans/AIiBCbVT/AIiBCbVT-freight-phev.csv',
	   ',',
	   '1',
	   'B2'
	)
	~	Dmnl
	~		|

All Fuels:
	electricity,
	hard coal,
	natural gas,
	nuclear,
	hydro,
	wind,
	solar,
	biomass,
	petroleum gasoline,
	petroleum diesel,
	biofuel gasoline,
	biofuel diesel,
	jet fuel or kerosene,
	heat,
	geothermal,
	lignite,
	crude oil,
	heavy or residual fuel oil,
	LPG propane or butane,
	municipal solid waste,
	hydrogen
	~	
	~	We create sub-ranges of All Fuels that match each sector's set of fuels \
		and map these sub-ranges to that sector, to simplify some equations.  (We \
		can't use the sub-ranges directly within each sector, as the ALLOCATE \
		AVAILABLE() function isn't compatible with sub-ranges.)
	|

Allocation Priority for Marginal Cost Buckets[Marginal Abatement Cost]=
	VMAX(PERAC Marginal Cost Definitions[Marginal Abatement Cost!])
	- PERAC Marginal Cost Definitions[Marginal Abatement Cost]
	~	$/metric ton CO2e
	~	This variable establishes the priority by which marginal cost buckets are \
		filled. The absolute value is not significant; the higher abatement cost \
		buckets simply need higher values to make sure they are filled last (the \
		cheapest abatement opportunities will be employed first).
	|

Amortized Decommissioning Costs=
	DEPRECIATE STRAIGHTLINE(Decommissioning Costs, Payment Period for Decommissioning Costs\
		, 1, 0)
	~	$
	~		|

Amount of CO2 Sequestered by Electricity Sector[Electricity Source]=
	This Year Pollutants Sequestered by Electricity Sector[CO2,Electricity Source]
	/ Grams per Metric Ton CO2e
	* GWP by Pollutant[CO2] {necessary for unit correction}
	~	metric tons CO2e
	~		|

Amount of CO2 Sequestered by Hydrogen Sector=
	This Year Pollutants Sequestered by Hydrogen Sector[CO2]
	/ Grams per Metric Ton CO2e
	* GWP by Pollutant[CO2] {necessary for unit correction}
	~	metric tons CO2e
	~		|

Amount of CO2 Sequestered by Industry Sector[Industry Category]=
	SUM(This Year Pollutants Sequestered by Industry Sector[Industry Category,CO2,Emissions Type\
		!])
	/ Grams per Metric Ton CO2e
	* GWP by Pollutant[CO2] {necessary for unit correction}
	~	metric tons CO2e
	~		|

Amount Received from Exporting Electricity=
	SUM(
	  Electricity Exports by Hour[Electricity Timeslice!,Hour!,last pass!]
	  * SHELF Days per Electricity Timeslice[Electricity Timeslice!]
	  * Marginal Dispatch Cost by Hour[Electricity Timeslice!,Hour!]
	)
	~	$
	~		|

Amount Spent on Buildings Fuels[Building Type,Building Fuel]=
	Building Components Energy Use Excluding Zero Cost Distributed Fuel Use[Building Type\
		,Building Fuel]
	* Buildings Fuel Cost per Unit Energy[Building Fuel,Building Type]
	~	$
	~		|

Amount Spent on Distributed Solar Capacity[Building Type]=
	This Year Change in Distributed Electricity Source Capacity[Building Type,solar PV es\
		]
	* Cost per Unit Distributed Solar Capacity
	~	$
	~		|

Amount Spent on District Heating Fuels[Industrial Fuel]=
	Fuel Used to Generate Heat[Industrial Fuel]
	* District Heat Fuel Cost per Unit Energy[Industrial Fuel]
	~	$
	~		|

Amount Spent on Electricity Fuels[Electricity Source]=
	Electricity Fuel Use[Electricity Source]
	* Electricity Fuel Cost per Unit Energy[Electricity Source]
	~	$
	~		|

Amount Spent on Geoengineering Fuels[Industrial Fuel]=
	QUANTUM(
	  Geoengineering Sector Energy Use[Industrial Fuel]
	  * Geoengineering Fuel Cost per Unit Energy[Industrial Fuel],
	
	  QSfCF Quantization Size for Cash Flows
	)
	~	$
	~		|

Amount Spent on Grid Batteries=
	(New Grid Battery Capacity+Policy Mandated Grid Battery Storage Additions)
	* Total Battery Cost per Unit Capacity
	~	$
	~		|

Amount Spent on Hydrogen Production Capital Eqpt[Hydrogen Production Pathway]=
	MAX(
	  0,
	
	  This Year Change in Hydrogen Produced by Pathway[Hydrogen Production Pathway]
	  * Hydrogen Production Equipment CapEx[Hydrogen Production Pathway]
	  * (1 + HPPECbP Hydrogen Production Percent Excess Capacity by Pathway[Hydrogen Production Pathway\
		])
	)
	~	$
	~		|

Amount Spent on Hydrogen Production OpEx[Hydrogen Production Pathway]=
	Hydrogen Production by Pathway[Hydrogen Production Pathway]
	* HPEC Hydrogen Production Equipment OpEx[Hydrogen Production Pathway]
	* (1 + HPPECbP Hydrogen Production Percent Excess Capacity by Pathway[Hydrogen Production Pathway\
		])
	~	$
	~		|

Amount Spent on Hydrogen Sector Fuels[Industrial Fuel]=
	Hydrogen Sector Fuel Use[Industrial Fuel]
	* Hydrogen Fuel Cost per Unit Energy[Industrial Fuel]
	~	$
	~		|

Amount Spent on Importing Electricity=
	Imported Electricity
	* EIaE Imported Electricity Price
	~	$
	~		|

Amount Spent on Industry Fuels[Industry Category,Industrial Fuel]=
	Industrial Fuel Use for Energy Purposes[Industrial Fuel,Industry Category]
	  * Industrial Fuel Cost per Unit Energy[Industry Category,Industrial Fuel]
	  * (1 - SoFCTiBoSFbI Share of Fuel Consumption That is Byproduct or Secondary Fuels by Industry\
		[Industry Category,Industrial Fuel])
	
	+ Industrial Fuel Use for Non Energy Purposes[Industry Category,Industrial Fuel]
	  * (
	      Industrial Fuel Cost per Unit Energy[Industry Category,Industrial Fuel]
	      - Industrial Fuel Carbon Tax Amount per Unit Energy[Industry Category,Industrial Fuel\
		]
	    )
	~	$
	~		|

Amount Spent on New Building Components[Building Type,Building Component]=
	BASoBC BAU Amount Spent on Building Components[Building Type,Building Component]
	* (1 + Percent Change in Components Energy Use[Building Type,Building Component]
	       * EoCPwEU Elasticity of Component Price wrt Energy Use[Building Component,Building Type\
		])
	* (1 - RnD Building Capital Cost Perc Reduction This Year[Building Component])
	
	+ Incremental Amount Spent to Buy Electrified Building Components[Building Type,Building Component\
		]
	~	$
	~		|

Amount Spent on Parking[Vehicle Type,Cargo Type,Vehicle Technology]=
	Vehicles[Vehicle Type,Cargo Type,Vehicle Technology]
	* AVPC Annual Vehicle Parking Cost[Vehicle Type,Cargo Type]
	~	$
	~		|

Amount Spent on Rebate Qualifying Components[Building Type,Building Component]=
	Amount Spent on New Building Components[Building Type,Building Component]
	* Fraction New Components by Quality Level[Building Type,Building Component,rebate qualifying\
		]
	~	$
	~		|

Amount Spent on Retrofitting Buildings[Building Type,Building Component]=
	Energy Use Reduction from Buildings Retrofit This Year[Building Type,Building Component\
		]
	* BRESaC Retrofitting Cost per Unit Energy Saved[Building Type,Building Component]
	* (1 - RnD Building Capital Cost Perc Reduction This Year[Building Component])
	~	$
	~		|

Amount Spent on Transportation Fuels[Transportation Fuel,Vehicle Type,Cargo Type,Vehicle Technology\
		]=
	Transportation Sector Fuel Used[Vehicle Type,Cargo Type,Vehicle Technology,Transportation Fuel\
		]
	* Transportation Fuel Cost per Unit Energy[Transportation Fuel]
	~	$
	~		|

Amount Spent on Vehicle Batteries[Vehicle Type,Cargo Type,Vehicle Technology]=
	New Vehicles[Vehicle Type,Cargo Type,Vehicle Technology] * One Year
	* This Year Battery Capacity by Vehicle Type[Cargo Type,Vehicle Type,Vehicle Technology\
		]
	* This Year Battery Manufacturing Price Before Subsidies
	~	$
	~		|

Amount Spent on Vehicle Insurance[Vehicle Type,Cargo Type,Vehicle Technology]=
	Vehicles[Vehicle Type,Cargo Type,Vehicle Technology]
	* AVIC Annual Vehicle Insurance Cost[Vehicle Type,Cargo Type]
	~	$
	~		|

Amount Spent on Vehicle Licensing Registration and Property Tax[Vehicle Type,Cargo Type\
		,Vehicle Technology]=
	Vehicles[Vehicle Type,Cargo Type,Vehicle Technology]
	* AVLRaPTC Annual Vehicle Licensing Registration and Property Tax Costs[Vehicle Type\
		,Cargo Type]
	~	$
	~		|

Amount Spent on Vehicle Maintenance[Vehicle Type,Cargo Type,Vehicle Technology]=
	Vehicles[Vehicle Type,Cargo Type,Vehicle Technology]
	* AVMC Annual Vehicle Maintenance Cost[Vehicle Type,Cargo Type,Vehicle Technology]
	~	$
	~		|

Amount Spent on Vehicle Manufacturing Excluding Batteries[Vehicle Type,Cargo Type,Vehicle Technology\
		]=
	New Vehicles[Vehicle Type,Cargo Type,Vehicle Technology] 
	* One Year
	* (New Vehicle Price after RnD Without Subsidies[Cargo Type,Vehicle Type,Vehicle Technology\
		]
	   / RPEF Retail Price Equivalent Factor[Cargo Type,Vehicle Type]
	  )
	- Amount Spent on Vehicle Batteries[Vehicle Type,Cargo Type,Vehicle Technology]
	~	$
	~		|

Amount Spent on Vehicle Markups[Vehicle Type,Cargo Type,Vehicle Technology]=
	New Vehicles[Vehicle Type,Cargo Type,Vehicle Technology]
	* One Year
	* New Vehicle Price after RnD Without Subsidies[Cargo Type,Vehicle Type,Vehicle Technology\
		]
	* (1 - 1 / RPEF Retail Price Equivalent Factor[Cargo Type,Vehicle Type])
	~	$
	~		|

Annual Additional Capacity Retired due to Early Retirement Policy[Electricity Source]\
		=
	0,	{hard coal}
	0,	{natural gas steam turbine}
	0,	{natural gas combined cycle}
	0,	{nuclear}
	0,	{hydro}
	0,	{onshore wind}
	0,	{solar PV}
	0,	{solar thermal}
	0,	{biomass}
	0,	{geothermal}
	0,	{petroleum}
	0,	{natural gas peaker}
	0,	{lignite}
	0,	{offshore wind}
	0,	{crude oil}
	0,	{heavy or residual fuel oil}
	0,	{municipal solid waste}
	0,      {hard coal w CCS}
	0,      {natural gas combined cycle w CCS}
	0,      {biomass w CCS}
	0,      {lignite w CCS}
	0,      {small modular reactor}
	0,      {hydrogen combustion turbine}
	0       {hydrogen combined cycle}
	~	MW [0,10000]
	~		|

Annual Additional Capacity Retired due to Early Retirement Policy This Year[Electricity Source\
		]=
	Annual Additional Capacity Retired due to Early Retirement Policy[Electricity Source\
		]
	* VECTOR ELM MAP(
	    Selected Policy Implementation Schedule[elec early retirement X hard coal es],
	
	    (Electricity Source-1)
	  )
	~	MW
	~		|

Annual Average Hourly Spare Potential Output from Surviving Capacity=
	ZIDZ(
	  SUM(
	    Spare Potential Output from Surviving Capacity by Hour[Electricity Timeslice!,Hour\
		!]
	    * SHELF Days per Electricity Timeslice[Electricity Timeslice!]
	  ),
	
	  SUM(SHELF Days per Electricity Timeslice[Electricity Timeslice!])
	  * ELMCOUNT(Hour)
	)
	~	MW*hr
	~		|

Annual Capacity Market Costs for Seasonal Dispatchable Reliability[Electricity Source\
		]=
	IF THEN ELSE(
	
	  Elec Portfolio Percentage to Seek This Year[RPS]=1,
	
	  Electricity Generation Capacity[Electricity Source]
	  * Capacity Market Price for Seasonal Dispatchable Reliability Adjusted for Availability\
		[Electricity Source
	]
	  * Elec Portfolio Qualifying Sources[Electricity Source,RPS]
	  * Days per Year
	  * One Day,
	
	  IF THEN ELSE(
	
	    Elec Portfolio Percentage to Seek This Year[CES]=1,
	
	    Electricity Generation Capacity[Electricity Source]
	    * Capacity Market Price for Seasonal Dispatchable Reliability Adjusted for Availability\
		[Electricity Source
	]
	    * Elec Portfolio Qualifying Sources[Electricity Source,CES]
	    * Days per Year
	    * One Day,
	
	    Electricity Generation Capacity[Electricity Source]
	    * Capacity Market Price for Seasonal Dispatchable Reliability Adjusted for Availability\
		[Electricity Source
	]
	    * Days per Year
	    * One Day
	   )
	)
	~	$
	~		|

Annual Cost Recovery for Capacity Construction and Retrofits=
	QUANTUM(
	  Annual Cost Recovery for New Capacity Construction and Retrofits
	  +Total Annual Cost Recovery for Historical Power Plant Construction Costs,
	
	  Quantization Size for Dollars
	)
	~	$
	~		|

Annual Cost Recovery for Historical Power Plant Construction Costs by Vintage[Modeled Vintage\
		]=
	DEPRECIATE STRAIGHTLINE(
	  Annual Financing Repayment for Historical Power Plant Construction Costs[Modeled Vintage\
		]
	  * Remaining Years of Repayment for Historical Capacity Additions[Modeled Vintage] \
		/ One Year,
	  Remaining Years of Repayment for Historical Capacity Additions[Modeled Vintage],
	  1,
	  0
	)
	~	$
	~		|

Annual Cost Recovery for New Capacity Construction and Retrofits=
	DEPRECIATE STRAIGHTLINE(
	
	  SUM((Cost of Capacity Construction before Construction Subsidies[Electricity Source\
		!]
	 +  Cost of Capacity Retrofitting before Construction Subsidies[Electricity Source!]
	  - Capacity Construction Subsidies Paid[Electricity Source!])
	
	  *Capital Recovery Factor for Power Plants[Electricity Source!])
	
	  *RPfFESCC Repayment Period for Financed Electricity Sector Capital Costs
	
	   /One Year,
	 
	  RPfFESCC Repayment Period for Financed Electricity Sector Capital Costs,
	
	  1,
	
	  0)
	~	$
	~		|

Annual Cost to Keep Generation Capacity Online Past Repayment Period=
	QUANTUM(
	  SUM(
	    Capacity Market Price for Seasonal Dispatchable Reliability Adjusted for Availability\
		[Electricity Source!]
	    * Generation Capacity Kept Online due to Predicted Capacity Payment[Electricity Source\
		!]
	    )
	  * Days per Year
	  * One Day,
	
	  Quantization Size for Dollars
	)
	~	$
	~		|

Annual Decrease in Demand from Load Shifting Technologies=
	SUM(
	  (Decrease in Demand by Hour for Diurnal Net Peak Load Reduction and RPS Compliance\
		[Electricity Timeslice!,Hour!]
	  + Decrease in Demand by Hour for Seasonal Net Peak Load Reduction[Electricity Timeslice\
		!,Hour!]
	  )
	  *SHELF Days per Electricity Timeslice[Electricity Timeslice!]
	)
	~	MW*hour
	~		|

Annual Decrease in Demand from Load Shifting Technologies Excluding Demand Response Programs\
		=
	Annual Decrease in Demand from Load Shifting Technologies
	- SUM(Maximum Daily Quantity of Electricity Reduced by Demand Response Programs[Electricity Timeslice\
		!]
	    * SHELF Days per Electricity Timeslice[Electricity Timeslice!]
	     )
	~	MW*hour
	~		|

Annual Electricity Dispatched by Guaranteed Dispatch[Electricity Source]=
	SUM(
	  Electricity Dispatched by Guaranteed Dispatch by Hour[Electricity Source,Electricity Timeslice\
		!,Hour!]
	  * SHELF Days per Electricity Timeslice[Electricity Timeslice!]
	)
	~	MW*hour
	~		|

Annual Electricity Dispatched by Least Cost[Electricity Source]=
	SUM(Electricity Dispatched by Least Cost by Hour[Electricity Timeslice!,Hour!,Electricity Source\
		]
	* SHELF Days per Electricity Timeslice[Electricity Timeslice!]
	)
	~	MW*hour
	~		|

Annual Electricity Dispatched to Meet Elec Portfolio Stds[Electricity Source]=
	SUM(
	  Electricity Dispatched to Meet Elec Portfolio Stds[Electricity Timeslice!,Hour!,Electricity Source\
		]
	  * SHELF Days per Electricity Timeslice[Electricity Timeslice!]
	)
	~	MW*hour
	~		|

Annual Financing Repayment for Historical Power Plant Construction Costs[Modeled Vintage\
		]=
	IF THEN ELSE(
	  Time = INITIAL TIME,
	  SUM(
	    Historical Power Plant Construction Costs[Electricity Source!,Modeled Vintage]
	    * Capital Recovery Factor for Power Plants[Electricity Source!]
	  ),
	  0
	)
	~	$
	~		|

Annual Financing Repayment for Newly Purchased Hydrogen Production Eqpt[Hydrogen Production Pathway\
		]=
	Amount Spent on Hydrogen Production Capital Eqpt[Hydrogen Production Pathway]
	* Capital Recovery Factor for Hydrogen Producers
	/ One Year
	~	$/Year
	~		|

Annual Financing Repayment for Newly Purchased Industrial CCS Equipment[Industry Category\
		]=
	CCS New Capital Eqpt Cost by Industry[Industry Category]
	* BAU Capital Recovery Factor for CCS by Industry Category[Industry Category]
	* SoICETAF Share of Industry Capital Expenditures That Are Financed[Industry Category\
		]
	~	$
	~		|

Annual Financing Repayment for Newly Purchased Industrial Equipment[Industry Category\
		,Industrial Process]=
	SUM(
	  Annuity Factor by Industry Fuel and Process[Industry Category,Industrial Fuel!,Industrial Process\
		]
	  * Industrial Equipment Capital Cost per Unit Energy Before Clean Heat Subsidy[Industry Category\
		,Industrial Fuel!,Industrial Process]
	  * New Industrial Equipment Potential Energy Use by Fuel Type and Process[Industry Category\
		,Industrial Fuel!,Industrial Process]
	)
	* SoICETAF Share of Industry Capital Expenditures That Are Financed[Industry Category\
		]
	~	$
	~		|

Annual Financing Repayment for Newly Purchased Waste Heat Recovery Equipment[Industry Category\
		]=
	New Waste Heat Recovery Equipment Capital Expenditures That Are Financed[Industry Category\
		]
	* Capital Recovery Factor for Financed Waste Heat Recovery Equipment[Industry Category\
		]
	/ One Year
	~	$/Year
	~		|

Annual Financing Repayment per Unit Capacity[Electricity Source]=
	Construction Cost per Unit Capacity after Construction Subsidies and Spur Line Construction\
		[Electricity Source]
	* Capital Recovery Factor for Power Plants[Electricity Source]
	~	$/MW
	~		|

Annual Financing Repayment per Unit Retrofitted Capacity[CCUS Electricity Source]=
	Capital Recovery Factor for Power Plants[CCUS Electricity Source]
	* CCaMC Power Plant CCS Retrofitting Costs[CCUS Electricity Source]
	~	$/MW
	~		|

Annual Financing Repayment per Unit Storage Capacity for Hybrid Power Plants[Electricity Source\
		]=
	Hybrid Battery Cost per Unit Power Plant Capacity after Construction Subsidies
	*Capital Recovery Factor for Power Plants[Electricity Source]
	~	$/MW
	~		|

Annual Financing Repayments for Hydrogen Production Eqpt Expiring This Year[Hydrogen Production Pathway\
		]= DELAY FIXED (
	Annual Financing Repayment for Newly Purchased Hydrogen Production Eqpt[Hydrogen Production Pathway\
		],
	RPfFHSCC Repayment Period for Financed Hydrogen Sector Capital Costs,
	0)
	~	$/Year
	~		|

Annual Five Year Average Electricity Dispatched by Least Cost[Electricity Source]=
	SUM(Five Year Average Electricity Dispatched by Least Cost by Hour[Electricity Timeslice\
		!,Hour!,Electricity Source]
	* SHELF Days per Electricity Timeslice[Electricity Timeslice!]
	)
	~	MW*hour
	~		|

Annual Fixed OM Cost per Unit Capacity for Plants Built This Year[Electricity Source]\
		=
	SUM(
	  CCaMC Annual Fixed OM Cost per Unit Capacity[Electricity Source,Modeled Vintage!]
	  * This Year Modeled Vintage Flag[Modeled Vintage!]
	)
	~	$/MW
	~		|

Annual Fuel Expenditures for a Vehicle Sold This Year[Vehicle Type,Cargo Type,Vehicle Technology\
		]=
	New Vehicle Fuel Cost per Unit Vehicle Distance[Vehicle Type,Cargo Type,Vehicle Technology\
		]
	* Average Annual Dist Traveled by Vehicle Type[Vehicle Type,Cargo Type,Vehicle Technology\
		]
	~	$/vehicle
	~		|

Annual Industrial CCS Equipment Financing Repayments Expiring After Repayment Period[\
		Industry Category]= DELAY FIXED (
	Annual Financing Repayment for Newly Purchased Industrial CCS Equipment[Industry Category\
		],
	RPfFISCC Repayment Period for Financed Industry Sector Capital Costs[other processes\
		],
	0)
	~	$
	~		|

Annual Industrial Equipment Financing Repayments Expiring After Repayment Period[Industry Category\
		,Industrial Process]= DELAY FIXED (
	Annual Financing Repayment for Newly Purchased Industrial Equipment[Industry Category\
		,Industrial Process],
	RPfFISCC Repayment Period for Financed Industry Sector Capital Costs[Industrial Process\
		],
	0)
	~	$
	~		|

Annual Industrial Equipment Financing Reqayments Expiring After Repayment Period[Industry Category\
		]= DELAY FIXED (
	Annual Financing Repayment for Newly Purchased Waste Heat Recovery Equipment[Industry Category\
		],
	RPfFISCC Repayment Period for Financed Industry Sector Capital Costs[other processes\
		],
	0)
	~	$/Year
	~		|

Annual Maximum Potential Electricity Output[Electricity Source]=
	SUM(Annual Maximum Potential Electricity Output by Hour[Electricity Source,Electricity Timeslice\
		!,Hour!])
	~	MW*hr
	~		|

Annual Maximum Potential Electricity Output by Hour[Electricity Source,Electricity Timeslice\
		,Hour]=
	Potential Capacity by Hour[Electricity Source,Electricity Timeslice,Hour]
	* SHELF Days per Electricity Timeslice[Electricity Timeslice] * One Hour
	~	MW*hr
	~		|

Annual Net Energy Market Revenue per MW by Power Plant Type[Electricity Source]=
	ZIDZ(SUM(Hourly Net Energy Market Revenue from Total Electricity Dispatched by Power Plant Type\
		[Electricity Timeslice!,Hour!,Electricity Source]*SHELF Days per Electricity Timeslice\
		[Electricity Timeslice!]),Electricity Generation Capacity[Electricity Source])
	~	$/MW
	~		|

Annual Output from Distributed Electricity Capacity[Electricity Source]=
	SUM(Hourly Output from Distributed Electricity Capacity by Building Type[Electricity Source\
		,Electricity Timeslice!,Hour!,Building Type!]*SHELF Days per Electricity Timeslice[\
		Electricity Timeslice!])
	~	MW*hr
	~		|

Annual Output from Distributed Electricity Capacity by Building Type[Electricity Source\
		,Building Type]=
	Annual Output from Distributed Electricity Capacity[Electricity Source]
	* ZIDZ(
	    Distributed Electricity Source Capacity[Building Type,Electricity Source],
	    SUM(Distributed Electricity Source Capacity[Building Type!,Electricity Source])
	  )
	~	MW*hour
	~		|

Annual Output from Diurnal Grid Batteries=
	Annual Decrease in Demand from Load Shifting Technologies Excluding Demand Response Programs
	*Share of Maximum Annual Decrease in Demand from Diurnal Grid Batteries
	~	MW*hour
	~		|

Annual Repayment for Financed Buildings Sector Capital Expenses[Building Type]=
	(Amount Spent on Distributed Solar Capacity[Building Type]
	- Subsidy Paid on Distributed Solar Capacity[Building Type]
	+ SUM(Amount Spent on Retrofitting Buildings[Building Type,Building Component!])
	- Subsidy Paid for Retrofitting Buildings[Building Type])
	* Capital Recovery Factor for Buildings Sector Investments
	~	$
	~		|

Annual Repayment for This Year Electricty Transmission Distribution and Storage Expenses\
		=
	(Distribution Construction Costs
	  + Transmission Construction Costs
	  +Amount Spent on Grid Batteries
	  -Subsidies Paid for New Grid Battery Construction
	  )
	* Capital Recovery Factor for Other Electricity Sector Investments
	~	$
	~		|

Annualized Fixed Costs per Unit New Capacity[Electricity Source]=
	Annual Fixed OM Cost per Unit Capacity for Plants Built This Year[Electricity Source\
		]
	+ Annual Financing Repayment per Unit Capacity[Electricity Source]
	~	$/MW
	~		|

Annualized Fixed Costs per Unit New Elec Output Using Expected Capacity Factors[Electricity Source\
		]=
	XIDZ(
	  Annualized Fixed Costs per Unit New Capacity[Electricity Source],
	
	  Expected Capacity Factor x Hours per Year for Plants Built This Year Without Hypothetical Calculations\
		[Electricity Source],
	
	 9999
	)
	~	$/(MW*hr)
	~		|

Annuity Factor by Industry Fuel and Process[Industry Category,Industrial Fuel,Industrial Process\
		]=
	ZIDZ(
	  Financing Interest Rate by Industry[Industry Category,Industrial Fuel,Industrial Process\
		]
	  * (1 + Financing Interest Rate by Industry[Industry Category,Industrial Fuel,Industrial Process\
		])^(RPfFISCC Repayment Period for Financed Industry Sector Capital Costs[Industrial Process\
		]
	 / One Year)
	,
	
	  (1 + Financing Interest Rate by Industry[Industry Category,Industrial Fuel,Industrial Process\
		])^(RPfFISCC Repayment Period for Financed Industry Sector Capital Costs[Industrial Process\
		]
	 / One Year)
	  - 1
	)
	~	Dmnl
	~		|

AOCoLUPpUA Annual Ongoing Cost of Land Use Policies per Unit Area[Land Use Policy]=
	GET DIRECT CONSTANTS(
	   'InputData/land/AOCoLUPpUA/AOCoLUPpUA.csv',
	   ',',
	   'B2*'
	)
	~	$/acre
	~		|

Available Capacity After Elec Portfolio Std Dispatch[Electricity Timeslice,Hour,Electricity Source\
		]=
	MAX(
	  0,
	
	  Available Capacity After Guaranteed Dispatch[Electricity Timeslice,Hour,Electricity Source\
		]
	  - Electricity Dispatched to Meet Elec Portfolio Stds[Electricity Timeslice,Hour,Electricity Source\
		]/ One Hour
	)
	~	MW
	~		|

Available Capacity After Guaranteed Dispatch[Electricity Timeslice,Hour,Electricity Source\
		]=
	MAX(
	  0,
	
	  Available Capacity by Hour[Electricity Source,Electricity Timeslice,Hour]
	  - Electricity Dispatched by Guaranteed Dispatch by Hour[Electricity Source,Electricity Timeslice\
		,Hour]/One Hour
	)
	~	MW
	~		|

Available Capacity by Hour[Electricity Source,Electricity Timeslice,Hour]=
	Electricity Generation Capacity[Electricity Source]
	* Hourly Bid Electricity Capacity Factors by Plant Type[Electricity Timeslice,Hour,Electricity Source\
		]
	* (1 - Share of Electricity Generation Capacity Built This Year[Electricity Source] \
		* TACFMfPBTY Time Adjusted Capacity Factor Multiplier for Plants Built This Year[Electricity Source\
		])
	~	MW
	~		|

Available Capacity for Least Cost Dispatch Mapped[Electricity Timeslice,Hour,Electricity Source\
		]=
	Available Capacity After Elec Portfolio Std Dispatch[Electricity Timeslice,Hour,Electricity Source\
		]
	* One Hour
	~	MW*hour
	~		|

AVCC Average Vehicle Charger Capacity[Vehicle Type,Cargo Type]=
	GET DIRECT CONSTANTS(
	   'InputData/trans/AVCC/AVCC.csv',
	   ',',
	   'B2'
	)
	~	kW
	~		|

Average Annual Dist Traveled by Vehicle Type[Vehicle Type,Cargo Type,Vehicle Technology\
		]=
	BAADTbVT BAU Average Annual Dist Traveled by Vehicle Type[Vehicle Type,Cargo Type]
	* (1 + Perc Change in Avg Annual Dist Traveled by Vehicle Type[Vehicle Type,Cargo Type\
		,Vehicle Technology])
	~	miles/vehicle
	~		|

Average Annual Dist Traveled by Vehicle Type Weighted by Technology[Vehicle Type,Cargo Type\
		]=
	ZIDZ(
	
	  SUM(
	    Average Annual Dist Traveled by Vehicle Type[Vehicle Type,Cargo Type,Vehicle Technology\
		!]
	    * Last Year Vehicles[Vehicle Type,Cargo Type,Vehicle Technology!]
	  ),
	
	  SUM(Last Year Vehicles[Vehicle Type,Cargo Type,Vehicle Technology!])
	)
	~	miles/vehicle
	~		|

average day electricity timeslice:
	average winter day,
	average spring day,
	average summer day,
	average fall day
	~	
	~		|

Average Five Year Prior Pretax Electricity Price by Sector[Sectors]=
	BAU Pretax Fuel Price by Sector[electricity,Sectors]
	~	
	~		|

Average Four Year Prior Net Energy Market Revenue by Plant Type Excluding Subsidies for Hybrid Power Plants\
		[Hybrid Electricity Source]=
	IF THEN ELSE(
	 Time - INITIAL TIME <= 1,
	 One Year Average Net Energy Market Revenue by Plant Type Excluding Subsidies for Hybrid Power Plants\
		[Hybrid Electricity Source
	],
	 
	 IF THEN ELSE(
	  Time - INITIAL TIME = 2,
	  Two Year Average Net Energy Market Revenue by Plant Type Excluding Subsidies for Hybrid Power Plants\
		[Hybrid Electricity Source
	],
	
	  IF THEN ELSE(
	   Time - INITIAL TIME = 3,
	   Three Year Average Net Energy Market Revenue by Plant Type Excluding Subsidies for Hybrid Power Plants\
		[Hybrid Electricity Source
	],
	   Four Year Average Net Energy Market Revenue by Plant Type Excluding Subsidies for Hybrid Power Plants\
		[Hybrid Electricity Source
	]
	  )
	 )
	)
	
	+Expected Capacity Factor x Hours per Year for Plants Built This Year[Hybrid Electricity Source\
		]*Variable Subsidies per Unit New Elec Output
	[Hybrid Electricity Source]
	~	$/MW
	~		|

Average Four Year Prior Total Predicted Net Energy Market Revenue per MW[Electricity Source\
		]=
	IF THEN ELSE(
	 Time - INITIAL TIME <= 1,
	 Last Year Total Five Year Average Net Energy Market Revenue per MW[Electricity Source\
		],
	
	 IF THEN ELSE(
	  Time - INITIAL TIME = 2,
	  Two Year Average Total Predicted Net Energy Market Revenue per MW[Electricity Source\
		],
	
	  IF THEN ELSE(
	   Time - INITIAL TIME = 3,
	   Three Year Average Total Predicted Net Energy Market Revenue per MW[Electricity Source\
		],
	
	   Four Year Average Total Predicted Net Energy Market Revenue per MW[Electricity Source\
		]
	
	  )
	 )
	)
	
	+ (Total Subsidies per Unit Electricity Output Adjusted for Lifetime[Electricity Source\
		]
	  + Carbon Price Credit per MWh[Electricity Source])
	  *Expected Capacity Factor x Hours per Year for Plants Built This Year
	[Electricity Source]
	~	$/(MW*hr)
	~		|

Average Three Year Prior Net Loss per Unit Output[Electricity Source,Optimization Pass\
		]=
	IF THEN ELSE(
	  Net Loss per Unit Capacity[Electricity Source,Optimization Pass]>0
	  :AND:
	  Last Year Net Loss per Unit Capacity[Electricity Source,Optimization Pass]>0
	  :AND:
	  Two Years Prior Net Loss per Unit Capacity[Electricity Source,Optimization Pass]>0\
		,
	
	  (Net Loss per Unit Capacity[Electricity Source,Optimization Pass]+Last Year Net Loss per Unit Capacity\
		[Electricity Source,Optimization Pass]+Two Years Prior Net Loss per Unit Capacity[Electricity Source\
		,Optimization Pass])/3,
	
	  0
	
	)
	~	$/MW
	~		|

Average Three Year Prior Net Loss per Unit Output Excluding Capacity Payment[Electricity Source\
		]=
	IF THEN ELSE(
	  Net Loss per Unit Capacity Excluding Predicted Capacity Payment[Electricity Source\
		]>0
	  :AND:
	  Last Year Net Loss per Unit Capacity Excluding Predicted Capacity Payment[Electricity Source\
		]>0
	  :AND:
	  Two Years Prior Net Loss per Unit Capacity Excluding Capacity Payment[Electricity Source\
		]>0,
	
	  (Net Loss per Unit Capacity Excluding Predicted Capacity Payment[Electricity Source\
		]+Last Year Net Loss per Unit Capacity Excluding Predicted Capacity Payment[Electricity Source\
		]+Two Years Prior Net Loss per Unit Capacity Excluding Capacity Payment[Electricity Source\
		])/3,
	
	  0
	
	)
	~	$/MW
	~		|

