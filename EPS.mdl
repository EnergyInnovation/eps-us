Does Carbon Tax Exempt Process Emissions This Year[Industry Category]=
	IF THEN ELSE(
	  BEPEfCT Boolean Exempt Process Emissions from Carbon Tax[Industry Category] > 0,
	
	  1 - Toggle Whether Carbon Tax Affects Process Emissions This Year[Industry Category\
		],
	
	  Toggle Whether Carbon Tax Affects Process Emissions This Year[Industry Category]
	)
	~	Dmnl
	~		|

Dollar per BTU Tolerance Unit Correction=
	1
	~	BTU/$
	~		|

Dollar per MWhr Tolerance Unit Correction Factor=
	1
	~	(MW*hour)/$
	~		|

Domestic Consumption of Nonenergy Products[Industry Category]=
	Output by ISIC Code by Year[Industry Category ISIC Code]
	+ Imports of Nonenergy Products[Industry Category]
	- Exports of Nonenergy Products[Industry Category]
	~	$
	~		|

Domestic Content Share of Consumption Before Import Substitution by ISIC Code[ISIC Code\
		] :EXCEPT:  [Industry Category ISIC Code
]=
	BAU Domestic Content Share of Consumption by ISIC Code from Exogenous Data[ISIC Code\
		] ~~|
Domestic Content Share of Consumption Before Import Substitution by ISIC Code[Industry Category ISIC Code\
		]=
	BAU Domestic Content Share of Consumption by ISIC Code from Exogenous Data[Industry Category ISIC Code\
		]
	+ (1 - BAU Domestic Content Share of Consumption by ISIC Code from Exogenous Data[Industry Category ISIC Code\
		])
	  * Fraction of Imported Industrial Outputs Shifted to In Region Suppliers This Year\
		[Industry Category]
	~	Dmnl
	~		|

Domestic Content Share of Consumption by ISIC Code[ISIC Code] :EXCEPT:   [Industry Category ISIC Code\
		]=
	Domestic Content Share of Consumption Before Import Substitution by ISIC Code[ISIC Code\
		] ~~|
Domestic Content Share of Consumption by ISIC Code[Industry Category ISIC Code]=
	Domestic Content Share of Consumption Before Import Substitution by ISIC Code[Industry Category ISIC Code\
		]
	* (1 - Percent of Purchases of Domestically Produced Goods Shifted to Purchases of Imports\
		[Industry Category])
	~	Dmnl
	~		|

Domestic Employee Compensation by ISIC Code[ISIC Code]=
	BAU Domestic Employee Compensation by ISIC Code[ISIC Code]
	+ Change in Domestic Employee Compensation by ISIC Code[ISIC Code]
	~	$
	~		|

Domestic Employment by Demographic Trait[Demographic Trait]=
	BAU Domestic Employment by Demographic Trait[Demographic Trait]
	+ Change in Domestic Jobs by Demographic Trait[Demographic Trait]
	~	jobs
	~		|

Domestic Employment by ISIC Code[ISIC Code]=
	BAU Domestic Employment by ISIC Code[ISIC Code]
	+ Change in Domestic Jobs after Productivity Effects by ISIC Code[ISIC Code]
	~	jobs
	~		|

Domestic Job Requirements by Industry per Unit Energy Production by Industry Excluding Direct Impacts\
		[Source ISIC Code,Target ISIC Code]=
	Calculated Leontief Inverse Matrix Excluding Direct Impacts[Source ISIC Code,Target ISIC Code\
		]
	* Within Industry Jobs per Unit Energy Production[Source ISIC Code]
	~	jobs/BTU
	~		|

Domestic Job Requirements by Industry per Unit Output by Industry[Source ISIC Code,Target ISIC Code\
		]=
	Calculated Leontief Inverse Matrix[Source ISIC Code,Target ISIC Code]
	* Within Industry Jobs per Unit Output[Source ISIC Code]
	~	jobs/$
	~		|

Domestic Job Requirements by Industry per Unit Output by Industry Excluding Direct Impacts\
		[Source ISIC Code,Target ISIC Code]=
	Calculated Leontief Inverse Matrix Excluding Direct Impacts[Source ISIC Code,Target ISIC Code\
		]
	* Within Industry Jobs per Unit Output[Source ISIC Code]
	~	jobs/$
	~		|

Domestic Jobs by Union Status[Union Status]=
	BAU Domestic Jobs by Union Status[Union Status]
	+ Change in Domestic Jobs by Union Status[Union Status]
	~	jobs
	~		|

Domestic Nonenergy Industry Expenses Passed Through to Buyers by Producer ISIC Code[ISIC Code\
		]=
	Nonenergy Industry Expenses Passed Through to Buyers by Producer ISIC Code[ISIC Code\
		]
	* Domestic Content Share of Consumption by ISIC Code[ISIC Code]
	~	$
	~		|

Domestic Output by ISIC Code[ISIC Code]=
	MAX(
	  0,
	
	  BAU Output by ISIC Code by Year[ISIC Code]
	  + Industry Contribution to Change in Domestic Output by ISIC Code[ISIC Code]
	  + Household and Government Contribution to Change in Domestic Output by ISIC Code[\
		ISIC Code]
	)
	~	$
	~		|

Domestic Value Added by Industry per Unit Energy Production by Industry Excluding Direct Impacts\
		[Source ISIC Code,Target ISIC Code]=
	Calculated Leontief Inverse Matrix Excluding Direct Impacts[Source ISIC Code,Target ISIC Code\
		]
	* Within Industry Value Added per Unit Energy Production[Source ISIC Code]
	~	$/BTU
	~		|

Domestic Value Added Requirements by Industry per Unit Output by Industry[Source ISIC Code\
		,Target ISIC Code]=
	Calculated Leontief Inverse Matrix[Source ISIC Code,Target ISIC Code]
	* Within Industry Value Added per Unit Output[Source ISIC Code]
	~	Dmnl
	~		|

Domestic Value Added Requirements by Industry per Unit Output by Industry Excluding Direct Impacts\
		[Source ISIC Code,Target ISIC Code]=
	Calculated Leontief Inverse Matrix Excluding Direct Impacts[Source ISIC Code,Target ISIC Code\
		]
	* Within Industry Value Added per Unit Output[Source ISIC Code]
	~	Dmnl
	~		|

Domestically Produced Energy by Producing ISIC Code[ISIC Code]=
	Total Primary Energy Use by Producing ISIC Code[ISIC Code]
	* Domestic Content Share of Consumption by ISIC Code[ISIC Code]
	~	BTU
	~		|

DPbES Dispatch Priority by Electricity Source[Electricity Source]:=
	GET DIRECT DATA(
	   'InputData/elec/DPbES/DPbES.csv',
	   ',',
	   '1',
	   'B2'
	)
	~	Dmnl
	~		|

DR Discount Rate=
	GET DIRECT CONSTANTS(
	   'InputData/cost-outputs/DR/DR.csv',
	   ',',
	   'B2*'
	)
	~	Dmnl [0,0.15]
	~	This is the annual percentage rate by which future savings (e.g. fuel cost \
		savings) are discounted when making price-driven purchasing decisions in \
		the current year.  The value used should be one that is reasonable for \
		people who are looking to buy fuel-consuming capital equipment, such as \
		industrial equipment or building components.  The model works in real \
		dollars, so this rate should be the growth in real value, not the growth \
		in nominal value plus real value.
	|

DRC Average DR Hours per Day on Which DR is Called Upon=
	GET DIRECT CONSTANTS(
	   'InputData/elec/DRC/DRC-ADRHpDRE.csv',
	   ',',
	   'B2*'
	)
	~	hours
	~		|

DRC BAU Demand Response Capacity:INTERPOLATE::=
	GET DIRECT DATA(
	   'InputData/elec/DRC/DRC-BDRC.csv',
	   ',',
	   '1',
	   'B2'
	)
	~	MW
	~		|

DRC Potential Additional Demand Response Capacity:INTERPOLATE::=
	GET DIRECT DATA(
	   'InputData/elec/DRC/DRC-PADRC.csv',
	   ',',
	   '1',
	   'B2'
	)
	~	MW
	~		|

DRCo Annual Cost per Unit Demand Response Capacity[Cash Flow Entity] :EXCEPT:  [cash flow entity excluding energy suppliers\
		]=
	DRCo Annual Cost per Unit Demand Response Capacity[nonenergy industries] ~~|
DRCo Annual Cost per Unit Demand Response Capacity[cash flow entity excluding energy suppliers\
		]=
	GET DIRECT CONSTANTS(
	   'InputData/elec/DRCo/DRCo-ACpUDRC.csv',
	   ',',
	   'B2*'
	)
	~	$/MW
	~		|

DRCo Share of DR by Provider[Cash Flow Entity] :EXCEPT: [cash flow entity excluding energy suppliers\
		]=
	0 ~~|
DRCo Share of DR by Provider[cash flow entity excluding energy suppliers]=
	GET DIRECT CONSTANTS(
	   'InputData/elec/DRCo/DRCo-SoDRbP.csv',
	   ',',
	   'B2*'
	)
	~	Dmnl
	~		|

Duration Multiplier for Subsidies for Carbon Sequestration[Electricity Source]=
	ZIDZ(
	  (1/(1-ACTR Average Corporate Tax Rate))
	  *Capital Recovery Factor for Power Plants[Electricity Source],
	  Capital Recovery Factor for Subisides per Unit Electricity Output[Electricity Source\
		]
	)
	~	Dmnl
	~		|

Duration Multiplier for Subsidies per Unit Electricity Output[Electricity Source]=
	ZIDZ(
	  (1/(1-ACTR Average Corporate Tax Rate))
	  *Capital Recovery Factor for Power Plants[Electricity Source],
	  Capital Recovery Factor for Subsidies per Unit Electricity Output[Electricity Source\
		]
	)
	~	Dmnl
	~		|

Economic Benefit from Avoided Climate Damages=
	- Change in Total CO2e Emissions
	* SCoC Social Cost of Carbon
	~	$
	~		|

Economic Capacity Retirements by Optimization Pass[Electricity Source,Optimization Pass\
		]=
	QUANTUM(
	  MIN(Desired Cost Driven Capacity Retirements[Electricity Source,Optimization Pass]\
		,
	    Max Capacity that Can be Retired Economically by Plant Type[Electricity Source])\
		,
	
	  MPPC Minimum Power Plant Capacity[Electricity Source]
	 )
	~	MW
	~	If the same power plant is scheduled to retire and is also uneconomic to \
		operate, that plant retires only once, not twice.  Therefore, we must use \
		a MAX() function here instead of adding the capacity that meets each \
		retirement condition.
	|

Economic Capacity Retirements Excluding Capacity Payment[Electricity Source]=
	QUANTUM(
	  MIN(Desired Cost Driven Capacity Retirements Excluding Capacity Payment[Electricity Source\
		],
	    Max Capacity that Can be Retired Economically by Plant Type[Electricity Source])\
		,
	
	  MPPC Minimum Power Plant Capacity[Electricity Source]
	 )
	~	MW
	~		|

Economically Driven Fraction of CO2 Captured by Industry Category[Industry Category,Emissions Type\
		]=
	Start Year BAU Fraction of CCS Potential Achieved by Industry Sector[Industry Category\
		,Emissions Type]
	+ Cumulative CCS Retrofit Capacity Built During Model Run[Industry Category,Emissions Type\
		]
	~	Dmnl
	~		|

EGGRA Boolean Use Exogenous GDP Growth Rate Adjustment=
	GET DIRECT CONSTANTS(
	   'InputData/ctrl-settings/EGGRA/EGGRA-use-adjustment.csv',
	   ',',
	   'B2*'
	)
	~	Dmnl [0,1,1]
	~		|

EGGRA Boolean Use Exogenous GDP Growth Rate Adjustment This Year=
	EGGRA Boolean Use Exogenous GDP Growth Rate Adjustment
	* Selected Policy Implementation Schedule[settings exogenous GDP adjustment X]
	~	Dmnl
	~		|

EGGRA Exogenous GDP Growth Rate Adjustment:=
	GET DIRECT DATA(
	   'InputData/ctrl-settings/EGGRA/EGGRA-gdp-adjustment.csv',
	   ',',
	   '1',
	   'B2'
	)
	~	Dmnl
	~		|

EHPpUC Electrolyzer Hydrogen Production per Unit Capacity:=
	GET DIRECT DATA(
	   'InputData/hydgn/EHPpUC/EHPpUC.csv',
	   ',',
	   '1',
	   'B2'
	)
	~	BTU/MW
	~		|

EIaE BAU Exported Electricity:=
	GET DIRECT DATA(
	   'InputData/elec/EIaE/EIaE-BEE.csv',
	   ',',
	   '1',
	   'B2'
	)
	~	MW*hour
	~		|

EIaE BAU Imported Electricity by Electricity Source[Electricity Source]:INTERPOLATE::=
	GET DIRECT DATA(
	   'InputData/elec/EIaE/EIaE-BIE.csv',
	   ',',
	   '1',
	   'B2'
	)
	~	MW*hour
	~		|

EIaE Imported Electricity Price=
	GET DIRECT CONSTANTS(
	   'InputData/elec/EIaE/EIaE-IEP.csv',
	   ',',
	   'B2*'
	)
	~	$/(MW*hr)
	~		|

Elec Portfolio Alternative Compliance Payment=
	IF THEN ELSE(
	
	  Boolean Use Non BAU RPS Alternative Compliance Payment This Year > 0,
	
	  RACP RPS Alternative Compliance Payment,
	
	  BRACP BAU RPS Alternative Compliance Payment
	)
	~	$/(MW*hr)
	~		|

Elec Portfolio Percentage by Year from Policy Setting[Future Year,RPS]=
	Selected Policy Implementation Schedule for Future Years[elec renewable portfolio standards X\
		,Future Year]
	  * Renewable Portfolio Std Percentage ~~|
Elec Portfolio Percentage by Year from Policy Setting[Future Year,CES]=
	Selected Policy Implementation Schedule for Future Years[elec clean electricity standards X\
		,Future Year]
	  * Clean Electricity Std Percentage
	~	Dmnl
	~		|

Elec Portfolio Percentage that Would be Achieved with Only Surviving Plants[Clean Elec Requirement\
		]=
	ZIDZ(
	  Surviving Potential Elec Portfolio Qualifying Output[Clean Elec Requirement],
	
	  SUM(Total Electricity Demand by Hour After Demand Altering Technologies excluding New Hybrid Batteries\
		[Electricity Timeslice!,Hour!]*SHELF Days per Electricity Timeslice[Electricity Timeslice\
		!])
	)
	~	Dmnl
	~		|

Elec Portfolio Percentage to Seek This Year[Clean Elec Requirement]=
	MIN(
	
	  0.9999,
	
	  MAX(
	    0,
	
	    MAX(
	      Legally Required Elec Portfolio Percentage[Clean Elec Requirement],
	
	      Elec Portfolio Percentage with Foresight[Clean Elec Requirement]
	      * BESHFoFRV Boolean Electricity Suppliers Have Foresight of Future RPS Values
	    )
	  )
	)
	~	Dmnl
	~		|

Elec Portfolio Percentage with Foresight[Clean Elec Requirement]=
	Elec Portfolio Percentage that Would be Achieved with Only Surviving Plants[Clean Elec Requirement\
		]
	+ VMAX(Slope of Line Approaching Future Elec Portfolio Percentages by Year[Future Year\
		!,Clean Elec Requirement])
	~	Dmnl
	~		|

Elec Portfolio Qualifying Sources[Electricity Source,RPS]=
	RQSD RPS Qualifying Source Definitions[Electricity Source] ~~|
Elec Portfolio Qualifying Sources[Electricity Source,CES]=
	RQSD CES Qualifying Source Definitions[Electricity Source]
	~	Dmnl
	~		|

Elec Portfolio Std Achieved This Year[Clean Elec Requirement]=
	SUM(
	  Electricity Generation by Type[Electricity Source!]
	  * Elec Portfolio Qualifying Sources[Electricity Source!,Clean Elec Requirement]
	)
	/ SUM(Electricity Generation by Type[Electricity Source!])
	~	Dmnl
	~		~	:SUPPLEMENTARY 
	|

Elec Supplier Fixed OM Costs[Electricity Source]=
	Electricity Generation Capacity[Electricity Source]
	* Weighted Average Annual Fixed OM Cost per Unit Capacity[Electricity Source]
	~	$
	~		|

Elec Supplier Variable OM Costs[Electricity Source]=
	Electricity Generation by Type[Electricity Source]
	* Weighted Average Variable OM Cost per Unit Electricity Output[Electricity Source]
	~	$
	~		|

ElecDemand:
	demand1
	~	
	~		|

Electricity Demand by Industry[Industry Category]=
	Industrial Fuel Use[electricity if,Industry Category]
	* MWh per BTU
	~	MW*hour
	~		|

Electricity Demand Mapped to ElecDemand[Electricity Timeslice,Hour,ElecDemand]=
	QUANTUM(Unmet Electricity Demand After Elec Portfolio Std Dispatch[Electricity Timeslice\
		,Hour],1)
	~	MW*hr
	~		|

Electricity Dispatch Required to Satisfy Elec Portfolio Stds[Electricity Timeslice,Hour\
		,Clean Elec Requirement]=
	Total Electricity Demand by Hour After Demand Altering Technologies[Electricity Timeslice\
		,Hour
	]
	* Legally Required Elec Portfolio Percentage[Clean Elec Requirement]
	~	MW*hr
	~		|

Electricity Dispatched by Guaranteed Dispatch by Hour[Electricity Source,Electricity Timeslice\
		,Hour]=
	IF THEN ELSE(
	 SUM(First Pass Electricity Dispatched by Guaranteed Dispatch by Hour[Electricity Source\
		!,Electricity Timeslice,Hour]) > Total Electricity Demand by Hour After Demand Altering Technologies\
		[Electricity Timeslice,Hour],
	
	 First Pass Electricity Dispatched by Guaranteed Dispatch by Hour[Electricity Source\
		,Electricity Timeslice,Hour]
	 * MIN(
	     1,
	     Total Electricity Demand by Hour After Demand Altering Technologies[Electricity Timeslice\
		,Hour]/
	     SUM(First Pass Electricity Dispatched by Guaranteed Dispatch by Hour[Electricity Source\
		!,Electricity Timeslice,Hour])
	     ),
	 First Pass Electricity Dispatched by Guaranteed Dispatch by Hour[Electricity Source\
		,Electricity Timeslice,Hour]
	)
	~	MW*hour
	~	If the amount of guaranteed dispatch after the first pass still exceeds \
		the total amount of electricity demand in a given hour, the first tier \
		sources of guaranteed dispatch are scaled back proportionately so that \
		total hourly demand is not exceeded.
	|

Electricity Dispatched by Least Cost by Hour[Electricity Timeslice,Hour,Electricity Source\
		]=
	IF THEN ELSE( 
	     Unmet Electricity Demand After Elec Portfolio Std Dispatch[Electricity Timeslice\
		,Hour]*MWhr Tolerance Unit Correction Factor
	<Tolerance,
	     0,
	     SUPPLY AT PRICE(
	              Available Capacity for Least Cost Dispatch Mapped[Electricity Timeslice\
		,Hour,Electricity Source
	], 
	              Power Plant Least Cost Dispatch Parameters as Vector[Electricity Source\
		,ptype],
	              Electricity Market Price Adjusted for Zero Least Cost Dispatch Hours[Electricity Timeslice\
		,Hour])
	 )
	~	MW*hr
	~		|

Electricity Dispatched to Meet Elec Portfolio Stds[Electricity Timeslice,Hour,Electricity Source\
		]=
	Zero and Negative Cost Electricity Dispatched to Meet RPS[Electricity Timeslice,Hour\
		,Electricity Source]
	+ Positive Cost Electricity Dispatched to Meet RPS[Electricity Timeslice,Hour,Electricity Source\
		]
	+ Zero and Negative Cost Electricity Dispatched to Meet CES[Electricity Source,Electricity Timeslice\
		,Hour]
	+ Positive Cost Electricity Dispatched to Meet CES[Electricity Timeslice,Hour,Electricity Source\
		]
	~	MW*hr
	~		|

Electricity Exports by Hour[Electricity Timeslice,Hour,pass1]=
	IF THEN ELSE(Daily Net Imported Electricity>=0,0,
	  MAX(MaMHEIaE Minimum Hourly Exports,MIN(MaMHEIaE Maximum Hourly Exports,
	    -Daily Net Imported Electricity*Share of Exports by Hour by Optimization Pass[Electricity Timeslice\
		,Hour,pass1]
	   )
	  )
	) ~~|
Electricity Exports by Hour[Electricity Timeslice,Hour,current pass]=
	IF THEN ELSE(Daily Net Imported Electricity>=0,0,
	MAX(MaMHEIaE Minimum Hourly Exports,MIN(MaMHEIaE Maximum Hourly Exports,
	  Remaining Electricity Exports by Electricity Timeslice by Optimization Pass[Electricity Timeslice\
		,preceeding pass]
	  *Share of Exports by Hour by Optimization Pass[Electricity Timeslice,Hour,current pass\
		]
	  + Electricity Exports by Hour[Electricity Timeslice,Hour,preceeding pass]
	   )
	 )
	)
	~	MW*hr
	~		|

Electricity Fuel Carbon Tax Amount per Unit Energy[Electricity Source]=
	Carbon Tax Rate[electricity sector]
	/ Grams per Metric Ton CO2e
	* Electricity Fuel Taxable CO2e Emissions Intensity[Electricity Source]
	~	$/BTU
	~		|

Electricity Fuel Cost per Unit Energy[Electricity Source]=
	MAX(Pretax Fuel Cost per Unit Energy by Sector after Fuel Price Deregulation[electricity source within all fuels\
		,electricity sector]
	    * (1 + FSPbPPT Fuel Surcharge Percentage by Power Plant Type[Electricity Source]\
		)
	
	  + Electricity Fuel Total Tax or Subsidy Amount per Unit Energy[Electricity Source]\
		,
	0
	)
	~	$/BTU
	~	We apply the fuel surcharge to the fuel cost but not to the fuel taxes.  \
		Fuel taxes are based on energy content and on GHG emissions, while the \
		surcharge is based on purchased quantity and cadence, and so should not \
		affect the amount of tax.
	|

Electricity Fuel Other Tax or Subsidy Amount per Unit Energy[Electricity Source]=
	Fuel Tax or Subsidy by Sector[electricity source within all fuels,electricity sector\
		]
	~	$/BTU
	~		|

Electricity Fuel Pollutant Emissions Intensities This Year[Pollutant,Electricity Source\
		]=
	PEI Electricity Fuel Pollutant Emissions Intensities[Pollutant,Electricity Source]
	  * (1 - PEIIR Electricity Fuel Pollutant Emissions Intensity Improvement Rate[Pollutant\
		,Electricity Source])
	    ^(Dimensionless Time - Initial Time Dimensionless)
	~	g pollutant/BTU
	~		|

Electricity Fuel Pollutant Emissions Intensity per MWh[Electricity Source,Pollutant]=
	Electricity Fuel Pollutant Emissions Intensities This Year[Pollutant,Electricity Source\
		]
	* Weighted Average Heat Rate by Electricity Fuel[Electricity Source]
	~	g pollutant/(MW*hour)
	~		|

Electricity Fuel Taxable CO2e Emissions Intensity[Electricity Source]=
	SUM(
	  Electricity Fuel Pollutant Emissions Intensities This Year[Pollutant!,Electricity Source\
		]
	  * GWP by Pollutant[Pollutant!]
	  * Electricity Pollutants Taxed by Carbon Pricing[Electricity Source,Pollutant!]
	)
	~	g CO2e/BTU
	~		|

Electricity Fuel Total Tax or Subsidy Amount per Unit Energy[Electricity Source]=
	Electricity Fuel Carbon Tax Amount per Unit Energy[Electricity Source]
	+ Electricity Fuel Other Tax or Subsidy Amount per Unit Energy[Electricity Source]
	~	$/BTU
	~		|

Electricity Fuel Use[Electricity Source]=
	Electricity Generation by Type[Electricity Source]
	  * Weighted Average Heat Rate by Electricity Fuel[Electricity Source]
	~	BTU
	~		|

Electricity Generation by Type[Electricity Source]=
	QUANTUM(
	  Annual Electricity Dispatched by Guaranteed Dispatch[Electricity Source]
	  + Annual Electricity Dispatched to Meet Elec Portfolio Stds[Electricity Source]
	  + Annual Electricity Dispatched by Least Cost[Electricity Source],
	
	  Quantization Size for Annual Dispatch
	)
	~	MW*hour
	~		|

Electricity Generation by Type Including Distributed Generation[Electricity Source]=
	Electricity Generation by Type[Electricity Source]
	+ Annual Output from Distributed Electricity Capacity[Electricity Source]
	~	MW*hour
	~		|

Electricity Generation Capacity[Electricity Source]=
	IF THEN ELSE(
	
	 SUM(Electricity Generation Capacity by Vintage[Electricity Source,Modeled Vintage!]\
		) < MPPC Minimum Power Plant Capacity[Electricity Source] * 0.1,
	
	 0,
	
	 SUM(Electricity Generation Capacity by Vintage[Electricity Source,Modeled Vintage!]\
		)
	)
	~	MW
	~	To avoid cases where quantized planned retirements leave only a small \
		fraction of one plant online,we round down to 0 in cases where less than \
		10% of the minimum power plant capacity is remaining across vintages for a \
		given plant type.
	|

Electricity Generation Capacity before Dispatchable CES Additions[Electricity Source]\
		=
	Surviving Electricity Generation Capacity before Economic Retirements[Electricity Source\
		]
	+New Policy Mandated Capacity[Electricity Source]
	~	MW
	~		|

Electricity Generation Capacity before Reliability Additions[Electricity Source]=
	Surviving Electricity Generation Capacity before Economic Retirements[Electricity Source\
		]
	+New Generation Capacity before Reliability Additions[Electricity Source]
	~	MW
	~		|

Electricity Generation Capacity by Type Including Distributed Generation[Electricity Source\
		]=
	Electricity Generation Capacity[Electricity Source]
	+ SUM(Distributed Electricity Source Capacity[Building Type!,Electricity Source])
	~	MW
	~		|

Electricity Generation Capacity by Type Including Distributed Generation as of Two Years Ago\
		[Electricity Source]= DELAY FIXED (
	Last Year Electricity Generation Capacity by Type Including Distributed Generation[Electricity Source\
		],
	1,
	Start Year Electricity Generation Capacity Summed Across Vintages[Electricity Source\
		] + SUM(Start Year Distributed Electricity Capacity
	[Building Type!,Electricity Source]))
	~	MW
	~		|

Electricity Generation Capacity by Vintage[Electricity Source,Modeled Vintage]=
	Last Year Electricity Generation Capacity by Vintage[Electricity Source,Modeled Vintage\
		]
	- Capacity Retirements by Vintage[Electricity Source,Modeled Vintage] * One Year
	+ 
	IF THEN ELSE(
	  This Year Modeled Vintage Flag[Modeled Vintage],
	  New and Retrofit Generation Capacity[Electricity Source],
	  0
	)
	~	MW
	~		|

Electricity Generation Capacity Relative to Start Year=
	SUM(Electricity Generation Capacity[Electricity Source!])
	/ SUM(BHRaSYC Start Year Electricity Generation Capacity by Vintage[Electricity Source\
		!,Modeled Vintage!])
	~	Dmnl
	~		|

Electricity Imports by Hour[Electricity Timeslice,Hour,pass1]=
	IF THEN ELSE(Daily Net Imported Electricity<=0,0,
	  MAX(MaMHEIaE Minimum Hourly Imports,MIN(MaMHEIaE Maximum Hourly Imports,
	    Daily Net Imported Electricity*Share of Imports by Hour by Optimization Pass[Electricity Timeslice\
		,Hour,pass1]
	   )
	  )
	) ~~|
Electricity Imports by Hour[Electricity Timeslice,Hour,current pass]=
	IF THEN ELSE(Daily Net Imported Electricity<=0,0,
	MAX(MaMHEIaE Minimum Hourly Imports,MIN(MaMHEIaE Maximum Hourly Imports,
	  Remaining Electricity Imports by Electricity Timeslice and Optimization Pass[Electricity Timeslice\
		,preceeding pass]*Share of Imports by Hour by Optimization Pass
	[Electricity Timeslice,Hour,current pass]+ Electricity Imports by Hour
	[Electricity Timeslice,Hour,preceeding pass]
	 )
	)
	)
	~	MW*hr
	~		|

Electricity Market Price[Electricity Timeslice,Hour]=
	FIND MARKET PRICE(
	 Electricity Demand Mapped to ElecDemand[Electricity Timeslice,Hour,demand1],Fixed Electricity Demand Vector\
		[demand1,ptype],
	Available Capacity for Least Cost Dispatch Mapped[Electricity Timeslice,Hour,hard coal es\
		],Power Plant Least Cost Dispatch Parameters as Vector[hard coal es,ptype]
	)
	~	$/(MW*hour)
	~		|

Electricity Market Price Adjusted for Zero Least Cost Dispatch Hours[Electricity Timeslice\
		,Hour]=
	IF THEN ELSE(
	Electricity Demand Mapped to ElecDemand[Electricity Timeslice,Hour,demand1]*MWhr Tolerance Unit Correction Factor\
		 < Tolerance
	,
	0,
	Electricity Market Price[Electricity Timeslice,Hour])
	~	$/(MW*hour)
	~		|

Electricity Pollutants Taxed by Carbon Pricing[Electricity Source,Pollutant]=
	IF THEN ELSE(
	  Boolean Non BAU Pollutants Affected by Carbon Tax This Year = 0,
	  BPTbCP BAU Electricity Pollutants Taxed by Carbon Pricing[Electricity Source,Pollutant\
		],
	  PTbCP Electricity Pollutants Taxed by Carbon Pricing[Electricity Source,Pollutant]
	)
	~	Dmnl
	~		|

Electricity Sector Carbon Tax Rebate due to CCS[Electricity Source]=
	Amount of CO2 Sequestered by Electricity Sector[Electricity Source]
	* Carbon Tax Rate[electricity sector]
	~	$
	~		|

Electricity Sector Carbon Tax Revenue=
	SUM(
	  Electricity Fuel Use[Electricity Source!]
	  * Electricity Fuel Carbon Tax Amount per Unit Energy[Electricity Source!]
	)
	~	$
	~		|

Electricity Sector CCS Subsidy per MWh[Electricity Source] :EXCEPT:     [biomass w CCS es\
		]=
	Metric Tons CO2 Stored per MWh[Electricity Source]
	* (BCS BAU Electricity CCS Subsidy[Electricity Source]
	  + Additional Subsidy for Elec CCS This Year[Electricity Source]) ~~|
Electricity Sector CCS Subsidy per MWh[biomass w CCS es]=
	BwCCSSpM Biomass with CCS Storage per MWh
	* (BCS BAU Electricity CCS Subsidy[biomass w CCS es]
	  + Additional Subsidy for Elec CCS This Year[biomass w CCS es])
	~	$/(MW*hour)
	~		|

Electricity Sector CCS Transportation and Storage Costs[Electricity Source]=
	Electricity Sector CCS Transportation and Storage Costs per MWh[Electricity Source]
	* Electricity Generation by Type[Electricity Source]
	~	$
	~		|

Electricity Sector CCS Transportation and Storage Costs per MWh[Electricity Source]=
	MAX(
	  (CCSTaSC CCS Transportation and Storage Costs 
	  - CCSTaSC CCS Transportation and Storage Subsidies)
	  * (1 - Perc Subsidy for Electricity Sector CCS Transport and Storage Costs This Year\
		),
	
	  0
	)
	
	* Metric Tons CO2 Stored per MWh[Electricity Source]
	~	$/(MW*hour)
	~		|

Electricity Sector CCS Transportation and Storage Subsidies[Electricity Source]=
	Electricity Generation by Type[Electricity Source]
	* Metric Tons CO2 Stored per MWh[Electricity Source]
	
	* 
	(
	  CCSTaSC CCS Transportation and Storage Subsidies
	  + 
	  ((CCSTaSC CCS Transportation and Storage Costs - CCSTaSC CCS Transportation and Storage Subsidies\
		)
	    * Perc Subsidy for Electricity Sector CCS Transport and Storage Costs
	  )
	)
	~	$
	~		|

Electricity Sector Change in Amount Spent on Capital Equipment by Recipient ISIC Code\
		[ISIC Code] :EXCEPT:    [ISIC 27]=
	Change in Capacity Construction Costs by Recipient ISIC Code[ISIC Code]
	+ Change in Transmission Construction Costs by Recipient ISIC Code[ISIC Code]
	+ Change in Spur Line Construction Costs by Recipient ISIC Code[ISIC Code]
	+ Change in Distribution Construction Costs by Recipient ISIC Code[ISIC Code]
	+Change in Ongoing Capital Costs by Recipient ISIC Code[ISIC Code] ~~|
Electricity Sector Change in Amount Spent on Capital Equipment by Recipient ISIC Code\
		[ISIC 27 {Electrical equipment}]=
	Change in Capacity Construction Costs by Recipient ISIC Code[ISIC 27]
	+ Change in Transmission Construction Costs by Recipient ISIC Code[ISIC 27]
	+ Change in Spur Line Construction Costs by Recipient ISIC Code[ISIC 27]
	+ Change in Distribution Construction Costs by Recipient ISIC Code[ISIC 27]
	+ Change in Ongoing Capital Costs by Recipient ISIC Code[ISIC 27]
	
	+ Change in Electricity Sector Battery Costs
	~	$
	~		|

Electricity Sector Change in Amount Spent on OM and Decommissioning by ISIC Code[ISIC Code\
		] :EXCEPT:  [ISIC 41T43]=
	Change in Electricity Sector OM Costs by Recipient ISIC Code[ISIC Code] ~~|
Electricity Sector Change in Amount Spent on OM and Decommissioning by ISIC Code[ISIC 41T43\
		 {Construction}]=
	Change in Electricity Sector OM Costs by Recipient ISIC Code[ISIC 41T43]
	+ Change in Decommissioning Costs
	~	$
	~		|

Electricity Sector Change in CCS Subsidy Amount Paid[Electricity Source]=
	This Year CCS Subsidies Paid[Electricity Source]
	- BAU This Year CCS Subsidies Paid[Electricity Source]
	~	$
	~		|

Electricity Sector Change in Energy Expenditures by Entity[Cash Flow Entity] :EXCEPT:\
		 [foreign entities],[electricity suppliers]=
	0 ~~|
Electricity Sector Change in Energy Expenditures by Entity[foreign entities]=
	Change in Amount Received from Exporting Electricity ~~|
Electricity Sector Change in Energy Expenditures by Entity[electricity suppliers]=
	SUM(Change in Amount Spent on Electricity Fuels[Electricity Source!])
	+ Change in Amount Spent on Importing Electricity
	~	$
	~		|

Electricity Sector Change in Fuel Costs by Recipient[government]=
	SUM(Change in Electricity Fuel Taxes Paid[Electricity Source!]) ~~|
Electricity Sector Change in Fuel Costs by Recipient[nonenergy industries]=
	0 ~~|
Electricity Sector Change in Fuel Costs by Recipient[labor and consumers]=
	0 ~~|
Electricity Sector Change in Fuel Costs by Recipient[foreign entities]=
	Change in Amount Spent on Importing Electricity ~~|
Electricity Sector Change in Fuel Costs by Recipient[electricity suppliers]=
	Change in Amount Received from Exporting Electricity ~~|
Electricity Sector Change in Fuel Costs by Recipient[coal suppliers]=
	Electricity Sector Change in Fuel Industry Cash Flow before Subsidies and Electricity Exports\
		[hard coal es]
	+ Electricity Sector Change in Fuel Industry Cash Flow before Subsidies and Electricity Exports\
		[lignite es]
	+ Electricity Sector Change in Fuel Industry Cash Flow before Subsidies and Electricity Exports\
		[hard coal w CCS es]
	+ Electricity Sector Change in Fuel Industry Cash Flow before Subsidies and Electricity Exports\
		[lignite w CCS es] ~~|
Electricity Sector Change in Fuel Costs by Recipient[natural gas and petroleum suppliers\
		]=
	Electricity Sector Change in Fuel Industry Cash Flow before Subsidies and Electricity Exports\
		[natural gas steam turbine es]
	+ Electricity Sector Change in Fuel Industry Cash Flow before Subsidies and Electricity Exports\
		[natural gas combined cycle es]
	+ Electricity Sector Change in Fuel Industry Cash Flow before Subsidies and Electricity Exports\
		[petroleum es]
	+ Electricity Sector Change in Fuel Industry Cash Flow before Subsidies and Electricity Exports\
		[natural gas peaker es]
	+ Electricity Sector Change in Fuel Industry Cash Flow before Subsidies and Electricity Exports\
		[crude oil es]
	+ Electricity Sector Change in Fuel Industry Cash Flow before Subsidies and Electricity Exports\
		[heavy or residual fuel oil es]
	+ Electricity Sector Change in Fuel Industry Cash Flow before Subsidies and Electricity Exports\
		[natural gas combined cycle w CCS es] ~~|
Electricity Sector Change in Fuel Costs by Recipient[biomass and biofuel suppliers]=
	Electricity Sector Change in Fuel Industry Cash Flow before Subsidies and Electricity Exports\
		[biomass es]
	+ Electricity Sector Change in Fuel Industry Cash Flow before Subsidies and Electricity Exports\
		[biomass w CCS es] ~~|
Electricity Sector Change in Fuel Costs by Recipient[other energy suppliers]=
	Electricity Sector Change in Fuel Industry Cash Flow before Subsidies and Electricity Exports\
		[nuclear es]
	+ Electricity Sector Change in Fuel Industry Cash Flow before Subsidies and Electricity Exports\
		[municipal solid waste es]
	+ Electricity Sector Change in Fuel Industry Cash Flow before Subsidies and Electricity Exports\
		[small modular reactor es]
	+ Electricity Sector Change in Fuel Industry Cash Flow before Subsidies and Electricity Exports\
		[hydrogen combustion turbine es]
	+ Electricity Sector Change in Fuel Industry Cash Flow before Subsidies and Electricity Exports\
		[hydrogen combined cycle es]
	~	$
	~	Changes in revenue to electricity suppliers for domestic electricity sales \
		are handled in the sectors that demand electricity.
	|

Electricity Sector Change in Fuel Industry Cash Flow[Electricity Source]=
	Electricity Sector Change in Fuel Industry Cash Flow before Subsidies and Electricity Exports\
		[Electricity Source]
	+ Electricity Sector Change in Subsidies and Tax Rebates by Electricity Source[Electricity Source\
		]
	+ Change in Amount Received from Exporting Electricity
	  * Percentage Electricity Generation by Source[Electricity Source]
	~	$
	~		|

Electricity Sector Change in Fuel Industry Cash Flow before Subsidies and Electricity Exports\
		[Electricity Source]=
	Change in Amount Spent on Electricity Fuels[Electricity Source]
	- Change in Electricity Fuel Taxes Paid[Electricity Source]
	~	$
	~		|

Electricity Sector Change in Fuel Industry Cash Flow Before Subsidies and Tax Rebates\
		[Electricity Source]=
	Electricity Sector Change in Fuel Industry Cash Flow before Subsidies and Electricity Exports\
		[Electricity Source]
	+ Change in Amount Received from Exporting Electricity
	  * Percentage Electricity Generation by Source[Electricity Source]
	~	$
	~		|

Electricity Sector Change in Fuel Industry Cash Flow Including Subsidies Mapped to All Fuels Subscript\
		[All Fuels] :EXCEPT:    [electricity source within all fuels
]=
	0 ~~|
Electricity Sector Change in Fuel Industry Cash Flow Including Subsidies Mapped to All Fuels Subscript\
		[electricity source within all fuels] :EXCEPT:    [solar],[wind],[natural gas],[hard coal\
		],[biomass],[lignite],[nuclear],[hydrogen]=
	Electricity Sector Change in Fuel Industry Cash Flow[Electricity Source] ~~|
Electricity Sector Change in Fuel Industry Cash Flow Including Subsidies Mapped to All Fuels Subscript\
		[solar]=
	Electricity Sector Change in Fuel Industry Cash Flow[solar PV es]
	+ Electricity Sector Change in Fuel Industry Cash Flow[solar thermal es] ~~|
Electricity Sector Change in Fuel Industry Cash Flow Including Subsidies Mapped to All Fuels Subscript\
		[wind]=
	Electricity Sector Change in Fuel Industry Cash Flow[onshore wind es]
	+ Electricity Sector Change in Fuel Industry Cash Flow[offshore wind es] ~~|
Electricity Sector Change in Fuel Industry Cash Flow Including Subsidies Mapped to All Fuels Subscript\
		[natural gas]=
	Electricity Sector Change in Fuel Industry Cash Flow[natural gas steam turbine es]
	+ Electricity Sector Change in Fuel Industry Cash Flow[natural gas combined cycle es\
		]
	+ Electricity Sector Change in Fuel Industry Cash Flow[natural gas peaker es]
	+ Electricity Sector Change in Fuel Industry Cash Flow[natural gas combined cycle w CCS es\
		] ~~|
Electricity Sector Change in Fuel Industry Cash Flow Including Subsidies Mapped to All Fuels Subscript\
		[hard coal]=
	Electricity Sector Change in Fuel Industry Cash Flow[hard coal es]
	+ Electricity Sector Change in Fuel Industry Cash Flow[hard coal w CCS es] ~~|
Electricity Sector Change in Fuel Industry Cash Flow Including Subsidies Mapped to All Fuels Subscript\
		[biomass]=
	Electricity Sector Change in Fuel Industry Cash Flow[biomass es]
	+ Electricity Sector Change in Fuel Industry Cash Flow[biomass w CCS es] ~~|
Electricity Sector Change in Fuel Industry Cash Flow Including Subsidies Mapped to All Fuels Subscript\
		[lignite]=
	Electricity Sector Change in Fuel Industry Cash Flow[lignite es]
	+ Electricity Sector Change in Fuel Industry Cash Flow[lignite w CCS es] ~~|
Electricity Sector Change in Fuel Industry Cash Flow Including Subsidies Mapped to All Fuels Subscript\
		[nuclear]=
	Electricity Sector Change in Fuel Industry Cash Flow[nuclear es]
	+ Electricity Sector Change in Fuel Industry Cash Flow[small modular reactor es] ~~|
Electricity Sector Change in Fuel Industry Cash Flow Including Subsidies Mapped to All Fuels Subscript\
		[hydrogen]=
	Electricity Sector Change in Fuel Industry Cash Flow[hydrogen combustion turbine es]
	+ Electricity Sector Change in Fuel Industry Cash Flow[hydrogen combined cycle es]
	~	$
	~		|

Electricity Sector Change in Fuel Industry Cash Flow Mapped to All Fuels Subscript[All Fuels\
		] :EXCEPT:   [electricity source within all fuels
]=
	0 ~~|
Electricity Sector Change in Fuel Industry Cash Flow Mapped to All Fuels Subscript[electricity source within all fuels\
		] 
:EXCEPT:   [solar],[wind],[natural gas],[hard coal],[biomass],[lignite],[nuclear],[hydrogen\
		]=
	Electricity Sector Change in Fuel Industry Cash Flow Before Subsidies and Tax Rebates\
		[Electricity Source] ~~|
Electricity Sector Change in Fuel Industry Cash Flow Mapped to All Fuels Subscript[solar\
		]=
	Electricity Sector Change in Fuel Industry Cash Flow Before Subsidies and Tax Rebates\
		[solar PV es]
	+ Electricity Sector Change in Fuel Industry Cash Flow Before Subsidies and Tax Rebates\
		[solar thermal es] ~~|
Electricity Sector Change in Fuel Industry Cash Flow Mapped to All Fuels Subscript[wind\
		]=
	Electricity Sector Change in Fuel Industry Cash Flow Before Subsidies and Tax Rebates\
		[onshore wind es]
	+ Electricity Sector Change in Fuel Industry Cash Flow Before Subsidies and Tax Rebates\
		[offshore wind es] ~~|
Electricity Sector Change in Fuel Industry Cash Flow Mapped to All Fuels Subscript[natural gas\
		]=
	Electricity Sector Change in Fuel Industry Cash Flow Before Subsidies and Tax Rebates\
		[natural gas steam turbine es]
	+ Electricity Sector Change in Fuel Industry Cash Flow Before Subsidies and Tax Rebates\
		[natural gas combined cycle es]
	+ Electricity Sector Change in Fuel Industry Cash Flow Before Subsidies and Tax Rebates\
		[natural gas peaker es]
	+ Electricity Sector Change in Fuel Industry Cash Flow Before Subsidies and Tax Rebates\
		[natural gas combined cycle w CCS es
] ~~|
Electricity Sector Change in Fuel Industry Cash Flow Mapped to All Fuels Subscript[hard coal\
		]=
	Electricity Sector Change in Fuel Industry Cash Flow Before Subsidies and Tax Rebates\
		[hard coal es]
	+ Electricity Sector Change in Fuel Industry Cash Flow Before Subsidies and Tax Rebates\
		[hard coal w CCS es] ~~|
Electricity Sector Change in Fuel Industry Cash Flow Mapped to All Fuels Subscript[biomass\
		]=
	Electricity Sector Change in Fuel Industry Cash Flow Before Subsidies and Tax Rebates\
		[biomass es]
	+ Electricity Sector Change in Fuel Industry Cash Flow Before Subsidies and Tax Rebates\
		[biomass w CCS es] ~~|
Electricity Sector Change in Fuel Industry Cash Flow Mapped to All Fuels Subscript[lignite\
		]=
	Electricity Sector Change in Fuel Industry Cash Flow Before Subsidies and Tax Rebates\
		[lignite es]
	+ Electricity Sector Change in Fuel Industry Cash Flow Before Subsidies and Tax Rebates\
		[lignite w CCS es] ~~|
Electricity Sector Change in Fuel Industry Cash Flow Mapped to All Fuels Subscript[nuclear\
		]=
	Electricity Sector Change in Fuel Industry Cash Flow Before Subsidies and Tax Rebates\
		[nuclear es]
	+ Electricity Sector Change in Fuel Industry Cash Flow Before Subsidies and Tax Rebates\
		[small modular reactor es] ~~|
Electricity Sector Change in Fuel Industry Cash Flow Mapped to All Fuels Subscript[hydrogen\
		]=
	Electricity Sector Change in Fuel Industry Cash Flow Before Subsidies and Tax Rebates\
		[hydrogen combustion turbine es]
	+ Electricity Sector Change in Fuel Industry Cash Flow Before Subsidies and Tax Rebates\
		[hydrogen combined cycle es]
	~	$
	~		|

Electricity Sector Change in Nonenergy Expenditures by Entity[Cash Flow Entity] :EXCEPT:\
		               [government],[electricity suppliers
],[nonenergy industries]=
	0 ~~|
Electricity Sector Change in Nonenergy Expenditures by Entity[government]=
	SUM(Change in Electricity Sector Carbon Tax Rebate due to CCS[Electricity Source!])
	+ SUM(Change in Capacity Construction Subsidies Paid[Electricity Source!])
	+ SUM(Electricity Sector Change in CCS Subsidy Amount Paid[Electricity Source!])
	+ SUM(Change in Electricity Generation Subsidies Paid[Electricity Source!])
	+ SUM(Change in ZEC Subsidies[Electricity Source!])
	+ Change in Subsidies Paid for New Grid Battery Construction
	+ Change in Subsidies Paid for Grid Battery Production
	+ SUM(Change in Electricity Sector CCS Transportation and Storage Subsidies[Electricity Source\
		!]) ~~|
Electricity Sector Change in Nonenergy Expenditures by Entity[electricity suppliers]=
	Change in Repayment of Financing for Electricity Sector Capital Expenditures
	+ SUM(Electricity Sector Change in Amount Spent on OM and Decommissioning by ISIC Code\
		[ISIC Code!])
	+ SUM(Change in Demand Response Costs by Recipient[Cash Flow Entity!]) ~~|
Electricity Sector Change in Nonenergy Expenditures by Entity[nonenergy industries]=
	SUM(Electricity Sector Change in Amount Spent on Capital Equipment by Recipient ISIC Code\
		[ISIC Code!])
	~	$
	~		|

Electricity Sector Change in Nonenergy Industry Expenditures by ISIC Code[ISIC Code] \
		:EXCEPT:    [ISIC 64T66]=
	0 ~~|
Electricity Sector Change in Nonenergy Industry Expenditures by ISIC Code[ISIC 64T66 \
		{Finance and insurance}]=
	Electricity Sector Change in Nonenergy Expenditures by Entity[nonenergy industries]
	~	$
	~		|

Electricity Sector Change in Nonenergy Industry Revenue by ISIC Code[ISIC Code] :EXCEPT:\
		    [ISIC 64T66],[ISIC 27]=
	Electricity Sector Change in Amount Spent on Capital Equipment by Recipient ISIC Code\
		[ISIC Code]
	+ Electricity Sector Change in Amount Spent on OM and Decommissioning by ISIC Code[ISIC Code\
		]
	
	+ Change in Nonenergy Industry Demand Response Costs by ISIC Code[ISIC Code] ~~|
Electricity Sector Change in Nonenergy Industry Revenue by ISIC Code[ISIC 64T66 {Financial and insurance activities}\
		]=
	Electricity Sector Change in Amount Spent on Capital Equipment by Recipient ISIC Code\
		[ISIC 64T66]
	+ Change in Repayment of Financing for Electricity Sector Capital Expenditures
	+ Electricity Sector Change in Amount Spent on OM and Decommissioning by ISIC Code[ISIC 64T66\
		]
	
	+ Change in Nonenergy Industry Demand Response Costs by ISIC Code[ISIC 64T66] ~~|
Electricity Sector Change in Nonenergy Industry Revenue by ISIC Code[ISIC 27 {Manufacture of Electrical Equipment}\
		]=
	Change in Subsidies Paid for Grid Battery Production Retained by Manufacturers
	+ Electricity Sector Change in Amount Spent on Capital Equipment by Recipient ISIC Code\
		[ISIC 27]
	+ Electricity Sector Change in Amount Spent on OM and Decommissioning by ISIC Code[ISIC 27\
		]
	
	+ Change in Nonenergy Industry Demand Response Costs by ISIC Code[ISIC 27]
	~	$
	~		|

Electricity Sector Change in Revenue by Entity[Cash Flow Entity] :EXCEPT:      [nonenergy industries\
		]=
	Electricity Sector Change in Fuel Costs by Recipient[Cash Flow Entity]
	+ Change in Demand Response Costs by Recipient[Cash Flow Entity]
	+ Electricity Sector Change in Subsidies and Tax Rebates by Recipient[Cash Flow Entity\
		] ~~|
Electricity Sector Change in Revenue by Entity[nonenergy industries]=
	SUM(Electricity Sector Change in Amount Spent on Capital Equipment by Recipient ISIC Code\
		[ISIC Code!])
	+ Change in Repayment of Financing for Electricity Sector Capital Expenditures
	+ SUM(Electricity Sector Change in Amount Spent on OM and Decommissioning by ISIC Code\
		[ISIC Code!])
	+ Electricity Sector Change in Fuel Costs by Recipient[nonenergy industries]
	+ Change in Demand Response Costs by Recipient[nonenergy industries]
	+ Electricity Sector Change in Subsidies and Tax Rebates by Recipient[nonenergy industries\
		]
	+ Change in Subsidies Paid for Grid Battery Production Retained by Manufacturers
	~	$
	~		|

Electricity Sector Change in Subsidies and Tax Rebates by Electricity Source[Electricity Source\
		]=
	Change in Capacity Construction Subsidies Paid[Electricity Source]
	+ Change in Electricity Sector Carbon Tax Rebate due to CCS[Electricity Source]
	+ Electricity Sector Change in CCS Subsidy Amount Paid[Electricity Source]
	+ Change in Electricity Generation Subsidies Paid[Electricity Source]
	+ Change in ZEC Subsidies[Electricity Source]
	+ Change in Electricity Sector CCS Transportation and Storage Subsidies[Electricity Source\
		]
	~	$
	~		|

Electricity Sector Change in Subsidies and Tax Rebates by Recipient[Cash Flow Entity]\
		 :EXCEPT:     [electricity suppliers
]=
	0 ~~|
Electricity Sector Change in Subsidies and Tax Rebates by Recipient[electricity suppliers\
		]=
	SUM(Electricity Sector Change in Subsidies and Tax Rebates by Electricity Source[Electricity Source\
		!])
	+ Change in Subsidies Paid for New Grid Battery Construction
	+ Change in Subsidies Paid for Grid Battery Production Passed Through to Consumers
	~	$
	~		|

Electricity Sector Change in Subsidies for Grid Batteries=
	Change in Subsidies Paid for Grid Battery Production Passed Through to Consumers
	+ Change in Subsidies Paid for New Grid Battery Construction
	~	$
	~		|

Electricity Sector CO2e Emissions[Electricity Source]=
	SUM(
	  Electricity Sector Pollutant Emissions[Pollutant!,Electricity Source]
	  * GWP by Pollutant[Pollutant!]
	)
	~	g CO2e
	~		|

Electricity Sector Other Fuel Tax Revenue=
	SUM(
	  Electricity Fuel Use[Electricity Source!]
	  * Electricity Fuel Other Tax or Subsidy Amount per Unit Energy[Electricity Source!\
		]
	)
	~	$
	~		|

Electricity Sector Pollutant Emissions[Pollutant,Electricity Source] :EXCEPT:   [CO2,\
		biomass es],[CO2,biomass w CCS es]=
	MAX(
	  0,
	
	  (
	    Electricity Sector Pollutant Emissions before CCS[Pollutant,Electricity Source]
	    - This Year Pollutants Sequestered by Electricity Sector[Pollutant,Electricity Source\
		]
	  )
	  * (1 + Perc Change in In Scope Emissions due to Electricity Exports)
	  + Absolute Change in In Scope Emissions due to Electricity Imports[Pollutant,Electricity Source\
		]
	) ~~|
Electricity Sector Pollutant Emissions[CO2,biomass es]=
	(
	  Electricity Sector Pollutant Emissions before CCS[CO2,biomass es]
	  - This Year Pollutants Sequestered by Electricity Sector[CO2,biomass es]
	)
	* (1 + Perc Change in In Scope Emissions due to Electricity Exports)
	+ Absolute Change in In Scope Emissions due to Electricity Imports[CO2,biomass es] ~~|
Electricity Sector Pollutant Emissions[CO2,biomass w CCS es]=
	(
	  Electricity Sector Pollutant Emissions before CCS[CO2,biomass w CCS es]
	  - This Year Pollutants Sequestered by Electricity Sector[CO2,biomass w CCS es]
	)
	* (1 + Perc Change in In Scope Emissions due to Electricity Exports)
	+ Absolute Change in In Scope Emissions due to Electricity Imports[CO2,biomass w CCS es\
		]
	~	g pollutant
	~	CO2 emissions from biomass and biomass with CCS are the only emissions \
		types that are allowed to be negative.
	|

Electricity Sector Pollutant Emissions before CCS[Pollutant,Electricity Source]=
	Electricity Generation by Type[Electricity Source]
	  * Electricity Fuel Pollutant Emissions Intensity per MWh[Electricity Source,Pollutant\
		]
	~	g pollutant
	~		|

Electricity Source:
	hard coal es,
	natural gas steam turbine es,
	natural gas combined cycle es,
	nuclear es,
	hydro es,
	onshore wind es,
	solar PV es,
	solar thermal es,
	biomass es,
	geothermal es,
	petroleum es,
	natural gas peaker es,
	lignite es,
	offshore wind es,
	crude oil es,
	heavy or residual fuel oil es,
	municipal solid waste es,
	hard coal w CCS es,
	natural gas combined cycle w CCS es,
	biomass w CCS es,
	lignite w CCS es,
	small modular reactor es,
	hydrogen combustion turbine es,
	hydrogen combined cycle es
	-> electricity source within all fuels
	~	
	~		|

electricity source within all fuels:
	hard coal,
	natural gas,
	natural gas,
	nuclear,
	hydro,
	wind,
	solar,
	solar,
	biomass,
	geothermal,
	petroleum diesel,
	natural gas,
	lignite,
	wind,
	crude oil,
	heavy or residual fuel oil,
	municipal solid waste,
	hard coal,
	natural gas,
	biomass,
	lignite,
	nuclear,
	hydrogen,
	hydrogen
	-> Electricity Source
	~	
	~	The sub-range for the Electricity Sector fuels repeats the same element on \
		multiple lines because All Fuels consolidates solar PV and solar thermal \
		into "solar," onshore wind and offshore wind into "wind," all natural gas \
		plant types into "natural gas," all coal plant types into "hard coal," all \
		lignite plant types into "lignite," all biomass plant types into \
		"biomass," and nuclear and small modular reactor plant types into \
		"nuclear," and we need a one-to-one correspondance to do subscript \
		mapping.  This appears to work in Vensim but may be non-standard usage of \
		subscript mapping.
	|

Electricity Subtotal Change in Capital Expenditures=
	Change in Electricity Sector Battery Costs
	+ SUM(Change in Electricity Sector Capacity Construction Costs[Electricity Source!])
	+ Change in Transmission Construction Costs
	+ SUM(Change in Spur Line Construction Costs[Electricity Source!])
	+ Change in Distribution Construction Costs
	~	$
	~		|

Electricity Subtotal Change in OM Expenditures=
	Change in Amount Spent on Importing Electricity
	+ SUM(Change in Electricity Sector OM Costs by Recipient ISIC Code[ISIC Code!])
	+ SUM(Change in Demand Response Costs by Recipient[Cash Flow Entity!])
	+ SUM(Change in Electricity Sector CCS Transportation and Storage Costs[Electricity Source\
		!])
	+ Change in Transmission OM Costs
	+ Change in Distribution OM Costs
	+ Change in Decommissioning Costs
	~	$
	~		|

Electricity Subtotal Change in Other Expenditures=
	SUM(Change in Electricity Generation Subsidies Paid[Electricity Source!])
	+ SUM(Change in Capacity Construction Subsidies Paid[Electricity Source!])
	+ SUM(Change in Electricity Sector Carbon Tax Rebate due to CCS[Electricity Source!]\
		)
	+ SUM(Electricity Sector Change in CCS Subsidy Amount Paid[Electricity Source!])
	+ SUM(Change in Electricity Sector CCS Transportation and Storage Subsidies[Electricity Source\
		!])
	~	$
	~		|

Electricity Subtotal Change in Tax Revenues=
	SUM(Change in Electricity Fuel Taxes Paid[Electricity Source!])
	~	$
	~		|

Electricity Supplier Costs Recovered through Electricity Rates per Unit Electricity Delivered\
		=
	(Electricity Supplier Recoverable OM and Other Expenditures
	 +Wholesale Energy Market Costs
	 +This Year Capacity Market Repayment*One Year
	 +This Year Ongoing CES Costs
	 +SYTaDC Start Year Transmission Capital Costs
	 +SYTaDC Start Year Distribution Capital Costs
	)
	
	/Total Electricity Demand Plus Exports in BTU
	~	$/BTU
	~		|

Electricity Supplier Costs Recovered through Electricity Rates per Unit Electricity Delivered for Cost of Service Rates\
		=
	QUANTUM(
	  Total Annual Recoverable Costs for Cost of Service Rates
	  /Total Electricity Demand in BTU,
	
	  Quantization Size for Dollars
	)
	~	$/BTU
	~		|

Electricity Supplier Other Expenditures=
	SUM(Cost of Providing Demand Response by Recipient[Cash Flow Entity!])
	+ Amortized Decommissioning Costs
	~	$
	~		|

Electricity Supplier Recoverable OM and Other Expenditures=
	Repayment of Financing for Electricity Sector Capital Expenditures Including Construction Subsidies
	+Amount Spent on Importing Electricity
	+Electricity Transmission and Distribution OM Expenditures
	+Electricity Supplier Other Expenditures
	{-Amount Received from Exporting Electricity}
	-SUM(Electricity Sector Carbon Tax Rebate due to CCS[Electricity Source!])
	~	$
	~		|

Electricity Timeslice:
	average winter day,
	average spring day,
	average summer day,
	average fall day,
	peak summer day,
	peak winter day
	~	
	~		|

Electricity Transmission and Distribution OM Expenditures=
	Distribution OM Costs
	+Transmission OM Costs
	~	$
	~		|

Embedded CO2 in Exported Fuels[All Fuels]=
	Fuel Exports[All Fuels]
	* CO2 Emissions Intensity by Fuel for All Fuels[All Fuels]
	~	g pollutant
	~		|

Emissions Type:
	energy related emissions,
	process emissions
	~	
	~		|

Energy Export Revenue including Electricity[All Fuels] :EXCEPT: [electricity]=
	QUANTUM(
	  Fuel Export Revenue[All Fuels],
	  QSfCF Quantization Size for Cash Flows
	) ~~|
Energy Export Revenue including Electricity[electricity]=
	Amount Received from Exporting Electricity
	~	$
	~		|

Energy Exports including Electricity[All Fuels] :EXCEPT:   [electricity]=
	QUANTUM(
	  Fuel Exports[All Fuels],
	  QSfE Quantization Size for Energy
	) ~~|
Energy Exports including Electricity[electricity]=
	Exported Electricity
	/ MWh per BTU
	~	BTU
	~		|

Energy Import Expenditures including Electricity[All Fuels] :EXCEPT: [electricity]=
	QUANTUM(
	  Fuel Import Expenditures[All Fuels],
	  QSfCF Quantization Size for Cash Flows
	) ~~|
Energy Import Expenditures including Electricity[electricity]=
	Amount Spent on Importing Electricity
	~	$
	~		|

Energy Imports including Electricity[All Fuels] :EXCEPT:   [electricity]=
	QUANTUM(
	  Fuel Imports[All Fuels],
	  QSfE Quantization Size for Energy
	) ~~|
Energy Imports including Electricity[electricity]=
	Imported Electricity
	/ MWh per BTU
	~	BTU
	~		|

energy industries within industry category:
	coal mining 05,
	oil and gas extraction 06,
	refined petroleum and coke 19,
	energy pipelines and gas processing 352T353
	~	
	~		|

Energy Intensity of Industrial Production by Fuel and Process for New Equipment in Electricity Equivalent\
		[Industry Category
,Industrial Fuel,Industrial Process]=
	Start Year Energy Intensity of Industrial Production by Fuel and Process in Electricity Equivalent\
		[Industry Category,Industrial Fuel
	,Industrial Process]
	* New Industrial Equipment Energy Intensity[Industry Category,Industrial Fuel,Industrial Process\
		]
	/ SYIEUEFbIPaF Start Year Industrial Equipment Unit Energy Factor by Industrial Process and Fuel\
		[Industrial Fuel,Industrial Process]
	~	BTU/$
	~		|

Energy Intensity of Industrial Production by Fuel for New Equipment in Electricity Equivalent\
		[Industry Category,Industrial Fuel]=
	SUM(Energy Intensity of Industrial Production by Fuel and Process for New Equipment in Electricity Equivalent\
		[Industry Category,Industrial Fuel,Industrial Process!])
	~	BTU/$
	~		|

Energy Production including Energy Carriers[All Fuels] :EXCEPT:  [electricity],[heat]\
		,[hydrogen]=
	QUANTUM(
	  Fuel Production[All Fuels],
	  QSfE Quantization Size for Energy
	) ~~|
Energy Production including Energy Carriers[electricity]=
	SUM(Electricity Generation by Type[Electricity Source!])
	/ MWh per BTU ~~|
Energy Production including Energy Carriers[heat]=
	QUANTUM(
	  Total District Heat Use,
	  QSfE Quantization Size for Energy
	) ~~|
Energy Production including Energy Carriers[hydrogen]=
	QUANTUM(
	  SUM(Hydrogen Production by Pathway[Hydrogen Production Pathway!]),
	  QSfE Quantization Size for Energy
	)
	~	BTU
	~		|

Energy Production per Unit Output[ISIC Code]=
	ZIDZ(
	
	  Fuel Production Mapped to ISIC Codes[ISIC Code],
	
	  Output by ISIC Code by Year[ISIC Code]
	)
	~	BTU/$
	~		|

Energy Related CO2 Emissions with Reallocated Energy Carrier Emissions by Agriculture\
		=
	SUM(Industrial Sector Energy Related Emissions after CCS[Industrial Fuel!,agriculture and forestry 01T03\
		,CO2])
	
	+ Total Energy Related Emissions[electricity sector,CO2]
	  * Share of Energy Carrier Use by Sector[industry sector,electricity]
	  * Share of Industrial Energy Carrier Use by Industry[electricity if,agriculture and forestry 01T03\
		]
	
	+ SUM(District Heating Pollutant Emissions[CO2,Industrial Fuel!])
	  * Share of Energy Carrier Use by Sector[industry sector,heat]
	  * Share of Industrial Energy Carrier Use by Industry[heat if,agriculture and forestry 01T03\
		]
	
	+ SUM(Hydrogen Sector Pollutant Emissions[CO2,Industrial Fuel!])
	  * Share of Energy Carrier Use by Sector[industry sector,hydrogen]
	  * Share of Industrial Energy Carrier Use by Industry[hydrogen if,agriculture and forestry 01T03\
		]
	~	g pollutant
	~		|

Energy Related CO2 Emissions with Reallocated Energy Carrier Emissions by Buildings Sector\
		=
	Total Energy Related Emissions[residential buildings sector,CO2]
	+ Total Energy Related Emissions[commercial buildings sector,CO2]
	
	+ Total Energy Related Emissions[electricity sector,CO2]
	  * Share of Energy Carrier Use by Sector[residential buildings sector,electricity]
	+ Total Energy Related Emissions[electricity sector,CO2]
	  * Share of Energy Carrier Use by Sector[commercial buildings sector,electricity]
	
	+ SUM(District Heating Pollutant Emissions[CO2,Industrial Fuel!])
	  * Share of Energy Carrier Use by Sector[residential buildings sector,heat]
	+ SUM(District Heating Pollutant Emissions[CO2,Industrial Fuel!])
	  * Share of Energy Carrier Use by Sector[commercial buildings sector,heat]
	
	+ SUM(Hydrogen Sector Pollutant Emissions[CO2,Industrial Fuel!])
	  * Share of Energy Carrier Use by Sector[residential buildings sector,hydrogen]
	+ SUM(Hydrogen Sector Pollutant Emissions[CO2,Industrial Fuel!])
	  * Share of Energy Carrier Use by Sector[commercial buildings sector,hydrogen]
	~	g pollutant
	~		|

Energy Related CO2 Emissions with Reallocated Energy Carrier Emissions by Geoengineering Sector\
		=
	Total Energy Related Emissions[geoengineering sector,CO2]
	
	+ Total Energy Related Emissions[electricity sector,CO2]
	  * Share of Energy Carrier Use by Sector[geoengineering sector,electricity]
	
	+ SUM(District Heating Pollutant Emissions[CO2,Industrial Fuel!])
	  * Share of Energy Carrier Use by Sector[geoengineering sector,heat]
	
	+ SUM(Hydrogen Sector Pollutant Emissions[CO2,Industrial Fuel!])
	  * Share of Energy Carrier Use by Sector[geoengineering sector,hydrogen]
	~	g pollutant
	~		|

Energy Related CO2 Emissions with Reallocated Energy Carrier Emissions by Industry Sector\
		=
	Total Energy Related Emissions[industry sector,CO2]
	- SUM(Industrial Sector Energy Related Emissions after CCS[Industrial Fuel!,agriculture and forestry 01T03\
		,CO2])
	- SUM(Industrial Sector Energy Related Emissions after CCS[Industrial Fuel!,water and waste 36T39\
		,CO2])
	
	+ Total Energy Related Emissions[electricity sector,CO2]
	  * Share of Energy Carrier Use by Sector[industry sector,electricity]
	  * (1 -
	      (Share of Industrial Energy Carrier Use by Industry[electricity if,agriculture and forestry 01T03\
		]
	        + Share of Industrial Energy Carrier Use by Industry[electricity if,water and waste 36T39\
		]
	      )
	    )
	
	+ SUM(District Heating Pollutant Emissions[CO2,Industrial Fuel!])
	  * Share of Energy Carrier Use by Sector[industry sector,heat]
	  * (1 -
	      (Share of Industrial Energy Carrier Use by Industry[heat if,agriculture and forestry 01T03\
		]
	        + Share of Industrial Energy Carrier Use by Industry[heat if,water and waste 36T39\
		]
	      )
	    )
	
	+ SUM(Hydrogen Sector Pollutant Emissions[CO2,Industrial Fuel!])
	  * Share of Energy Carrier Use by Sector[industry sector,hydrogen]
	  * (1 -
	      (Share of Industrial Energy Carrier Use by Industry[hydrogen if,agriculture and forestry 01T03\
		]
	        + Share of Industrial Energy Carrier Use by Industry[hydrogen if,water and waste 36T39\
		]
	      )
	    )
	~	g pollutant
	~		|

Energy Related CO2 Emissions with Reallocated Energy Carrier Emissions by Transportation Sector\
		=
	Total Energy Related Emissions[transportation sector,CO2]
	+ Total Energy Related Emissions[electricity sector,CO2]
	  * Share of Energy Carrier Use by Sector[transportation sector,electricity]
	
	+ SUM(Hydrogen Sector Pollutant Emissions[CO2,Industrial Fuel!])
	  * Share of Energy Carrier Use by Sector[transportation sector,hydrogen]
	~	g pollutant
	~		|

Energy Related CO2 Emissions with Reallocated Energy Carrier Emissions by Waste Management\
		=
	SUM(Industrial Sector Energy Related Emissions after CCS[Industrial Fuel!,water and waste 36T39\
		,CO2])
	
	+ Total Energy Related Emissions[electricity sector,CO2]
	  * Share of Energy Carrier Use by Sector[industry sector,electricity]
	  * Share of Industrial Energy Carrier Use by Industry[electricity if,water and waste 36T39\
		]
	
	+ SUM(District Heating Pollutant Emissions[CO2,Industrial Fuel!])
	  * Share of Energy Carrier Use by Sector[industry sector,heat]
	  * Share of Industrial Energy Carrier Use by Industry[heat if,water and waste 36T39\
		]
	
	+ SUM(Hydrogen Sector Pollutant Emissions[CO2,Industrial Fuel!])
	  * Share of Energy Carrier Use by Sector[industry sector,hydrogen]
	  * Share of Industrial Energy Carrier Use by Industry[hydrogen if,water and waste 36T39\
		]
	~	g pollutant
	~		|

Energy Related CO2 per Unit GDP=
	SUM(Total Energy Related Emissions[Sectors!,CO2])
	/ Gross Domestic Product
	~	g pollutant/$
	~		|

Energy Related Pollutant Emissions by Fuel[Pollutant,electricity]=
	0 ~~|
Energy Related Pollutant Emissions by Fuel[Pollutant,hard coal]=
	SUM(Direct Buildings Pollutant Emissions[Building Type!,Building Component!,hard coal bf\
		,Pollutant])
	+ District Heating Pollutant Emissions[Pollutant,hard coal if]
	+ Electricity Sector Pollutant Emissions[Pollutant,hard coal es]
	+ Hydrogen Sector Pollutant Emissions[Pollutant,hard coal if]
	+ SUM(Industrial Sector Energy Related Emissions after CCS[hard coal if,Industry Category\
		!,Pollutant])
	+ Geoengineering Sector Pollutant Emissions Excluding Captured CO2[Pollutant,hard coal if\
		] ~~|
Energy Related Pollutant Emissions by Fuel[Pollutant,natural gas]=
	SUM(Direct Buildings Pollutant Emissions[Building Type!,Building Component!,natural gas bf\
		,Pollutant])
	+ District Heating Pollutant Emissions[Pollutant,natural gas if]
	+ Electricity Sector Pollutant Emissions[Pollutant,natural gas steam turbine es]
	+ Electricity Sector Pollutant Emissions[Pollutant,natural gas combined cycle es]
	+ Electricity Sector Pollutant Emissions[Pollutant,natural gas peaker es]
	+ Hydrogen Sector Pollutant Emissions[Pollutant,natural gas if]
	+ SUM(Industrial Sector Energy Related Emissions after CCS[natural gas if,Industry Category\
		!,Pollutant])
	+ SUM(Transportation Pollutant Emissions Disaggregated[Vehicle Type!,Pollutant,Cargo Type\
		!,natural gas tf])
	+ Geoengineering Sector Pollutant Emissions Excluding Captured CO2[Pollutant,natural gas if\
		] ~~|
Energy Related Pollutant Emissions by Fuel[Pollutant,nuclear]=
	0 ~~|
Energy Related Pollutant Emissions by Fuel[Pollutant,hydro]=
	0 ~~|
Energy Related Pollutant Emissions by Fuel[Pollutant,wind]=
	0 ~~|
Energy Related Pollutant Emissions by Fuel[Pollutant,solar]=
	0 ~~|
Energy Related Pollutant Emissions by Fuel[Pollutant,biomass]=
	SUM(Direct Buildings Pollutant Emissions[Building Type!,Building Component!,biomass bf\
		,Pollutant])
	+ District Heating Pollutant Emissions[Pollutant,biomass if]
	+ Electricity Sector Pollutant Emissions[Pollutant,biomass es]
	+ Hydrogen Sector Pollutant Emissions[Pollutant,biomass if]
	+ SUM(Industrial Sector Energy Related Emissions after CCS[biomass if,Industry Category\
		!,Pollutant])
	+ Geoengineering Sector Pollutant Emissions Excluding Captured CO2[Pollutant,biomass if\
		] ~~|
Energy Related Pollutant Emissions by Fuel[Pollutant,petroleum gasoline]=
	SUM(Transportation Pollutant Emissions Disaggregated[Vehicle Type!,Pollutant,Cargo Type\
		!,petroleum gasoline tf]) ~~|
Energy Related Pollutant Emissions by Fuel[Pollutant,petroleum diesel]=
	SUM(Direct Buildings Pollutant Emissions[Building Type!,Building Component!,petroleum diesel bf\
		,Pollutant])
	+ District Heating Pollutant Emissions[Pollutant,petroleum diesel if]
	+ Electricity Sector Pollutant Emissions[Pollutant,petroleum es]
	+ Hydrogen Sector Pollutant Emissions[Pollutant,petroleum diesel if]
	+ SUM(Industrial Sector Energy Related Emissions after CCS[petroleum diesel if,Industry Category\
		!,Pollutant])
	+ SUM(Transportation Pollutant Emissions Disaggregated[Vehicle Type!,Pollutant,Cargo Type\
		!,petroleum diesel tf])
	+ Geoengineering Sector Pollutant Emissions Excluding Captured CO2[Pollutant,petroleum diesel if\
		] ~~|
Energy Related Pollutant Emissions by Fuel[Pollutant,biofuel gasoline]=
	SUM(Transportation Pollutant Emissions Disaggregated[Vehicle Type!,Pollutant,Cargo Type\
		!,biofuel gasoline tf]) ~~|
Energy Related Pollutant Emissions by Fuel[Pollutant,biofuel diesel]=
	SUM(Transportation Pollutant Emissions Disaggregated[Vehicle Type!,Pollutant,Cargo Type\
		!,biofuel diesel tf]) ~~|
Energy Related Pollutant Emissions by Fuel[Pollutant,jet fuel or kerosene]=
	SUM(Transportation Pollutant Emissions Disaggregated[Vehicle Type!,Pollutant,Cargo Type\
		!,jet fuel tf])
	+ SUM(Direct Buildings Pollutant Emissions[Building Type!,Building Component!,kerosene bf\
		,Pollutant]) ~~|
Energy Related Pollutant Emissions by Fuel[Pollutant,heat]=
	0 ~~|
Energy Related Pollutant Emissions by Fuel[Pollutant,geothermal]=
	0 ~~|
Energy Related Pollutant Emissions by Fuel[Pollutant,lignite]=
	Electricity Sector Pollutant Emissions[Pollutant,lignite es] ~~|
Energy Related Pollutant Emissions by Fuel[Pollutant,crude oil]=
	Electricity Sector Pollutant Emissions[Pollutant,crude oil es]
	+ SUM(Industrial Sector Energy Related Emissions after CCS[crude oil if,Industry Category\
		!,Pollutant])
	+ Geoengineering Sector Pollutant Emissions Excluding Captured CO2[Pollutant,crude oil if\
		] ~~|
Energy Related Pollutant Emissions by Fuel[Pollutant,heavy or residual fuel oil]=
	SUM(Direct Buildings Pollutant Emissions[Building Type!,Building Component!,heavy or residual fuel oil bf\
		,Pollutant])
	+ District Heating Pollutant Emissions[Pollutant,heavy or residual fuel oil if]
	+ Electricity Sector Pollutant Emissions[Pollutant,heavy or residual fuel oil es]
	+ Hydrogen Sector Pollutant Emissions[Pollutant,heavy or residual fuel oil if]
	+ SUM(Industrial Sector Energy Related Emissions after CCS[heavy or residual fuel oil if\
		,Industry Category!,Pollutant]
	)
	+ SUM(Transportation Pollutant Emissions Disaggregated[Vehicle Type!,Pollutant,Cargo Type\
		!,heavy or residual fuel oil tf
	])
	+ Geoengineering Sector Pollutant Emissions Excluding Captured CO2[Pollutant,heavy or residual fuel oil if\
		] ~~|
Energy Related Pollutant Emissions by Fuel[Pollutant,LPG propane or butane]=
	SUM(Direct Buildings Pollutant Emissions[Building Type!,Building Component!,LPG propane or butane bf\
		,Pollutant])
	+ District Heating Pollutant Emissions[Pollutant,LPG propane or butane if]
	+ Hydrogen Sector Pollutant Emissions[Pollutant,LPG propane or butane if]
	+ SUM(Industrial Sector Energy Related Emissions after CCS[LPG propane or butane if,\
		Industry Category!,Pollutant])
	+ SUM(Transportation Pollutant Emissions Disaggregated[Vehicle Type!,Pollutant,Cargo Type\
		!,LPG propane or butane tf])
	+ Geoengineering Sector Pollutant Emissions Excluding Captured CO2[Pollutant,LPG propane or butane if\
		] ~~|
Energy Related Pollutant Emissions by Fuel[Pollutant,municipal solid waste]=
	Electricity Sector Pollutant Emissions[Pollutant,municipal solid waste es] ~~|
Energy Related Pollutant Emissions by Fuel[Pollutant,hydrogen]=
	SUM(Direct Buildings Pollutant Emissions[Building Type!,Building Component!,hydrogen bf\
		,Pollutant])
	+ District Heating Pollutant Emissions[Pollutant,hydrogen if]
	+ Hydrogen Sector Pollutant Emissions[Pollutant,hydrogen if]
	+ SUM(Industrial Sector Energy Related Emissions after CCS[hydrogen if,Industry Category\
		!,Pollutant])
	+ SUM(Transportation Pollutant Emissions Disaggregated[Vehicle Type!,Pollutant,Cargo Type\
		!,hydrogen tf])
	+ Geoengineering Sector Pollutant Emissions Excluding Captured CO2[Pollutant,hydrogen if\
		]
	~	g pollutant
	~		|

energy supplier cash flow entity:
	electricity suppliers,
	coal suppliers,
	natural gas and petroleum suppliers,
	biomass and biofuel suppliers,
	other energy suppliers
	~	
	~		|

Energy Use Reduction from Buildings Retrofit This Year[Building Type,Building Component\
		]=
	MAX(
	  0,
	
	  SUM(Reduction in All Existing Buildings Energy Use due to Retrofitting Preexisting Buildings\
		[Building Type,Building Fuel!,Building Component]
	  - Last Year Reduction in All Existing Buildings Energy Use due to Retrofitting Preexisting Buildings\
		[Building Type,Building Fuel!,Building Component
	])
	)
	~	BTU
	~		|

Envelope Multiplier Unit Correction Factor=
	1
	~	1/BTU
	~		|

EoBSDwEC Elasticity of Building Service Demand wrt Energy Cost[Building Fuel,Building Type\
		]=
	GET DIRECT CONSTANTS(
	   'InputData/bldgs/EoBSDwEC/EoBSDwEC.csv',
	   ',',
	   'B2'
	)
	~	Dmnl
	~	These are short-run elasticities, which we use to represent the elasticity \
		as a result of behavior change.
	|

EoCEDwEC Elasticity of Component Energy Demand wrt Energy Cost[Building Fuel,Building Type\
		]=
	GET DIRECT CONSTANTS(
	   'InputData/bldgs/EoCEDwEC/EoCEDwEC.csv',
	   ',',
	   'B2'
	)
	~	Dmnl
	~	This is the non-behavioral component of long-run elasticity- e.g. the \
		component reflecting changes in equipment rather than behavior of building \
		occupants.  See the Excel file in the InputData folder for more details.
	|

