Boolean Use Non BAU Minimum Required ZEV Sales Percentage by Subregion[Cargo Type,Vehicle Type\
		]=
	0,	0,	0,	0,	0,	0;	{passenger}
	0,	0,	0,	0,	0,	0;	{freight}
	{LDVs}	{HDVs}	{airc}	{rail}	{ship}	{mtrbk}
	~	Dmnl [0,1]
	~		|

Boolean Use Non BAU Minimum Required ZEV Sales Percentage This Year by Subregion[Cargo Type\
		,Vehicle Type]=
	Boolean Use Non BAU Minimum Required ZEV Sales Percentage by Subregion[Cargo Type,Vehicle Type\
		]
	* VECTOR ELM MAP(
	    Selected Policy Implementation Schedule[trans non BAU ZEV minimum X passenger X LDVs\
		],
	
	    (Cargo Type-1)*ELMCOUNT(Vehicle Type) + (Vehicle Type-1)
	  )
	~	Dmnl
	~		|

