Binding Peak Hour for Clean Dispatchable Reliability[peak day electricity timeslice,Hour\
		]=
	IF THEN ELSE(SUM(Net Electricity Clean Firm Demand Relative to Available Clean Firm Supply by Hour before Additions\
		[Hour!,peak day electricity timeslice!])=0,0,
	
	IF THEN ELSE(Net Electricity Clean Firm Demand Relative to Available Clean Firm Supply by Hour before Additions\
		[Hour,peak day electricity timeslice]=VMAX(Net Electricity Clean Firm Demand Relative to Available Clean Firm Supply by Hour before Additions\
		[Hour!,peak day electricity timeslice!]),1,0)
	
	)
	~	Dmnl
	~		|

Binding Peak Hour for Reliability Additions[peak day electricity timeslice,Hour]=
	IF THEN ELSE(Net Electricity Demand Relative to Available Supply by Hour before Reliability Additions\
		[peak day electricity timeslice,Hour]<=0,0,
	
	IF THEN ELSE(Net Electricity Demand Relative to Available Supply by Hour before Reliability Additions\
		[peak day electricity timeslice,Hour]=VMAX(Net Electricity Demand Relative to Available Supply by Hour before Reliability Additions\
		[peak day electricity timeslice!,Hour!]),1,0)
	
	)
	~	Dmnl
	~		|

biomass and biofuel within all fuels:
