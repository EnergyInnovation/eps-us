Salvageable Curtailed Capacity by Hour for Hybrid Power Plants[Electricity Source,Electricity Timeslice\
		,Hour]=
	MIN(
	  Expected Curtailed Capacity by Hour for Plants Built This Year[Electricity Source,\
		Electricity Timeslice,Hour],
	  HESBCpUEC Hybrid Electricity Source Battery Capacity per Unit Electricity Capacity
	)
	~	Dmnl
	~		|

SCoC Social Cost of Carbon:INTERPOLATE::=
	GET DIRECT DATA(
	   'InputData/add-outputs/SCoC/SCoC.csv',
	   ',',
	   'A',
	   'B2'
	)
	~	$/g CO2e
	~		|

Season:
	summer,
	winter
	~	
	~	This subscript is used in the Electricity Sector power plant peaking \
		calculations.
	|

Second Tier Guaranteed Dispatch Amount[Electricity Source,Electricity Timeslice,Hour]\
		=
	Guaranteed Dispatch Amount[Electricity Source,Electricity Timeslice,Hour]
	- First Tier Guaranteed Dispatch Amount[Electricity Source,Electricity Timeslice,Hour\
		]
	~	MW*hour
	~		|

secondary petroleum product within all fuels:
	petroleum gasoline,
	petroleum diesel,
	jet fuel or kerosene,
	heavy or residual fuel oil,
	LPG propane or butane
	~	
	~		|

Sectors:
	transportation sector,
	electricity sector,
	residential buildings sector,
	commercial buildings sector,
	industry sector,
	district heat and hydrogen sector,
	LULUCF sector,
	geoengineering sector
	~	
	~	These sectors are used to manage differential BAU fuel prices by sector \
		and CCS allocation between electricity and industry sectors.  Since fuel \
		prices differ by building type, the buildings sector is split into \
		residential and commercial buildings.
	|

Selected Policy Implementation Schedule[Policy Element]=
	SUM(
	  IF THEN ELSE(
	    Policy Implementation Schedule Selector = Policy Schedule Sequence Numbers[Policy Schedule\
		!],
	    1,
	    0
	  )
	  * FoPITY Fraction of Policy Implemented This Year[Policy Schedule!,Policy Element]\
		(Dimensionless Time)
	)
	~	Dmnl
	~		|

Selected Policy Implementation Schedule for Future Years[Policy Element,Future Year]=
	SUM(
	  IF THEN ELSE(
	    Policy Implementation Schedule Selector = Policy Schedule Sequence Numbers[Policy Schedule\
		!],
	    1,
	    0
	  )
	  * FoPITY Fraction of Policy Implemented This Year[Policy Schedule!,Policy Element]\
		(Numerical Future Year Definitions[
	Future Year]/One Year)
	)
	~	Dmnl
	~		|

SES Seasonal Electricity Storage Annual Charge and Discharge Cycles=
	GET DIRECT CONSTANTS(
	   'InputData/elec/SES/SES-annual-cycles.csv',
	   ',',
	   'B2*'
	)
	~	Dmnl
	~		|

SES Seasonal Electricity Storage Capacity:=
	GET DIRECT DATA(
	   'InputData/elec/SES/SES-capacity.csv',
	   ',',
	   '1',
	   'B2'
	)
	~	MW*hr
	~	This variable should be in MWh, not MW, and indicates the total quantity \
		of electricity that can be stored using seasonal technologies. It is \
		multiplied by the annual number of charge/discharge cycles to establish \
		the quantity of electricity these technologies absorb and dispense each \
		year.
	|

SES Seasonal Electricity Storage Round Trip Efficiency=
	GET DIRECT CONSTANTS(
	   'InputData/elec/SES/SES-efficiency.csv',
	   ',',
	   'B2*'
	)
	~	Dmnl
	~		|

sex:
	male,
	female
	~	
	~		|

Share of All Existing Buildings Subject to Retrofitting to Date[Building Type]=
	Share of Preexisting Buildings Subject to Retrofitting To Date[Building Type]
	* Share of Start Year Buildings Surviving[Building Type]
	~	Dmnl
	~		|

Share of Annual Expected Output that Can be Shifted[Electricity Source]=
	SUM(Share of Daily Expected Output that Can be Shifted by Electricity Timeslice[Electricity Source\
		,Electricity Timeslice
	!]*SHELF Days per Electricity Timeslice[Electricity Timeslice!])
	/SUM(SHELF Days per Electricity Timeslice[Electricity Timeslice!])
	~	Dmnl
	~		|

Share of Available Capacity Actually Dispatched by Hour[Electricity Timeslice, Hour]=
	ZIDZ(
	  Total Electricity Dispatched by Hour[Electricity Timeslice,Hour]/One Hour,
	
	  SUM(Available Capacity by Hour[Electricity Source!,Electricity Timeslice,Hour])
	)
	~	Dmnl
	~		~	:SUPPLEMENTARY 
	|

Share of Buildings Sector Energy Use by Building Component[Building Type,Building Fuel\
		,Building Component]=
	ZIDZ(
	  Building Components Energy Use[Building Type,Building Fuel,Building Component],
	  SUM(Building Components Energy Use[Building Type!,Building Fuel,Building Component\
		!])
	)
	~	Dmnl
	~		|

Share of Daily Expected Output that Can be Shifted by Electricity Timeslice[Electricity Source\
		,Electricity Timeslice]=
	MIN(1,
	      ZIDZ((HESBCpUEC Hybrid Electricity Source Battery Capacity per Unit Electricity Capacity
	*GBSC Diurnal Grid Battery Daily Storage Duration),
	      Expected Daily Hours of Electricity Output by Electricity Timeslice[Electricity Source
	,Electricity Timeslice]
	     ))
	~	Dmnl
	~		|

Share of Distributed Electricity Emissions by Building Type[Building Type,Electricity Source\
		]=
	ZIDZ(Distributed Electricity Source Capacity[Building Type,Electricity Source],
	  SUM(Distributed Electricity Source Capacity[Building Type!,Electricity Source])
	)
	~	Dmnl
	~		|

Share of Electricity Generation Capacity Built This Year[Electricity Source]=
	ZIDZ(
	
	  SUM((Electricity Generation Capacity by Vintage[Electricity Source,Modeled Vintage\
		!]*This Year Modeled Vintage Flag[Modeled Vintage
	!])),
	
	  Electricity Generation Capacity[Electricity Source]
	
	)
	~	Dmnl
	~		|

Share of Energy Carrier Use by Sector[Sectors,All Fuels] :EXCEPT: [Sectors,primary fuel\
		]=
	ZIDZ(
	  Total Energy Use by Sector[Sectors,All Fuels],
	  SUM(Total Energy Use by Sector[Sectors!,All Fuels])
	) ~~|
Share of Energy Carrier Use by Sector[Sectors,primary fuel]=
	0
	~	Dmnl
	~		|

Share of EVs Used for Grid Balancing=
	0
	~	Dmnl [0,1]
	~		|

Share of EVs Used for Grid Balancing This Year=
	Share of EVs Used for Grid Balancing
	* Selected Policy Implementation Schedule[elec use EVs for grid balancing X]
	~	Dmnl
	~		|

Share of Exports by Hour by Optimization Pass[Electricity Timeslice,Hour,Optimization Pass\
		]=
	ZIDZ(Inverted Spare Potential Output from Surviving Capacity by Hour by Optimization Pass\
		[Electricity Timeslice,Hour,Optimization Pass],
	SUM(Inverted Spare Potential Output from Surviving Capacity by Hour by Optimization Pass\
		[Electricity Timeslice,Hour!,Optimization Pass]))
	~	Dmnl
	~		|

Share of Fuel Production by Energy Supplier Cash Flow Entity[cash flow entity excluding energy suppliers\
		]=
	0 ~~|
Share of Fuel Production by Energy Supplier Cash Flow Entity[electricity suppliers]=
	ZIDZ(
	  Energy Production including Energy Carriers[electricity],
	
	  SUM(Energy Production including Energy Carriers[All Fuels!])
	) ~~|
Share of Fuel Production by Energy Supplier Cash Flow Entity[coal suppliers]=
	ZIDZ(
	  SUM(Energy Production including Energy Carriers[coal mining industry fuel within all fuels\
		!]),
	
	  SUM(Energy Production including Energy Carriers[All Fuels!])
	) ~~|
Share of Fuel Production by Energy Supplier Cash Flow Entity[natural gas and petroleum suppliers\
		]=
	ZIDZ(
	  SUM(Energy Production including Energy Carriers[NGPS industry fuel within all fuels\
		!]),
	
	  SUM(Energy Production including Energy Carriers[All Fuels!])
	) ~~|
Share of Fuel Production by Energy Supplier Cash Flow Entity[biomass and biofuel suppliers\
		]=
	ZIDZ(
	  SUM(Energy Production including Energy Carriers[biomass and biofuel within all fuels\
		!]),
	
	  SUM(Energy Production including Energy Carriers[All Fuels!])
	) ~~|
Share of Fuel Production by Energy Supplier Cash Flow Entity[other energy suppliers]=
	ZIDZ(
	  SUM(Energy Production including Energy Carriers[other energy supplier fuel within all fuels\
		!]),
	
	  SUM(Energy Production including Energy Carriers[All Fuels!])
	)
	~	Dmnl
	~		|

Share of Fuel Production by Fuel within ISIC Code[All Fuels,ISIC Code]=
	ZIDZ(BAU Energy Production including Energy Carriers[All Fuels]*FtPICM Fuel to Producing ISIC Code Map\
		[All Fuels,ISIC Code
	],
	  SUM(BAU Energy Production including Energy Carriers[All Fuels!]*FtPICM Fuel to Producing ISIC Code Map\
		[All Fuels!,
	ISIC Code]))
	~	Dmnl
	~		|

Share of Imports by Hour by Optimization Pass[Electricity Timeslice,Hour,Optimization Pass\
		]=
	ZIDZ(Spare Potential Output from Surviving Capacity by Hour by Optimization Pass[Electricity Timeslice\
		,Hour,Optimization Pass],SUM(Spare Potential Output from Surviving Capacity by Hour by Optimization Pass\
		[Electricity Timeslice,Hour!,Optimization Pass]))
	~	Dmnl
	~		|

Share of Industrial Energy Carrier Use by Industry[electricity if,Industry Category]=
	ZIDZ(
	  Industrial Fuel Use[electricity if,Industry Category],
	
	  SUM(Industrial Fuel Use[electricity if,Industry Category!])
	) ~~|
Share of Industrial Energy Carrier Use by Industry[heat if,Industry Category]=
	ZIDZ(
	  Industrial Fuel Use[heat if,Industry Category],
	
	  SUM(Industrial Fuel Use[heat if,Industry Category!])
	) ~~|
Share of Industrial Energy Carrier Use by Industry[hydrogen if,Industry Category]=
	ZIDZ(
	  Industrial Fuel Use[hydrogen if,Industry Category],
	
	  SUM(Industrial Fuel Use[hydrogen if,Industry Category!])
	)
	~	Dmnl
	~		|

Share of Max Hourly Exports Met[Electricity Timeslice,Hour,Optimization Pass]=
	ZIDZ(Electricity Exports by Hour[Electricity Timeslice,Hour,Optimization Pass],
	  MaMHEIaE Maximum Hourly Exports)
	~	Dmnl
	~		|

Share of Max Hourly Imports Met[Electricity Timeslice,Hour,Optimization Pass]=
	ZIDZ(Electricity Imports by Hour[Electricity Timeslice,Hour,Optimization Pass],
	  MaMHEIaE Maximum Hourly Imports)
	~	Dmnl
	~		|

Share of Maximum Annual Decrease in Demand from Diurnal Grid Batteries=
	ZIDZ(
	  Maximum Annual Decrease in Demand from Diurnal Grid Batteries,
	
	  (Maximum Annual Decrease in Demand from Diurnal Grid Batteries
	  + Maximum Annual Decrease in Demand from EVs
	  + Maximum Annual Decrease in Demand from Pumped Hydro
	  + Maximum Annual Decrease in Demand from Seasonal Electricity Storage
	  )
	)
	~	Dmnl
	~		|

Share of New Industrial Equipment Allocated by Fuel Type in Electricity Equivalent[Industry Category\
		,Industrial Fuel,Industrial Process]=
	ZIDZ(
	  10000*
	  IES Industrial Equipment Shareweights[Industry Category,Industrial Fuel,Industrial Process\
		]
	  * exp(Industrial Equipment Annual Costs and Annual Financing Repayment per Unit Industrial Output in Electricity Equivalent
	[Industry Category,Industrial Fuel,Industrial Process
	]
	    * IELC Industrial Equipment Logit Coefficient),
	  10000*
	  SUM(
	    IES Industrial Equipment Shareweights[Industry Category,Industrial Fuel!,Industrial Process\
		]
	    * exp(Industrial Equipment Annual Costs and Annual Financing Repayment per Unit Industrial Output in Electricity Equivalent
	[Industry Category,Industrial Fuel!,
	Industrial Process]
	      * IELC Industrial Equipment Logit Coefficient)
	  )
	)
	~	Dmnl
	~	Using standard "Logit" function as described at \
		https://jgcri.github.io/gcam-doc/choice.html
	|

Share of New Industrial Equipment by Fuel Type and Process in Electricity Equivalent[\
		Industry Category,Target Industrial Fuel,Industrial Process]=
	Share of New Industrial Equipment by Fuel Type and Process in Electricity Equivalent after Electrification Policy\
		[Industry Category
	,Target Industrial Fuel,Industrial Process]
	*
	(1 - Fraction of Eligible Industrial Energy Use Shifted to Alternate Fuel This Year[\
		Industry Category,Industrial Process])
	
	+ 
	SUM(
	  Share of New Industrial Equipment by Fuel Type and Process in Electricity Equivalent after Electrification Policy\
		[Industry Category,Source Industrial Fuel!,Industrial Process]
	  * Fraction of Eligible Industrial Energy Use Shifted to Alternate Fuel This Year[Industry Category\
		,Industrial Process]
	  * NIEAFSM New Industrial Equipment Alternative Fuel Shifting Matrix[Target Industrial Fuel\
		,Source Industrial Fuel!]
	)
	~	Dmnl
	~		|

Share of New Industrial Equipment by Fuel Type and Process in Electricity Equivalent after Electrification Policy\
		[Industry Category
,Industrial Fuel,Industrial Process] :EXCEPT:    [Industry Category,electricity if,Industrial Process\
		]=
	Share of New Industrial Equipment Allocated by Fuel Type in Electricity Equivalent[Industry Category\
		,Industrial Fuel,Industrial Process]
	- Share of New Industrial Equipment Allocated by Fuel Type in Electricity Equivalent\
		[Industry Category,Industrial Fuel,Industrial Process]
	* IFStE Industrial Fuels Subject to Electrification[Industry Category,Industrial Fuel\
		]
	* Fraction of Eligible Industrial Energy Use Shifted to Electricity This Year[Industry Category\
		,Industrial Process] ~~|
Share of New Industrial Equipment by Fuel Type and Process in Electricity Equivalent after Electrification Policy\
		[Industry Category
,electricity if,Industrial Process]=
	Share of New Industrial Equipment Allocated by Fuel Type in Electricity Equivalent[Industry Category\
		,electricity if,Industrial Process]
	
	+ SUM(
	    Share of New Industrial Equipment Allocated by Fuel Type in Electricity Equivalent\
		[Industry Category,Industrial Fuel!,Industrial Process]
	    * IFStE Industrial Fuels Subject to Electrification[Industry Category,Industrial Fuel\
		!]
	  )
	  * Fraction of Eligible Industrial Energy Use Shifted to Electricity This Year[Industry Category\
		,Industrial Process]
	~	Dmnl
	~		|

Share of New Industrial Equipment by Fuel Type in Electricity Equivalent[Industry Category\
		,Industrial Fuel]=
	ZIDZ(
	  SUM(Output from New Industrial Equipment by Fuel Type and Industrial Process[Industry Category\
		,Industrial Fuel,Industrial Process
	!]),
	
	  SUM(Output from New Industrial Equipment[Industry Category,Industrial Process!])
	)
	~	Dmnl
	~		|

Share of Off Grid Electricity Demand That is New This Year Met by Power Plant Type[Electricity Source\
		]=
	ZIDZ(
	
	  (
	    GHESS Green Hydrogen Electricity Supply Shareweights[Electricity Source]
	    * exp(MAX(1, Cost per Unit New Elec Output Using Expected Capacity Factors[Electricity Source\
		]/Cost per Unit New Elec Output Unit Correction Factor
	)/10^4*GHESLE Green Hydrogen Electricity Supply Logit Exponent
	  )
	  ),
	
	  (
	    SUM(GHESS Green Hydrogen Electricity Supply Shareweights[Electricity Source!]
	    * exp(MAX(1, Cost per Unit New Elec Output Using Expected Capacity Factors[Electricity Source\
		!]/Cost per Unit New Elec Output Unit Correction Factor
	)/10^4*GHESLE Green Hydrogen Electricity Supply Logit Exponent
	  )
	  )
	)
	)
	~	Dmnl
	~		|

Share of Output by Energy Supplier Cash Flow Entity[Cash Flow Entity]=
	ZIDZ(
	  SUM(BAU Output by ISIC Code by Year[Fossil and Energy Utility ISIC Code!]),
	
	  SUM(BAU Output by ISIC Code by Year[ISIC Code!])
	)
	* Share of Fuel Production by Energy Supplier Cash Flow Entity[Cash Flow Entity]
	~	Dmnl
	~		|

Share of Preexisting Buildings Subject to Retrofitting[Building Type]=
	0,	{urban residential}
	0,	{rural residential}
	0	{commercial}
	~	Dmnl [0,1]
	~		|

Share of Preexisting Buildings Subject to Retrofitting To Date[Building Type]=
	Share of Preexisting Buildings Subject to Retrofitting[Building Type]
	* VECTOR ELM MAP(
	    Selected Policy Implementation Schedule[bldgs retrofitting X urban residential],
	
	    (Building Type-1)
	  )
	~	Dmnl
	~		|

Share of Start Year Buildings Surviving[Building Type]=
	MAX(
	  0,
	
	  1 -
	  (
	    (Time - INITIAL TIME + 1)
	    / CL Component Lifetime[Building Type,envelope]
	  )
	)
	~	Dmnl
	~		|

