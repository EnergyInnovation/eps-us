	   ',',
	   '1',
	   'B2'
	)
	~	$/metric ton CO2e
	~		|

DACD Direct Air Capture Energy Intensity[Industrial Fuel]:=
	GET DIRECT DATA(
	   'InputData/geoeng/DACD/DACD-energyintensity.csv',
	   ',',
	   '1',
	   'B2'
	)
	~	BTU/metric ton CO2e
	~		|

DACD Direct Air Capture Potential:INTERPOLATE::=
	GET DIRECT DATA(
	   'InputData/geoeng/DACD/DACD-potential.csv',
	   ',',
	   '1',
	   'B2'
	)
	~	metric tons CO2e
	~		|

Daily Average Hourly Spare Potential Output from Surviving Capacity[Electricity Timeslice\
		]=
	SUM(Spare Potential Output from Surviving Capacity by Hour after Seasonal Net Peak Load Reduction\
		[Electricity Timeslice,Hour!])
	/ ELMCOUNT(Hour)
	~	MW*hr
	~		|

Daily Decrease in Demand for Seasonal Net Peak Load Reduction[Electricity Timeslice]=
	ZIDZ(Aggregate Decrease in Demand by Timeslice for Seasonal Net Peak Load Reduction[\
		Electricity Timeslice],SHELF Days per Electricity Timeslice[Electricity Timeslice])
	~	MW*hr
	~		|

Daily Exported Electricity=
	Exported Electricity/Days per Year
	~	MW*hr
	~		|

Daily Hours of Charged or Discharged Generation[Hybrid Electricity Source,Electricity Timeslice\
		]=
	MIN(GBSC Diurnal Grid Battery Daily Storage Duration*HESBCpUEC Hybrid Electricity Source Battery Capacity per Unit Electricity Capacity\
		,
	      Expected Daily Hours of Electricity Output by Electricity Timeslice[Hybrid Electricity Source\
		,Electricity Timeslice]*HESBCpUEC Hybrid Electricity Source Battery Capacity per Unit Electricity Capacity
	   )
	~	hours
	~		|

Daily Imported Electricity=
	Imported Electricity/Days per Year
	~	MW*hr
	~		|

Daily Increase in Demand for Seasonal Net Peak Load Reduction[Electricity Timeslice]=
	ZIDZ(Aggregate Increase in Demand by Timeslice for Seasonal Net Peak Load Reduction[\
		Electricity Timeslice], SHELF Days per Electricity Timeslice[Electricity Timeslice]\
		)
	~	MW*hr
	~		|

Daily Net Imported Electricity=
	Daily Imported Electricity
	-Daily Exported Electricity
	~	MW*hr
	~		|

Days per Year=
	365
	~	Dmnl
	~		|

DCCpUIiPL Distribution Construction Cost per Unit Increase in Peak Load=
	GET DIRECT CONSTANTS(
	   'InputData/elec/DCCpUIiPL/DCCpUIiPL.csv',
	   ',',
	   'B2*'
	)
	~	$/MW
	~		|

DCLGA Data Center Load Growth Assumption=
