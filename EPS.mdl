	~		|

This Year Green Hydrogen Cost=
	Cost per Unit New Hydrogen Production[electrolysis with guaranteed clean electricity\
		]
	~	$/BTU
	~		|

This Year Grid Battery Storage Capacity excluding Hybrid Batteries=
	Last Year Grid Battery Storage Capacity excluding Hybrid Batteries
	+ New Grid Battery Capacity
	~	MW*hour
	~		|

This Year Grid Battery Storage Capacity excluding Hybrid Batteries in MW=
	This Year Total Grid Battery Storage Capacity excluding Hybrid Batteries
	/ GBSC Diurnal Grid Battery Daily Storage Duration
	~	MW
	~		|

This Year Grid Battery Storage Capacity in MW=
	(This Year Total Grid Battery Storage Capacity excluding Hybrid Batteries+SUM(This Year Hybrid Grid Battery Storage Capacity
	[
	Electricity Source!]))
	/ GBSC Diurnal Grid Battery Daily Storage Duration
	~	MW
	~		|

This Year Hybrid Grid Battery Storage Capacity[Electricity Source]=
	New Hybrid Grid Battery Storage Capacity[Electricity Source]
	+ Last Year Hybrid Grid Battery Storage Capacity[Electricity Source]
	~	MW*hour
	~		|

This Year Hybrid Grid Battery Storage Capacity in MW=
	SUM(This Year Hybrid Grid Battery Storage Capacity[Electricity Source!])
	/ GBSC Diurnal Grid Battery Daily Storage Duration
	~	MW
	~		|

This Year Increase in Pollutants Sequestered by Hydrogen Sector[Pollutant]=
	IF THEN ELSE(
	  Time = INITIAL TIME,
	
	  0,
	
	  MAX(
	    0,
	
	    This Year Pollutants Sequestered by Hydrogen Sector[Pollutant]
	    - Last Year Pollutants Sequestered by Hydrogen Sector[Pollutant]
	  )
	)
	~	g pollutant
	~		|

This Year Increase in Pollutants Sequestered by Industry Sector[Industry Category,Pollutant\
		,Emissions Type]=
	IF THEN ELSE(
	  Time = INITIAL TIME,
	
	  0,
	
	  MAX(
	    0,
	
	    This Year Pollutants Sequestered by Industry Sector[Industry Category,Pollutant,\
		Emissions Type]
	    - Last Year Pollutants Sequestered by Industry Sector[Industry Category,Pollutant\
		,Emissions Type]
	  )
	)
	~	g pollutant
	~		|

This Year Industrial Energy Use Reduction Due to Process Improvements[Industry Category\
		,Industrial Fuel]=
	1
	/ (1 + Percentage Improvement in Industrial Process Efficiency above BAU This Year[Industry Category\
		,Industrial Fuel])
	~	Dmnl
	~		|

This Year Low Carbon Hydrogen Cost=
	ZIDZ(
	  SUM(
	    Cost per Unit New Hydrogen Production[Hydrogen Production Pathway!]
	    * Last Year Low Carbon Hydrogen Production Shares by Pathway[Hydrogen Production Pathway\
		!]
	  ),
	
	  SUM(Last Year Low Carbon Hydrogen Production Shares by Pathway[Hydrogen Production Pathway\
		!])
	)
	~	$/BTU
	~		|

This Year Model Run Vintage Flag[Model Run Vintage]=
	IF THEN ELSE(
	  Model Run Vintage to Year Mapping[Model Run Vintage] = Dimensionless Time,
	
	  1,
	
	  0
	)
	~	Dmnl
	~		|

This Year Modeled Vintage Flag[Modeled Vintage]=
	IF THEN ELSE(
	  Modeled Vintage to Year Mapping[Modeled Vintage] = Dimensionless Time,
	
	  1,
	
	  0
	)
	~	Dmnl
	~		|

This Year Number of EV Chargers=
	BNoEVC BAU Number of EV Chargers
	* (1 + Percentage Increase in EV Chargers This Year)
	~	chargers
	~		|

This Year Ongoing CES Costs=
	SUM(CES Costs for Incremental Capacity Additions[Clean Elec Requirement!])
	+SUM(Last Year Ongoing CES Costs[Clean Elec Requirement!])
	+SUM(CES Costs for ACP Compliance[Clean Elec Requirement!])
	-SUM(CES Costs for Incremental Capacity Additions after Financial Lifetime[Clean Elec Requirement\
		!])
	~	$
	~		|

This Year Ongoing Repayment for Buildings Sector Financed Capital Expenses[Building Type\
		]=
	Annual Repayment for Financed Buildings Sector Capital Expenses[Building Type]
	
	+ Last Year Repayment for Financed Buildings Sector Capital Expenses[Building Type]
	~	$
	~		|

This Year Ongoing Subsidies Paid per Unit Electricity Output[Electricity Source]=
	Subsidies Paid per Unit Electricity Output for Newly Eligible Generation Capacity[Electricity Source\
		]
	
	+Last Year Subsidies Paid per Unit Electricity Output for Newly Eligible Generation Capacity\
		[Electricity Source]
	
	- Subsidy Payments per Unit Electricity Output Expiring After Subsidy Duration Period\
		[Electricity Source]
	~	$
	~		|

This Year Other Hydrogen Cost=
	ZIDZ(
	  SUM(
	    Last Year Other Hydrogen Production Shares by Pathway[Hydrogen Production Pathway\
		!]
	    * Cost per Unit New Hydrogen Production[Hydrogen Production Pathway!]
	  ),
	
	  SUM(Last Year Other Hydrogen Production Shares by Pathway[Hydrogen Production Pathway\
		!])
	)
	~	$/BTU
	~		|

This Year Pollutants Sequestered by Electricity Sector[Pollutant,Electricity Source] \
		:EXCEPT:     [CO2,Electricity Source
]=
	0 ~~|
This Year Pollutants Sequestered by Electricity Sector[CO2,Electricity Source]=
	Electricity Generation by Type[Electricity Source]
	* Metric Tons CO2 Stored per MWh[Electricity Source]
	* Grams per Metric Ton CO2e
	* Grams Pollutant per Gram CO2e Unit Converter
	~	g pollutant
	~		|

This Year Pollutants Sequestered by Hydrogen Sector[Pollutant] :EXCEPT: [CO2]=
	0 ~~|
This Year Pollutants Sequestered by Hydrogen Sector[CO2]=
	SUM(Hydrogen Sector Fuel Use by Pathway[natural gas reforming with CCS,Industrial Fuel\
		!]
	* Industrial Fuel Pollutant Emissions Intensities This Year[cement and other nonmetallic minerals 239\
		,CO2,Industrial Fuel!])
	* CCP CO2 Capture Potential by Hydrogen Sector
	~	g pollutant
	~		|

This Year Pollutants Sequestered by Industry Sector[Industry Category,Pollutant,energy related emissions\
		]=
	This Year Energy Related Pollutants Sequestered by Industry Sector[Industry Category\
		,Pollutant] ~~|
This Year Pollutants Sequestered by Industry Sector[Industry Category,Pollutant,process emissions\
		]=
	This Year Process Pollutants Sequestered by Industry Sector[Industry Category,Pollutant\
		]
	~	g pollutant
	~		|

This Year Pretax Electricity Price by Sector[Sectors]=
	MAX(0,
	  
	 IF THEN ELSE(
	  
	  Time=INITIAL TIME,
	  
	  Start Year Electricity Prices by Sector[Sectors],
	
	  Last Year Electricity Supplier Expenditures after Subsidies per Unit Electricity Produced
	  +Last Year Additional Retail Electricity Costs per Unit Electricity Produced[Sectors\
		]
	  
	 )
	)
	~	$/BTU
	~		|

This Year Process Pollutants Sequestered by Industry Sector[Industry Category,Pollutant\
		] :EXCEPT: [Industry Category,CO2]=
	0 ~~|
This Year Process Pollutants Sequestered by Industry Sector[Industry Category,CO2]=
	Process Emissions before CCS[Industry Category,CO2]
	* Fraction of CO2 Captured by Industry Category[Industry Category,process emissions]
	~	g pollutant
	~		|

This Year Reduction in Industrial Energy Consumption for Heat Generation due to Waste Heat Recovery\
		[Industry Category]=
	WHRPbI Waste Heat Recovery Potential by Industry[Industry Category]
	* Perc of Waste Heat Recovery Potential Achieved This Year[Industry Category]
	~	Dmnl
	~		|

This Year Solar and Wind Hard Costs as Fraction of Last Year Hard Costs[Electricity Source\
		] :EXCEPT:   [solar PV es],[onshore wind es],[offshore wind es]=
	0 ~~|
This Year Solar and Wind Hard Costs as Fraction of Last Year Hard Costs[onshore wind es\
		]=
	(1 - PDiCCpDoC Perc Decline in Capacity Cost per Doubling of Capacity[onshore wind es\
		])
	^ ( LN(
	        This Year Electricity Generation Affecting Learning[onshore wind es]
	        / Last Year Electricity Generation Affecting Learning[onshore wind es]
	      )
	    / LN(2)
	  ) ~~|
This Year Solar and Wind Hard Costs as Fraction of Last Year Hard Costs[solar PV es]=
	(1 - PDiCCpDoC Perc Decline in Capacity Cost per Doubling of Capacity[solar PV es])
	^ ( LN(
	        This Year Electricity Generation Affecting Learning[solar PV es]
	        / Last Year Electricity Generation Affecting Learning[solar PV es]
	      )
	    / LN(2)
	  ) ~~|
This Year Solar and Wind Hard Costs as Fraction of Last Year Hard Costs[offshore wind es\
		]=
	(1 - PDiCCpDoC Perc Decline in Capacity Cost per Doubling of Capacity[offshore wind es\
		])
	^ ( LN(
	        This Year Electricity Generation Affecting Learning[offshore wind es]
	        / Last Year Electricity Generation Affecting Learning[offshore wind es]
	      )
	    / LN(2)
	  )
	~	Dmnl
	~		|

This Year Total Grid Battery Storage Capacity excluding Hybrid Batteries=
	This Year Grid Battery Storage Capacity excluding Hybrid Batteries
	+ This Year Cumulative Policy Mandated Grid Battery Storage
	~	MW*hour
	~		|

This Year Total Grid Battery Storage Capacity excluding Hybrid Batteries in MW=
	This Year Total Grid Battery Storage Capacity excluding Hybrid Batteries
	/ GBSC Diurnal Grid Battery Daily Storage Duration
	~	MW
	~		|

This Year Vintage Flag[Vintage]=
	IF THEN ELSE(
	  Vintage to Year Mapping[Vintage] = Dimensionless Time,
	
	  1,
	
	  0
	)
	~	Dmnl
	~		|

Three Year Average Net Energy Market Revenue by Plant Type Excluding Subsidies for Hybrid Power Plants\
		[Hybrid Electricity Source]=
	DEPRECIATE STRAIGHTLINE(
	 One Year Average Net Energy Market Revenue by Plant Type Excluding Subsidies for Hybrid Power Plants\
		[Hybrid Electricity Source],
	 3,
	 1,
	 0
	)
	~	$/MW
	~		|

Three Year Average Total Predicted Net Energy Market Revenue per MW[Electricity Source\
		]=
	DEPRECIATE STRAIGHTLINE(
	 Last Year Total Five Year Average Net Energy Market Revenue per MW[Electricity Source\
		],
	 3,
	 1,
	 0
	)
	~	$/(MW*hr)
	~		|

Three Year Average Wholesale Energy Market Costs=
	DEPRECIATE STRAIGHTLINE(
	 One Year Average Wholesale Energy Market Costs,
	 3,
	 1,
	 0
	)
	~	$
	~		|

Three Year Weighted Average Hypothetical Electricity Capacity Factor[Electricity Timeslice\
		,Hour,Electricity Source]=
	(Last Year Hypothetical Hourly Electricity Capacity Factor[Electricity Timeslice,Hour\
		,Electricity Source]
	+ Two Years Prior Hypothetical Hourly Electricity Capacity Factor[Electricity Timeslice\
		,Hour,Electricity Source]
	+ Three Years Prior Hypothetical Hourly Electricity Capacity Factor[Electricity Timeslice\
		,Hour,Electricity Source]
	)
	/3
	~	Dmnl
	~		|

Three Years Prior Hypothetical Hourly Electricity Capacity Factor[Electricity Timeslice\
		,Hour,Electricity Source]= DELAY FIXED (
	  Two Years Prior Hypothetical Hourly Electricity Capacity Factor[Electricity Timeslice\
		,Hour,Electricity Source],
	  1,
	  SYSHECF Start Year Seasonal Expected Hourly Electricity Capacity Factors[Electricity Source\
		,Electricity Timeslice,Hour
	] * RAF Regional Availability Factor for Generation[Electricity Source])
	~	Dmnl
	~		|

TLIM Total Leontief Inverse Matrix[Source ISIC Code, Target ISIC Code]=
	GET DIRECT CONSTANTS(
	   'InputData/io-model/TLIM/TLIM.csv',
	   ',',
	   'B2'
	)
	~	Dmnl
	~		|

Toggle Carbon Tax Border Adjustment=
	0
	~	Dmnl [0,1,1]
	~		|

Toggle Carbon Tax Border Adjustment This Year=
	Toggle Carbon Tax Border Adjustment
	* Selected Policy Implementation Schedule[cross toggle carbon tax border adjustment X\
		]
	~	Dmnl
	~		|

Toggle Whether Carbon Tax Affects Process Emissions[Industry Category]=
	0,	{agriculture and forestry 01T03}
	0,	{coal mining 05}
	0,	{oil and gas extraction 06}
	0,	{other mining and quarrying 07T08 - NOT USED}
	0,	{food beverage and tobacco 10T12 - NOT USED}
	0,	{textiles apparel and leather 13T15 - NOT USED}
	0,	{wood products 16 - NOT USED}
	0,	{pulp paper and printing 17T18 - NOT USED}
	0,	{refined petroleum and coke 19 - NOT USED}
	0,	{chemicals 20}
	0,	{rubber and plastic products 22 - NOT USED}
	0,	{glass and glass products 231 - NOT USED}
	0,	{cement and other nonmetallic minerals 239}
	0,	{iron and steel 241 - NOT USED}
	0,	{other metals 242 - NOT USED}
	0,	{metal products except machinery and vehicles 25 - NOT USED}
	0,	{computers and electronics 26 - NOT USED}
	0,	{appliances and electrical equipment 27 - NOT USED}
	0,	{other machinery 28 - NOT USED}
	0,	{road vehicles 29 - NOT USED}
	0,	{nonroad vehicles 30 - NOT USED}
	0,	{other manufacturing 31T33 - NOT USED}
	0,	{energy pipelines and gas processing 352T353}
	0,	{water and waste 36T39}
	0	{construction 41T43 - NOT USED}
	~	Dmnl [0,1,1]
	~		|

Toggle Whether Carbon Tax Affects Process Emissions This Year[Industry Category]=
	Toggle Whether Carbon Tax Affects Process Emissions[Industry Category]
	* VECTOR ELM MAP(
	    Selected Policy Implementation Schedule[cross toggle whether carbon tax affects process emissions X agriculture and forestry 01T03\
		],
	
	    (Industry Category-1)
	  )
	~	Dmnl
	~		|

Toggle Whether Policies Affect Energy Prices[All Fuels]=
	0,	{electricity}
	0,	{hard coal}
	0,	{natural gas}
	0,	{nuclear - NOT USED}
	0,	{hydro - NOT USED}
	0,	{wind - NOT USED}
	0,	{solar - NOT USED}
	0,	{biomass}
	0,	{petroleum gasoline}
	0,	{petroleum diesel}
	0,	{biofuel gasoline}
	0,	{biofuel diesel}
	0,	{jet fuel or kerosene}
	0,	{heat}
	0,	{geothermal - NOT USED}
	0,	{lignite}
	0,	{crude oil}
	0,	{heavy or residual fuel oil}
	0,	{LPG propane or butane}
	0,	{municipal solid waste - NOT USED}
	0	{hydrogen}
	~	Dmnl [0,1,1]
	~	This policy reverses the behavior set in the control lever "BAEPAbCiPC \
		Boolean Are Energy Prices Affected by Changes in Production Costs."  This \
		variable is not a Boolean and may be set to any value between zero and \
		one, to phase in or phase out the change in behavior.
	|

Toggle Whether Policies Affect Energy Prices This Year[All Fuels]=
	Toggle Whether Policies Affect Energy Prices[All Fuels]
	* VECTOR ELM MAP(
	    Selected Policy Implementation Schedule[cross toggle whether policies affect energy prices X electricity\
		],
	
	    (All Fuels-1)
	  )
	~	Dmnl
	~		|

Tolerance = 1e-06
	~	Dmnl
	~	Tolerance threshold for comparing floating point numbers
	|

Total Annual Cost Recovery for Historical Power Plant Construction Costs=
	SUM(Annual Cost Recovery for Historical Power Plant Construction Costs by Vintage[Modeled Vintage\
		!])
	~	$
	~		|

Total Annual Recoverable Costs for Cost of Service Rates=
	QUANTUM(
	  Total Cost of Power Generation
	  +Annual Cost Recovery for Capacity Construction and Retrofits
	  +Annual Cost to Keep Generation Capacity Online Past Repayment Period
	  +Total Cost of Transmission Distribution Storage and Other,
	
	  Quantization Size for Dollars
	)
	~	$
	~		|

Total Annual Vehicle Costs[Vehicle Type,Cargo Type,Vehicle Technology]=
	Annual Fuel Expenditures for a Vehicle Sold This Year[Vehicle Type,Cargo Type,Vehicle Technology\
		]
	+ AVMC Annual Vehicle Maintenance Cost[Vehicle Type,Cargo Type,Vehicle Technology]
	+ AVIC Annual Vehicle Insurance Cost[Vehicle Type,Cargo Type]
	+ AVPC Annual Vehicle Parking Cost[Vehicle Type,Cargo Type]
	+ AVLRaPTC Annual Vehicle Licensing Registration and Property Tax Costs[Vehicle Type\
		,Cargo Type]
	~	$/vehicle
	~		|

Total Battery Cost per Unit Capacity=
	Battery Energy Cost per Unit Capacity
	+ Battery Power Cost per Unit Capacity
	  / GBSC Diurnal Grid Battery Daily Storage Duration
	~	$/(MW*hour)
	~		|

Total BAU Fuel Use for Energy Purposes by Industrial Process in Electricity Equivalent\
		[Industry Category,Industrial Process]=
	SUM(BAU Industrial Equipment Energy Use from Input Data by Industrial Process in Electricity Equivalent\
		[Industry Category,Industrial Fuel!,Industrial Process])
	~	BTU
	~		|

Total Capacity Market Costs=
	(SUM(Annual Capacity Market Costs for Seasonal Dispatchable Reliability[Electricity Source\
		!])
	 + Capacity Market Costs for Diurnal Storage
	)
	~	$
	~		|

Total Carbon Tax Revenue=
	SUM(Transportation Sector Carbon Tax Revenue[Vehicle Type!,Cargo Type!])
	+ Electricity Sector Carbon Tax Revenue
	+ Buildings Sector Carbon Tax Revenue
	+ SUM(Industry Sector Carbon Tax Revenue[Industry Category!])
	+ District Heat Sector Carbon Tax Revenue
	+ Hydrogen Sector Carbon Tax Revenue
	+ Geoengineering Sector Carbon Tax Revenue
	~	$
	~		|

Total Change in Average Household Energy Expenditures=
	Direct Change in Energy Expenditures by Entity[labor and consumers]
	/ NoH Number of Households
	~	$/households
	~		|

Total Change in CapEx and OpEx=
	Total Change in CapEx and OpEx before Tax Rebates
	
	- Government Revenue Change Allocated by Mechanism[household taxes]
	- Government Revenue Change Allocated by Mechanism[payroll taxes]
	- Government Revenue Change Allocated by Mechanism[corporate taxes]
	~	$
	~		|

Total Change in CapEx and OpEx before Tax Rebates=
	Total Change in Capital Expenditures
	+ Total Change in Fuel Expenditures
	+ Total Change in OM Expenditures
	+ SUM(Change in Carbon Tax on Process Emissions by Industry[Industry Category!])
	~	$
	~		|

Total Change in Capital Expenditures=
	QUANTUM(
	  Buildings Subtotal Change in Capital Expenditures
	  + Transportation Subtotal Change in Capital Expenditures
	  + Cost of CHP Conversion for Heat
	  + Hydrogen Sector Subtotal Change in Capital Expenditures
	  + Electricity Subtotal Change in Capital Expenditures
	  + Industry Subtotal Change in Capital Expenditures
	  + Change in Geoengineering CapEx and OM Spending This Year,
	
	  QSfCF Quantization Size for Cash Flows
	)
	~	$
	~		|

Total Change in Energy Market and CES Revenue for CCUS Retrofits[CCUS Electricity Source\
		, Optimization Pass,RPS]=
	Predicted Change in Energy Market Revenue for CCUS Retrofits[CCUS Electricity Source\
		]
	+ RPS Revenue at Marginal Capacity Factor by Optimization Pass[Optimization Pass,CCUS Electricity Source\
		]
	-RPS Revenue at Marginal Capacity Factor by Optimization Pass[Optimization Pass,CCUS Source Electricity Source\
		] ~~|
Total Change in Energy Market and CES Revenue for CCUS Retrofits[CCUS Electricity Source\
		,Optimization Pass,CES]=
	Predicted Change in Energy Market Revenue for CCUS Retrofits[CCUS Electricity Source\
		]
	+ SUM(RPS Revenue at Marginal Capacity Factor by Optimization Pass[last pass!,CCUS Electricity Source\
		])
	+ CES Revenue at Marginal Capacity Factor by Optimization Pass[Optimization Pass,CCUS Electricity Source\
		]
	- SUM(RPS Revenue at Marginal Capacity Factor by Optimization Pass[last pass!,CCUS Source Electricity Source\
		])
	 -CES Revenue at Marginal Capacity Factor by Optimization Pass[Optimization Pass,CCUS Source Electricity Source\
		]
	~	$/MW
	~		|

Total Change in Fuel Expenditures=
	QUANTUM(
	  SUM(Change in Amount Spent on Buildings Fuels[Building Type!,Building Fuel!])
	  + SUM(Change in Amount Spent on District Heating Fuels[Industrial Fuel!])
	  + SUM(Change in Amount Spent on Hydrogen Sector Fuels[Industrial Fuel!])
	  + SUM(Change in Amount Spent on Electricity Fuels[Electricity Source!])
	  + SUM(Change in Amount Spent on Industry Fuels[Industry Category!,Industrial Fuel!\
		])
	  + SUM(Change in Amount Spent on Transportation Fuels[Transportation Fuel!,Vehicle Type\
		!,Cargo Type!,Vehicle Technology
	!])
	  + SUM(Change in Fuel Import Expenditures[All Fuels!])
	  + SUM(Change in Amount Spent on Geoengineering Fuels[Industrial Fuel!]),
	
	  QSfCF Quantization Size for Cash Flows
	)
	~	$
	~		|

Total Change in OM Expenditures=
	QUANTUM(
	  Transport Subtotal Change in OM Expenditures
	  + Electricity Subtotal Change in OM Expenditures
	  + Industry Subtotal Change in OM Expenditures
	  + Hydrogen Sector Subtotal Change in OM Expenditures
	  + SUM(Change in Forest Expenses by Entity[Cash Flow Entity!]),
	
	  QSfCF Quantization Size for Cash Flows
	)
	~	$
	~		|

Total Change in Process Emissions[Industry Category,Industry Process Emissions Policy\
		,Pollutant]=
	Decrease in Process Emissions due to Policies[Industry Category,Industry Process Emissions Policy\
		,Pollutant]
	
	+ 
	
	Non BAU Process Emissions Additions at BAU Production Levels[Industry Category,Industry Process Emissions Policy\
		,Pollutant]
	* (1 + Percent Change in Production due to Policies[Industry Category])
	~	g pollutant
	~		|

Total Change in Subsidies=
	QUANTUM(
	  Transportation Subtotal Change in Other Expenditures
	  + Electricity Subtotal Change in Other Expenditures
	  + Industry Subtotal Change in Other Expenditures
	  + Hydrogen Subtotal Change in Subsidies
	  + SUM(Change in Revenue from Buildings Sector Subsidies and Rebates by Entity[Cash Flow Entity\
		!])
	  + SUM(Change in Thermal Fuel Subsidies Paid[All Fuels!]),
	
	  QSfCF Quantization Size for Cash Flows
	)
	~	$
	~		~	:SUPPLEMENTARY 
	|

Total Change in Tax Revenues=
	QUANTUM(
	  Buildings Subtotal Change in Tax Revenues
	  + District Heating Subtotal Change in Tax Revenues
	  + Electricity Subtotal Change in Tax Revenues
	  + SUM(Change in Tax Paid on Fuel Exports[All Fuels!])
	  + Industry Subtotal Change in Tax Revenues
	  + Transportation Subtotal Change in Tax Revenues
	  + SUM(Change in Taxes Paid on Geoengineering Fuels[Industrial Fuel!])
	  + SUM(Change in Domestic Individual Income Tax Revenue by ISIC Code[ISIC Code!]),
	
	  QSfCF Quantization Size for Cash Flows
	)
	~	$
	~		~	:SUPPLEMENTARY 
	|

Total CO2e Emissions=
	SUM(
	  Total Pollutant Emissions[Pollutant!]
	  * GWP by Pollutant[Pollutant!])
	~	g CO2e
	~		|

Total CO2e Emissions by Pollutant[Pollutant]=
	Total Pollutant Emissions[Pollutant]
	* GWP by Pollutant[Pollutant]
	~	g CO2e
	~		|

Total CO2e Emissions by Sector[Sectors]=
	SUM(
	  Total Pollutant Emissions by Sector[Sectors,Pollutant!]
	  * GWP by Pollutant[Pollutant!]
	)
	~	g CO2e
	~		|

Total CO2e Emissions per Unit GDP=
	Total CO2e Emissions
	/ Gross Domestic Product
	~	g CO2e/$
	~		|

Total Cost of Power Generation=
	Generation Costs
	+Interregional Electricity Trade Costs
	+SUM(Electricity Sector CCS Transportation and Storage Costs[Electricity Source!])
	+This Year Ongoing CES Costs
	-SUM(Electricity Sector Carbon Tax Rebate due to CCS[Electricity Source!])
	-SUM(This Year CCS Subsidies Paid[Electricity Source!])
	-SUM(This Year Ongoing Subsidies Paid per Unit Electricity Output[Electricity Source\
		!])
	~	$
	~		|

Total Cost of Transmission Distribution Storage and Other=
	QUANTUM(
	  Repayment of Financing for Electricity Sector Capital Expenditures Including Construction Subsidies
	  +Electricity Supplier Other Expenditures
	  +Electricity Transmission and Distribution OM Expenditures
	  +SYTaDC Start Year Transmission Capital Costs
	  +SYTaDC Start Year Distribution Capital Costs,
	
	  Quantization Size for Dollars
	)
	~	$
	~		|

Total Demand Shifting Capacity in MW[Electricity Timeslice,Hour]=
	This Year Demand Response Capacity
	+ Last Year Grid and Hybrid Battery Storage Available in MW[Electricity Timeslice]
	+ BPHC BAU Pumped Hydro Capacity * SYSHECF Start Year Seasonal Expected Capacity Factor for Pumped Hydro\
		[Electricity Timeslice
	,Hour]
	+ Total EV Battery Capacity Available in MW
	~	MW
	~		|

Total Deployed and Under Construction CCS[Industry Category,Emissions Type]=
	Last Year Total Deployed and Under Construction CCS[Industry Category,Emissions Type\
		]
	+ CCS Retrofit Capacity Construction Started This Year[Industry Category,Emissions Type\
		]
	~	Dmnl
	~		|

Total District Heat Use=
	(
	  SUM(Building Components Energy Use[Building Type!,heat bf,Building Component!])
	  + SUM(Industrial Fuel Use[heat if,Industry Category!])
	)
	/ (1 - HDL Heat Distribution Losses)
	~	BTU
	~		|

Total District Heat Use by Fuel before CHP[Industrial Fuel]=
	Total District Heat Use
	* Fraction of District Heat Provided by Fuel[Industrial Fuel]
	~	BTU
	~		|

Total Electricity Demand=
	SUM(Transportation Sector Electricity Demand[Vehicle Type!,Cargo Type!])
	+ SUM(Buildings Sector Electricity Demand[Building Type!,Building Component!])
	+ Industrial Sector Electricity Demand
	+ District Heat Electricity Demand
	+ Geoengineering Sector Electricity Demand
	+ Hydrogen Sector Grid Electricity Demand
	+ BAU Data Center Load
	~	MW*hour
	~		|

Total Electricity Demand after Tnd Losses and Own Use=
	Total Electricity Demand
	+(Total Electricity Demand*Transmission and Distribution Loss Percentage)
	+(Total Electricity Demand*BPPEOUP BAU Power Plant Electricity Own Use Percentage)
	~	MW*hr
	~		|

Total Electricity Demand by Hour After Demand Altering Technologies[Electricity Timeslice\
		,Hour]=
	Total Electricity Demand by Hour After Demand Altering Technologies excluding New Hybrid Batteries\
		[Electricity Timeslice,Hour]
	~	MW*hr
	~		|

Total Electricity Demand by Hour After Demand Altering Technologies excluding New Hybrid Batteries\
		[Electricity Timeslice,Hour]=
	Total Electricity Demand by Hour Before Demand Altering Technologies[Electricity Timeslice\
		,Hour]
	+ Change in Electricity Demand from Demand Altering Technologies for Net Peak Load Reduction excluding Hybrid Batteries\
		[Electricity Timeslice,Hour]
	~	MW*hr
	~		|

Total Electricity Demand by Hour after Seasonal Net Peak Load Reduction[Electricity Timeslice\
		,Hour]=
	MAX(
	  0,
	
	  Total Electricity Demand by Hour Before Demand Altering Technologies[Electricity Timeslice\
		,Hour]
	  + Increase in Demand by Hour for Seasonal Net Peak Load Reduction[Electricity Timeslice\
		,Hour]
	  - Decrease in Demand by Hour for Seasonal Net Peak Load Reduction[Electricity Timeslice\
		,Hour]
	)
	~	MW*hr
	~		|

Total Electricity Demand by Hour Before Demand Altering Technologies[Electricity Timeslice\
		,Hour]=
	MAX(
	  0,
	
	  Total Electricity Demand by Hour before Net Imports[Electricity Timeslice,Hour]
	  + SUM(Electricity Exports by Hour[Electricity Timeslice,Hour,last pass!])
	  - SUM(Electricity Imports by Hour[Electricity Timeslice,Hour,last pass!])
	)
	~	MW*hr
	~		|

Total Electricity Demand by Hour Before Demand Altering Technologies Plus Reserve Margin\
		[Electricity Timeslice,Hour]=
	MAX(0,
	Total Electricity Demand by Hour Before Demand Altering Technologies[Electricity Timeslice\
		,Hour]
	  - SUM(Electricity Exports by Hour[Electricity Timeslice,Hour,last pass!]))
	* (1 + RM Reserve Margin)
	+ Change in Electricity Demand from Demand Altering Technologies for Net Peak Load Reduction excluding Hybrid Batteries\
		[Electricity Timeslice,Hour]
	~	MW*hr
	~		|

Total Electricity Demand by Hour Before Demand Altering Technologies Plus Reserve Margin Required from Clean Dispatchable Resource\
		[Electricity Timeslice,Hour]=
	Required Share of Peak Demand from Clean Firm Resources*Total Electricity Demand by Hour After Demand Altering Technologies excluding New Hybrid Batteries\
		[Electricity Timeslice,Hour]
	~	MW*hr
	~		|

Total Electricity Demand by Hour before Distributed Generation[Electricity Timeslice,\
		Hour]=
	(SUM(
	  (Buildings Sector Electricity Demand[urban residential,Building Component!]
	    + Buildings Sector Electricity Demand[rural residential,Building Component!])
	  * Adjusted Load Factors for Residential Buildings Sector[Building Component!,Electricity Timeslice\
		,Hour]
	)
	
	+ SUM(
	    Buildings Sector Electricity Demand[commercial,Building Component!]
	    * Adjusted Load Factors for Commercial Buildings Sector[Building Component!,Electricity Timeslice\
		,Hour]
	  )
	
	+ SUM(
	    Transportation Sector Electricity Demand[Vehicle Type!,Cargo Type!]
	    * Adjusted Load Factors for Transporation Sector[Vehicle Type!,Electricity Timeslice\
		,Hour]
	  )
	
	+ SUM(
	    Total Industrial Electricity Demand by Hour Before CCS[Electricity Timeslice,Hour\
		,Industry Category!]
	  )
	
	+ SUM(
	    Fuel Used for CCS by Industry Sector[electricity if,Industry Category!]
	    * Adjusted Load Factors for Industrial CCS[Electricity Timeslice,Hour]
	  ) * MWh per BTU
	
	+ (District Heat Electricity Demand
	    + Hydrogen Sector Grid Electricity Demand)
	  * Adjusted Load Factors for District Heat and Hydrogen Sectors[Electricity Timeslice\
		,Hour]
	
	+ Geoengineering Sector Electricity Demand
	  * Adjusted Load Factors for Geoengineering Sector[Electricity Timeslice,Hour]
	
	
	+ BAU Data Center Load
	  * Adjusted Load Factors for Data Centers[Electricity Timeslice,Hour]
	)
	
	* (Total Electricity Demand after Tnd Losses and Own Use
	   /Total Electricity Demand)
	~	MW*hr
	~		|

Total Electricity Demand by Hour before Net Imports[Electricity Timeslice,Hour]=
	Total Electricity Demand by Hour before Distributed Generation[Electricity Timeslice\
		,Hour]
	-SUM(Hourly Output from Distributed Electricity Capacity[Electricity Source!,Electricity Timeslice\
		,Hour])
	~	MW*hr
	~		|

Total Electricity Demand in BTU=
	Total Electricity Demand
	/MWh per BTU
	~	BTU
	~		|

Total Electricity Demand Including TnD Losses=
	SUM(
	  Total Electricity Demand by Hour After Demand Altering Technologies[Electricity Timeslice\
		!
	,Hour!]
	  * SHELF Days per Electricity Timeslice[Electricity Timeslice!]
	)
	~	MW*hour
	~		|

Total Electricity Demand Plus Exports in BTU=
	(Total Electricity Demand + Exported Electricity)
	/ MWh per BTU
	~	BTU
	~		|

Total Electricity Dispatched by Hour[Electricity Timeslice,Hour]=
	SUM(Total Electricity Dispatched by Hour by Plant Type[Electricity Timeslice,Hour,Electricity Source\
		!])
	~	MW*hr
	~		|

Total Electricity Dispatched by Hour by Plant Type[Electricity Timeslice,Hour,Electricity Source\
		]=
	MAX(0,
	  Electricity Dispatched by Guaranteed Dispatch by Hour[Electricity Source,Electricity Timeslice\
		,Hour]
	  + Electricity Dispatched to Meet Elec Portfolio Stds[Electricity Timeslice,Hour,Electricity Source\
		]
	  + Electricity Dispatched by Least Cost by Hour[Electricity Timeslice,Hour,Electricity Source\
		]
	 )
	~	MW*hr
	~		|

Total Electricity Dispatched by Hour by Plant Type on Peak Summer Day[Hour,Electricity Source\
		]=
	SUM(Total Electricity Dispatched by Hour by Plant Type[peak summer day electricity timeslice\
		!,Hour,Electricity Source])
	/ ELMCOUNT(peak summer day electricity timeslice)
	~	MW*hr
	~		|

Total Electricity Dispatched by Hour by Plant Type on Peak Winter Day[Hour,Electricity Source\
		]=
	SUM(Total Electricity Dispatched by Hour by Plant Type[peak winter day electricity timeslice\
		!,Hour,Electricity Source])
	/ ELMCOUNT(peak winter day electricity timeslice)
	~	MW*hr
	~		|

Total Electricity Dispatched by Hour by Plant Type Using Five Year Averages[Electricity Timeslice\
		,Hour,Electricity Source]=
	MAX(0,
	  Electricity Dispatched by Guaranteed Dispatch by Hour[Electricity Source,Electricity Timeslice\
		,Hour]
	  + Electricity Dispatched to Meet Elec Portfolio Stds[Electricity Timeslice,Hour,Electricity Source\
		]
	  + Five Year Average Electricity Dispatched by Least Cost by Hour[Electricity Timeslice\
		,Hour,Electricity Source]
	 )
	~	MW*hr
	~		|

Total Electricity Generation Capacity by Optimization Pass for Seasonal Clean Dispatchable Reliability\
		[Electricity Source
,Optimization Pass] :EXCEPT:             [Clean Dispatchable Electricity Source,Optimization Pass\
		]=
	Electricity Generation Capacity before Dispatchable CES Additions[Electricity Source\
		] ~~|
Total Electricity Generation Capacity by Optimization Pass for Seasonal Clean Dispatchable Reliability\
		[Clean Dispatchable Electricity Source
,Optimization Pass]=
	Electricity Generation Capacity before Dispatchable CES Additions[Clean Dispatchable Electricity Source\
		]
	+New Capacity Desired for Seasonal Clean Dispatchable Reliability by Optimization Pass\
		[Clean Dispatchable Electricity Source,Optimization Pass]
	+Retrofitted Capacity Desired for Seasonal Clean Dispatchable Reliability by Optimization Pass\
		[Clean Dispatchable Electricity Source,Optimization Pass]
	~	MW
	~		|

Total Electricity Generation Capacity by Optimization Pass for Seasonal Dispatchable Reliability\
		[Electricity Source,Optimization Pass]=
	Electricity Generation Capacity before Reliability Additions[Electricity Source]
	-Economic Capacity Retirements by Optimization Pass[Electricity Source,Optimization Pass\
		]
	+New Capacity Desired for Seasonal Dispatchable Reliability by Optimization Pass[Electricity Source\
		,Optimization Pass]
	~	MW
	~		|

Total Energy Market and Capacity Market Revenue for Seasonal Clean Disatchable Reliability CCUS Retrofits\
		[Clean Dispatchable Electricity Source,Optimization Pass] :EXCEPT:             [CCUS Electricity Source\
		,Optimization Pass]=
	0 ~~|
Total Energy Market and Capacity Market Revenue for Seasonal Clean Disatchable Reliability CCUS Retrofits\
		[CCUS Electricity Source,Optimization Pass]=
	Predicted Change in Energy Market Revenue for CCUS Retrofits[CCUS Electricity Source\
		]
	+ (
	  Capacity Market Price for Seasonal Clean Dispatchable Reliability by Optimization Pass\
		[Optimization Pass]
	  * Last Year Hourly Bid Electricity Capacity Factors for Clean Firm Reliability in Binding Hour by Plant Type\
		[CCUS Electricity Source
	]
	  * Days per Year
	  * One Day
	  )
	*Elec Portfolio Qualifying Sources[CCUS Electricity Source,CES]
	~	$/MW
	~		|

Total Energy Market and Capacity Market Revenue for Seasonal Clean Dispatchable Reliability\
		[Clean Dispatchable Electricity Source,Optimization Pass]=
	Average Four Year Prior Total Predicted Net Energy Market Revenue per MW[Clean Dispatchable Electricity Source\
		]
	+ (
	  Capacity Market Price for Seasonal Clean Dispatchable Reliability by Optimization Pass\
		[Optimization Pass]
	  * Last Year Hourly Bid Electricity Capacity Factors for Clean Firm Reliability in Binding Hour by Plant Type\
		[Clean Dispatchable Electricity Source
	]
	  * Days per Year
	  * One Day
	  )
	*Elec Portfolio Qualifying Sources[Clean Dispatchable Electricity Source,CES]
	~	$/MW
	~		|

Total Energy Market and CES Revenue and Variable Subsidies[Electricity Source]=
	SUM(Total Energy Market and CES Revenue and Variable Subsidies by Optimization Pass[\
		Electricity Source,last pass!,CES])
	~	$/(MW*hour)
	~		|

Total Energy Market and CES Revenue and Variable Subsidies by Optimization Pass[Electricity Source\
		,Optimization Pass,RPS]=
	Average Four Year Prior Total Predicted Net Energy Market Revenue per MW[Electricity Source\
		]
	+RPS Revenue at Marginal Capacity Factor by Optimization Pass[Optimization Pass,Electricity Source\
		] ~~|
Total Energy Market and CES Revenue and Variable Subsidies by Optimization Pass[Electricity Source\
		,Optimization Pass,CES]=
	Average Four Year Prior Total Predicted Net Energy Market Revenue per MW[Electricity Source\
		]
	+ SUM(RPS Revenue at Marginal Capacity Factor by Optimization Pass[last pass!,Electricity Source\
		])
	+CES Revenue at Marginal Capacity Factor by Optimization Pass[Optimization Pass,Electricity Source\
		]
	~	$/MW
	~		|

Total Energy Market and CES Revenue and Variable Subsidies by Optimization Pass for Hybrid Power Plants\
		[Hybrid Electricity Source,Optimization Pass,CES]=
	Average Four Year Prior Net Energy Market Revenue by Plant Type Excluding Subsidies for Hybrid Power Plants\
		[Hybrid Electricity Source]
	+ (CES Revenue at Marginal Capacity Factor by Optimization Pass[Optimization Pass,Hybrid Electricity Source\
		]+ SUM(RPS Revenue at Marginal Capacity Factor by Optimization Pass[last pass!,Hybrid Electricity Source\
		]))*(1-Share of Annual Expected Output that Can be Shifted[Hybrid Electricity Source\
		])
	+(CES Revenue at Expected Capacity Factor by Optimization Pass[Hybrid Electricity Source\
		,Optimization Pass]+ SUM(RPS Revenue at Expected Capacity Factor by Optimization Pass\
		[Hybrid Electricity Source,last pass!]))*(Share of Annual Expected Output that Can be Shifted\
		[Hybrid Electricity Source]) ~~|
Total Energy Market and CES Revenue and Variable Subsidies by Optimization Pass for Hybrid Power Plants\
		[Hybrid Electricity Source,Optimization Pass,RPS]=
	Average Four Year Prior Net Energy Market Revenue by Plant Type Excluding Subsidies for Hybrid Power Plants\
		[Hybrid Electricity Source]
	+ RPS Revenue at Marginal Capacity Factor by Optimization Pass[Optimization Pass,Hybrid Electricity Source\
		]*(1-Share of Annual Expected Output that Can be Shifted[Hybrid Electricity Source]\
		)
	+RPS Revenue at Expected Capacity Factor by Optimization Pass[Hybrid Electricity Source\
		,Optimization Pass]*(Share of Annual Expected Output that Can be Shifted[Hybrid Electricity Source\
		])
	~	$/MW
	~		|

Total Energy Related Emissions[Sectors,Pollutant] :EXCEPT:   [industry sector,Pollutant\
		],[LULUCF sector,Pollutant],[geoengineering sector,Pollutant]=
	Total Pollutant Emissions by Sector[Sectors,Pollutant] ~~|
Total Energy Related Emissions[industry sector,Pollutant]=
	Total Pollutant Emissions by Sector[industry sector,Pollutant]
	- SUM(Process Emissions after CCS[Industry Category!,Pollutant]) ~~|
Total Energy Related Emissions[LULUCF sector,Pollutant]=
	Total Pollutant Emissions by Sector[LULUCF sector,Pollutant]
	- LULUCF Anthropogenic Pollutant Emissions[Pollutant] ~~|
Total Energy Related Emissions[geoengineering sector,Pollutant]=
	SUM(Geoengineering Sector Pollutant Emissions Excluding Captured CO2[Pollutant,Industrial Fuel\
		!])
	~	g pollutant
	~		|

Total Energy Related Emissions in CO2e[Sectors]=
	SUM(
	  Total Energy Related Emissions[Sectors,Pollutant!]
	  * GWP by Pollutant[Pollutant!]
	)
	~	g CO2e
	~		|

Total Energy Use[All Fuels]=
	SUM(Total Energy Use by Sector[Sectors!,All Fuels])
	~	BTU
	~		|

Total Energy Use by Sector[transportation sector,transportation fuel within all fuels\
		]=
	SUM(Transportation Sector Fuel Used[Vehicle Type!,Cargo Type!,Vehicle Technology!,Transportation Fuel\
		]) ~~|
Total Energy Use by Sector[electricity sector,electricity source within all fuels] :EXCEPT:\
		      [electricity sector,natural gas
],[electricity sector,wind],[electricity sector,solar],[electricity sector,hard coal]\
		,[electricity sector,biomass],[electricity sector
,lignite],[electricity sector,nuclear],[electricity sector,hydrogen]=
	Electricity Fuel Use[Electricity Source] ~~|
Total Energy Use by Sector[industry sector,industrial fuel within all fuels] :EXCEPT:\
		 [industry sector,hydrogen]=
	SUM(Industrial Fuel Use[Industrial Fuel,Industry Category!]) ~~|
Total Energy Use by Sector[residential buildings sector,building fuel within all fuels\
		]=
	SUM(Building Components Energy Use[urban residential,Building Fuel,Building Component\
		!])
	+ SUM(Building Components Energy Use[rural residential,Building Fuel,Building Component\
		!]) ~~|
Total Energy Use by Sector[commercial buildings sector,building fuel within all fuels\
		]=
	SUM(Building Components Energy Use[commercial,Building Fuel,Building Component!]) ~~|
Total Energy Use by Sector[district heat and hydrogen sector,industrial fuel within all fuels\
		] :EXCEPT: [district heat and hydrogen sector,hydrogen]=
	Fuel Used to Generate Heat[Industrial Fuel]
	+ Hydrogen Sector Fuel Use[Industrial Fuel] ~~|
Total Energy Use by Sector[geoengineering sector,industrial fuel within all fuels] :EXCEPT:\
		 [geoengineering sector,hydrogen]=
	Geoengineering Sector Energy Use[Industrial Fuel] ~~|
Total Energy Use by Sector[electricity sector,natural gas]=
	Electricity Fuel Use[natural gas steam turbine es]
	+ Electricity Fuel Use[natural gas combined cycle es]
	+ Electricity Fuel Use[natural gas peaker es]
	+ Electricity Fuel Use[natural gas combined cycle w CCS es] ~~|
Total Energy Use by Sector[electricity sector,wind]=
	Electricity Fuel Use[onshore wind es]
	+ Electricity Fuel Use[offshore wind es] ~~|
Total Energy Use by Sector[electricity sector,solar]=
	Electricity Fuel Use[solar PV es]
	+ Electricity Fuel Use[solar thermal es] ~~|
Total Energy Use by Sector[transportation sector,All Fuels] :EXCEPT: [transportation sector\
		,transportation fuel within all fuels
]=
	0 ~~|
Total Energy Use by Sector[electricity sector,All Fuels] :EXCEPT: [electricity sector\
		,electricity source within all fuels
]=
	0 ~~|
Total Energy Use by Sector[industry sector,All Fuels] :EXCEPT: [industry sector,industrial fuel within all fuels\
		]=
	0 ~~|
Total Energy Use by Sector[residential buildings sector,All Fuels] :EXCEPT: [residential buildings sector\
		,building fuel within all fuels
]=
	0 ~~|
Total Energy Use by Sector[commercial buildings sector,All Fuels] :EXCEPT: [commercial buildings sector\
		,building fuel within all fuels
]=
	0 ~~|
Total Energy Use by Sector[district heat and hydrogen sector,All Fuels] :EXCEPT: [district heat and hydrogen sector\
		,industrial fuel within all fuels
]=
	0 ~~|
Total Energy Use by Sector[geoengineering sector,All Fuels] :EXCEPT: [geoengineering sector\
		,industrial fuel within all fuels
]=
	0 ~~|
Total Energy Use by Sector[LULUCF sector,All Fuels]=
	0 ~~|
Total Energy Use by Sector[electricity sector,hard coal]=
	Electricity Fuel Use[hard coal es]
	+ Electricity Fuel Use[hard coal w CCS es] ~~|
Total Energy Use by Sector[electricity sector,biomass]=
	Electricity Fuel Use[biomass es]
	+ Electricity Fuel Use[biomass w CCS es] ~~|
Total Energy Use by Sector[electricity sector,lignite]=
	Electricity Fuel Use[lignite es]
	+ Electricity Fuel Use[lignite w CCS es] ~~|
Total Energy Use by Sector[electricity sector,nuclear]=
	Electricity Fuel Use[nuclear es]
	+ Electricity Fuel Use[small modular reactor es] ~~|
Total Energy Use by Sector[electricity sector,hydrogen]=
	Electricity Fuel Use[hydrogen combustion turbine es]
	+ Electricity Fuel Use[hydrogen combined cycle es] ~~|
Total Energy Use by Sector[industry sector,hydrogen]=
	SUM(Industrial Fuel Use[hydrogen if,Industry Category!])
	+ SUM(Industrial Fuel Use[green hydrogen if,Industry Category!])
	+ SUM(Industrial Fuel Use[low carbon hydrogen if,Industry Category!]) ~~|
Total Energy Use by Sector[district heat and hydrogen sector,hydrogen]=
	Fuel Used to Generate Heat[hydrogen if]
	+ Hydrogen Sector Fuel Use[hydrogen if]
	
	+ Fuel Used to Generate Heat[green hydrogen if]
	+ Hydrogen Sector Fuel Use[green hydrogen if]
	
	+ Fuel Used to Generate Heat[low carbon hydrogen if]
	+ Hydrogen Sector Fuel Use[low carbon hydrogen if] ~~|
Total Energy Use by Sector[geoengineering sector,hydrogen]=
	Geoengineering Sector Energy Use[hydrogen if]
	+ Geoengineering Sector Energy Use[green hydrogen if]
	+ Geoengineering Sector Energy Use[low carbon hydrogen if]
	~	BTU
	~	This variable must include energy carriers (electricity, heat, and \
		hydrogen), as it is used to allocate these energy carriers in an output \
		graph.  A subsequent variable filters out the energy carriers for use in \
		the primary energy graphs.
	|

Total EV Battery Capacity=
	SUM(
	  Vehicles[Vehicle Type!,Cargo Type!,Vehicle Technology!]
	  * This Year Battery Capacity by Vehicle Type[Cargo Type!,Vehicle Type!,Vehicle Technology\
		!]
	)
	/ kWh per MWh
	~	MW*hr
	~		|

Total EV Battery Capacity Available in MW=
	SUM(
	  Vehicles[Vehicle Type!,Cargo Type!,battery electric vehicle]
	  *AVCC Average Vehicle Charger Capacity[Vehicle Type!,Cargo Type!]
	  *Fraction of EVs Used for Grid Balancing on Average Day
	 )
	~	MW
	~		|

Total Final Energy Use by Sector[Sectors,All Fuels] :EXCEPT:    [electricity sector,All Fuels\
		],[industry sector,All Fuels],[district heat and hydrogen sector,All Fuels]=
	Total Energy Use by Sector[Sectors,All Fuels] ~~|
Total Final Energy Use by Sector[electricity sector,All Fuels]=
	0 ~~|
Total Final Energy Use by Sector[industry sector,All Fuels]=
	SUM(Industry Sector Final Energy Use by Industry[All Fuels,Industry Category!]) ~~|
Total Final Energy Use by Sector[district heat and hydrogen sector,All Fuels]=
	0
	~	BTU
	~		|

Total Hydrogen Demand=
	SUM(Hydrogen Demand by Sector[Sectors!])
	~	BTU
	~		|

Total Industrial Electricity Demand by Hour Before CCS[Electricity Timeslice,Hour,Industry Category\
		] :EXCEPT:      [Electricity Timeslice,Hour,industry categories w industry wide load factors\
		]=
	SUM(
	  Industrial Equipment Energy Use by Fuel Type and Process[Industry Category,electricity if\
		,Industrial Process!]
	  * Adjusted Load Factors for Industrial Processes[Electricity Timeslice,Hour,Industrial Process\
		!]
	)
	* MWh per BTU ~~|
Total Industrial Electricity Demand by Hour Before CCS[Electricity Timeslice,Hour,industry categories w industry wide load factors\
		]=
	SUM(
	  Industrial Equipment Energy Use by Fuel Type and Process[industry categories w industry wide load factors\
		,electricity if,Industrial Process!]
	)
	* Adjusted Load Factors for Industry Categories[Electricity Timeslice,Hour,Industry Cat w Industry wide Load Factor\
		]
	* MWh per BTU
	~	MW*hr
	~		|

Total New and Retrofit Capacity Desired due to Cost Effectiveness by CES Optimization Pass\
		[Electricity Source, Optimization Pass]=
	New Capacity Desired due to Cost Effectivness by Optimization Pass[Electricity Source\
		,Optimization Pass,CES]
	+ Retrofitted Capacity Desired due to Cost Effectiveness by Optimization Pass[Electricity Source\
		,Optimization Pass,CES]
	+New Capacity Desired due to Cost Effectivness by Optimization Pass for Hybrid Power Plants\
		[Electricity Source,Optimization Pass,CES]
	~	MW
	~		|

Total New and Retrofit Capacity Desired due to Cost Effectiveness by RPS Optimization Pass\
		[Electricity Source, Optimization Pass]=
	New Capacity Desired due to Cost Effectivness by Optimization Pass[Electricity Source\
		,Optimization Pass,RPS]
	+ Retrofitted Capacity Desired due to Cost Effectiveness by Optimization Pass[Electricity Source\
		,Optimization Pass,RPS]
	+New Capacity Desired due to Cost Effectivness by Optimization Pass for Hybrid Power Plants\
		[Electricity Source,Optimization Pass,RPS]
	~	MW
	~		|

Total New Capacity Desired due to Cost Effectiveness[Electricity Source,RPS]=
	New Capacity Desired due to Cost Effectiveness[Electricity Source,RPS]
	+New Capacity Desired due to Cost Effectiveness for Hybrid Power Plants[Electricity Source\
		,RPS] ~~|
Total New Capacity Desired due to Cost Effectiveness[Electricity Source,CES]=
	New Capacity Desired due to Cost Effectiveness[Electricity Source,CES]
	+New Capacity Desired due to Cost Effectiveness for Hybrid Power Plants[Electricity Source\
		,CES]
	~	MW
	~		|

Total New Capacity for Reliability[Electricity Source]=
	QUANTUM( New Dispatchable Only Capacity Desired for Seasonal Reliability[Electricity Source\
		],
	MPPC Minimum Power Plant Capacity[Electricity Source])
	~	MW
	~		~	:SUPPLEMENTARY 
	|

Total New Low Carbon Hydrogen Production Capacity This Year=
	MAX(
	  0,
	  Low Carbon Hydrogen Demand - 
	  (Surviving Capacity Available After Green Hydrogen Demand[electrolysis with guaranteed clean electricity\
		]
	  + Surviving Capacity Available After Green Hydrogen Demand[natural gas reforming with CCS\
		])
	)
	~	BTU
	~		|

Total New Other Hydrogen Production Capacity This Year=
	MAX(
	  0,
	  Other Hydrogen Demand - 
	  SUM(Surviving Capacity Available After Low Carbon Hydrogen Demand[Hydrogen Production Pathway\
		!])
	)
	~	BTU
	~		|

Total Other Fuel Tax Revenue=
	Transportation Sector Other Fuel Tax Revenue
	+ Electricity Sector Other Fuel Tax Revenue
	+ Buildings Sector Other Fuel Tax Revenue
	+ Industry Sector Other Fuel Tax Revenue
	+ District Heat and Hydrogen Sector Other Fuel Tax Revenue
	+ Geoengineering Sector Other Fuel Tax Revenue
	~	$
	~		|

Total Pollutant Emissions[Pollutant]=
	SUM(Total Pollutant Emissions by Sector[Sectors!,Pollutant])
	~	g pollutant
	~		|

Total Pollutant Emissions by Sector[transportation sector,Pollutant]=
	QUANTUM(
	  Transportation Sector Pollutant Emissions[Pollutant],
	
	  QSfP Quantization Size for Pollutants
	) ~~|
Total Pollutant Emissions by Sector[electricity sector,Pollutant]=
	QUANTUM(
	  SUM(Electricity Sector Pollutant Emissions[Pollutant,Electricity Source!]),
	
	  QSfP Quantization Size for Pollutants
	) ~~|
Total Pollutant Emissions by Sector[residential buildings sector,Pollutant]=
	QUANTUM(
	  Buildings Sector Pollutant Emissions[urban residential,Pollutant]
	  + Buildings Sector Pollutant Emissions[rural residential,Pollutant],
	
	  QSfP Quantization Size for Pollutants
	) ~~|
Total Pollutant Emissions by Sector[commercial buildings sector,Pollutant]=
	QUANTUM(
	  Buildings Sector Pollutant Emissions[commercial,Pollutant],
	
	  QSfP Quantization Size for Pollutants
	) ~~|
Total Pollutant Emissions by Sector[industry sector,Pollutant]=
	QUANTUM(
	  SUM(Industrial Sector Pollutant Emissions[Industry Category!,Pollutant]),
	
	  QSfP Quantization Size for Pollutants
	) ~~|
Total Pollutant Emissions by Sector[district heat and hydrogen sector,Pollutant]=
	QUANTUM(
	  SUM(District Heating Pollutant Emissions[Pollutant,Industrial Fuel!])
	  + SUM(Hydrogen Sector Pollutant Emissions[Pollutant,Industrial Fuel!]),
	
	  QSfP Quantization Size for Pollutants
	) ~~|
Total Pollutant Emissions by Sector[LULUCF sector,Pollutant]=
	QUANTUM(
	  LULUCF Anthropogenic Pollutant Emissions[Pollutant],
	
	  QSfP Quantization Size for Pollutants
	) ~~|
Total Pollutant Emissions by Sector[geoengineering sector,Pollutant]=
	QUANTUM(
	  Geoengineering Sector Pollutant Emissions[Pollutant],
	
	  QSfP Quantization Size for Pollutants
	)
	~	g pollutant
	~		|

Total Primary Energy Use[primary fuel]=
	Total Primary Fuel Use[primary fuel] ~~|
Total Primary Energy Use[hydro]=
	Renewable Electricity Generation Converted to Primary Energy[hydro es] ~~|
Total Primary Energy Use[wind]=
	Renewable Electricity Generation Converted to Primary Energy[onshore wind es]
	+ Renewable Electricity Generation Converted to Primary Energy[offshore wind es] ~~|
Total Primary Energy Use[solar]=
	Renewable Electricity Generation Converted to Primary Energy[solar PV es]
	+ Renewable Electricity Generation Converted to Primary Energy[solar thermal es] ~~|
Total Primary Energy Use[geothermal]=
	Renewable Electricity Generation Converted to Primary Energy[geothermal es] ~~|
Total Primary Energy Use[electricity]=
	0 {energy carrier, not primary energy} ~~|
Total Primary Energy Use[heat]=
	0 {energy carrier, not primary energy} ~~|
Total Primary Energy Use[hydrogen]=
	0 {energy carrier, not primary energy} ~~|
Total Primary Energy Use[petroleum gasoline]=
	0 ~~|
Total Primary Energy Use[petroleum diesel]=
	0 ~~|
Total Primary Energy Use[biofuel gasoline]=
	0 ~~|
Total Primary Energy Use[biofuel diesel]=
	0 ~~|
Total Primary Energy Use[jet fuel or kerosene]=
	0 ~~|
Total Primary Energy Use[heavy or residual fuel oil]=
	0 ~~|
Total Primary Energy Use[LPG propane or butane]=
	0
	~	BTU
	~		|

Total Primary Energy Use by Producing ISIC Code[ISIC Code]=
	SUM(
	  Total Primary Energy Use[All Fuels!]
	  * FtPICM Fuel to Producing ISIC Code Map[All Fuels!,ISIC Code]
	)
	~	BTU
	~		|

Total Primary Energy Use per Unit GDP=
	SUM(Total Primary Energy Use[All Fuels!])
	/ Gross Domestic Product
	~	BTU/$
	~		|

Total Primary Fuel Use[All Fuels]=
	SUM(Total Primary Fuel Use by Sector[Sectors!,All Fuels])
	~	BTU
	~		|

Total Primary Fuel Use by Sector[Sectors,All Fuels] :EXCEPT: [Sectors,primary fuel]=
	0 ~~|
Total Primary Fuel Use by Sector[Sectors,primary fuel]=
	Total Energy Use by Sector[Sectors,primary fuel]
	~	BTU
	~		|

Total Qualifying CES Electricity Demand by Hour After Demand Altering Technologies[Electricity Timeslice\
		,Hour]=
	IF THEN ELSE(
	
	  Boolean Exclude Elec Exports from Elec Portfolio Stds[CES] = 1,
	
	  MAX(Total Electricity Demand by Hour After Demand Altering Technologies[Electricity Timeslice\
		,Hour] - Electricity Exports by Hour
	[Electricity Timeslice,Hour,pass20], 0),
	
	  Total Electricity Demand by Hour After Demand Altering Technologies[Electricity Timeslice\
		,Hour]
	)
	~	MW*hr
	~		|

Total Qualifying RPS Electricity Demand by Hour After Demand Altering Technologies[Electricity Timeslice\
		,Hour]=
	IF THEN ELSE(
	
	  Boolean Exclude Elec Exports from Elec Portfolio Stds[RPS] = 1,
	
	  MAX(Total Electricity Demand by Hour After Demand Altering Technologies[Electricity Timeslice\
		,Hour] - Electricity Exports by Hour
	[Electricity Timeslice,Hour,pass20], 0),
	
	  Total Electricity Demand by Hour After Demand Altering Technologies[Electricity Timeslice\
		,Hour]
	)
	~	MW*hr
	~		|

Total Subsidies per Unit Electricity Output Adjusted for Lifetime[Electricity Source]\
		=
	(Electricity Sector CCS Subsidy per MWh[Electricity Source]*BCS Duration of Subsidies for Carbon Sequestration
	  + Subsidy per Unit Electricity Output[Electricity Source]*BS Duration of Subsidies per Unit Electricity Output\
		[Electricity Source]
	)
	
	/ RPfFESCC Repayment Period for Financed Electricity Sector Capital Costs
	~	$/(MW*hour)
	~		|

Total Surviving Capacity Used for Low Carbon Hydrogen Production=
	MIN(
	  Low Carbon Hydrogen Demand,
	  Surviving Capacity Available After Green Hydrogen Demand[electrolysis with guaranteed clean electricity\
		]
	  + Surviving Capacity Available After Green Hydrogen Demand[natural gas reforming with CCS\
		]
	)
	~	BTU
	~		|

Total Surviving Capacity Used for Other Hydrogen Demand=
	MAX(
	  0,
	  MIN(
	    SUM(Surviving Capacity Available After Low Carbon Hydrogen Demand[Hydrogen Production Pathway\
		!]),
	    Other Hydrogen Demand
	  )
	)
	~	BTU
	~		|

Total Tax Paid on Buildings Fuels[Building Type,Building Fuel]=
	Building Components Energy Use Excluding Zero Cost Distributed Fuel Use[Building Type\
		,Building Fuel]
	* Buildings Fuel Total Tax or Subsidy Amount per Unit Energy[Building Fuel,Building Type\
		]
	~	$
	~		|

Total Tax Paid on Electricity Fuels[Electricity Source]=
	Electricity Fuel Use[Electricity Source]
	* Electricity Fuel Total Tax or Subsidy Amount per Unit Energy[Electricity Source]
	~	$
	~		|

Total Tax Paid on Fuels to Generate Heat[Industrial Fuel]=
	Fuel Used to Generate Heat[Industrial Fuel]
	* District Heat Fuel Total Tax or Subsidy Amount per Unit Energy[Industrial Fuel]
	~	$
	~		|

Total Tax Paid on Hydrogen Sector Fuels[Industrial Fuel]=
	Hydrogen Sector Fuel Use[Industrial Fuel]
	* Hydrogen Fuel Total Tax or Subsidy Amount per Unit Energy[Industrial Fuel]
	~	$
	~		|

Total Tax Paid on Transportation Fuels[Transportation Fuel,Vehicle Type,Cargo Type,Vehicle Technology\
		]=
	Transportation Sector Fuel Used[Vehicle Type,Cargo Type,Vehicle Technology,Transportation Fuel\
		]
	* Transportation Fuel Total Tax or Subsidy Amount per Unit Energy[Transportation Fuel\
		,Vehicle Type]
	~	$
	~		|

Total Vehicle Battery Production Subsidy Amount Paid[Vehicle Type,Cargo Type,Vehicle Technology\
		]=
	Subsidy for Vehicle Battery Production
	* New Vehicles[Vehicle Type,Cargo Type,Vehicle Technology]
	* This Year Battery Capacity by Vehicle Type[Cargo Type,Vehicle Type,Vehicle Technology\
		]
	* One Year
	~	$
	~		|

Total Vehicle Subsidy Amount Paid[Vehicle Type,Cargo Type,Vehicle Technology]=
	New Vehicles[Vehicle Type,Cargo Type,Vehicle Technology]
	* Vehicle Subsidy[Cargo Type,Vehicle Type,Vehicle Technology]
	*One Year
	~	$
	~		|

Transmission and Distribution Loss Percentage=
	BTaDLP BAU Transmission and Distribution Loss Percentage
	* (1 - Percentage TnD Losses Avoided This Year)
	~	Dmnl
	~		|

Transmission Construction Costs=
	SUM(New Generation Capacity Excluding Retrofit Capacity[Electricity Source!])
	* TCCpUNEC Transmission Construction Cost per Unit New Electricity Capacity
	~	$
	~		|

Transmission OM Costs=
	Electricity Generation Capacity Relative to Start Year
	* SYTaDC Start Year Transmission OM Costs
	~	$
	~		|

Transport Fares Paid[Vehicle Type,Cargo Type]=
	SUM(Cargo Dist Transported by Vehicle Technology[Vehicle Type,Cargo Type,Vehicle Technology\
		!])
	* FpUCD Fares per Unit Cargo Distance[Vehicle Type,Cargo Type]
	~	$
	~		|

Transport Subtotal Change in OM Expenditures=
	SUM(Change in Amount Spent on Vehicle Maintenance[Vehicle Type!,Cargo Type!,Vehicle Technology\
		!])
	+ SUM(Change in Transport Fares Paid[Vehicle Type!,Cargo Type!])
	+ SUM(Change in Amount Spent on Vehicle Insurance[Vehicle Type!,Cargo Type!,Vehicle Technology\
		!])
	+ SUM(Change in Amount Spent on Parking[Vehicle Type!,Cargo Type!,Vehicle Technology\
		!])
	+ SUM(Change in Amount Spent on Vehicle Licensing Registration and Property Tax[Vehicle Type\
		!,Cargo Type!,Vehicle Technology!])
	~	$
	~		|

Transportation CO2 Emissions Intensities Weighted by Fuel Type Consumption[Vehicle Type\
		,Cargo Type,Vehicle Technology]=
	ZIDZ(
	  SUM(
	    Transportation Fuel Pollutant Emissions Intensities This Year[Vehicle Type,CO2,Transportation Fuel\
		!]
	    * BPoEFUbVT BAU Perc of Each Fuel Used by Veh Technology[Vehicle Type,Cargo Type\
		,Vehicle Technology,Transportation Fuel!]),
	 
	  SUM(BPoEFUbVT BAU Perc of Each Fuel Used by Veh Technology[Vehicle Type,Cargo Type\
		,Vehicle Technology,Transportation Fuel!])
	)
	~	g pollutant/BTU
	~		|

Transportation Electricity Demand by Vehicle Type[Vehicle Type,Cargo Type,Vehicle Technology\
		]=
	Transportation Sector Fuel Used[Vehicle Type,Cargo Type,Vehicle Technology,electricity tf\
		]
	* MWh per BTU
	~	MW*hour
	~		|

Transportation Energy Use by Fuel[Transportation Fuel]=
	SUM(Transportation Sector Fuel Used[Vehicle Type!,Cargo Type!,Vehicle Technology!,Transportation Fuel\
		])
	~	BTU
	~		~	:SUPPLEMENTARY 
	|

Transportation Fuel:
	electricity tf,
	natural gas tf,
	petroleum gasoline tf,
	petroleum diesel tf,
	biofuel gasoline tf,
	biofuel diesel tf,
	jet fuel tf,
	heavy or residual fuel oil tf,
	LPG propane or butane tf,
	hydrogen tf
	-> transportation fuel within all fuels
	~	
	~		|

Transportation Fuel Carbon Tax Amount per Unit Energy[Vehicle Type,Transportation Fuel\
		]=
	Carbon Tax Rate[transportation sector]
	/ Grams per Metric Ton CO2e
	* Transportation Fuel Taxable CO2e Emissions Intensity[Vehicle Type,Transportation Fuel\
		]
	* IF THEN ELSE(
	   Boolean Use Non BAU Carbon Tax Vehicle Type Qualification This Year > 0,
	   FoVTStCT Fraction of Vehicle Types Subject to Carbon Tax[Vehicle Type],
	   BFoVTStCT BAU Fraction of Vehicle Types Subject to Carbon Tax[Vehicle Type]
	)
	~	$/BTU
	~		|

Transportation Fuel Cost per Unit Energy[electricity tf]=
	MAX(Pretax Fuel Cost per Unit Energy by Sector after Fuel Price Deregulation[electricity\
		,transportation sector]
	  + Transportation Fuel Total Tax or Subsidy Amount per Unit Energy[electricity tf,LDVs\
		],
	0
	) ~~|
Transportation Fuel Cost per Unit Energy[natural gas tf]=
	Pretax Fuel Cost per Unit Energy by Sector after Fuel Price Deregulation[natural gas\
		,transportation sector]
	+ Transportation Fuel Total Tax or Subsidy Amount per Unit Energy[natural gas tf,HDVs\
		] ~~|
Transportation Fuel Cost per Unit Energy[petroleum gasoline tf]=
	Pretax Fuel Cost per Unit Energy by Sector after Fuel Price Deregulation[petroleum gasoline\
		,transportation sector]
	+ Transportation Fuel Total Tax or Subsidy Amount per Unit Energy[petroleum gasoline tf\
		,LDVs] ~~|
Transportation Fuel Cost per Unit Energy[petroleum diesel tf]=
	Pretax Fuel Cost per Unit Energy by Sector after Fuel Price Deregulation[petroleum diesel\
		,transportation sector]
	+ Transportation Fuel Total Tax or Subsidy Amount per Unit Energy[petroleum diesel tf\
		,HDVs] ~~|
Transportation Fuel Cost per Unit Energy[biofuel gasoline tf]=
	Pretax Fuel Cost per Unit Energy by Sector after Fuel Price Deregulation[biofuel gasoline\
		,transportation sector]
	+ Transportation Fuel Total Tax or Subsidy Amount per Unit Energy[biofuel gasoline tf\
		,LDVs] ~~|
Transportation Fuel Cost per Unit Energy[biofuel diesel tf]=
	Pretax Fuel Cost per Unit Energy by Sector after Fuel Price Deregulation[biofuel diesel\
		,transportation sector]
	+ Transportation Fuel Total Tax or Subsidy Amount per Unit Energy[biofuel diesel tf,\
		HDVs] ~~|
Transportation Fuel Cost per Unit Energy[jet fuel tf]=
	Pretax Fuel Cost per Unit Energy by Sector after Fuel Price Deregulation[jet fuel or kerosene\
		,transportation sector]
	+ Transportation Fuel Total Tax or Subsidy Amount per Unit Energy[jet fuel tf,aircraft\
		] ~~|
Transportation Fuel Cost per Unit Energy[heavy or residual fuel oil tf]=
	Pretax Fuel Cost per Unit Energy by Sector after Fuel Price Deregulation[heavy or residual fuel oil\
		,transportation sector]
	+ Transportation Fuel Total Tax or Subsidy Amount per Unit Energy[heavy or residual fuel oil tf\
		,ships] ~~|
Transportation Fuel Cost per Unit Energy[LPG propane or butane tf]=
	Pretax Fuel Cost per Unit Energy by Sector after Fuel Price Deregulation[LPG propane or butane\
		,transportation sector]
	+ Transportation Fuel Total Tax or Subsidy Amount per Unit Energy[LPG propane or butane tf\
		,LDVs] ~~|
Transportation Fuel Cost per Unit Energy[hydrogen tf]=
	Pretax Fuel Cost per Unit Energy by Sector after Fuel Price Deregulation[hydrogen,transportation sector\
		]
	+ Transportation Fuel Total Tax or Subsidy Amount per Unit Energy[hydrogen tf,LDVs]
	~	$/BTU
	~	We need this subscripted only by fuel type, not vehicle type, for use \
		calculating percentage differences from BAU.  Carbon intensity of fuels \
		should not vary significantly based on which type of vehicle burns those \
		fuels, as CO2 is not captured or eliminated through control technologies \
		in vehicles (like a catalytic converter for NOx).  Accordingly, we use the \
		main vehicle type that burns each fuel type to populate this variable.
	|

Transportation Fuel Other Tax or Subsidy Amount per Unit Energy[Transportation Fuel]=
	Fuel Tax or Subsidy by Sector[transportation fuel within all fuels,transportation sector\
		]
	~	$/BTU
	~		|

Transportation Fuel Pollutant Emissions Intensities before Fuel Economy Adjustment[Vehicle Type\
		,Pollutant,Transportation Fuel]=
	IF THEN ELSE(
	  SRPbVT Separately Regulated Pollutants by Vehicle Type[Vehicle Type,Pollutant] = 1\
		,
	
	  Transportation Fuel Pollutant Emissions Intensities This Year[Vehicle Type,Pollutant\
		,Transportation Fuel]
	  * (1 - Percentage Reduction of Separately Regulated Pollutants This Year[Vehicle Type\
		,Pollutant]),
	
	  Transportation Fuel Pollutant Emissions Intensities This Year[Vehicle Type,Pollutant\
		,Transportation Fuel]
	)
	~	g pollutant/BTU
	~		|

Transportation Fuel Pollutant Emissions Intensities This Year[Vehicle Type,Pollutant,\
		Transportation Fuel]=
	PEI Transportation Fuel Pollutant Emissions Intensities[Vehicle Type,Pollutant,Transportation Fuel\
		]
	  * (1 - PEIIR Transportation Fuel Pollutant Emissions Intensity Improvement Rate[Vehicle Type\
		,Pollutant,Transportation Fuel
	])
	    ^(Dimensionless Time - Initial Time Dimensionless)
	~	g pollutant/BTU
	~		|

Transportation Fuel Taxable CO2e Emissions Intensity[Vehicle Type,Transportation Fuel\
		]=
	SUM(
	  Transportation Fuel Pollutant Emissions Intensities This Year[Vehicle Type,Pollutant\
		!,Transportation Fuel]
	  * GWP by Pollutant[Pollutant!]
	  * Transportation Pollutants Taxed by Carbon Pricing[Vehicle Type,Pollutant!]
	)
	~	g CO2e/BTU
	~		|

Transportation Fuel Total Tax or Subsidy Amount per Unit Energy[Transportation Fuel,Vehicle Type\
		]=
	Transportation Fuel Carbon Tax Amount per Unit Energy[Vehicle Type,Transportation Fuel\
		]
	+ Transportation Fuel Other Tax or Subsidy Amount per Unit Energy[Transportation Fuel\
		]
	~	$/BTU
	~		|

transportation fuel within all fuels:
	electricity,
	natural gas,
	petroleum gasoline,
	petroleum diesel,
	biofuel gasoline,
	biofuel diesel,
	jet fuel or kerosene,
	heavy or residual fuel oil,
	LPG propane or butane,
	hydrogen
	-> Transportation Fuel
	~	
	~		|

Transportation Pollutant Emissions Disaggregated[Vehicle Type,Pollutant,Cargo Type,Transportation Fuel\
		]=
	IF THEN ELSE(
	  SRPbVT Separately Regulated Pollutants by Vehicle Type[Vehicle Type,Pollutant] = 1\
		,
	  
	  SUM(Transportation Sector Fuel Used[Vehicle Type,Cargo Type,Vehicle Technology!,Transportation Fuel\
		]
	    * Transportation Fuel Pollutant Emissions Intensities before Fuel Economy Adjustment\
		[Vehicle Type,Pollutant,Transportation Fuel]
	    * (1 + Percent Change in Fleet Avg Fuel Economy[Vehicle Type,Cargo Type,Vehicle Technology\
		!])),
	
	  SUM(Transportation Sector Fuel Used[Vehicle Type,Cargo Type,Vehicle Technology!,Transportation Fuel\
		]
	    * Transportation Fuel Pollutant Emissions Intensities before Fuel Economy Adjustment\
		[Vehicle Type,Pollutant,Transportation Fuel])
	)
	~	g pollutant
	~	If a pollutant is separately-regulated, we must UNDO the effects of fuel \
		economy improvements on that pollutant's emissions (to reflect the way \
		that automakers scale back control technologies to narrowly comply with \
		limits on separately-regulated pollutants as fuel economy improves).
	|

Transportation Pollutants Taxed by Carbon Pricing[Vehicle Type,Pollutant]=
	IF THEN ELSE(Boolean Non BAU Pollutants Affected by Carbon Tax This Year = 0,
	  BPTbCP BAU Transportation Pollutants Taxed by Carbon Pricing[Vehicle Type,Pollutant\
		],
	  PTbCP Transportation Pollutants Taxed by Carbon Pricing[Vehicle Type,Pollutant]
	)
	~	Dmnl
	~		|

Transportation Sector Carbon Tax Revenue[Vehicle Type,Cargo Type]=
	SUM(Transportation Sector Fuel Used[Vehicle Type,Cargo Type,Vehicle Technology!,Transportation Fuel\
		!]
	* Transportation Fuel Carbon Tax Amount per Unit Energy[Vehicle Type,Transportation Fuel\
		!])
	~	$
	~		|

Transportation Sector Change in Energy Expenditures by Entity[Cash Flow Entity]=
	SUM(
	  Change in Amount Spent on Transportation Fuels by Vehicle Type[Vehicle Type!,Cargo Type\
		!]
	  * Fraction of Vehicles Owned by Entity after Allocation to Energy Supplier Entities\
		[Vehicle Type!,Cash Flow Entity,Cargo Type!]
	)
	~	$
	~		|

Transportation Sector Change in Energy Expenditures by Entity and Fuel[Transportation Fuel\
		,Cash Flow Entity]=
	SUM(
	  Change in Amount Spent on Transportation Fuels[Transportation Fuel,Vehicle Type!,Cargo Type\
		!,Vehicle Technology!]
	  * Fraction of Vehicles Owned by Entity after Allocation to Energy Supplier Entities\
		[Vehicle Type!,Cash Flow Entity,Cargo Type!]
	)
	~	$
	~		|

Transportation Sector Change in Fuel Industry Cash Flow[electricity tf]=
	Transportation Sector Change in Fuel Industry Cash Flow before Subsidies[electricity tf\
		]
	
	+ Change in Revenue from Vehicle and Battery Subsidies by Entity[electricity suppliers\
		]
	
	+ Change in Revenue from Vehicle and Battery Subsidies by Entity[coal suppliers] ~~|
Transportation Sector Change in Fuel Industry Cash Flow[natural gas tf]=
	Transportation Sector Change in Fuel Industry Cash Flow before Subsidies[natural gas tf\
		]
	
	+ Change in Revenue from Vehicle and Battery Subsidies by Entity[natural gas and petroleum suppliers\
		]
	  * ZIDZ(
	      Fuel Production[natural gas],
	
	      SUM(Fuel Production[NGPS industry fuel within all fuels!])
	        - Fuel Production[crude oil]
	    ) ~~|
Transportation Sector Change in Fuel Industry Cash Flow[petroleum gasoline tf]=
	Transportation Sector Change in Fuel Industry Cash Flow before Subsidies[petroleum gasoline tf\
		]
	
	+ Change in Revenue from Vehicle and Battery Subsidies by Entity[natural gas and petroleum suppliers\
		]
	  * ZIDZ(
	      Fuel Production[petroleum gasoline],
	
	      SUM(Fuel Production[NGPS industry fuel within all fuels!])
	        - Fuel Production[crude oil]
	    ) ~~|
Transportation Sector Change in Fuel Industry Cash Flow[petroleum diesel tf]=
	Transportation Sector Change in Fuel Industry Cash Flow before Subsidies[petroleum diesel tf\
		]
	
	+ Change in Revenue from Vehicle and Battery Subsidies by Entity[natural gas and petroleum suppliers\
		]
	  * ZIDZ(
	      Fuel Production[petroleum diesel],
	
	      SUM(Fuel Production[NGPS industry fuel within all fuels!])
	        - Fuel Production[crude oil]
	    ) ~~|
Transportation Sector Change in Fuel Industry Cash Flow[biofuel gasoline tf]=
	Transportation Sector Change in Fuel Industry Cash Flow before Subsidies[biofuel gasoline tf\
		]
	
	+ Change in Revenue from Vehicle and Battery Subsidies by Entity[biomass and biofuel suppliers\
		]
	  * ZIDZ(
	      Fuel Production[biofuel gasoline],
	
	      SUM(Fuel Production[biomass and biofuel within all fuels!])
	        - Fuel Production[biomass]
	    ) ~~|
Transportation Sector Change in Fuel Industry Cash Flow[biofuel diesel tf]=
	Transportation Sector Change in Fuel Industry Cash Flow before Subsidies[biofuel diesel tf\
		]
	
	+ Change in Revenue from Vehicle and Battery Subsidies by Entity[biomass and biofuel suppliers\
		]
	  * ZIDZ(
	      Fuel Production[biofuel diesel],
	
	      SUM(Fuel Production[biomass and biofuel within all fuels!])
	        - Fuel Production[biomass]
	    ) ~~|
Transportation Sector Change in Fuel Industry Cash Flow[jet fuel tf]=
	Transportation Sector Change in Fuel Industry Cash Flow before Subsidies[jet fuel tf\
		]
	
	+ Change in Revenue from Vehicle and Battery Subsidies by Entity[natural gas and petroleum suppliers\
		]
	  * ZIDZ(
	      Fuel Production[jet fuel or kerosene],
	
	      SUM(Fuel Production[NGPS industry fuel within all fuels!])
	        - Fuel Production[crude oil]
	    ) ~~|
Transportation Sector Change in Fuel Industry Cash Flow[heavy or residual fuel oil tf\
		]=
	Transportation Sector Change in Fuel Industry Cash Flow before Subsidies[heavy or residual fuel oil tf\
		]
	
	+ Change in Revenue from Vehicle and Battery Subsidies by Entity[natural gas and petroleum suppliers\
		]
	  * ZIDZ(
	      Fuel Production[heavy or residual fuel oil],
	
	      SUM(Fuel Production[NGPS industry fuel within all fuels!])
	        - Fuel Production[crude oil]
	    ) ~~|
Transportation Sector Change in Fuel Industry Cash Flow[LPG propane or butane tf]=
	Transportation Sector Change in Fuel Industry Cash Flow before Subsidies[LPG propane or butane tf\
		]
	
	+ Change in Revenue from Vehicle and Battery Subsidies by Entity[natural gas and petroleum suppliers\
		]
	  * ZIDZ(
	      Fuel Production[LPG propane or butane],
	
	      SUM(Fuel Production[NGPS industry fuel within all fuels!])
	        - Fuel Production[crude oil]
	    ) ~~|
Transportation Sector Change in Fuel Industry Cash Flow[hydrogen tf]=
	Transportation Sector Change in Fuel Industry Cash Flow before Subsidies[hydrogen tf\
		]
	
	+ Change in Revenue from Vehicle and Battery Subsidies by Entity[other energy suppliers\
		]
	~	$
	~	The "Transportation Fuel" in this variable's subscript is the fuel \
		supplied by the fuel supplier who is receiving this revenue.  All types of \
		energy suppliers could conceivably own electric vehicles, but this \
		variable is subscripted by Transportation Fuel, and coal isn't a \
		transportation fuel, so we don't have an easy way to assign this money to \
		coal suppliers.  We could build a separate structure for this, but EV \
		rebates due to ownership of EVs by these companies is an extremely tiny \
		cash flow, so it is not worth the extra complexity.  Instead, we include \
		it in the same category as electricity suppliers, who are the main \
		purchasers of coal.
	|

Transportation Sector Change in Fuel Industry Cash Flow before Subsidies[Transportation Fuel\
		]=
	SUM(Change in Amount Spent on Transportation Fuels[Transportation Fuel,Vehicle Type!\
		,Cargo Type!,Vehicle Technology!])
	- SUM(Change in Transportation Fuel Taxes Paid[Transportation Fuel,Vehicle Type!,Cargo Type\
		!,Vehicle Technology!])
	~	$
	~		|

Transportation Sector Change in Fuel Industry Cash Flow Including Subsidies Mapped to All Fuels Subscript\
		[All Fuels] :EXCEPT:      [transportation fuel within all fuels
]=
	0 ~~|
Transportation Sector Change in Fuel Industry Cash Flow Including Subsidies Mapped to All Fuels Subscript\
		[transportation fuel within all fuels]=
	Transportation Sector Change in Fuel Industry Cash Flow[Transportation Fuel]
	~	$
	~		|

Transportation Sector Change in Fuel Industry Cash Flow Mapped to All Fuels Subscript\
		[All Fuels] :EXCEPT:  [transportation fuel within all fuels]=
	0 ~~|
Transportation Sector Change in Fuel Industry Cash Flow Mapped to All Fuels Subscript\
		[transportation fuel within all fuels]=
	Transportation Sector Change in Fuel Industry Cash Flow before Subsidies[Transportation Fuel\
		]
	~	$
	~		|

Transportation Sector Change in Nonenergy Expenditures by Entity[Cash Flow Entity] :EXCEPT:\
		      [government],[labor and consumers
],[nonenergy industries]=
	SUM(
	  (Change in Amount Spent on Vehicle Manufacturing Excluding Batteries by Vehicle Type\
		[Vehicle Type!,Cargo Type!]
	    + Change in Amount Spent on Vehicle Markups by Vehicle Type[Vehicle Type!,Cargo Type\
		!]
	    + Change in Amount Spent on Vehicle Batteries by Vehicle Type[Vehicle Type!,Cargo Type\
		!]
	    + Change in Amount Spent on EV Chargers by Vehicle Type[Vehicle Type!,Cargo Type\
		!]
	    + Change in Amount Spent on Vehicle Maintenance by Vehicle Type[Vehicle Type!,Cargo Type\
		!]
	    + Change in Amount Spent on Vehicle Insurance by Vehicle Type[Vehicle Type!,Cargo Type\
		!]
	    + Change in Amount Spent on Parking by Vehicle Type[Vehicle Type!,Cargo Type!]
	    + Change in Amount Spent on Vehicle Licensing Registration and Property Tax by Vehicle Type\
		[Vehicle Type!,Cargo Type
	!]
	  )
	  * Fraction of Vehicles Owned by Entity after Allocation to Energy Supplier Entities\
		[Vehicle Type!,Cash Flow Entity,Cargo Type
	!]
	) ~~|
Transportation Sector Change in Nonenergy Expenditures by Entity[government]=
	SUM(
	  (Change in Amount Spent on Vehicle Manufacturing Excluding Batteries by Vehicle Type\
		[Vehicle Type!,Cargo Type!]
	    + Change in Amount Spent on Vehicle Markups by Vehicle Type[Vehicle Type!,Cargo Type\
		!]
	    + Change in Amount Spent on Vehicle Batteries by Vehicle Type[Vehicle Type!,Cargo Type\
		!]
	    + Change in Amount Spent on EV Chargers by Vehicle Type[Vehicle Type!,Cargo Type\
		!]
	    + Change in Amount Spent on Vehicle Maintenance by Vehicle Type[Vehicle Type!,Cargo Type\
		!]
	    + Change in Amount Spent on Vehicle Insurance by Vehicle Type[Vehicle Type!,Cargo Type\
		!]
	    + Change in Amount Spent on Parking by Vehicle Type[Vehicle Type!,Cargo Type!]
	    + Change in Amount Spent on Vehicle Licensing Registration and Property Tax by Vehicle Type\
		[Vehicle Type!,Cargo Type
	!]
	  )
	  * Fraction of Vehicles Owned by Entity after Allocation to Energy Supplier Entities\
		[Vehicle Type!,government,Cargo Type
	!]
	)
	
	+ SUM(Change in Total Vehicle Subsidy Amount Paid[Vehicle Type!,Cargo Type!,Vehicle Technology\
		!])
	
	+ SUM(Change in Total Vehicle Battery Production Subsidy Amount Paid[Vehicle Type!,Cargo Type\
		!,Vehicle Technology!]) ~~|
Transportation Sector Change in Nonenergy Expenditures by Entity[labor and consumers]\
		=
	SUM(
	  (Change in Amount Spent on Vehicle Manufacturing Excluding Batteries by Vehicle Type\
		[Vehicle Type!,Cargo Type!]
	    + Change in Amount Spent on Vehicle Markups by Vehicle Type[Vehicle Type!,Cargo Type\
		!]
	    + Change in Amount Spent on Vehicle Batteries by Vehicle Type[Vehicle Type!,Cargo Type\
		!]
	    + Change in Amount Spent on EV Chargers by Vehicle Type[Vehicle Type!,Cargo Type\
		!]
	    + Change in Amount Spent on Vehicle Maintenance by Vehicle Type[Vehicle Type!,Cargo Type\
		!]
	    + Change in Amount Spent on Vehicle Insurance by Vehicle Type[Vehicle Type!,Cargo Type\
		!]
	    + Change in Amount Spent on Parking by Vehicle Type[Vehicle Type!,Cargo Type!]
	    + Change in Amount Spent on Vehicle Licensing Registration and Property Tax by Vehicle Type\
		[Vehicle Type!,Cargo Type
	!]
	  )
	  * Fraction of Vehicles Owned by Entity after Allocation to Energy Supplier Entities\
		[Vehicle Type!,labor and consumers
	,Cargo Type!]
	)
	
	+ SUM(Change in Transport Fares Paid[Vehicle Type!,passenger]) ~~|
Transportation Sector Change in Nonenergy Expenditures by Entity[nonenergy industries\
		]=
	SUM(
	  (Change in Amount Spent on Vehicle Manufacturing Excluding Batteries by Vehicle Type\
		[Vehicle Type!,Cargo Type!]
	    + Change in Amount Spent on Vehicle Markups by Vehicle Type[Vehicle Type!,Cargo Type\
		!]
	    + Change in Amount Spent on Vehicle Batteries by Vehicle Type[Vehicle Type!,Cargo Type\
		!]
	    + Change in Amount Spent on EV Chargers by Vehicle Type[Vehicle Type!,Cargo Type\
		!]
	    + Change in Amount Spent on Vehicle Maintenance by Vehicle Type[Vehicle Type!,Cargo Type\
		!]
	    + Change in Amount Spent on Vehicle Insurance by Vehicle Type[Vehicle Type!,Cargo Type\
		!]
	    + Change in Amount Spent on Parking by Vehicle Type[Vehicle Type!,Cargo Type!]
	    + Change in Amount Spent on Vehicle Licensing Registration and Property Tax by Vehicle Type\
		[Vehicle Type!,Cargo Type
	!]
	  )
	  * Fraction of Vehicles Owned by Entity after Allocation to Energy Supplier Entities\
		[Vehicle Type!,nonenergy industries
	,Cargo Type!]
	)
	
	+ SUM(Change in Transport Fares Paid[Vehicle Type!,freight])
	~	$
	~		|

Transportation Sector Change in Nonenergy Industry Expenditures by ISIC Code[ISIC Code\
		]=
	(Transportation Sector Change in Energy Expenditures by Entity[nonenergy industries]
	  + Transportation Sector Change in Nonenergy Expenditures by Entity[nonenergy industries\
		])
	* Percent of Output by Nonenergy Industry ISIC Code[ISIC Code]
	~	$
	~		|

Transportation Sector Change in Nonenergy Industry Revenue by ISIC Code[ISIC Code] :EXCEPT:\
		         [ISIC 29],[ISIC 30],[
ISIC 45T47
],[ISIC 49T53],[ISIC 64T66],[ISIC 27]=
	Change in Revenue from Vehicle and Battery Subsidies by Entity[nonenergy industries]
	* Percent of Output by Nonenergy Industry ISIC Code[ISIC Code]
	
	+ Change in Amount Spent on EV Chargers
	  * EVCRSbRIC EV Charger Revenue Share by Recipient ISIC Code[ISIC Code]
	
	+ SUM(Change in Amount Spent on Vehicle Markups[Vehicle Type!,Cargo Type!,Vehicle Technology\
		!]
	  * VRSbRIC Vehicle Revenue Share by Recipient ISIC Code Excluding Batteries[ISIC Code\
		, Vehicle Type!]) ~~|
Transportation Sector Change in Nonenergy Industry Revenue by ISIC Code[ISIC 29 {Motor vehicles, trailers and semi-trailers}\
		]=
	SUM(Change in Amount Spent on Vehicle Manufacturing Excluding Batteries[LDVs,Cargo Type\
		!,Vehicle Technology!])
	+ SUM(Change in Amount Spent on Vehicle Manufacturing Excluding Batteries[HDVs,Cargo Type\
		!,Vehicle Technology!])
	+ SUM(Change in Amount Spent on Vehicle Manufacturing Excluding Batteries[motorbikes\
		,Cargo Type!,Vehicle Technology!])
	
	+ Change in Revenue from Vehicle and Battery Subsidies by Entity[nonenergy industries\
		]
	  * Percent of Output by Nonenergy Industry ISIC Code[ISIC 29]
	
	+ Change in Amount Spent on EV Chargers
	  * EVCRSbRIC EV Charger Revenue Share by Recipient ISIC Code[ISIC 29]
	
	+ SUM(Change in Amount Spent on Vehicle Markups[Vehicle Type!,Cargo Type!,Vehicle Technology\
		!]
	  * VRSbRIC Vehicle Revenue Share by Recipient ISIC Code Excluding Batteries[ISIC 29\
		, Vehicle Type!]) ~~|
Transportation Sector Change in Nonenergy Industry Revenue by ISIC Code[ISIC 30 {Other transport equipment}\
		]=
	SUM(Change in Amount Spent on Vehicle Manufacturing Excluding Batteries[aircraft,Cargo Type\
		!,Vehicle Technology!])
	+ SUM(Change in Amount Spent on Vehicle Manufacturing Excluding Batteries[rail,Cargo Type\
		!,Vehicle Technology!])
	+ SUM(Change in Amount Spent on Vehicle Manufacturing Excluding Batteries[ships,Cargo Type\
		!,Vehicle Technology!])
	
	+ Change in Revenue from Vehicle and Battery Subsidies by Entity[nonenergy industries\
		]
	  * Percent of Output by Nonenergy Industry ISIC Code[ISIC 30]
	
	+ Change in Amount Spent on EV Chargers
	  * EVCRSbRIC EV Charger Revenue Share by Recipient ISIC Code[ISIC 30]
	
	+ SUM(Change in Amount Spent on Vehicle Markups[Vehicle Type!,Cargo Type!,Vehicle Technology\
		!]
	  * VRSbRIC Vehicle Revenue Share by Recipient ISIC Code Excluding Batteries[ISIC 30\
		,Vehicle Type!]) ~~|
Transportation Sector Change in Nonenergy Industry Revenue by ISIC Code[ISIC 45T47 {Wholesale and retail trade; repair of motor vehicles}\
		]=
	SUM(Change in Amount Spent on Vehicle Maintenance[Vehicle Type!,Cargo Type!,Vehicle Technology\
		!])
	
	+ Change in Amount Spent on EV Chargers
	  * EVCRSbRIC EV Charger Revenue Share by Recipient ISIC Code[ISIC 45T47]
	
	+ SUM(Change in Amount Spent on Vehicle Markups[Vehicle Type!,Cargo Type!,Vehicle Technology\
		!]
	  * VRSbRIC Vehicle Revenue Share by Recipient ISIC Code Excluding Batteries[ISIC 45T47\
		,Vehicle Type!]) ~~|
Transportation Sector Change in Nonenergy Industry Revenue by ISIC Code[ISIC 49T53 {Transportation and storage}\
		]=
	Change in Fare Revenue by Transport Supplier[nonenergy industries]
	
	+ SUM(Change in Amount Spent on Parking[Vehicle Type!,Cargo Type!,Vehicle Technology\
		!])
	
	+ Change in Revenue from Vehicle and Battery Subsidies by Entity[nonenergy industries\
		]
	  * Percent of Output by Nonenergy Industry ISIC Code[ISIC 49T53]
	
	+ Change in Amount Spent on EV Chargers
	  * EVCRSbRIC EV Charger Revenue Share by Recipient ISIC Code[ISIC 49T53]
	
	+ SUM(Change in Amount Spent on Vehicle Markups[Vehicle Type!,Cargo Type!,Vehicle Technology\
		!]
	  * VRSbRIC Vehicle Revenue Share by Recipient ISIC Code Excluding Batteries[ISIC 49T53\
		,Vehicle Type!]) ~~|
Transportation Sector Change in Nonenergy Industry Revenue by ISIC Code[ISIC 64T66 {Financial and insurance activities}\
		]=
	SUM(Change in Amount Spent on Vehicle Insurance[Vehicle Type!,Cargo Type!,Vehicle Technology\
		!])
	
	+ Change in Revenue from Vehicle and Battery Subsidies by Entity[nonenergy industries\
		]
	  * Percent of Output by Nonenergy Industry ISIC Code[ISIC 64T66]
	
	+ Change in Amount Spent on EV Chargers
	  * EVCRSbRIC EV Charger Revenue Share by Recipient ISIC Code[ISIC 64T66]
	
	+ SUM(Change in Amount Spent on Vehicle Markups[Vehicle Type!,Cargo Type!,Vehicle Technology\
		!]
	  * VRSbRIC Vehicle Revenue Share by Recipient ISIC Code Excluding Batteries[ISIC 64T66\
		,Vehicle Type!]) ~~|
Transportation Sector Change in Nonenergy Industry Revenue by ISIC Code[ISIC 27 {electrical equipment}\
		]=
	SUM(Change in Amount Spent on Vehicle Batteries[Vehicle Type!,Cargo Type!,Vehicle Technology\
		!])
	
	+ Change in Revenue from Vehicle and Battery Subsidies by Entity[nonenergy industries\
		]
	  * Percent of Output by Nonenergy Industry ISIC Code[ISIC 27]
	
	+ Change in Amount Spent on EV Chargers
	  * EVCRSbRIC EV Charger Revenue Share by Recipient ISIC Code[ISIC 27]
	
	+ SUM(Change in Amount Spent on Vehicle Markups[Vehicle Type!,Cargo Type!,Vehicle Technology\
		!]
	  * VRSbRIC Vehicle Revenue Share by Recipient ISIC Code Excluding Batteries[ISIC 27\
		,Vehicle Type!])
	
	+ SUM(Change in Total Vehicle Battery Production Subsidy Retained by Manufacturers[Vehicle Type\
		!,Cargo Type!,Vehicle Technology!])
	~	$
	~		|

Transportation Sector Change in Revenue by Entity[government]=
	SUM(Change in Transportation Fuel Taxes Paid[Transportation Fuel!,Vehicle Type!,Cargo Type\
		!,Vehicle Technology!])
	+ Change in Revenue from Vehicle and Battery Subsidies by Entity[government]
	
	+ Change in Fare Revenue by Transport Supplier[government]
	
	+ SUM(Change in Amount Spent on Vehicle Licensing Registration and Property Tax[Vehicle Type\
		!,Cargo Type!,Vehicle Technology
	!]) ~~|
Transportation Sector Change in Revenue by Entity[nonenergy industries]=
	SUM(Transportation Sector Change in Nonenergy Industry Revenue by ISIC Code[ISIC Code\
		!])
	
	{change in revenue from vehicle and battery subsidies and fare revenue are already included in Transportation Sector Change in Nonenergy Industry Revenue by ISIC Code}\
		 ~~|
Transportation Sector Change in Revenue by Entity[labor and consumers]=
	Change in Revenue from Vehicle and Battery Subsidies by Entity[labor and consumers]
	
	+ Change in Fare Revenue by Transport Supplier[labor and consumers] ~~|
Transportation Sector Change in Revenue by Entity[foreign entities]=
	Change in Revenue from Vehicle and Battery Subsidies by Entity[foreign entities]
	
	+ Change in Fare Revenue by Transport Supplier[foreign entities] ~~|
Transportation Sector Change in Revenue by Entity[electricity suppliers]=
	Transportation Sector Change in Fuel Industry Cash Flow before Subsidies[electricity tf\
		]
	+ Change in Revenue from Vehicle and Battery Subsidies by Entity[electricity suppliers\
		] ~~|
Transportation Sector Change in Revenue by Entity[coal suppliers]=
	Change in Revenue from Vehicle and Battery Subsidies by Entity[coal suppliers] ~~|
Transportation Sector Change in Revenue by Entity[natural gas and petroleum suppliers\
		]=
	Transportation Sector Change in Fuel Industry Cash Flow before Subsidies[natural gas tf\
		]
	+ Transportation Sector Change in Fuel Industry Cash Flow before Subsidies[petroleum gasoline tf\
		]
	+ Transportation Sector Change in Fuel Industry Cash Flow before Subsidies[petroleum diesel tf\
		]
	+ Transportation Sector Change in Fuel Industry Cash Flow before Subsidies[jet fuel tf\
		]
	+ Transportation Sector Change in Fuel Industry Cash Flow before Subsidies[heavy or residual fuel oil tf\
		]
	+ Transportation Sector Change in Fuel Industry Cash Flow before Subsidies[LPG propane or butane tf\
		]
	+ Change in Revenue from Vehicle and Battery Subsidies by Entity[natural gas and petroleum suppliers\
		] ~~|
Transportation Sector Change in Revenue by Entity[biomass and biofuel suppliers]=
	Transportation Sector Change in Fuel Industry Cash Flow before Subsidies[biofuel gasoline tf\
		]
	+ Transportation Sector Change in Fuel Industry Cash Flow before Subsidies[biofuel diesel tf\
		]
	+ Change in Revenue from Vehicle and Battery Subsidies by Entity[biomass and biofuel suppliers\
		] ~~|
Transportation Sector Change in Revenue by Entity[other energy suppliers]=
	Transportation Sector Change in Fuel Industry Cash Flow before Subsidies[hydrogen tf\
		]
	+ Change in Revenue from Vehicle and Battery Subsidies by Entity[other energy suppliers\
		]
	~	$
	~		|

Transportation Sector Electricity Demand[Vehicle Type,Cargo Type]=
	SUM(Transportation Electricity Demand by Vehicle Type[Vehicle Type,Cargo Type,Vehicle Technology\
		!])
	~	MW*hour
	~		|

Transportation Sector Fuel that would be Used in Absence of LCFS[Vehicle Type,Cargo Type\
		,Vehicle Technology,Transportation Fuel]=
	ZIDZ(
	  Cargo Dist Transported by Vehicle Technology[Vehicle Type,Cargo Type,Vehicle Technology\
		],
	  Fleet Avg Fuel Economy[Vehicle Type,Cargo Type,Vehicle Technology]
	)
	* BPoEFUbVT BAU Perc of Each Fuel Used by Veh Technology[Vehicle Type,Cargo Type,Vehicle Technology\
		,Transportation Fuel]
	~	BTU
	~		|

Transportation Sector Fuel that would be Used in Absence of LCFS by Regulated Vehicle Types\
		[Vehicle Type,Cargo Type,Vehicle Technology
,Transportation Fuel]=
	Transportation Sector Fuel that would be Used in Absence of LCFS[Vehicle Type,Cargo Type\
		,Vehicle Technology,Transportation Fuel]
	* IF THEN ELSE(Boolean Use Non BAU LCFS Vehicle Types This Year=1,
	               PVTStL Policy Vehicle Types Subject to LCFS[Vehicle Type,Cargo Type],
	               BVTStL BAU Vehicle Types Subject to LCFS[Vehicle Type,Cargo Type])
	~	BTU
	~		|

Transportation Sector Fuel Used[Vehicle Type,Cargo Type,Vehicle Technology,Transportation Fuel\
		]=
	Transportation Sector Fuel that would be Used in Absence of LCFS[Vehicle Type,Cargo Type\
		,Vehicle Technology,Transportation Fuel]
	+ Change in Fuel Use by Fuel and Technology due to LCFS[Vehicle Type,Cargo Type,Vehicle Technology\
		,Transportation Fuel]
	~	BTU
	~		|

Transportation Sector Other Fuel Tax Revenue=
	SUM(Transportation Sector Fuel Used[Vehicle Type!,Cargo Type!,Vehicle Technology!,Transportation Fuel\
		!]
	* Transportation Fuel Other Tax or Subsidy Amount per Unit Energy[Transportation Fuel\
		!])
	~	$
	~		|

Transportation Sector Pollutant Emissions[Pollutant]=
	SUM(Transportation Pollutant Emissions Disaggregated[Vehicle Type!,Pollutant,Cargo Type\
		!,Transportation Fuel!])
	~	g pollutant
	~		|

Transportation Subtotal Change in Capital Expenditures=
	SUM(Change in Amount Spent on Vehicle Batteries[Vehicle Type!,Cargo Type!,Vehicle Technology\
		!])
	+ SUM(Change in Amount Spent on Vehicle Manufacturing Excluding Batteries[Vehicle Type\
		!,Cargo Type!,Vehicle Technology!])
	+ SUM(Change in Amount Spent on Vehicle Markups[Vehicle Type!,Cargo Type!,Vehicle Technology\
		!])
	+ Change in Amount Spent on EV Chargers
	~	$
	~		|

Transportation Subtotal Change in Other Expenditures=
	SUM(Change in Total Vehicle Battery Production Subsidy Amount Paid[Vehicle Type!,Cargo Type\
		!,Vehicle Technology!])
	+ SUM(Change in Total Vehicle Subsidy Amount Paid[Vehicle Type!,Cargo Type!,Vehicle Technology\
		!])
	~	$
	~		|

Transportation Subtotal Change in Tax Revenues=
	SUM(Change in Transportation Fuel Taxes Paid[Transportation Fuel!,Vehicle Type!,Cargo Type\
		!,Vehicle Technology!])
	~	$
	~		|

