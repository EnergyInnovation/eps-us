Minimum Share of Start Year Industrial Equipment Retired To Date[Industry Category,Industrial Process\
		]=
	MAX(
	  MIN(
	    1,
	
	    Minimum Share of Start Year Industrial Equipment Retired[Industry Category,Industrial Process\
		]
	    * VECTOR ELM MAP(
	        Selected Policy Implementation Schedule[indst eqpt early retirement X agriculture and forestry 01T03 X boilers\
		],
	
	        (Industry Category-1)*ELMCOUNT(Industrial Process) + (Industrial Process-1)
	      )
	  ),
	  Last Year Minimum Share of Start Year Industrial Equipment Retired To Date[Industry Category\
		,Industrial Process]
	)
