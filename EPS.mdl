Value of CCS[Industry Category,process emissions]=
	Carbon Tax Rate[industry sector]
	* (1 - Does Carbon Tax Exempt Process Emissions This Year[Industry Category])
	
	+ Industrial CCS Transportation and Storage Subsidy
	+ Industry Sector CCS Subsidy by Industry Category[Industry Category] ~~|
Value of CCS[Industry Category,energy related emissions]=
	Industry Sector CCS Subsidy by Industry Category[Industry Category]
	+ Carbon Tax Rate[industry sector]
	+ Industrial CCS Transportation and Storage Subsidy
	~	$/metric ton CO2e
	~		|

Variable Costs per Unit New Elec Output[Electricity Source]=
	Fuel Cost per Unit Output for Plants Built This Year[Electricity Source]
	+ Variable OM Cost per Unit Output for Plants Built This Year[Electricity Source]
	+ Electricity Sector CCS Transportation and Storage Costs per MWh[Electricity Source\
		]
	-Carbon Price Credit per MWh[Electricity Source]
	- Subsidy per Unit Electricity Output Adjusted for Subsidy Duration[Electricity Source\
		]
	- CCS Subsidy per MWh Adjusted for Subsidy Duration[Electricity Source]
	~	$/(MW*hr)
	~		|

Variable OM Cost per Unit Output for Plants Built This Year[Electricity Source]=
	SUM(
	  CCaMC Variable OM Cost per Unit Output[Electricity Source,Modeled Vintage!]
	  * This Year Modeled Vintage Flag[Modeled Vintage!]
	)
	~	$/(MW*hour)
	~		|

Variable Renewable Electricity Source:
	onshore wind es,
	solar PV es,
	solar thermal es,
	offshore wind es
	~	
	~		|

Variable Subsidies per Unit Elec Output[Electricity Source]=
	Carbon Price Credit per MWh[Electricity Source]
	+CCS Subsidy per Unit Output for Dispatch[Electricity Source]
	+Subsidy per Unit Electricity Output for Dispatch[Electricity Source]
	+ (BS BAU Subsidy per Unit Electricity Output for Existing Plants[Electricity Source\
		]
	   * (1-Percent Reduction in BAU Subsidies This Year[electricity source within all fuels\
		])
	  )
	~	$/(MW*hr)
	~		|

Variable Subsidies per Unit New Elec Output[Electricity Source]=
	Carbon Price Credit per MWh[Electricity Source]
	+CCS Subsidy per MWh Adjusted for Subsidy Duration[Electricity Source]
	+Subsidy per Unit Electricity Output Adjusted for Subsidy Duration[Electricity Source\
		]
	~	$/(MW*hr)
	~		|

VBDR Vehicle Buyer Discount Rate[Vehicle Type]=
	GET DIRECT CONSTANTS(
	   'InputData/trans/VBDR/VBDR.csv',
	   ',',
	   'B2*'
	)
	~	Dmnl
	~		|

Vehicle Allocation Unit Correction=
	1
	~	vehicle/$
	~		|

Vehicle Subsidy[passenger,Vehicle Type,Vehicle Technology]=
	(BVS BAU Vehicle Subsidy[passenger,Vehicle Type,Vehicle Technology]
	  + Additional Passenger Vehicle Subsidy This Year[Vehicle Type,Vehicle Technology])\
		 ~~|
Vehicle Subsidy[freight,Vehicle Type,Vehicle Technology]=
	BVS BAU Vehicle Subsidy[freight,Vehicle Type,Vehicle Technology]
	+ Additional Freight Vehicle Subsidy This Year[Vehicle Type,Vehicle Technology]
	~	$/vehicle
	~		|

Vehicle Technologies Qualifying as ZEVs[Vehicle Type,Vehicle Technology]=
	IF THEN ELSE(
	  Boolean Use Non BAU ZEV Qualifying Vehicle Definitions This Year > 0,
	
	  VTQaZ Vehicle Technologies Qualifying as ZEVs[Vehicle Type,Vehicle Technology],
	
	  BVTQaZ BAU Vehicle Technologies Qualifying as ZEVs[Vehicle Type,Vehicle Technology\
		]
	)
	~	Dmnl
	~		|

Vehicle Technology:
	battery electric vehicle,
	natural gas vehicle,
	gasoline vehicle,
	diesel vehicle,
	plugin hybrid vehicle,
	LPG vehicle,
	hydrogen vehicle
	~	
	~		|

Vehicle Type:
	LDVs,
	HDVs,
	aircraft,
	rail,
	ships,
	motorbikes
	~	
	~		|

Vehicles[Vehicle Type,Cargo Type,Vehicle Technology]=
	Last Year Vehicles[Vehicle Type,Cargo Type,Vehicle Technology]
	+ New Vehicles[Vehicle Type,Cargo Type,Vehicle Technology] * One Year
	- Retiring Vehicles[Vehicle Type,Cargo Type,Vehicle Technology] * One Year
	~	vehicles
	~		|

Vehicles per Million Vehicles=
	1e+06
	~	vehicles/million vehicles
	~		|

Vehicles per Thousand Vehicles=
	1000
	~	vehicles/thousand vehicles
	~		|

