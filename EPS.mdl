Battery Charge Parameters[Hybrid Electricity Source,Electricity Timeslice,Hour,ptype]\
		=
	1 ~~|
Battery Charge Parameters[Hybrid Electricity Source,Electricity Timeslice,Hour,ppriority\
		]=
	-Last Year Five Year Average Marginal Dispatch Cost by Hour[Electricity Timeslice,Hour\
		]
	* Dollar per MWhr Tolerance Unit Correction Factor ~~|
Battery Charge Parameters[Hybrid Electricity Source,Electricity Timeslice,Hour,pwidth\
		]=
	1 ~~|
Battery Charge Parameters[Hybrid Electricity Source,Electricity Timeslice,Hour,pextra\
		]=
	0
	~	Dmnl
	~		|

Battery Charging Allocation[Hybrid Electricity Source,Electricity Timeslice,Hour]=
	ALLOCATE AVAILABLE(
	  Hourly Share of Battery Capacity That Can be Charged[Hybrid Electricity Source,Electricity Timeslice\
		,Hour],
	  Battery Charge Parameters[Hybrid Electricity Source,Electricity Timeslice,Hour,ptype\
		],
	  Daily Hours of Charged or Discharged Generation[Hybrid Electricity Source,Electricity Timeslice\
		]/One Hour)
	~	Dmnl
	~		|

Battery Discharge Parameters[Hybrid Electricity Source,Electricity Timeslice,Hour,ptype\
		]=
	1 ~~|
Battery Discharge Parameters[Hybrid Electricity Source,Electricity Timeslice,Hour,ppriority\
		]=
	Last Year Five Year Average Marginal Dispatch Cost by Hour[Electricity Timeslice,Hour\
		]
	* Dollar per MWhr Tolerance Unit Correction Factor ~~|
Battery Discharge Parameters[Hybrid Electricity Source,Electricity Timeslice,Hour,pwidth\
		]=
	1 ~~|
Battery Discharge Parameters[Hybrid Electricity Source,Electricity Timeslice,Hour,pextra\
		]=
	0
	~	Dmnl
	~		|

Battery Discharging Allocation[Hybrid Electricity Source,Electricity Timeslice,Hour]=
	ALLOCATE AVAILABLE(
	  Hourly Share of Capacity that Can be Discharged[Hybrid Electricity Source,Electricity Timeslice\
		,Hour],
	  Battery Discharge Parameters[Hybrid Electricity Source,Electricity Timeslice,Hour,\
		ptype],
	  Daily Hours of Charged or Discharged Generation[Hybrid Electricity Source,Electricity Timeslice\
		]/One Hour)
	~	Dmnl
	~		|

Battery Energy Balance of System Cost per Unit Capacity=
	First Year Battery Energy Cost per Unit Capacity
	* BCpUC Battery Balance of System Cost as Share of First Year Cost
	~	$/(MW*hr)
	~		|

Battery Energy Cost per Unit Capacity=
	IF THEN ELSE(
	   BCpUC Battery Energy Cost per Unit Capacity > 0,
	
	   BCpUC Battery Energy Cost per Unit Capacity,
	
	  IF THEN ELSE(
	    Battery Energy Cost per Unit Capacity with One Year Delay > 0,
	      (Battery Energy Cost per Unit Capacity with One Year Delay
	       - Battery Energy Balance of System Cost per Unit Capacity)
	      * This Year Battery Cost as Fraction of Last Year Battery Cost
	      + Battery Energy Balance of System Cost per Unit Capacity,
	
	      (Last Year Battery Energy Cost per Unit Capacity
	       - Battery Energy Balance of System Cost per Unit Capacity)
	      * This Year Battery Cost as Fraction of Last Year Battery Cost
	      + Battery Energy Balance of System Cost per Unit Capacity
	   )
	)
	~	$/(MW*hr)
	~	Only the cost of the battery itself, not the balance of system, is \
		affected by endogenous learning.
	|

Battery Energy Cost per Unit Capacity with One Year Delay= DELAY FIXED (
	BCpUC Battery Energy Cost per Unit Capacity,
	1,
	First Year Battery Energy Cost per Unit Capacity)
	~	$/(MW*hour)
	~		|

Battery Power Balance of System Cost per Unit Capacity=
	First Year Battery Power Cost per Unit Capacity
	* BCpUC Battery Balance of System Cost as Share of First Year Cost
	~	$/MW
	~		|

Battery Power Cost per Unit Capacity=
	IF THEN ELSE(
	   BCpUC Battery Power Cost per Unit Capacity > 0,
	
	   BCpUC Battery Power Cost per Unit Capacity,
	
	  IF THEN ELSE(
	    Battery Power Cost per Unit Capacity with One Year Delay > 0,
	      (Battery Power Cost per Unit Capacity with One Year Delay
	       - Battery Power Balance of System Cost per Unit Capacity)
	      * This Year Battery Cost as Fraction of Last Year Battery Cost
	      + Battery Power Balance of System Cost per Unit Capacity,
	
	      (Last Year Battery Power Cost per Unit Capacity
	       - Battery Power Balance of System Cost per Unit Capacity)
	      * This Year Battery Cost as Fraction of Last Year Battery Cost
	      + Battery Power Balance of System Cost per Unit Capacity
	   )
	)
	~	$/MW
	~		|

Battery Power Cost per Unit Capacity with One Year Delay=
	DELAY FIXED(
	BCpUC Battery Power Cost per Unit Capacity,
	1,
	First Year Battery Power Cost per Unit Capacity
	)
	~	$/MW
	~		|

Battery Storage Capacity Outside Modeled Region Affecting Learning=
	MAX(
	  0,
	
	  (BGBSC BAU Global Battery Storage Capacity
	    - BAU Cumulative Battery Capacity Deployed)
	  * FoTOMRAEL Fraction of Technology Outside Modeled Region Affecting Endogenous Learning
	)
	~	MW*hr
	~		|

Battery Storage Usage Factor Discount in Binding Peak Hour=
	SUM(
	  Binding Peak Hour for Reliability Additions[peak day electricity timeslice!,Hour!]
	  * UFDfGBS Usage Factor Discount for Grid Battery Storage[peak day electricity timeslice\
		!]
	)
	~	Dmnl
	~		|

BAU Absolute Change in In Scope Emissions due to Electricity Imports[Pollutant,Electricity Source\
		]=
	IF THEN ELSE(
	  BIEfIE Boolean Include Emissions from Imported Electricity > 0,
	
	  BAU Pollutant Emissions from Imported Electricity[Pollutant,Electricity Source],
	
	  0
	)
	~	g pollutant
	~		|

BAU Achieved Capacity Factors[Electricity Source]=
	MAX(0,
	 SUM(BAU Achieved Capacity Factors by Hour[Electricity Timeslice!,Hour!,Electricity Source\
		]
	     * SHELF Days per Electricity Timeslice[Electricity Timeslice!]
	     * One Hour)
	 /Hours per Year
	)
	~	Dmnl
	~		|

BAU Achieved Capacity Factors by Hour[Electricity Timeslice,Hour,Electricity Source]=
	ZIDZ(BAU Total Electricity Dispatched by Hour by Plant Type[Electricity Timeslice,Hour\
		,Electricity Source],
	     BAU Electricity Generation Capacity[Electricity Source]*One Hour* (1 - BAU Share of Electricity Generation Capacity Built This Year\
		[Electricity Source] * TACFMfPBTY Time Adjusted Capacity Factor Multiplier for Plants Built This Year
	[Electricity Source]))
	~	Dmnl
	~		|

BAU Achieved LCFS Percentage=
	ZIDZ(
	  SUM(BAU Carbon Free Energy after LCFS[Vehicle Type!,Cargo Type!,Vehicle Technology\
		!,Transportation Fuel!]),
	
	  SUM(BAU Fuel that would be Used by Regulated Vehicle Types in Absence of LCFS with Elec Eff Adj\
		[Vehicle Type!,Cargo Type!,Vehicle Technology!,Transportation Fuel!])
	)
	~	Dmnl
	~		~	:SUPPLEMENTARY 
	|

BAU Achieved LCFS Percentage before Fuel Shifts=
	ZIDZ(
	  SUM(BAU Carbon Free Energy in Absence of LCFS by Vehicle Type[Vehicle Type!,Cargo Type\
		!,Vehicle Technology!,Transportation Fuel!]),
	
	  SUM(BAU Fuel that would be Used by Regulated Vehicle Types in Absence of LCFS with Elec Eff Adj\
		[Vehicle Type!,Cargo Type!,Vehicle Technology!,Transportation Fuel!])
	)
	~	Dmnl
	~		~	:SUPPLEMENTARY 
	|

BAU Actual Elec Portfolio Std Qualifying Electricity Generation[Clean Elec Requirement\
		]=
	SUM(
	  BAU Electricity Generation by Type[Electricity Source!]
	  * Elec Portfolio Qualifying Sources[Electricity Source!,Clean Elec Requirement]
	)
	~	MW*hour
	~		~	:SUPPLEMENTARY 
	|

BAU Actual Total Electricity Demand=
	SUM(
	  BAU Total Electricity Demand by Hour After Demand Altering Technologies[Electricity Timeslice
	!,Hour!]
	  * SHELF Days per Electricity Timeslice[Electricity Timeslice!]
	)
	~	MW*hour
	~		~	:SUPPLEMENTARY 
	|

BAU Actual Total Electricity Generation=
	SUM(BAU Electricity Generation by Type[Electricity Source!])
	~	MW*hour
	~		~	:SUPPLEMENTARY 
	|

BAU Additional Carbon Free Energy Allocated by Fuel and Technology[Vehicle Type,Cargo Type\
		,Vehicle Technology,Transportation Fuel] :EXCEPT: [Vehicle Type,Cargo Type,gasoline vehicle\
		,biofuel gasoline tf],[Vehicle Type,Cargo Type,diesel vehicle,biofuel diesel tf],[Vehicle Type\
		,Cargo Type,plugin hybrid vehicle,electricity tf]=
	0 ~~|
BAU Additional Carbon Free Energy Allocated by Fuel and Technology[Vehicle Type,Cargo Type\
		,gasoline vehicle,biofuel gasoline tf]=
	BAU Required Increase in Carbon Free Energy Assigned to Vehicle and Fuel Types[Vehicle Type\
		,Cargo Type,biofuel gasoline tf] ~~|
BAU Additional Carbon Free Energy Allocated by Fuel and Technology[Vehicle Type,Cargo Type\
		,diesel vehicle,biofuel diesel tf]=
	BAU Required Increase in Carbon Free Energy Assigned to Vehicle and Fuel Types[Vehicle Type\
		,Cargo Type,biofuel diesel tf] ~~|
BAU Additional Carbon Free Energy Allocated by Fuel and Technology[Vehicle Type,Cargo Type\
		,plugin hybrid vehicle,electricity tf]=
	BAU Required Increase in Carbon Free Energy Assigned to Vehicle and Fuel Types[Vehicle Type\
		,Cargo Type,electricity tf]
	~	BTU
	~	See the note in the variable "Carbon Free Energy that Can be Provided by \
		Fuel" for an explanation of why we assign all biofuels to the "gasoline \
		vehicle" and "petroleum vehicle" technologies (rather than giving a share \
		to the "plugin hybrid vehicle" technology).
	|

BAU Additional Fuel Use by Fuel and Technology due to LCFS with Elec Eff Adj[Vehicle Type\
		,Cargo Type,Vehicle Technology,
Transportation Fuel]=
	ZIDZ(
	  BAU Additional Carbon Free Energy Allocated by Fuel and Technology[Vehicle Type,Cargo Type\
		,Vehicle Technology,Transportation Fuel
	],
	  (1 - Carbon Intensity Ratios by Transportation Fuel[Transportation Fuel])
	)
	~	BTU
	~		|

BAU Aggregate Decrease in Demand by Timeslice for Seasonal Net Peak Load Reduction[Electricity Timeslice\
		]=
	SUM(BAU Aggregate Increase in Demand by Timeslice for Seasonal Net Peak Load Reduction\
		[Electricity Timeslice!])
	* BAU Weighted Average Round Trip Efficiency for Seasonal Shifting
	* ZIDZ(
	    BAU Aggregate Shortfall in Potential Output from Surviving Capacity vs Average[Electricity Timeslice\
		],
	    SUM(BAU Aggregate Shortfall in Potential Output from Surviving Capacity vs Average\
		[Electricity Timeslice!])
	  )
	~	MW*hr
	~		|

BAU Aggregate Excess Potential Output from Surviving Capacity vs Average[Electricity Timeslice\
		]=
	SUM(BAU Excess Potenial Output from Surviving Capacity vs Annual Average by Hour[Electricity Timeslice\
		,Hour!])
	* SHELF Days per Electricity Timeslice[Electricity Timeslice]
	~	MW*hr
	~		|

BAU Aggregate Increase in Demand by Timeslice for Seasonal Net Peak Load Reduction[Electricity Timeslice\
		]=
	MIN(
	  BAU Maximum Annual Quantity of Electricity Absorbed for Seasonal Net Peak Load Reduction
	  * ZIDZ(
	      BAU Aggregate Excess Potential Output from Surviving Capacity vs Average[Electricity Timeslice\
		],
	      SUM(BAU Aggregate Excess Potential Output from Surviving Capacity vs Average[Electricity Timeslice\
		!])
	    ),
	
	  BAU Aggregate Excess Potential Output from Surviving Capacity vs Average[Electricity Timeslice\
		]
	)
	~	MW*hr
	~		|

BAU Aggregate Shortfall in Potential Output from Surviving Capacity vs Average[Electricity Timeslice\
		]=
	SUM(BAU Shortfall in Potenial Output from Surviving Capacity vs Annual Average by Hour\
		[Electricity Timeslice,Hour!])
	* SHELF Days per Electricity Timeslice[Electricity Timeslice]
	~	MW*hr
	~		|

BAU Amortized Decommissioning Costs=
	DEPRECIATE STRAIGHTLINE(BAU Decommissioning Costs, Payment Period for Decommissioning Costs\
		, 1, 0)
	~	$
	~		|

BAU Amount of CO2 Sequestered by Electricity Sector[Electricity Source]=
	BAU This Year Pollutants Sequestered by Electricity Sector[CO2,Electricity Source]
	/ Grams per Metric Ton CO2e
	* GWP by Pollutant[CO2] {necessary for unit correction}
	~	metric tons CO2e
	~		|

BAU Amount of CO2 Sequestered by Hydrogen Sector=
	BAU This Year Pollutants Sequestered by Hydrogen Sector[CO2]
	/ Grams per Metric Ton CO2e
	* GWP by Pollutant[CO2] {necessary for unit correction}
	~	metric tons CO2e
	~		|

BAU Amount of CO2 Sequestered by Industry Sector[Industry Category]=
	SUM(BAU This Year Pollutants Sequestered by Industry Sector[Industry Category,CO2,Emissions Type\
		!])
	/ Grams per Metric Ton CO2e
	* GWP by Pollutant[CO2] {necessary for unit correction}
	~	metric ton CO2e
	~		|

BAU Amount Received from Exporting Electricity=
	SUM(
	  BAU Electricity Exports by Hour[Electricity Timeslice!,Hour!,last pass!]
	  * SHELF Days per Electricity Timeslice[Electricity Timeslice!]
	  * BAU Marginal Dispatch Cost by Hour[Electricity Timeslice!,Hour!]
	)
	~	$
	~		|

BAU Amount Spent on Buildings Fuels[Building Type,Building Fuel]=
	BAU Building Components Energy Use Excluding Zero Cost Distributed Fuel Use[Building Type\
		,Building Fuel]
	* BAU Buildings Fuel Cost per Unit Energy[Building Fuel,Building Type]
	~	$
	~		|

BAU Amount Spent on Buildings Fuels Mapped to All Fuels Subscript[All Fuels] :EXCEPT:\
		 [building fuel within all fuels]=
	0 ~~|
BAU Amount Spent on Buildings Fuels Mapped to All Fuels Subscript[building fuel within all fuels\
		]=
	SUM(BAU Amount Spent on Buildings Fuels[Building Type!,Building Fuel])
	~	$
	~		|

BAU Amount Spent on Distributed Solar Capacity[Building Type]=
	BAU This Year Increase in Distributed Electricity Source Capacity[Building Type,solar PV es\
		]
	* BAU Cost per Unit Distributed Solar Capacity
	~	$
	~		|

BAU Amount Spent on District Heating Fuels[Industrial Fuel]=
	BAU Fuel Used to Generate Heat[Industrial Fuel]
	* BAU District Heat Fuel Cost per Unit Energy[Industrial Fuel]
	~	$
	~		|

BAU Amount Spent on District Heating Fuels Mapped to All Fuels Subscript[All Fuels] :EXCEPT:\
		 [industrial fuel within all fuels]=
	0 ~~|
BAU Amount Spent on District Heating Fuels Mapped to All Fuels Subscript[industrial fuel within all fuels\
		] :EXCEPT: [hydrogen]=
	BAU Amount Spent on District Heating Fuels[Industrial Fuel] ~~|
BAU Amount Spent on District Heating Fuels Mapped to All Fuels Subscript[hydrogen]=
	BAU Amount Spent on District Heating Fuels[hydrogen if]
	+ BAU Amount Spent on District Heating Fuels[green hydrogen if]
	+ BAU Amount Spent on District Heating Fuels[low carbon hydrogen if]
	~	$
	~		|

BAU Amount Spent on Electricity Fuels[Electricity Source]=
	BAU Electricity Fuel Use[Electricity Source]
	* BAU Electricity Fuel Cost per Unit Energy[Electricity Source]
	~	$
	~		|

BAU Amount Spent on Electricity Fuels Mapped to All Fuels Subscript[All Fuels] :EXCEPT:\
		 [electricity source within all fuels]=
	0 ~~|
BAU Amount Spent on Electricity Fuels Mapped to All Fuels Subscript[electricity source within all fuels\
		] :EXCEPT:   [solar],[wind],[natural gas],[hard coal],[biomass],[lignite],[nuclear]\
		,[hydrogen]=
	BAU Amount Spent on Electricity Fuels[Electricity Source] ~~|
BAU Amount Spent on Electricity Fuels Mapped to All Fuels Subscript[solar]=
	BAU Amount Spent on Electricity Fuels[solar PV es]
	+ BAU Amount Spent on Electricity Fuels[solar thermal es] ~~|
BAU Amount Spent on Electricity Fuels Mapped to All Fuels Subscript[wind]=
	BAU Amount Spent on Electricity Fuels[onshore wind es]
	+ BAU Amount Spent on Electricity Fuels[offshore wind es] ~~|
BAU Amount Spent on Electricity Fuels Mapped to All Fuels Subscript[natural gas]=
	BAU Amount Spent on Electricity Fuels[natural gas steam turbine es]
	+ BAU Amount Spent on Electricity Fuels[natural gas combined cycle es]
	+ BAU Amount Spent on Electricity Fuels[natural gas peaker es]
	+ BAU Amount Spent on Electricity Fuels[natural gas combined cycle w CCS es] ~~|
BAU Amount Spent on Electricity Fuels Mapped to All Fuels Subscript[hard coal]=
	BAU Amount Spent on Electricity Fuels[hard coal es]
	+ BAU Amount Spent on Electricity Fuels[hard coal w CCS es] ~~|
BAU Amount Spent on Electricity Fuels Mapped to All Fuels Subscript[biomass]=
	BAU Amount Spent on Electricity Fuels[biomass es]
	+ BAU Amount Spent on Electricity Fuels[biomass w CCS es] ~~|
BAU Amount Spent on Electricity Fuels Mapped to All Fuels Subscript[lignite]=
	BAU Amount Spent on Electricity Fuels[lignite es]
	+ BAU Amount Spent on Electricity Fuels[lignite w CCS es] ~~|
BAU Amount Spent on Electricity Fuels Mapped to All Fuels Subscript[nuclear]=
	BAU Amount Spent on Electricity Fuels[nuclear es]
	+ BAU Amount Spent on Electricity Fuels[small modular reactor es] ~~|
BAU Amount Spent on Electricity Fuels Mapped to All Fuels Subscript[hydrogen]=
	BAU Amount Spent on Electricity Fuels[hydrogen combustion turbine es]
	+ BAU Amount Spent on Electricity Fuels[hydrogen combined cycle es]
	~	$
	~		|

BAU Amount Spent on Geoengineering Fuels[Industrial Fuel]=
	QUANTUM(
	  BAU Geoengineering Sector Energy Use[Industrial Fuel]
	  * BAU Geoengineering Fuel Cost per Unit Energy[Industrial Fuel],
	
	  QSfCF Quantization Size for Cash Flows
	)
	~	$
	~		|

BAU Amount Spent on Grid Batteries=
	(BAU New Grid Battery Capacity+BPMGBSA BAU Policy Mandated Grid Battery Storage Additions\
		)
	* BAU Total Battery Cost per Unit Capacity
	~	$
	~		|

BAU Amount Spent on Hydrogen Production Capital Eqpt[Hydrogen Production Pathway]=
	MAX(
	  0,
	
	  BAU This Year Change in Hydrogen Produced by Pathway[Hydrogen Production Pathway]
	  * HPEC Hydrogen Production Equipment CapEx[Hydrogen Production Pathway]
	  * (1 + HPPECbP Hydrogen Production Percent Excess Capacity by Pathway[Hydrogen Production Pathway\
		])
	)
	~	$
	~		|

BAU Amount Spent on Hydrogen Production OpEx[Hydrogen Production Pathway]=
	BAU Hydrogen Production by Pathway[Hydrogen Production Pathway]
	* HPEC Hydrogen Production Equipment OpEx[Hydrogen Production Pathway]
	* (1 + HPPECbP Hydrogen Production Percent Excess Capacity by Pathway[Hydrogen Production Pathway\
		])
	~	$
	~		|

BAU Amount Spent on Hydrogen Sector Fuels[Industrial Fuel]=
	BAU Hydrogen Sector Fuel Use[Industrial Fuel]
	* BAU Hydrogen Fuel Cost per Unit Energy[Industrial Fuel]
	~	$
	~		|

BAU Amount Spent on Hydrogen Sector Fuels Mapped to All Fuels Subscript[All Fuels] :EXCEPT:\
		 [industrial fuel within all fuels]=
	0 ~~|
BAU Amount Spent on Hydrogen Sector Fuels Mapped to All Fuels Subscript[industrial fuel within all fuels\
		] :EXCEPT: [hydrogen]=
	BAU Amount Spent on Hydrogen Sector Fuels[Industrial Fuel] ~~|
BAU Amount Spent on Hydrogen Sector Fuels Mapped to All Fuels Subscript[hydrogen]=
	BAU Amount Spent on Hydrogen Sector Fuels[hydrogen if]
	+ BAU Amount Spent on Hydrogen Sector Fuels[green hydrogen if]
	+ BAU Amount Spent on Hydrogen Sector Fuels[low carbon hydrogen if]
	~	$
	~		|

BAU Amount Spent on Importing Electricity=
	BAU Imported Electricity
	* EIaE Imported Electricity Price
	~	$
	~		|

BAU Amount Spent on Industry Fuels[Industry Category,Industrial Fuel]=
	BAU Industrial Fuel Use for Energy Purposes[Industry Category,Industrial Fuel]
	  * BAU Industrial Fuel Cost per Unit Energy[Industry Category,Industrial Fuel]
	  * (1 - SoFCTiBoSFbI Share of Fuel Consumption That is Byproduct or Secondary Fuels by Industry\
		[Industry Category,Industrial Fuel])
	
	+ BAU Industrial Feedstock Use after Adjustments[Industry Category,Industrial Fuel]
	  * (
	      BAU Industrial Fuel Cost per Unit Energy[Industry Category,Industrial Fuel]
	      - BAU Industrial Fuel Carbon Tax Amount per Unit Energy[Industry Category,Industrial Fuel\
		]
	    )
	~	$
	~		|

BAU Amount Spent on Industry Fuels Mapped to All Fuels Subscript[All Fuels] :EXCEPT: \
		[industrial fuel within all fuels]=
	0 ~~|
BAU Amount Spent on Industry Fuels Mapped to All Fuels Subscript[industrial fuel within all fuels\
		] :EXCEPT: [hydrogen]=
	SUM(BAU Amount Spent on Industry Fuels[Industry Category!,Industrial Fuel]) ~~|
BAU Amount Spent on Industry Fuels Mapped to All Fuels Subscript[hydrogen]=
	SUM(BAU Amount Spent on Industry Fuels[Industry Category!,hydrogen if])
	+ SUM(BAU Amount Spent on Industry Fuels[Industry Category!,green hydrogen if])
	+ SUM(BAU Amount Spent on Industry Fuels[Industry Category!,low carbon hydrogen if])
	~	$
	~		|

BAU Amount Spent on Parking[Vehicle Type,Cargo Type,Vehicle Technology]=
	BAU Vehicles[Vehicle Type,Cargo Type,Vehicle Technology]
	* AVPC Annual Vehicle Parking Cost[Vehicle Type,Cargo Type]
	~	$
	~		|

BAU Amount Spent on Transportation Fuels[Transportation Fuel,Vehicle Type,Cargo Type,\
		Vehicle Technology]=
	BAU Transportation Sector Fuel Used[Vehicle Type,Cargo Type,Vehicle Technology,Transportation Fuel\
		]
	* BAU Transportation Fuel Cost per Unit Energy[Transportation Fuel]
	~	$
	~		|

BAU Amount Spent on Transportation Fuels Mapped to All Fuels Subscript[All Fuels] :EXCEPT:\
		 [transportation fuel within all fuels]=
	0 ~~|
BAU Amount Spent on Transportation Fuels Mapped to All Fuels Subscript[transportation fuel within all fuels\
		]=
	SUM(BAU Amount Spent on Transportation Fuels[Transportation Fuel,Vehicle Type!,Cargo Type\
		!,Vehicle Technology!])
	~	$
	~		|

BAU Amount Spent on Vehicle Batteries[Vehicle Type,Cargo Type,Vehicle Technology]=
	BAU New Vehicles[Vehicle Type,Cargo Type,Vehicle Technology] * One Year
	* This Year Battery Capacity by Vehicle Type[Cargo Type,Vehicle Type,Vehicle Technology\
		]
	* BAU This Year Battery Manufacturing Price Before Subsidies
	~	$
	~		|

BAU Amount Spent on Vehicle Insurance[Vehicle Type,Cargo Type,Vehicle Technology]=
	BAU Vehicles[Vehicle Type,Cargo Type,Vehicle Technology]
	* AVIC Annual Vehicle Insurance Cost[Vehicle Type,Cargo Type]
	~	$
	~		|

BAU Amount Spent on Vehicle Licensing Registration and Property Tax[Vehicle Type,Cargo Type\
		,Vehicle Technology]=
	BAU Vehicles[Vehicle Type,Cargo Type,Vehicle Technology]
	* AVLRaPTC Annual Vehicle Licensing Registration and Property Tax Costs[Vehicle Type\
		,Cargo Type]
	~	$
	~		|

BAU Amount Spent on Vehicle Maintenance[Vehicle Type,Cargo Type,Vehicle Technology]=
	BAU Vehicles[Vehicle Type,Cargo Type,Vehicle Technology]
	* AVMC Annual Vehicle Maintenance Cost[Vehicle Type,Cargo Type,Vehicle Technology]
	~	$
	~		|

BAU Amount Spent on Vehicle Manufacturing Excluding Batteries[Vehicle Type,Cargo Type\
		,Vehicle Technology]=
	BAU New Vehicles[Vehicle Type,Cargo Type,Vehicle Technology]
	* One Year
	* (BAU New Vehicle Price Without Subsidies[Vehicle Type,Cargo Type,Vehicle Technology\
		]
	  / RPEF Retail Price Equivalent Factor[Cargo Type,Vehicle Type]
	  )
	- BAU Amount Spent on Vehicle Batteries[Vehicle Type,Cargo Type,Vehicle Technology]
	~	$
	~		|

BAU Amount Spent on Vehicle Markups[Vehicle Type,Cargo Type,Vehicle Technology]=
	BAU New Vehicles[Vehicle Type,Cargo Type,Vehicle Technology]
	* One Year
	* BAU New Vehicle Price Without Subsidies[Vehicle Type,Cargo Type,Vehicle Technology\
		]
	* (1 - 1 / RPEF Retail Price Equivalent Factor[Cargo Type,Vehicle Type])
	~	$
	~		|

BAU Annual Average Hourly Spare Potential Output from Surviving Capacity=
	ZIDZ(
	  SUM(
	    BAU Spare Potential Output from Surviving Capacity by Hour[Electricity Timeslice\
		!,Hour!]
	    * SHELF Days per Electricity Timeslice[Electricity Timeslice!]
	  ),
	
	  SUM(SHELF Days per Electricity Timeslice[Electricity Timeslice!])
	  * ELMCOUNT(Hour)
	)
	~	MW*hr
	~		|

BAU Annual Capacity Market Costs for Seasonal Dispatchable Reliability[Electricity Source\
		]=
	IF THEN ELSE(
	
	  BAU Elec Portfolio Percentage to Seek This Year[RPS]=1,
	
	  BAU Electricity Generation Capacity[Electricity Source]
	  * BAU Capacity Market Price for Seasonal Dispatchable Reliability Adjusted for Availability\
		[Electricity Source
	]
	  * Elec Portfolio Qualifying Sources[Electricity Source,RPS]
	  * Days per Year
	  * One Day,
	
	  IF THEN ELSE(
	
	    BAU Elec Portfolio Percentage to Seek This Year[CES]=1,
	
	    BAU Electricity Generation Capacity[Electricity Source]
	    * BAU Capacity Market Price for Seasonal Dispatchable Reliability Adjusted for Availability\
		[Electricity Source
	]
	    * Elec Portfolio Qualifying Sources[Electricity Source,CES]
	    * Days per Year
	    * One Day,
	
	    BAU Electricity Generation Capacity[Electricity Source]
	    * BAU Capacity Market Price for Seasonal Dispatchable Reliability Adjusted for Availability\
		[Electricity Source
	]
	    * Days per Year
	    * One Day
	   )
	)
	~	$
	~		|

BAU Annual Cost Recovery for Capacity Construction and Retrofits=
	QUANTUM(
	  BAU Annual Cost Recovery for New Capacity Construction and Retrofits
	  +Total Annual Cost Recovery for Historical Power Plant Construction Costs,
	
	  Quantization Size for Dollars
	)
	~	$
	~		|

BAU Annual Cost Recovery for New Capacity Construction and Retrofits=
	DEPRECIATE STRAIGHTLINE(
	
	  SUM((BAU Cost of Capacity Construction before Construction Subsidies[Electricity Source\
		!]
	 +  BAU Cost of Capacity Retrofitting before Construction Subsidies[Electricity Source\
		!]
	  - BAU Capacity Construction Subsidies Paid[Electricity Source!])
	
	  *BAU Capital Recovery Factor for Power Plants[Electricity Source!])
	
	  *RPfFESCC Repayment Period for Financed Electricity Sector Capital Costs
	
	   /One Year,
	 
	  RPfFESCC Repayment Period for Financed Electricity Sector Capital Costs,
	
	  1,
	
	  0)
	~	$
	~		|

BAU Annual Cost to Keep Generation Capacity Online Past Repayment Period=
	QUANTUM(
	  SUM(
	    BAU Capacity Market Price for Seasonal Dispatchable Reliability Adjusted for Availability\
		[Electricity Source!]
	    * BAU Generation Capacity Kept Online due to Predicted Capacity Payment[Electricity Source\
		!]
	    )
	  * Days per Year
	  * One Day,
	
	  Quantization Size for Dollars
	)
	~	$
	~		|

BAU Annual Decrease in Demand from Load Shifting Technologies=
	SUM(
	  (BAU Decrease in Demand by Hour for Diurnal Net Peak Load Reduction and RPS Compliance\
		[Electricity Timeslice!,Hour!]
	  + BAU Decrease in Demand by Hour for Seasonal Net Peak Load Reduction[Electricity Timeslice\
		!,Hour!]
	  )
	  *SHELF Days per Electricity Timeslice[Electricity Timeslice!]
	)
	~	MW*hour
	~		|

BAU Annual Decrease in Demand from Load Shifting Technologies Excluding Demand Response Programs\
		=
	BAU Annual Decrease in Demand from Load Shifting Technologies
	- SUM(BAU Maximum Daily Quantity of Electricity Reduced by Demand Response Programs[\
		Electricity Timeslice!]
	    * SHELF Days per Electricity Timeslice[Electricity Timeslice!]
	     )
	~	MW*hour
	~		|

BAU Annual Electricity Dispatched by Guaranteed Dispatch[Electricity Source]=
	SUM(BAU Electricity Dispatched by Guaranteed Dispatch by Hour[Electricity Source,Electricity Timeslice\
		!,Hour!]
	* SHELF Days per Electricity Timeslice[Electricity Timeslice!]
	)
	~	MW*hour
	~		|

BAU Annual Electricity Dispatched by Least Cost[Electricity Source]=
	SUM(BAU Electricity Dispatched by Least Cost by Hour[Electricity Timeslice!,Hour!,Electricity Source\
		]
	* SHELF Days per Electricity Timeslice[Electricity Timeslice!]
	)
	~	MW*hour
	~		|

BAU Annual Electricity Dispatched to Meet Elec Portfolio Stds[Electricity Source]=
	SUM(BAU Electricity Dispatched to Meet Elec Portfolio Stds[Electricity Timeslice!,Hour\
		!,Electricity Source]
	* SHELF Days per Electricity Timeslice[Electricity Timeslice!]
	)
	~	MW*hour
	~		|

BAU Annual Financing Repayment for Newly Purchased Industrial CCS Equipment[Industry Category\
		]=
	BAU CCS New Capital Eqpt Cost by Industry[Industry Category]
	* BAU Capital Recovery Factor for CCS by Industry Category[Industry Category]
	* SoICETAF Share of Industry Capital Expenditures That Are Financed[Industry Category\
		]
	~	$
	~		|

BAU Annual Financing Repayment for Newly Purchased Industrial Equipment[Industry Category\
		,Industrial Process]=
	SUM(
	  BAU Annuity Factor by Industry Fuel and Process[Industry Category,Industrial Fuel!\
		,Industrial Process]
	  * BAU Industrial Equipment Capital Cost per Unit Energy After Subsidy[Industry Category\
		,Industrial Fuel!,Industrial Process]
	  * BAU New Industrial Equipment Energy Use by Fuel Type and Process[Industry Category\
		,Industrial Fuel!,Industrial Process]
	)
	* SoICETAF Share of Industry Capital Expenditures That Are Financed[Industry Category\
		]
	~	$
	~		|

BAU Annual Financing Repayment per Unit Capacity[Electricity Source]=
	BAU Construction Cost per Unit Capacity after Construction Subsidies and Spur Line Construction\
		[Electricity Source]
	* BAU Capital Recovery Factor for Power Plants[Electricity Source]
	~	$/MW
	~		|

BAU Annual Financing Repayment per Unit Retrofitted Capacity[Electricity Source]=
	Capital Recovery Factor for Power Plants[Electricity Source]
	* CCaMC Power Plant CCS Retrofitting Costs[Electricity Source]
	~	$/MW
	~		|

BAU Annual Financing Repayment per Unit Storage Capacity for Hybrid Power Plants[Electricity Source\
		]=
	BAU Hybrid Battery Cost per Unit Power Plant Capacity after Construction Subsidies
	*BAU Capital Recovery Factor for Power Plants[Electricity Source]
	~	$/MW
	~		|

BAU Annual Financing Repayments for Hydrogen Production Eqpt Expiring This Year[Hydrogen Production Pathway\
		]= DELAY FIXED (
	BAU Annual Financing Repayments for Newly Purchased Hydrogen Production Eqpt[Hydrogen Production Pathway\
		],
	RPfFHSCC Repayment Period for Financed Hydrogen Sector Capital Costs,
	0)
	~	$/Year
	~		|

BAU Annual Financing Repayments for Newly Purchased Hydrogen Production Eqpt[Hydrogen Production Pathway\
		]=
	BAU Amount Spent on Hydrogen Production Capital Eqpt[Hydrogen Production Pathway]
	* Capital Recovery Factor for Hydrogen Producers
	/ One Year
	~	$/Year
	~		|

BAU Annual Fixed OM Cost per Unit Capacity for Plants Built This Year[Electricity Source\
		]=
	SUM(
	  CCaMC Annual Fixed OM Cost per Unit Capacity[Electricity Source,Modeled Vintage!]
	  * This Year Modeled Vintage Flag[Modeled Vintage!]
	)
	~	$/MW
	~		|

BAU Annual Fuel Expenditures for a Vehicle Sold This Year[Vehicle Type,Cargo Type,Vehicle Technology\
		]=
	BAU New Vehicle Fuel Cost per Unit Vehicle Distance[Vehicle Type,Cargo Type,Vehicle Technology\
		]
	* BAADTbVT BAU Average Annual Dist Traveled by Vehicle Type[Vehicle Type,Cargo Type]
	~	$/vehicle
	~		|

BAU Annual Industrial CCS Equipment Financing Repayments Expiring After Repayment Period\
		[Industry Category]= DELAY FIXED (
	BAU Annual Financing Repayment for Newly Purchased Industrial CCS Equipment[Industry Category\
		],
	RPfFISCC Repayment Period for Financed Industry Sector Capital Costs[other processes\
		],
	0)
	~	$
	~		|

BAU Annual Industrial Equipment Financing Repayments Expiring After Repayment Period[\
		Industry Category,Industrial Process]= DELAY FIXED (
	BAU Annual Financing Repayment for Newly Purchased Industrial Equipment[Industry Category\
		,Industrial Process],
	RPfFISCC Repayment Period for Financed Industry Sector Capital Costs[Industrial Process\
		],
	0)
	~	$
	~		|

BAU Annual Maximum Potential Electricity Output[Electricity Source]=
	SUM(BAU Annual Maximum Potential Electricity Output by Hour[Electricity Source,Electricity Timeslice\
		!,Hour!])
	~	MW*hr
	~		|

BAU Annual Maximum Potential Electricity Output by Hour[Electricity Source,Electricity Timeslice\
		,Hour]=
	BAU Potential Capacity by Hour[Electricity Source,Electricity Timeslice,Hour]
	* SHELF Days per Electricity Timeslice[Electricity Timeslice] * One Hour
	~	MW*hr
	~		|

BAU Annual Net Energy Market Revenue per MW by Power Plant Type[Electricity Source]=
	ZIDZ(SUM(BAU Hourly Net Energy Market Revenue from Total Electricity Dispatched by Power Plant Type\
		[Electricity Timeslice!,Hour!,Electricity Source]*SHELF Days per Electricity Timeslice\
		[Electricity Timeslice!]),BAU Electricity Generation Capacity[Electricity Source])
	~	$/MW
	~		|

BAU Annual Output from Distributed Electricity Capacity[Electricity Source]=
	SUM(BAU Hourly Output from Distributed Electricity Capacity by Building Type[Electricity Source\
		,Electricity Timeslice!,Hour!,Building Type!]*SHELF Days per Electricity Timeslice[\
		Electricity Timeslice!])
	~	MW*hr
	~		|

BAU Annual Output from Distributed Electricity Capacity by Building Type[Electricity Source\
		,Building Type]=
	BAU Annual Output from Distributed Electricity Capacity[Electricity Source]
	* ZIDZ(
	    BDESC BAU Distributed Electricity Source Capacity[Building Type,Electricity Source\
		],
	    SUM(BDESC BAU Distributed Electricity Source Capacity[Building Type!,Electricity Source\
		])
	  )
	~	MW*hour
	~		|

BAU Annual Output from Diurnal Grid Batteries=
	BAU Annual Decrease in Demand from Load Shifting Technologies Excluding Demand Response Programs
	* BAU Share of Maximum Annual Decrease in Demand from Diurnal Grid Batteries
	~	MW*hour
	~		|

BAU Annual Repayment for Financed Buildings Sector Capital Expenses[Building Type]=
	(BAU Amount Spent on Distributed Solar Capacity[Building Type]
	- BAU Subsidy Paid on Distributed Solar Capacity[Building Type]
	)
	* Capital Recovery Factor for Buildings Sector Investments
	~	$
	~		|

BAU Annual Repayment for This Year Electricty Transmission Distribution and Storage Expenses\
		=
	(BAU Distribution Construction Costs
	  + BAU Transmission Construction Costs
	  +BAU Amount Spent on Grid Batteries
	  -BAU Subsidies Paid for New Grid Battery Construction
	  )
	* Capital Recovery Factor for Other Electricity Sector Investments
	~	$
	~		|

BAU Annualized Fixed Costs per Unit New Capacity[Electricity Source]=
	BAU Annual Fixed OM Cost per Unit Capacity for Plants Built This Year[Electricity Source\
		]
	+ BAU Annual Financing Repayment per Unit Capacity[Electricity Source]
	~	$/MW
	~		|

BAU Annualized Fixed Costs per Unit New Elec Output Using Expected Capacity Factors[Electricity Source\
		]=
	XIDZ(
	  BAU Annualized Fixed Costs per Unit New Capacity[Electricity Source],
	
	  BAU Expected Capacity Factor x Hours per Year for Plants Built This Year Without Hypothetical Calculations\
		[Electricity Source
	],
	
	  9999
	)
	~	$/(MW*hour)
	~		|

BAU Annuity Factor by Industry Fuel and Process[Industry Category,Industrial Fuel,Industrial Process\
		]=
	ZIDZ(
	  BCoISC Financing Interest Rate by Industry[Industry Category]
	  * (1 + BCoISC Financing Interest Rate by Industry[Industry Category])^(RPfFISCC Repayment Period for Financed Industry Sector Capital Costs
	[Industrial Process]
	 / One Year)
	,
	
	  (1 + BCoISC Financing Interest Rate by Industry[Industry Category])^(RPfFISCC Repayment Period for Financed Industry Sector Capital Costs
	[Industrial Process]
	 / One Year)
	  - 1
	)
	~	Dmnl
	~		|

BAU Anual Five Year Average Electricity Dispatched by Least Cost[Electricity Source]=
	SUM(BAU Five Year Average Electricity Dispatched by Least Cost by Hour[Electricity Timeslice\
		!,Hour!,Electricity Source]
	* SHELF Days per Electricity Timeslice[Electricity Timeslice!]
	)
	~	MW*hour
	~		|

BAU Available Capacity After Elec Portfolio Std Dispatch[Electricity Timeslice,Hour,Electricity Source\
		]=
	MAX(
	  0,
	
	  BAU Available Capacity After Guaranteed Dispatch[Electricity Timeslice,Hour,Electricity Source\
		]
	  - BAU Electricity Dispatched to Meet Elec Portfolio Stds[Electricity Timeslice,Hour\
		,Electricity Source]/One Hour
	)
	~	MW
	~		|

BAU Available Capacity After Guaranteed Dispatch[Electricity Timeslice,Hour,Electricity Source\
		]=
	MAX(
	  0,
	
	  BAU Available Capacity by Hour[Electricity Source,Electricity Timeslice,Hour]
	  - BAU Electricity Dispatched by Guaranteed Dispatch by Hour[Electricity Source,Electricity Timeslice\
		,Hour]/One Hour
	)
	~	MW
	~		|

BAU Available Capacity by Hour[Electricity Source,Electricity Timeslice,Hour]=
	BAU Electricity Generation Capacity[Electricity Source]
	* BAU Hourly Bid Electricity Capacity Factors by Plant Type[Electricity Source,Electricity Timeslice\
		,Hour]
	* (1 - BAU Share of Electricity Generation Capacity Built This Year[Electricity Source\
		] * TACFMfPBTY Time Adjusted Capacity Factor Multiplier for Plants Built This Year[\
		Electricity Source])
	~	MW
	~		|

BAU Available Capacity for Least Cost Dispatch Mapped[Electricity Timeslice,Hour,Electricity Source\
		]=
	BAU Available Capacity After Elec Portfolio Std Dispatch[Electricity Timeslice,Hour,\
		Electricity Source
	]
	* One Hour
	~	MW*hour
	~		|

BAU Average Five Year Prior Pretax Electricity Price by Sector[Sectors]=
	BAU Pretax Fuel Price by Sector[electricity,Sectors]
	~	
	~		|

BAU Average Four Year Prior Net Energy Market Revenue by Plant Type Excluding Subsidies for Hybrid Power Plants\
		[Hybrid Electricity Source]=
	IF THEN ELSE(
	 Time - INITIAL TIME <= 1,
	 BAU One Year Average Net Energy Market Revenue by Plant Type Excluding Subsidies for Hybrid Power Plants\
		[Hybrid Electricity Source
	],
	 
	 IF THEN ELSE(
	  Time - INITIAL TIME = 2,
	  BAU Two Year Average Net Energy Market Revenue by Plant Type Excluding Subsidies for Hybrid Power Plants\
		[Hybrid Electricity Source
	],
	
	  IF THEN ELSE(
	   Time - INITIAL TIME = 3,
	   BAU Three Year Average Net Energy Market Revenue by Plant Type Excluding Subsidies for Hybrid Power Plants\
		[Hybrid Electricity Source
	],
	   BAU Four Year Average Net Energy Market Revenue by Plant Type Excluding Subsidies for Hybrid Power Plants\
		[Hybrid Electricity Source
	]
	  )
	 )
	)
	
	+BAU Expected Capacity Factor x Hours per Year for Plants Built This Year[Hybrid Electricity Source\
		]*BAU Variable Subsidies per Unit New Electricity Output[Hybrid Electricity Source]
	~	$/MW
	~		|

BAU Average Four Year Prior Total Predicted Net Energy Market Revenue per MW[Electricity Source\
		]=
	IF THEN ELSE(
	 Time - INITIAL TIME <= 1,
	 BAU Last Year Total Five Year Average Net Energy Market Revenue per MW[Electricity Source\
		],
	
	 IF THEN ELSE(
	  Time - INITIAL TIME = 2,
	  BAU Two Year Average Total Predicted Net Energy Market Revenue per MW[Electricity Source\
		],
	
	  IF THEN ELSE(
	   Time - INITIAL TIME = 3,
	   BAU Three Year Average Total Predicted Net Energy Market Revenue per MW[Electricity Source\
		],
	
	   BAU Four Year Average Total Predicted Net Energy Market Revenue per MW[Electricity Source\
		]
	
	  )
	 )
	)
	
	+ (BAU Total Subsidies per Unit Electricity Output Adjusted for Lifetime[Electricity Source\
		]
	  + BAU Carbon Price Credit per MWh[Electricity Source])
	  * BAU Expected Capacity Factor x Hours per Year for Plants Built This Year[Electricity Source\
		]
	~	$/(MW*hr)
	~		|

BAU Average Three Year Prior Net Loss per Unit Output[Electricity Source,Optimization Pass\
		]=
	IF THEN ELSE(
	  BAU Net Loss per Unit Capacity[Electricity Source,Optimization Pass]>0
	  :AND:
	  BAU Last Year Net Loss per Unit Capacity[Electricity Source,Optimization Pass]>0
	  :AND:
	  BAU Two Years Prior Net Loss per Unit Capacity[Electricity Source,Optimization Pass\
		]>0,
	
	  (BAU Net Loss per Unit Capacity[Electricity Source,Optimization Pass]+BAU Last Year Net Loss per Unit Capacity\
		[Electricity Source,Optimization Pass]+BAU Two Years Prior Net Loss per Unit Capacity
	  [Electricity Source,Optimization Pass])/3,
	
	0
	
	)
	~	$/MW
	~		|

BAU Average Three Year Prior Net Loss per Unit Output Excluding Capacity Payment[Electricity Source\
		]=
	IF THEN ELSE(
	  BAU Net Loss per Unit Capacity Excluding Predicted Capacity Payment[Electricity Source\
		]>0
	  :AND:
	  BAU Last Year Net Loss per Unit Capacity Excluding Predicted Capacity Payment[Electricity Source\
		]>0
	  :AND:
	  BAU Two Years Prior Net Loss per Unit Capacity Excluding Capacity Payment[Electricity Source\
		]>0,
	
	  (BAU Net Loss per Unit Capacity Excluding Predicted Capacity Payment[Electricity Source\
		]+BAU Last Year Net Loss per Unit Capacity Excluding Predicted Capacity Payment[Electricity Source\
		]+BAU Two Years Prior Net Loss per Unit Capacity Excluding Capacity Payment[Electricity Source\
		])/3,
	
	  0
	
	)
	~	$/MW
	~		|

BAU Battery Charge Parameters[Hybrid Electricity Source,Electricity Timeslice,Hour,ptype\
		]=
	1 ~~|
BAU Battery Charge Parameters[Hybrid Electricity Source,Electricity Timeslice,Hour,ppriority\
		]=
	-BAU Last Year Five Year Average Marginal Dispatch Cost by Hour[Electricity Timeslice\
		,Hour]
	* Dollar per MWhr Tolerance Unit Correction Factor ~~|
BAU Battery Charge Parameters[Hybrid Electricity Source,Electricity Timeslice,Hour,pwidth\
		]=
	1 ~~|
BAU Battery Charge Parameters[Hybrid Electricity Source,Electricity Timeslice,Hour,pextra\
		]=
	0
	~	Dmnl
	~		|

BAU Battery Charging Allocation[Hybrid Electricity Source,Electricity Timeslice,Hour]\
		=
	ALLOCATE AVAILABLE(
	  BAU Hourly Share of Battery Capacity That Can be Charged[Hybrid Electricity Source\
		,Electricity Timeslice,Hour],
	  BAU Battery Charge Parameters[Hybrid Electricity Source,Electricity Timeslice,Hour\
		,ptype],
	  BAU Daily Hours of Charged or Discharged Generation[Hybrid Electricity Source,Electricity Timeslice\
		]/One Hour)
	~	Dmnl
	~		|

BAU Battery Discharge Parameters[Hybrid Electricity Source,Electricity Timeslice,Hour\
		,ptype]=
	1 ~~|
BAU Battery Discharge Parameters[Hybrid Electricity Source,Electricity Timeslice,Hour\
		,ppriority]=
	BAU Last Year Five Year Average Marginal Dispatch Cost by Hour[Electricity Timeslice\
		,Hour]
	* Dollar per MWhr Tolerance Unit Correction Factor ~~|
BAU Battery Discharge Parameters[Hybrid Electricity Source,Electricity Timeslice,Hour\
		,pwidth]=
	1 ~~|
BAU Battery Discharge Parameters[Hybrid Electricity Source,Electricity Timeslice,Hour\
		,pextra]=
	0
	~	Dmnl
	~		|

BAU Battery Discharging Allocation[Hybrid Electricity Source,Electricity Timeslice,Hour\
		]=
	ALLOCATE AVAILABLE(
	  BAU Hourly Share of Capacity that Can be Shifted[Hybrid Electricity Source,Electricity Timeslice\
		,Hour],
	  BAU Battery Discharge Parameters[Hybrid Electricity Source,Electricity Timeslice,Hour\
		,ptype],
	  BAU Daily Hours of Charged or Discharged Generation[Hybrid Electricity Source,Electricity Timeslice\
		]/One Hour)
	~	Dmnl
	~		|

BAU Battery Energy Cost per Unit Capacity=
	IF THEN ELSE(
	   BCpUC Battery Energy Cost per Unit Capacity > 0,
	
	   BCpUC Battery Energy Cost per Unit Capacity,
	
	  IF THEN ELSE(
	    Battery Energy Cost per Unit Capacity with One Year Delay > 0,
	      (Battery Energy Cost per Unit Capacity with One Year Delay
	       - Battery Energy Balance of System Cost per Unit Capacity)
	      * BAU This Year Battery Cost as Fraction of Last Year Battery Cost
	      + Battery Energy Balance of System Cost per Unit Capacity,
	
	      (BAU Last Year Battery Energy Cost per Unit Capacity
	       - Battery Energy Balance of System Cost per Unit Capacity)
	      * BAU This Year Battery Cost as Fraction of Last Year Battery Cost
	      + Battery Energy Balance of System Cost per Unit Capacity
	   )
	)
	~	$/(MW*hr)
	~	Only the cost of the battery itself, not the balance of system, is \
		affected by endogenous learning.
	|

BAU Battery Power Cost per Unit Capacity=
	IF THEN ELSE(
	   BCpUC Battery Power Cost per Unit Capacity > 0,
	
	   BCpUC Battery Power Cost per Unit Capacity,
	
	  IF THEN ELSE(
	    Battery Power Cost per Unit Capacity with One Year Delay > 0,
	      (Battery Power Cost per Unit Capacity with One Year Delay
	       - Battery Power Balance of System Cost per Unit Capacity)
	      * BAU This Year Battery Cost as Fraction of Last Year Battery Cost
	      + Battery Power Balance of System Cost per Unit Capacity,
	
	      (BAU Last Year Battery Power Cost per Unit Capacity
	       - Battery Power Balance of System Cost per Unit Capacity)
	      * BAU This Year Battery Cost as Fraction of Last Year Battery Cost
	      + Battery Power Balance of System Cost per Unit Capacity
	   )
	)
	~	$/MW
	~		|

BAU Battery Storage Usage Factor Discount in Binding Peak Hour=
	SUM(
	  BAU Binding Peak Hour for Reliability Additions[peak day electricity timeslice!,Hour\
		!]
	  * UFDfGBS Usage Factor Discount for Grid Battery Storage[peak day electricity timeslice\
		!]
	)
	~	Dmnl
	~		|

BAU Binding Peak Hour for Clean Dispatchable Reliability[peak day electricity timeslice\
		,Hour]=
	IF THEN ELSE(SUM(BAU Net Electricity Clean Firm Demand Relative to Available Clean Firm Supply by Hour before Additions\
		[Hour!,peak day electricity timeslice!])=0,0,
	
	IF THEN ELSE(BAU Net Electricity Clean Firm Demand Relative to Available Clean Firm Supply by Hour before Additions\
		[Hour,peak day electricity timeslice]=VMAX(BAU Net Electricity Clean Firm Demand Relative to Available Clean Firm Supply by Hour before Additions\
		[Hour!,peak day electricity timeslice!]),1,0)
	
	)
	~	Dmnl
	~		|

BAU Binding Peak Hour for Reliability Additions[peak day electricity timeslice,Hour]=
	IF THEN ELSE(BAU Net Electricity Demand Relative to Available Supply by Hour before Reliability Additions\
		[peak day electricity timeslice,Hour]<=0,0,
	
	IF THEN ELSE(BAU Net Electricity Demand Relative to Available Supply by Hour before Reliability Additions\
		[peak day electricity timeslice,Hour]=VMAX(BAU Net Electricity Demand Relative to Available Supply by Hour before Reliability Additions\
		[peak day electricity timeslice!,Hour!]),1,0)
	
	)
	~	Dmnl
	~		|

BAU Boolean Plant Types that May Not be Built due to Having Been Retired to Zero[Electricity Source\
		]=
	IF THEN ELSE(
	  BAU Start Year Electricity Generation Capacity Summed Across Vintages[Electricity Source\
		] > 0,
	
	  IF THEN ELSE(
	   BCRbQ BAU Capacity Retirements before Quantization[Electricity Source]
	    >= BAU Last Year Electricity Generation Capacity[Electricity Source],
	
	    1,
	
	    0
	  ),
	
	  0
	)
	~	Dmnl
	~		|

BAU BRAaCTSC BAU Range Anxiety Shadow Cost:INTERPOLATE::=
	GET DIRECT DATA(
	   'InputData/trans/BRASC/BRASC.csv',
	   ',',
	   '1',
	   'B2'
	)
	~	$/vehicle
	~		|

BAU Building Components Energy Use[Building Type,Building Fuel,Building Component] :EXCEPT:\
		  [commercial,Building Fuel,Building Component
]=
	(BAU Components Energy Use Before Correction Factor[Building Type,Building Fuel,Building Component\
		]
	  + BAU Correction for Difference in Input vs Calculated BAU Components Energy Use[Building Type\
		,Building Fuel,Building Component
])
	* (1 + Perc Change in Sectoral Energy Use due to Exogenous GDP Adjustment[residential buildings sector\
		]) ~~|
BAU Building Components Energy Use[commercial,Building Fuel,Building Component]=
	(BAU Components Energy Use Before Correction Factor[commercial,Building Fuel,Building Component\
		]
	  + BAU Correction for Difference in Input vs Calculated BAU Components Energy Use[commercial\
		,Building Fuel,Building Component
])
	* (1 + Perc Change in Sectoral Energy Use due to Exogenous GDP Adjustment[commercial buildings sector\
		])
	~	BTU
	~		|

BAU Building Components Energy Use Excluding Zero Cost Distributed Fuel Use[Building Type\
		,Building Fuel] :EXCEPT:     [Building Type,electricity bf]=
	SUM(BAU Building Components Energy Use[Building Type,Building Fuel,Building Component\
		!]) ~~|
BAU Building Components Energy Use Excluding Zero Cost Distributed Fuel Use[Building Type\
		,electricity bf]=
	SUM(BAU Building Components Energy Use[Building Type,electricity bf,Building Component\
		!])
	- SUM(BAU Annual Output from Distributed Electricity Capacity by Building Type[Clean Dispatchable Electricity Source\
		!,Building Type])/MWh per BTU
	~	BTU
	~		|

BAU Buildings Fuel Carbon Tax Amount per Unit Energy[Building Fuel,urban residential]\
		=
	BCTR BAU Carbon Tax Rate[residential buildings sector]
	/ Grams per Metric Ton CO2e
	* BAU Buildings Fuel Taxable CO2e Emissions Intensity[Building Fuel,urban residential\
		] ~~|
BAU Buildings Fuel Carbon Tax Amount per Unit Energy[Building Fuel,rural residential]\
		=
	BCTR BAU Carbon Tax Rate[residential buildings sector]
	/ Grams per Metric Ton CO2e
	* BAU Buildings Fuel Taxable CO2e Emissions Intensity[Building Fuel,rural residential\
		] ~~|
BAU Buildings Fuel Carbon Tax Amount per Unit Energy[Building Fuel,commercial]=
	BCTR BAU Carbon Tax Rate[commercial buildings sector]
	/ Grams per Metric Ton CO2e
	* BAU Buildings Fuel Taxable CO2e Emissions Intensity[Building Fuel,commercial]
	~	$/BTU
	~		|

BAU Buildings Fuel Cost per Unit Energy[Building Fuel,urban residential]=
	MAX(BAU Pretax Fuel Price by Sector Including Endogenous Electricity Prices[building fuel within all fuels\
		,residential buildings sector]
	  + BAU Buildings Fuel Total Tax or Subsidy Amount per Unit Energy[Building Fuel,urban residential\
		],
	0
	) ~~|
BAU Buildings Fuel Cost per Unit Energy[Building Fuel,rural residential]=
	MAX(BAU Pretax Fuel Price by Sector Including Endogenous Electricity Prices[building fuel within all fuels\
		,residential buildings sector]
	  + BAU Buildings Fuel Total Tax or Subsidy Amount per Unit Energy[Building Fuel,rural residential\
		],
	0
	) ~~|
BAU Buildings Fuel Cost per Unit Energy[Building Fuel,commercial]=
	MAX(BAU Pretax Fuel Price by Sector Including Endogenous Electricity Prices[building fuel within all fuels\
		,commercial buildings sector]
	  + BAU Buildings Fuel Total Tax or Subsidy Amount per Unit Energy[Building Fuel,commercial\
		],
	0
	)
	~	$/BTU
	~		|

BAU Buildings Fuel Other Tax or Subsidy Amount per Unit Energy[Building Fuel,urban residential\
		]=
	BAU Fuel Tax by Sector[building fuel within all fuels,residential buildings sector] ~~|
BAU Buildings Fuel Other Tax or Subsidy Amount per Unit Energy[Building Fuel,rural residential\
		]=
	BAU Fuel Tax by Sector[building fuel within all fuels,residential buildings sector] ~~|
BAU Buildings Fuel Other Tax or Subsidy Amount per Unit Energy[Building Fuel,commercial\
		]=
	BAU Fuel Tax by Sector[building fuel within all fuels,commercial buildings sector]
	~	$/BTU
	~		|

BAU Buildings Fuel Taxable CO2e Emissions Intensity[Building Fuel,Building Type]=
	SUM(
	  Buildings Fuel Pollutant Emissions Intensities This Year[Pollutant!,Building Fuel]
	  * GWP by Pollutant[Pollutant!]
	  * BPTbCP BAU Buildings Pollutants Taxed by Carbon Pricing[Building Type,Pollutant!\
		]
	)
	~	g CO2e/BTU
	~		|

BAU Buildings Fuel Total Tax or Subsidy Amount per Unit Energy[Building Fuel,Building Type\
		]=
	BAU Buildings Fuel Carbon Tax Amount per Unit Energy[Building Fuel,Building Type]
	+ BAU Buildings Fuel Other Tax or Subsidy Amount per Unit Energy[Building Fuel,Building Type\
		]
	~	$/BTU
	~		|

BAU Buildings Sector Carbon Tax Revenue=
	SUM(BAU Building Components Energy Use[Building Type!,Building Fuel!,Building Component\
		!]
	* BAU Buildings Fuel Carbon Tax Amount per Unit Energy[Building Fuel!,Building Type!\
		])
	~	$
	~		|

BAU Buildings Sector Electricity Demand[Building Type,Building Component]=
	BAU Building Components Energy Use[Building Type,electricity bf,Building Component]
	* MWh per BTU
	~	MW*hour
	~		|

BAU Buildings Sector Other Fuel Tax Revenue=
	SUM(BAU Building Components Energy Use[Building Type!,Building Fuel!,Building Component\
		!]
	* BAU Buildings Fuel Other Tax or Subsidy Amount per Unit Energy[Building Fuel!,Building Type\
		!])
	~	$
	~		|

BAU Buildings Sector Pollutant Emissions[Building Type,Pollutant]=
	SUM(BAU Direct Components Pollutant Emissions[Building Type,Building Fuel!,Pollutant\
		])
	+ Distributed Electricity Sources Buildings Pollutant Emissions[Building Type,Pollutant\
		]
	~	g pollutant
	~		|

BAU Buildings Sector Pollutant Emissions Summed Across Building Types[Pollutant]=
	SUM(BAU Buildings Sector Pollutant Emissions[Building Type!,Pollutant])
	~	g pollutant
	~	This variable is only used to populate a graph in Vensim.
	~	:SUPPLEMENTARY 
	|

BAU Capacity Construction Subsidies Paid[Electricity Source]=
	BAU New Generation Capacity[Electricity Source]
	* BAU Subsidy per Unit Electricity Capacity Built[Electricity Source]
	
	+ BAU New Hybrid Grid Battery Storage Capacity[Electricity Source]
	* BAU Subsidy per Unit Grid Battery Capacity Deployed
	~	$
	~		|

BAU Capacity Market Costs for Diurnal Storage=
	(SUM
	  (BAU Capacity Market Price for Seasonal Dispatchable Reliability by Optimization Pass\
		[last pass!]
	  )
	  * (1 - BAU Battery Storage Usage Factor Discount in Binding Peak Hour)
	  *BAU This Year Grid Battery Storage Capacity excluding Hybrid Batteries in MW
	)
	
	*ESTRTE Grid Battery Round Trip Efficiency
	*Days per Year
	* One Day
	~	$
	~		|

BAU Capacity Market Optimization Step Size for Seasonal Clean Dispatchable Reliability\
		[pass1]=
	BAU Capacity Market Price for Seasonal Clean Dispatchable Reliability by Optimization Pass\
		[pass1]
	/ 2 ~~|
BAU Capacity Market Optimization Step Size for Seasonal Clean Dispatchable Reliability\
		[current pass]=
	IF THEN ELSE(
	  BAU Capacity Market Steps in Same Direction for Seasonal Clean Dispatchable Reliability\
		[preceeding pass]
	  > Steps Allowed in Same Direction Without Increasing Step Size,
	
	  BAU Capacity Market Optimization Step Size for Seasonal Clean Dispatchable Reliability\
		[preceeding pass] * 1.5,
	
	  IF THEN ELSE(
	    BAU Capacity Market Steps in Same Direction for Seasonal Clean Dispatchable Reliability\
		[preceeding pass]
	    > Steps Allowed in Same Direction With Declining Step Size,
	
	    BAU Capacity Market Optimization Step Size for Seasonal Clean Dispatchable Reliability\
		[preceeding pass],
	
	    BAU Capacity Market Optimization Step Size for Seasonal Clean Dispatchable Reliability\
		[preceeding pass]
	    / 2
	  )
	)
	~	$/MW
	~		|

BAU Capacity Market Optimization Step Size for Seasonal Dispatchable Reliability[pass1\
		]=
	BAU Capacity Market Price for Seasonal Dispatchable Reliability by Optimization Pass\
		[pass1]
	/ 2 ~~|
BAU Capacity Market Optimization Step Size for Seasonal Dispatchable Reliability[current pass\
		]=
	IF THEN ELSE(
	  BAU Capacity Market Steps in Same Direction for Seasonal Dispatchable Reliability[\
		preceeding pass]
	  > Steps Allowed in Same Direction Without Increasing Step Size,
	
	  BAU Capacity Market Optimization Step Size for Seasonal Dispatchable Reliability[preceeding pass\
		] * 1.5,
	
	  IF THEN ELSE(
	    BAU Capacity Market Steps in Same Direction for Seasonal Dispatchable Reliability\
		[preceeding pass]
	    > Steps Allowed in Same Direction With Declining Step Size,
	
	    BAU Capacity Market Optimization Step Size for Seasonal Dispatchable Reliability\
		[preceeding pass],
	
	    BAU Capacity Market Optimization Step Size for Seasonal Dispatchable Reliability\
		[preceeding pass]
	    / 2
	  )
	)
	~	$/(MW*day)
	~		|

BAU Capacity Market Price for Seasonal Clean Dispatchable Reliability Adjusted for Availability\
		[Electricity Source] :EXCEPT:  [Clean Dispatchable Electricity Source]=
	0 ~~|
BAU Capacity Market Price for Seasonal Clean Dispatchable Reliability Adjusted for Availability\
		[Clean Dispatchable Electricity Source]=
	SUM(BAU Capacity Market Price for Seasonal Clean Dispatchable Reliability by Optimization Pass\
		[last pass!]*Days per Year*One Day*BAU Last Year Hourly Bid Electricity Capacity Factors for Clean Firm Reliability in Binding Hour by Plant Type
	[Clean Dispatchable Electricity Source])
	~	$/MW
	~		|

BAU Capacity Market Price for Seasonal Clean Dispatchable Reliability by Optimization Pass\
		[pass1]=
	IF THEN ELSE(
	
	  Time = INITIAL TIME, 
	  0, 
	  Initial Guess at Capacity Market Price
	 ) ~~|
BAU Capacity Market Price for Seasonal Clean Dispatchable Reliability by Optimization Pass\
		[current pass]=
	IF THEN ELSE(
	  BAU Capacity Market Price for Seasonal Clean Dispatchable Reliability by Optimization Pass\
		[preceeding pass] = 0,
	
	  0,
	
	  MAX(
	    IF THEN ELSE(
	      BAU Net Electricity Clean Firm Demand Relative to Available Clean Firm Supply by Hour by Optimization Pass for Seasonal Dispatchable Reliability under CES\
		[preceeding pass] > 0,
	  
	      BAU Capacity Market Price for Seasonal Clean Dispatchable Reliability by Optimization Pass\
		[preceeding pass]
	      + BAU Capacity Market Optimization Step Size for Seasonal Clean Dispatchable Reliability\
		[current pass],
	
	      BAU Capacity Market Price for Seasonal Clean Dispatchable Reliability by Optimization Pass\
		[preceeding pass]
	      - BAU Capacity Market Optimization Step Size for Seasonal Clean Dispatchable Reliability\
		[current pass]
	    ),
	
	    0
	  )
	)
	~	$/(MW*day)
	~		|

BAU Capacity Market Price for Seasonal Dispatchable Reliability Adjusted for Availability\
		[Electricity Source]=
	VMAX(BAU Capacity Market Price for Seasonal Dispatchable Reliability by Optimization Pass\
		[last pass!]*BAU Hourly Bid Electricity Capacity Factors by Plant Type
	[Electricity Source,peak day electricity timeslice!,Hour!])
	~	$/(MW*day)
	~		|

BAU Capacity Market Price for Seasonal Dispatchable Reliability by Optimization Pass[\
		pass1]=
	IF THEN ELSE(
	
	  Time = INITIAL TIME, 
	  0, 
	  Initial Guess at Capacity Market Price
	 ) ~~|
BAU Capacity Market Price for Seasonal Dispatchable Reliability by Optimization Pass[\
		current pass]=
	IF THEN ELSE(
	  BAU Capacity Market Price for Seasonal Dispatchable Reliability by Optimization Pass\
		[preceeding pass] = 0,
	
	  0,
	
	  MAX(
	    IF THEN ELSE(
	      BAU Net Electricity Demand Relative to Available Supply in Binding Hour by Optimization Pass\
		[preceeding pass] > 0,
	  
	      BAU Capacity Market Price for Seasonal Dispatchable Reliability by Optimization Pass\
		[preceeding pass]
	      + BAU Capacity Market Optimization Step Size for Seasonal Dispatchable Reliability\
		[current pass],
	
	      BAU Capacity Market Price for Seasonal Dispatchable Reliability by Optimization Pass\
		[preceeding pass]
	      - BAU Capacity Market Optimization Step Size for Seasonal Dispatchable Reliability\
		[current pass]
	    ),
	
	    0
	  )
	)
	~	$/(MW*day)
	~		|

BAU Capacity Market Steps in Negative Direction for Seasonal Clean Dispatchable Reliability\
		[pass1]=
	0 ~~|
BAU Capacity Market Steps in Negative Direction for Seasonal Clean Dispatchable Reliability\
		[current pass]=
	IF THEN ELSE(
	  BAU Net Electricity Clean Firm Demand Relative to Available Clean Firm Supply by Hour by Optimization Pass for Seasonal Dispatchable Reliability under CES\
		[preceeding pass]
	  <0,
	BAU Capacity Market Steps in Negative Direction for Seasonal Clean Dispatchable Reliability\
		[preceeding pass] + 1,
	
	  0
	)
	~	Dmnl
	~		|

BAU Capacity Market Steps in Negative Direction for Seasonal Dispatchable Reliability\
		[pass1]=
	0 ~~|
BAU Capacity Market Steps in Negative Direction for Seasonal Dispatchable Reliability\
		[current pass]=
	IF THEN ELSE(
	  BAU Net Electricity Demand Relative to Available Supply in Binding Hour by Optimization Pass\
		[preceeding pass]
	  <0,
	BAU Capacity Market Steps in Negative Direction for Seasonal Dispatchable Reliability\
		[preceeding pass
	] + 1,
	
	  0
	)
	~	Dmnl
	~		|

BAU Capacity Market Steps in Positive Direction for Seasonal Clean Dispatchable Reliability\
		[pass1]=
	0 ~~|
BAU Capacity Market Steps in Positive Direction for Seasonal Clean Dispatchable Reliability\
		[current pass]=
	IF THEN ELSE(
	  BAU Net Electricity Clean Firm Demand Relative to Available Clean Firm Supply by Hour by Optimization Pass for Seasonal Dispatchable Reliability under CES\
		[preceeding pass]
	  >=0,
	
	  BAU Capacity Market Steps in Positive Direction for Seasonal Clean Dispatchable Reliability\
		[preceeding pass] + 1,
	
	  0
	)
	~	Dmnl
	~		|

BAU Capacity Market Steps in Positive Direction for Seasonal Dispatchable Reliability\
		[pass1]=
	0 ~~|
BAU Capacity Market Steps in Positive Direction for Seasonal Dispatchable Reliability\
		[current pass]=
	IF THEN ELSE(
	BAU Net Electricity Demand Relative to Available Supply in Binding Hour by Optimization Pass\
		[preceeding pass]
	  >=0,
	
	  BAU Capacity Market Steps in Positive Direction for Seasonal Dispatchable Reliability\
		[preceeding pass] + 1,
	
	  0
	)
	~	Dmnl
	~		|

BAU Capacity Market Steps in Same Direction for Seasonal Clean Dispatchable Reliability\
		[Optimization Pass]=
	MAX(
	  BAU Capacity Market Steps in Positive Direction for Seasonal Clean Dispatchable Reliability\
		[Optimization Pass],
	  BAU Capacity Market Steps in Negative Direction for Seasonal Clean Dispatchable Reliability\
		[Optimization Pass]
	)
	~	Dmnl
	~		|

BAU Capacity Market Steps in Same Direction for Seasonal Dispatchable Reliability[Optimization Pass\
		]=
	MAX(
	  BAU Capacity Market Steps in Positive Direction for Seasonal Dispatchable Reliability\
		[Optimization Pass],
	  BAU Capacity Market Steps in Negative Direction for Seasonal Dispatchable Reliability\
		[Optimization Pass]
	)
	~	Dmnl
	~		|

BAU Capacity Remaining to Retire After Vintage[Electricity Source,first modeled vintage\
		]=
	(
	  BAU Retiring Generation Capacity[Electricity Source]
	  + BAU Decrease in Capacity from CCUS Retrofits[Electricity Source]
	)
	- SUM(BAU Capacity Retirements by Vintage[Electricity Source,first modeled vintage!]\
		) * One Year ~~|
BAU Capacity Remaining to Retire After Vintage[Electricity Source,current modeled vintages\
		]=
	BAU Capacity Remaining to Retire After Vintage[Electricity Source,preceding modeled vintages\
		]
	- BAU Capacity Retirements by Vintage[Electricity Source,current modeled vintages] *\
		 One Year
	~	MW
	~		|

BAU Capacity Retirements Based on Economic Lifetime[Electricity Source,Modeled Vintage\
		]=
	IF THEN ELSE(
	  (Time-Modeled Vintage to Year Mapping[Modeled Vintage])=BGCL BAU Generation Capacity Lifetime\
		[Electricity Source],
	  1,
	  0
	)
	* BAU Last Year Electricity Generation Capacity by Vintage[Electricity Source,Modeled Vintage\
		]
	*BUCLfCR Boolean Use Capacity Lifetimes for Capacity Retirements
	~	MW
	~		|

BAU Capacity Retirements by Vintage[Electricity Source,first modeled vintage]=
	MIN(
	  SUM(BAU Last Year Electricity Generation Capacity by Vintage[Electricity Source,first modeled vintage\
		!]),
	
	  (BAU Retiring Generation Capacity[Electricity Source]+BAU Decrease in Capacity from CCUS Retrofits\
		[Electricity Source
	])
	) / One Year ~~|
BAU Capacity Retirements by Vintage[Electricity Source,current modeled vintages]=
	MIN(
	  BAU Last Year Electricity Generation Capacity by Vintage[Electricity Source,current modeled vintages\
		],
	
	  BAU Capacity Remaining to Retire After Vintage[Electricity Source,preceding modeled vintages\
		]
	) / One Year
	~	MW/Year
	~		|

BAU Capital Cost of Epqt to Sequester One Ton of Industry CO2 per Year[Industry Category\
		,Emissions Type]=
	BAU Last Year Capital Cost of Eqpt to Sequester One Ton of Industry CO2 per Year[Industry Category\
		,Emissions Type]
	* BAU This Year CCS Cost as Fraction of Last Year CCS Cost
	~	$/metric ton CO2e/Year
	~		|

BAU Capital Cost of Eqpt to Sequester One Ton of Hydrogen Sector CO2 per Year=
	BAU Last Year Capital Cost of Eqpt to Sequester One Ton of Hydrogen Sector CO2 per Year
	* BAU This Year CCS Cost as Fraction of Last Year CCS Cost
	~	$/metric ton CO2e/Year
	~		|

BAU Capital Recovery Factor by Industry Fuel and Process[Industry Category,Industrial Fuel\
		,Industrial Process]=
	ZIDZ(
	  BCoISC Weighted Average Cost of Capital by Industry[Industry Category]
	  * (1 + BCoISC Weighted Average Cost of Capital by Industry[Industry Category])^(RPfFISCC Repayment Period for Financed Industry Sector Capital Costs
	[Industrial Process]
	 / One Year)
	,
	
	  (1 + BCoISC Weighted Average Cost of Capital by Industry[Industry Category])^(RPfFISCC Repayment Period for Financed Industry Sector Capital Costs
	[Industrial Process]
	 / One Year)
	  - 1
	)
	~	Dmnl
	~		|

BAU Capital Recovery Factor for CCS by Industry Category[Industry Category]=
	ZIDZ(
	  BCoISC Financing Interest Rate by Industry[Industry Category]
	  * (1 + BCoISC Financing Interest Rate by Industry[Industry Category])^(RPfFISCC Repayment Period for Financed Industry Sector Capital Costs
	[other processes]
	 / One Year)
	,
	
	  (1 + BCoISC Financing Interest Rate by Industry[Industry Category])^(RPfFISCC Repayment Period for Financed Industry Sector Capital Costs
	[other processes]
	 / One Year)
	  - 1
	)
	~	Dmnl
	~		|

BAU Capital Recovery Factor for Power Plants[Electricity Source]=
	ZIDZ(
	  BCoESC BAU Cost of Electricity Sector Capital for Power Plants[Electricity Source]
	  * (1 + BCoESC BAU Cost of Electricity Sector Capital for Power Plants[Electricity Source\
		])^(RPfFESCC Repayment Period for Financed Electricity Sector Capital Costs
	 / One Year)
	,
	
	  (1 + BCoESC BAU Cost of Electricity Sector Capital for Power Plants[Electricity Source\
		])^(RPfFESCC Repayment Period for Financed Electricity Sector Capital Costs
	 / One Year)
	  - 1
	)
	~	Dmnl
	~		|

BAU Capital Recovery Factor for Subisides per Unit Electricity Output[Electricity Source\
		]=
	ZIDZ(
	  BCoESC BAU Cost of Electricity Sector Capital for Power Plants[Electricity Source]
	  * (1 + BCoESC BAU Cost of Electricity Sector Capital for Power Plants[Electricity Source\
		])^(BCS Duration of Subsidies for Carbon Sequestration
	 / One Year)
	,
	
	  (1 + BCoESC BAU Cost of Electricity Sector Capital for Power Plants[Electricity Source\
		])^(BCS Duration of Subsidies for Carbon Sequestration
	 / One Year)
	  - 1
	)
	~	Dmnl
	~		|

BAU Capital Recovery Factor for Subsidies per Unit Electricity Output[Electricity Source\
		]=
	ZIDZ(
	 BCoESC BAU Cost of Electricity Sector Capital for Power Plants[Electricity Source]
	  * (1 + BCoESC BAU Cost of Electricity Sector Capital for Power Plants[Electricity Source\
		])^(BS Duration of Subsidies per Unit Electricity Output
	[Electricity Source]
	 / One Year)
	,
	
	  (1 + BCoESC BAU Cost of Electricity Sector Capital for Power Plants[Electricity Source\
		])^(BS Duration of Subsidies per Unit Electricity Output
	[Electricity Source]
	  / One Year)
	  - 1
	)
	~	Dmnl
	~		|

BAU Carbon Free Energy after LCFS[Vehicle Type,Cargo Type,Vehicle Technology,Transportation Fuel\
		]=
	BAU Carbon Free Energy in Absence of LCFS by Vehicle Type[Vehicle Type,Cargo Type,Vehicle Technology\
		,Transportation Fuel]
	+ BAU Additional Carbon Free Energy Allocated by Fuel and Technology[Vehicle Type,Cargo Type\
		,Vehicle Technology,Transportation Fuel]
	~	BTU
	~		|

BAU Carbon Free Energy in Absence of LCFS by Vehicle Type[Vehicle Type,Cargo Type,Vehicle Technology\
		,Transportation Fuel]=
	BAU Fuel that would be Used by Regulated Vehicle Types in Absence of LCFS with Elec Eff Adj\
		[Vehicle Type,Cargo Type,Vehicle Technology
	,Transportation Fuel]
	* (1 - Carbon Intensity Ratios by Transportation Fuel[Transportation Fuel])
	~	BTU
	~		|

BAU Carbon Price Credit per MWh[Electricity Source]=
	Metric Tons CO2 Stored per MWh[Electricity Source]*BCTR BAU Carbon Tax Rate[electricity sector\
		]
	~	$/(MW*hr)
	~		|

BAU Carbon Tax Levied on Industrial Fuels[Industry Category]=
	SUM(
	  BAU Industrial Fuel Use for Energy Purposes[Industry Category,Industrial Fuel!]
	  * BAU Industrial Fuel Carbon Tax Amount per Unit Energy[Industry Category,Industrial Fuel\
		!]
	)
	~	$
	~		|

BAU Carbon Tax on Process Emissions by Industry[Industry Category]=
	IF THEN ELSE(
	  BEPEfCT Boolean Exempt Process Emissions from Carbon Tax[Industry Category] > 0,
	
	  0,
	
	  QUANTUM(
	
	    SUM(BAU Process Emissions in CO2e in Metric Tons[Industry Category,Pollutant!]
	    * BCTR BAU Carbon Tax Rate[industry sector]
	    * BFoICStCT BAU Fraction of Industry Category Subject to Carbon Tax[Industry Category\
		]
	    * BPTbCP BAU Industry Pollutants Taxed by Carbon Pricing[Industry Category,Pollutant\
		!]
	    ),
	
	    QSfCF Quantization Size for Cash Flows
	  )
	)
	~	$
	~		|

BAU Carbon Tax per Unit Industrial Output[Industry Category]=
	BCTR BAU Carbon Tax Rate[industry sector]
	* BAU Industrial Emissions per Unit Output[Industry Category]
	~	Dmnl
	~		|

BAU Carbon Tax Rebate on Exported Nonenergy Products[Industry Category]=
	IF THEN ELSE(
	  BDCTBA Boolean Disable Carbon Tax Border Adjustment = 0,
	
	  BAU Exports[Industry Category ISIC Code]
	  * BAU Carbon Tax per Unit Industrial Output[Industry Category],
	
	  0
	)
	* BRCToEP Boolean Rebate Carbon Tax on Exported Products
	* BFoICbCTBA BAU Fraction of Industry Covered by Carbon Tax Border Adjustment[Industry Category\
		]
	~	$
	~		|

BAU Cargo Dist Transported[Vehicle Type,Cargo Type]=
	SUM(Start Year Cargo Dist Transported[Vehicle Type,Cargo Type,Vehicle Technology!])
	* BCDTRtSY BAU Cargo Dist Transported Relative to Start Year[Vehicle Type,Cargo Type\
		]
	~	thing*miles
	~		|

BAU Cargo Dist Transported Allocated by Last Year Vehicle Technologies[Vehicle Type,Cargo Type\
		,Vehicle Technology]=
	BAU Cargo Dist Transported[Vehicle Type,Cargo Type]
	* (1 + Perc Change in Sectoral Energy Use due to Exogenous GDP Adjustment[transportation sector\
		])
	
	* ZIDZ(
	    BAU Last Year Vehicles[Vehicle Type,Cargo Type,Vehicle Technology],
	    SUM(BAU Last Year Vehicles[Vehicle Type,Cargo Type,Vehicle Technology!])
	  )
	~	thing*miles
	~		|

BAU Cargo Dist Transported by Vehicle Technology[Vehicle Type,Cargo Type,Vehicle Technology\
		]=
	SUM(BAU Cargo Dist Transported Allocated by Last Year Vehicle Technologies[Vehicle Type\
		,Cargo Type,Vehicle Technology!])
	* ZIDZ(
	    BAU Vehicles[Vehicle Type,Cargo Type,Vehicle Technology],
	    SUM(BAU Vehicles[Vehicle Type,Cargo Type,Vehicle Technology!])
	  )
	~	thing*miles
	~		|

BAU CCS Cost per Ton Blue Hydrogen Produced=
	MAX(
	  ZIDZ(BAU Capital Cost of Eqpt to Sequester One Ton of Hydrogen Sector CO2 per Year\
		 * One Year,
	    Discount Factor to Levelize Capital Costs)
	  + CC CCS Total OM Cost per Hydrogen Sector Ton Sequestered
	  + MAX(CCSTaSC CCS Transportation and Storage Costs - CCSTaSC CCS Transportation and Storage Subsidies\
		, 0)
	
	  ,
	
	  0
	)
	/ Grams per Metric Ton CO2e
	/ Grams Pollutant per Gram CO2e Unit Converter
	
	
	* Industrial Fuel Pollutant Emissions Intensities This Year[chemicals 20,CO2,natural gas if\
		]
	
	* FIoHP Fuel Intensity of Hydrogen Production[natural gas reforming with CCS,natural gas if\
		]
	
	* CCP CO2 Capture Potential by Hydrogen Sector
	~	$/BTU
	~		|

BAU CCS New Capital Eqpt Cost by Hydrogen Sector=
	BAU This Year Increase in Pollutants Sequestered by Hydrogen Sector[CO2]
	* BAU Capital Cost of Eqpt to Sequester One Ton of Hydrogen Sector CO2 per Year
	  / Grams Pollutant per Gram CO2e Unit Converter / Grams per Metric Ton CO2e * One Year
	~	$
	~		|

BAU CCS New Capital Eqpt Cost by Industry[Industry Category]=
	SUM(BAU This Year Increase in Pollutants Sequestered by Industry Sector[Industry Category\
		,CO2,Emissions Type!]
	  * BAU Capital Cost of Epqt to Sequester One Ton of Industry CO2 per Year[Industry Category\
		,Emissions Type!]
	)
	  / Grams Pollutant per Gram CO2e Unit Converter / Grams per Metric Ton CO2e * One Year
	~	$
	~		|

BAU CCS OM Cost by Hydrogen Sector=
	BAU This Year Pollutants Sequestered by Hydrogen Sector[CO2]
	* CC CCS Total OM Cost per Hydrogen Sector Ton Sequestered
	/ Grams per Metric Ton CO2e
	/ Grams Pollutant per Gram CO2e Unit Converter
	~	$
	~		|

BAU CCS OM Cost by Industry Sector[Industry Category]=
	SUM(BAU This Year Pollutants Sequestered by Industry Sector[Industry Category,CO2,Emissions Type\
		!]
	 * CC CCS Total OM Cost per Industry Ton Sequestered[Industry Category,Emissions Type\
		!]
	)
	/ Grams per Metric Ton CO2e
	/ Grams Pollutant per Gram CO2e Unit Converter
	~	$
	~		|

BAU CCS Retrofit Capacity Construction Started This Year[Industry Category,Emissions Type\
		]=
	MIN(
	  BAU Demand for CCS Not Already Existing or In Progress[Industry Category,Emissions Type\
		],
	
	  MAX(
	    BAU CCS Retrofit Capacity Desired[Industry Category,Emissions Type]
	    - Start Year BAU Fraction of CCS Potential Achieved by Industry Sector[Industry Category\
		,Emissions Type],
	    0
	  )
	  * SoCECRCSiaY Share of Cost Effective CCS Retrofit Construction Started in a Year
	)
	~	Dmnl
	~		|

BAU CCS Retrofit Capacity Desired[Industry Category,Emissions Type]=
	IF THEN ELSE(
	  BAU Value of CCS[Industry Category,Emissions Type] <= 0,
	
	  0,
	
	  LOOKUP BACKWARD(
	    CECRCbI Cost Effective CCS Retrofit Capacity by Industry[Industry Category,Emissions Type\
		],
	    BAU Value of CCS[Industry Category,Emissions Type]
	    / One Dollar
	    * One Metric Ton CO2e
	  )
	)
	~	Dmnl
	~	Lookup functions like LOOKUP BACKWARD are recommended to be dimensionless; \
		we divide by One Dollar and multiply by One Metric Ton CO2e to supress \
		warnings from the lookup function.
	|

BAU CCS Retrofit Capacity in Conveyor[Industry Category,Emissions Type]= 
	DELAY FIXED(
	  BAU CCS Retrofit Capacity Construction Started This Year[Industry Category,Emissions Type\
		], 
	  CRDT CCS Retrofit Deployment Time[Industry Category,Emissions Type],
	  0
	)
	~	Dmnl
	~		|

BAU CCS Subsidies Paid per Unit Electricity Output for Newly Eligible CCS Capacity[Electricity Source\
		]=
	BAU New Generation Capacity[Electricity Source]
	* BAU Expected Capacity Factor x Hours per Year for Plants Built This Year[Electricity Source\
		]
	* BAU CCS Subsidy per MWh[Electricity Source]
	~	$
	~		|

BAU CCS Subsidy Amount Paid to Electricity Sector[Electricity Source]=
	BAU This Year Pollutants Sequestered by Electricity Sector[CO2,Electricity Source]
	 / Grams Pollutant per Gram CO2e Unit Converter / Grams per Metric Ton CO2e
	 * BCS BAU Industry CCS Subsidy
	~	$
	~		|

BAU CCS Subsidy Amount Paid to Hydrogen Sector=
	BAU This Year Pollutants Sequestered by Hydrogen Sector[CO2]
	 / Grams Pollutant per Gram CO2e Unit Converter / Grams per Metric Ton CO2e
	 * BCS BAU Industry CCS Subsidy
	~	$
	~		|

BAU CCS Subsidy Amount Paid to Industry Sector[Industry Category]=
	SUM(BAU This Year Pollutants Sequestered by Industry Sector[Industry Category,CO2,Emissions Type\
		!])
	 / Grams Pollutant per Gram CO2e Unit Converter / Grams per Metric Ton CO2e
	 * BCS BAU Industry CCS Subsidy
	~	$
	~		|

BAU CCS Subsidy Payments per Unit Electricity Output Expiring After CCS Subsidy Duration Period\
		[Electricity Source]= DELAY FIXED (
	BAU CCS Subsidies Paid per Unit Electricity Output for Newly Eligible CCS Capacity[Electricity Source\
		], BCS Duration of Subsidies for Carbon Sequestration, 0)
	~	$
	~		|

BAU CCS Subsidy per MWh[Electricity Source] :EXCEPT:   [biomass w CCS es]=
	BAU Metric Tons CO2 Stored per MWh[Electricity Source]
	* BCS BAU Electricity CCS Subsidy[Electricity Source] ~~|
BAU CCS Subsidy per MWh[biomass w CCS es]=
	BwCCSSpM Biomass with CCS Storage per MWh
	* BCS BAU Electricity CCS Subsidy[biomass w CCS es]
	~	$/(MW*hour)
	~		|

BAU CCS Subsidy per MWh Adjusted for Subsidy Duration[Electricity Source]=
	BAU CCS Subsidy per MWh[Electricity Source]
	*BAU Duration Multiplier for Subsidies for Carbon Sequestration[Electricity Source]
	~	$/(MW*hr)
	~		|

BAU CCS Subsidy per Unit Output for Dispatch[Electricity Source]=
	IF THEN ELSE(
	  BAU Last Year Electricity Generation Capacity[Electricity Source]=0,
	                 
	  BAU CCS Subsidy per MWh[Electricity Source],
	                 
	  ZIDZ(
	    SUM(
	      BAU Last Year Electricity Generation Capacity by Vintage[Electricity Source,Modeled Vintage\
		!]
	      * BAU CCS Subsidy per Unit Output for Dispatch by Vintage[Electricity Source,Modeled Vintage\
		!]
	    ),
	    BAU Last Year Electricity Generation Capacity[Electricity Source]
	  )
	)
	~	$/(MW*hr)
	~		|

BAU CCS Subsidy per Unit Output for Dispatch by Vintage[Electricity Source,Modeled Vintage\
		]=
	DEPRECIATE STRAIGHTLINE(
	
	  BAU CCS Subsidy per MWh[Electricity Source]
	  * BCS Duration of Subsidies for Carbon Sequestration / One Year
	  * This Year Modeled Vintage Flag[Modeled Vintage],
	 
	  BCS Duration of Subsidies for Carbon Sequestration,
	
	  1,
	
	  0
	)
	~	$/(MW*hr)
	~		|

BAU CES Costs for ACP Compliance[RPS]=
	MAX(0,
	    BAU Elec Portfolio Percentage to Seek This Year[RPS]-SUM(BAU Expected Achievable Annual RPS by Optimization Pass\
		[last pass!])
	  )
	
	* BAU Optimized RPS Credit Price
	* BAU Total Electricity Demand Including TnD Losses ~~|
BAU CES Costs for ACP Compliance[CES]=
	MAX(0,
	    BAU Elec Portfolio Percentage to Seek This Year[CES]-SUM(BAU Expected Achievable Annual CES by Optimization Pass\
		[last pass!])
	  )
	
	* BAU Optimized CES Credit Price
	* BAU Total Electricity Demand Including TnD Losses
	~	$
	~		|

BAU CES Costs for Clean Dispatchable Plants for Reliability=
	(SUM(BAU New Dispatchable Only Clean Capacity Desired for Seasonal Reliability[Electricity Source\
		!]
	      * BAU Capacity Market Price for Seasonal Clean Dispatchable Reliability Adjusted for Availability\
		[Electricity Source
	!
	])
	
	 + SUM(BAU Retrofit Capacity for Clean Dispatchable Reliability[Electricity Source!]
	      * BAU Capacity Market Price for Seasonal Clean Dispatchable Reliability Adjusted for Availability\
		[Electricity Source
	!
	])
	)
	~	$
	~		|

BAU CES Costs for Incremental Capacity Additions[Clean Elec Requirement]=
	BAU CES Costs for Clean Dispatchable Plants for Reliability
	+BAU CES Costs for Market Based CES Mehcanism[Clean Elec Requirement]
	~	$
	~		|

BAU CES Costs for Incremental Capacity Additions after Financial Lifetime[Clean Elec Requirement\
		]= DELAY FIXED (
	BAU CES Costs for Incremental Capacity Additions[Clean Elec Requirement], RPfFESCC Repayment Period for Financed Electricity Sector Capital Costs\
		, 0)
	~	$
	~		|

BAU CES Costs for Market Based CES Mehcanism[RPS]=
	(SUM(BAU New Capacity Added or Retrofitted due to Elec Portfolio Stds excluding Hybrid Power Plants\
		[Electricity Source!,RPS]
	    *BAU Marginal Capacity Factor by Hour[Electricity Source!,Electricity Timeslice!\
		,Hour!,RPS]
	    *SHELF Days per Electricity Timeslice[Electricity Timeslice!]
	    *BAU Optimized RPS Credit Price
	     )* One Hour
	  )
	
	
	+(SUM(BAU New Capacity Added due to Elec Portfolio Stds for Hybrid Power Plants[Electricity Source\
		!,RPS]
	    *BAU Marginal Capacity Factor by Hour[Electricity Source!,Electricity Timeslice!\
		,Hour!,RPS]
	    *SHELF Days per Electricity Timeslice[Electricity Timeslice!]
	    *BAU Optimized RPS Credit Price
	    *(1-BAU Share of Annual Expected Output that Can be Shifted[Electricity Source!]\
		)
	     )* One Hour
	
	  +SUM(BAU New Capacity Added due to Elec Portfolio Stds for Hybrid Power Plants[Electricity Source\
		!,RPS]
	    *BAU Expected Capacity Factors by Hour for Plants Built This Year[Electricity Source\
		!,Electricity Timeslice!,Hour!]
	    *SHELF Days per Electricity Timeslice[Electricity Timeslice!]
	    *BAU Optimized RPS Credit Price
	    *BAU Share of Annual Expected Output that Can be Shifted[Electricity Source!]
	     )* One Hour
	  ) ~~|
BAU CES Costs for Market Based CES Mehcanism[CES]=
	(SUM(BAU New Capacity Added or Retrofitted due to Elec Portfolio Stds excluding Hybrid Power Plants\
		[Electricity Source!,CES]
	    *BAU Marginal Capacity Factor by Hour[Electricity Source!,Electricity Timeslice!\
		,Hour!,CES]
	    *SHELF Days per Electricity Timeslice[Electricity Timeslice!]
	    *(BAU Optimized CES Credit Price+BAU Optimized RPS Credit Price)
	     )* One Hour
	  )
	
	
	+(SUM(BAU New Capacity Added due to Elec Portfolio Stds for Hybrid Power Plants[Electricity Source\
		!,CES]
	    *BAU Marginal Capacity Factor by Hour[Electricity Source!,Electricity Timeslice!\
		,Hour!,CES]
	    *SHELF Days per Electricity Timeslice[Electricity Timeslice!]
	    *(BAU Optimized CES Credit Price + BAU Optimized RPS Credit Price)
	    *(1-BAU Share of Annual Expected Output that Can be Shifted[Electricity Source!]\
		)
	     )* One Hour
	
	  +SUM(BAU New Capacity Added due to Elec Portfolio Stds for Hybrid Power Plants[Electricity Source\
		!,CES]
	    *BAU Expected Capacity Factors by Hour for Plants Built This Year[Electricity Source\
		!,Electricity Timeslice!,Hour!]
	    *SHELF Days per Electricity Timeslice[Electricity Timeslice!]
	    *(BAU Optimized CES Credit Price + BAU Optimized RPS Credit Price)
	    *BAU Share of Annual Expected Output that Can be Shifted[Electricity Source!]
	     )* One Hour
	  )
	~	$
	~		|

BAU CES Credit Price by Optimization Pass[pass1]=
	BAU Initial Guess at CES Price ~~|
BAU CES Credit Price by Optimization Pass[current pass]=
	MIN(IF THEN ELSE(
	  BAU CES Credit Price by Optimization Pass[preceeding pass] = 0,
	
	  0,
	
	  MAX(
	    0,
	
	    IF THEN ELSE(
	      BAU Expected Achievable Annual CES by Optimization Pass[preceeding pass]
	      < BAU Elec Portfolio Percentage to Seek This Year[CES],
	  
	      BAU CES Credit Price by Optimization Pass[preceeding pass]
	      + BAU CES Optimization Step Size[current pass],
	
	      BAU CES Credit Price by Optimization Pass[preceeding pass]
	      - BAU CES Optimization Step Size[current pass]
	    )
	  )
	), BRACP BAU RPS Alternative Compliance Payment)
	~	$/(MW*hour)
	~		|

BAU CES Optimization Step Size[pass1]=
	ABS(BAU CES Credit Price by Optimization Pass[pass1])
	/ 2 ~~|
BAU CES Optimization Step Size[current pass]=
	IF THEN ELSE(
	  BAU CES Steps in Same Direction[preceeding pass]
	  > Steps Allowed in Same Direction Without Increasing Step Size,
	
	  BAU CES Optimization Step Size[preceeding pass] * 1.5,
	
	  IF THEN ELSE(
	    BAU CES Steps in Same Direction[preceeding pass]
	    > Steps Allowed in Same Direction With Declining Step Size,
	
	    BAU CES Optimization Step Size[preceeding pass],
	
	    BAU CES Optimization Step Size[preceeding pass]
	    / 2
	  )
	)
	~	$/(MW*hour)
	~		|

BAU CES Revenue at Expected Capacity Factor by Optimization Pass[Electricity Source, \
		Optimization Pass]=
	BAU CES Credit Price by Optimization Pass[Optimization Pass]
	    * BAU Expected Capacity Factor x Hours per Year for Plants Built This Year[Electricity Source
	]
	    * Elec Portfolio Qualifying Sources[Electricity Source,CES]
	~	$/MW
	~		|

BAU CES Revenue at Marginal Capacity Factor by Optimization Pass[Optimization Pass, Electricity Source\
		]=
	BAU CES Credit Price by Optimization Pass[Optimization Pass]
	* BAU Marginal Capacity Factor x Hours per Year[Electricity Source,CES]
	* Elec Portfolio Qualifying Sources[Electricity Source,CES]
	~	$/MW
	~		|

BAU CES Steps in Negative Direction[pass1]=
	0 ~~|
BAU CES Steps in Negative Direction[current pass]=
	IF THEN ELSE(
	  BAU Expected Achievable Annual CES by Optimization Pass[preceeding pass]
	  > BAU Elec Portfolio Percentage to Seek This Year[CES],
	
	  BAU CES Steps in Negative Direction[preceeding pass] + 1,
	
	  0
	)
	~	Dmnl
	~		|

BAU CES Steps in Positive Direction[pass1]=
	0 ~~|
BAU CES Steps in Positive Direction[current pass]=
	IF THEN ELSE(
	  BAU Expected Achievable Annual CES by Optimization Pass[preceeding pass]
	  < BAU Elec Portfolio Percentage to Seek This Year[CES],
	
	  BAU CES Steps in Positive Direction[preceeding pass] + 1,
	
	  0
	)
	~	Dmnl
	~		|

BAU CES Steps in Same Direction[Optimization Pass]=
	MAX(
	  BAU CES Steps in Positive Direction[Optimization Pass],
	  BAU CES Steps in Negative Direction[Optimization Pass]
	)
	~	Dmnl
	~		|

BAU Change in Annualized Fixed Costs per Unit Retrofitted Capacity[Electricity Source\
		] :EXCEPT:     [hard coal w CCS es],[natural gas combined cycle w CCS es],[biomass w CCS es\
		],[lignite w CCS es]=
	1e+07 ~~|
BAU Change in Annualized Fixed Costs per Unit Retrofitted Capacity[hard coal w CCS es\
		]=
	BAU Annual Financing Repayment per Unit Retrofitted Capacity[hard coal w CCS es]
	
	+ BAU Annualized Fixed Costs per Unit New Capacity[hard coal w CCS es]
	- BAU Annualized Fixed Costs per Unit New Capacity[hard coal es] ~~|
BAU Change in Annualized Fixed Costs per Unit Retrofitted Capacity[natural gas combined cycle w CCS es\
		]=
	BAU Annual Financing Repayment per Unit Retrofitted Capacity[natural gas combined cycle w CCS es\
		]
	
	+ BAU Annualized Fixed Costs per Unit New Capacity[natural gas combined cycle w CCS es\
		]
	- BAU Annualized Fixed Costs per Unit New Capacity[natural gas combined cycle es] ~~|
BAU Change in Annualized Fixed Costs per Unit Retrofitted Capacity[biomass w CCS es]=
	BAU Annual Financing Repayment per Unit Retrofitted Capacity[biomass w CCS es]
	
	+ BAU Annualized Fixed Costs per Unit New Capacity[biomass w CCS es]
	- BAU Annualized Fixed Costs per Unit New Capacity[biomass es] ~~|
BAU Change in Annualized Fixed Costs per Unit Retrofitted Capacity[lignite w CCS es]=
	BAU Annual Financing Repayment per Unit Retrofitted Capacity[lignite w CCS es]
	
	+ BAU Annualized Fixed Costs per Unit New Capacity[lignite w CCS es]
	- BAU Annualized Fixed Costs per Unit New Capacity[lignite es]
	~	$/MW
	~		|

BAU Change in Electricity Demand from Demand Altering Technologies for Net Peak Load Reduction exlcuding Hybrid Batteries\
		[Electricity Timeslice,Hour]=
	BAU Increase in Demand by Hour for Seasonal Net Peak Load Reduction[Electricity Timeslice\
		,Hour]
	+ BAU Increase in Demand by Hour for Diurnal Net Peak Load Reduction excluding Hybrid Batteries\
		[Electricity Timeslice,Hour]
	- BAU Decrease in Demand by Hour for Seasonal Net Peak Load Reduction[Electricity Timeslice\
		,Hour]
	- BAU Decrease in Demand by Hour for Diurnal Net Peak Load Reduction excluding Hybrid Batteries\
		[Electricity Timeslice,Hour]
	~	MW*hr
	~		|

BAU Change in Fuel Use by Fuel and Technology due to LCFS[Vehicle Type,Cargo Type,Vehicle Technology\
		,Transportation Fuel] :EXCEPT:   [Vehicle Type,Cargo Type,Vehicle Technology,electricity tf\
		]=
	BAU Change in Fuel Use by Fuel and Technology due to LCFS with Elec Eff Adj[Vehicle Type\
		,Cargo Type,Vehicle Technology,
	Transportation Fuel] ~~|
BAU Change in Fuel Use by Fuel and Technology due to LCFS[Vehicle Type,Cargo Type,Vehicle Technology\
		,electricity tf]=
	BAU Change in Fuel Use by Fuel and Technology due to LCFS with Elec Eff Adj[Vehicle Type\
		,Cargo Type,Vehicle Technology,
	electricity tf]
	* (1 - PTFURfE Percentage Transportation Fuel Use Reduction for Electricity[Vehicle Type\
		,Cargo Type])
	~	BTU
	~		|

BAU Change in Fuel Use by Fuel and Technology due to LCFS with Elec Eff Adj[Vehicle Type\
		,Cargo Type,Vehicle Technology,Transportation Fuel] :EXCEPT: [Vehicle Type,Cargo Type\
		,gasoline vehicle,petroleum gasoline tf],[Vehicle Type,Cargo Type,diesel vehicle,petroleum diesel tf\
		],[Vehicle Type,Cargo Type,plugin hybrid vehicle,Transportation Fuel]=
	BAU Additional Fuel Use by Fuel and Technology due to LCFS with Elec Eff Adj[Vehicle Type\
		,Cargo Type,Vehicle Technology,Transportation Fuel] ~~|
BAU Change in Fuel Use by Fuel and Technology due to LCFS with Elec Eff Adj[Vehicle Type\
		,Cargo Type,gasoline vehicle,petroleum gasoline tf]=
	- BAU Additional Fuel Use by Fuel and Technology due to LCFS with Elec Eff Adj[Vehicle Type\
		,Cargo Type,gasoline vehicle,biofuel gasoline tf] ~~|
BAU Change in Fuel Use by Fuel and Technology due to LCFS with Elec Eff Adj[Vehicle Type\
		,Cargo Type,diesel vehicle,petroleum diesel tf]=
	- BAU Additional Fuel Use by Fuel and Technology due to LCFS with Elec Eff Adj[Vehicle Type\
		,Cargo Type,diesel vehicle,biofuel diesel tf] ~~|
BAU Change in Fuel Use by Fuel and Technology due to LCFS with Elec Eff Adj[Vehicle Type\
		,Cargo Type,plugin hybrid vehicle,Transportation Fuel] :EXCEPT: [LDVs,Cargo Type,plugin hybrid vehicle\
		,petroleum gasoline tf],[HDVs,Cargo Type,plugin hybrid vehicle,petroleum diesel tf]\
		=
	BAU Additional Fuel Use by Fuel and Technology due to LCFS with Elec Eff Adj[Vehicle Type\
		,Cargo Type,plugin hybrid vehicle,Transportation Fuel] ~~|
BAU Change in Fuel Use by Fuel and Technology due to LCFS with Elec Eff Adj[LDVs,Cargo Type\
		,plugin hybrid vehicle,petroleum gasoline tf]=
	- BAU Additional Fuel Use by Fuel and Technology due to LCFS with Elec Eff Adj[LDVs,\
		Cargo Type,plugin hybrid vehicle,electricity tf] ~~|
BAU Change in Fuel Use by Fuel and Technology due to LCFS with Elec Eff Adj[HDVs,Cargo Type\
		,plugin hybrid vehicle,petroleum diesel tf]=
	- BAU Additional Fuel Use by Fuel and Technology due to LCFS with Elec Eff Adj[HDVs,\
		Cargo Type,plugin hybrid vehicle,electricity tf]
	~	BTU
	~		|

BAU Change in Peak Load=
	MAX(0,BAU Peak Electricity Load-BAU Last Year Electricity Peak Load)
	~	MW
	~		|

BAU Charging Availability Shadow Cost=
	MAX(
	  EVCAP EV Charging Availability Parameter A
	  * LN((BNoEVC BAU Number of EV Chargers*EV Charger Unit Correction)
	      / (BNoGP BAU Number of Gas Pumps*Gas Pump Unit Correction)
	      )
	  + EVCAP EV Charging Availability Parameter B,
	
	  0
	)
	~	$/vehicle
	~		|

BAU Clean Industrial Heat Investment Subsidy Amount Paid[Industry Category]=
	SUM(
	  BAU Clean Industrial Heat Investment Subsidy Rate[industrial heating process!,Industrial Fuel\
		!]
	  * BAU New Industrial Equipment Energy Use by Fuel Type and Process[Industry Category\
		,Industrial Fuel!,industrial heating process!]
	)
	~	$
	~		|

BAU Clean Industrial Heat Investment Subsidy Rate[industrial heating process,Industrial Fuel\
		]=
	IECCpUAEU Industrial Equipment Capital Cost per Unit Annual Energy Use[Industrial Fuel\
		,industrial heating process]
	* BCHSR BAU Clean Heat Investment Subsidy Rate[industrial heating process]
	* IFTQfS Industrial Fuel Types Qualifying for Clean Heat Investment Subsidy[Industrial Fuel\
		]
	~	$/BTU
	~		|

BAU Clean Industrial Heat Production Subsidy Rate by Equipment Vintage[Industrial Fuel\
		,industrial heating process,Model Run Vintage]=
	IF THEN ELSE(
	  This Year Model Run Vintage Flag[Model Run Vintage] = 1,
	  BAU Clean Industrial Heat Subsidy Rate by Fuel Type[Industrial Fuel,industrial heating process\
		],
	  IF THEN ELSE(
	    Dimensionless Time < Model Run Vintage to Year Mapping[Model Run Vintage],
	    0,
	    IF THEN ELSE(
	      Dimensionless Time >= Model Run Vintage to Year Mapping[Model Run Vintage] + BCHPD BAU Clean Heat PTC Duration\
		/One Year
	,
	      0,
	      Last Year BAU Clean Industrial Heat Production Subsidy Rate by Equipment Vintage\
		[Industrial Fuel,industrial heating process
	,Model Run Vintage]
	    )
	  )
	)
	~	$/BTU
	~		|

BAU Clean Industrial Heat Subsidy Rate by Fuel Type[Industrial Fuel,industrial heating process\
		]=
	BCHSR BAU Clean Heat Production Subsidy Rate[industrial heating process]
	
	* IFTQfS Industrial Fuel Types Qualifying for Clean Heat Investment Subsidy[Industrial Fuel\
		]
	~	$/BTU
	~		|

BAU Clean Industrial Heat Subsidy Rate by Fuel Type in Future Years[Industrial Fuel,industrial heating process\
		,Future Year]=
	IF THEN ELSE(
	
	  Numerical Future Year Definitions[Future Year] - Time < 0,
	  0, 
	  IF THEN ELSE(
	    Numerical Future Year Definitions[Future Year] - Time >= BCHPD BAU Clean Heat PTC Duration\
		, 
	    0,
	    BAU Clean Industrial Heat Subsidy Rate by Fuel Type[Industrial Fuel,industrial heating process\
		]
	  )
	)
	~	$/BTU
	~		|

BAU CO2 Captured via DAC=
	DACD Direct Air Capture Potential
	* BFoDACPA BAU Fraction of Direct Air Capture Potential Achieved
	~	metric ton CO2e
	~		|

BAU CO2 Captured via DAC in Grams=
	BAU CO2 Captured via Geoengineering
	* Grams per Metric Ton CO2e
	* Grams Pollutant per Gram CO2e Unit Converter
	~	g pollutant
	~		|

BAU CO2 Captured via Enhanced Rock Weathering=
	ERWD Enhanced Rock Weathering Potential
	* BFoERWPA BAU Fraction of Enhanced Rock Weathering Potential Achieved
	~	metric ton CO2e
	~		|

BAU CO2 Captured via Geoengineering=
	BAU CO2 Captured via DAC
	+ BAU CO2 Captured via Enhanced Rock Weathering
	~	metric ton CO2e
	~		|

BAU Compensation per Employee by ISIC Code[ISIC Code]=
	ZIDZ(
	  BAU Domestic Employee Compensation by ISIC Code[ISIC Code],
	
	  BAU Domestic Employment by ISIC Code[ISIC Code]
	)
	~	$/job
	~		|

BAU Components Energy Use Before Correction Factor[Building Type,Building Fuel,Building Component\
		]=
	BAU Last Year Components Energy Use[Building Type,Building Fuel,Building Component]
	+ BAU New Components Energy Use after Envelope Effects[Building Type,Building Fuel,Building Component\
		] * One Year
	- BAU Retiring Components Energy Use[Building Type,Building Fuel,Building Component]\
		 * One Year
	~	BTU
	~		|

BAU Constant Reading of BCTR[Sectors,Future Year]=
	GET DIRECT CONSTANTS(
	   'InputData/fuels/BCTR/BCTR.csv',
	   ',',
	   'B2'
	)
	~	$/metric ton CO2e
	~		|

BAU Construction Cost per Unit Capacity after Construction Subsidies and Spur Line Construction\
		[Electricity Source]=
	MAX(
	  0,
	
	  BAU Construction Cost per Unit Capacity before Construction Subsidies[Electricity Source\
		]
	    - BAU Subsidy per Unit Electricity Capacity Built[Electricity Source]
	)
	
	+ CCaMC Spur Line Construction Cost per Unit Capacity[Electricity Source]
	~	$/MW
	~		|

BAU Construction Cost per Unit Capacity before Construction Subsidies[Electricity Source\
		] :EXCEPT:            [onshore wind es
],[solar PV es
],[offshore wind es],[hard coal w CCS es],[natural gas combined cycle w CCS es],[biomass w CCS es\
		],[lignite w CCS es]=
	CCaMC BAU Construction Cost per Unit Capacity[Electricity Source] ~~|
BAU Construction Cost per Unit Capacity before Construction Subsidies[onshore wind es\
		]=
	IF THEN ELSE(
	  CCaMC BAU Construction Cost per Unit Capacity[onshore wind es] > 0,
	
	  CCaMC BAU Construction Cost per Unit Capacity[onshore wind es],
	
	  IF THEN ELSE(
	    CCaMC BAU Construction Cost per Unit Capacity With One Year Delay[onshore wind es\
		] > 0,
	      (CCaMC BAU Construction Cost per Unit Capacity With One Year Delay[onshore wind es\
		] - BAU Last Year Soft Costs per Unit Capacity
	[onshore wind es])
	      * BAU This Year Solar and Wind Hard Costs as Fraction of Last Year Hard Costs[\
		onshore wind es]
	      + CCaMC BAU Soft Costs per Unit Capacity[onshore wind es],
	
	      (BAU Last Year Construction Cost per Unit Capacity before Construction Subsidies\
		[onshore wind es] - BAU Last Year Soft Costs per Unit Capacity
	[onshore wind es])
	      * BAU This Year Solar and Wind Hard Costs as Fraction of Last Year Hard Costs[\
		onshore wind es]
	      + CCaMC BAU Soft Costs per Unit Capacity[onshore wind es]
	   )
	) ~~|
BAU Construction Cost per Unit Capacity before Construction Subsidies[solar PV es]=
	IF THEN ELSE(
	  CCaMC BAU Construction Cost per Unit Capacity[solar PV es] > 0,
	
	  CCaMC BAU Construction Cost per Unit Capacity[solar PV es],
	
	  IF THEN ELSE(
	    CCaMC BAU Construction Cost per Unit Capacity With One Year Delay[solar PV es] >\
		 0,
	      (CCaMC BAU Construction Cost per Unit Capacity With One Year Delay[solar PV es\
		] - BAU Last Year Soft Costs per Unit Capacity
	[solar PV es])
	      * BAU This Year Solar and Wind Hard Costs as Fraction of Last Year Hard Costs[\
		solar PV es]
	      + CCaMC BAU Soft Costs per Unit Capacity[solar PV es],
	
	      (BAU Last Year Construction Cost per Unit Capacity before Construction Subsidies\
		[solar PV es] - BAU Last Year Soft Costs per Unit Capacity
	[solar PV es])
	      * BAU This Year Solar and Wind Hard Costs as Fraction of Last Year Hard Costs[\
		solar PV es]
	      + CCaMC BAU Soft Costs per Unit Capacity[solar PV es]
	   )
	) ~~|
BAU Construction Cost per Unit Capacity before Construction Subsidies[offshore wind es\
		]=
	IF THEN ELSE(
	  CCaMC BAU Construction Cost per Unit Capacity[offshore wind es] > 0,
	
	  CCaMC BAU Construction Cost per Unit Capacity[offshore wind es],
	
	  IF THEN ELSE(
	    CCaMC BAU Construction Cost per Unit Capacity With One Year Delay[offshore wind es\
		] > 0,
	      (CCaMC BAU Construction Cost per Unit Capacity With One Year Delay[offshore wind es\
		] - BAU Last Year Soft Costs per Unit Capacity
	[offshore wind es])
	      * BAU This Year Solar and Wind Hard Costs as Fraction of Last Year Hard Costs[\
		offshore wind es]
	      + CCaMC BAU Soft Costs per Unit Capacity[offshore wind es],
	
	      (BAU Last Year Construction Cost per Unit Capacity before Construction Subsidies\
		[offshore wind es] - BAU Last Year Soft Costs per Unit Capacity
	[offshore wind es])
	      * BAU This Year Solar and Wind Hard Costs as Fraction of Last Year Hard Costs[\
		offshore wind es]
	      + CCaMC BAU Soft Costs per Unit Capacity[offshore wind es]
	   )
	) ~~|
BAU Construction Cost per Unit Capacity before Construction Subsidies[hard coal w CCS es\
		]=
	IF THEN ELSE(
	  CCaMC BAU Construction Cost per Unit Capacity[hard coal w CCS es] > 0,
	
	  CCaMC BAU Construction Cost per Unit Capacity[hard coal w CCS es],
	
	  IF THEN ELSE(
	    CCaMC BAU Construction Cost per Unit Capacity With One Year Delay[hard coal w CCS es\
		] > 0,
	      (CCaMC BAU Construction Cost per Unit Capacity With One Year Delay[hard coal w CCS es\
		] - BAU Last Year Soft Costs per Unit Capacity
	[onshore wind es])
	      * BAU This Year CCS Cost as Fraction of Last Year CCS Cost
	      + CCaMC BAU Soft Costs per Unit Capacity[hard coal w CCS es],
	
	      (BAU Last Year Construction Cost per Unit Capacity before Construction Subsidies\
		[hard coal w CCS es] - BAU Last Year Soft Costs per Unit Capacity
	[hard coal w CCS es])
	      * BAU This Year CCS Cost as Fraction of Last Year CCS Cost
	      + CCaMC BAU Soft Costs per Unit Capacity[hard coal w CCS es]
	   )
	) ~~|
BAU Construction Cost per Unit Capacity before Construction Subsidies[natural gas combined cycle w CCS es\
		]=
	IF THEN ELSE(
	  CCaMC BAU Construction Cost per Unit Capacity[natural gas combined cycle w CCS es]\
		 > 0,
	
	  CCaMC BAU Construction Cost per Unit Capacity[natural gas combined cycle w CCS es]\
		,
	
	  IF THEN ELSE(
	    CCaMC BAU Construction Cost per Unit Capacity With One Year Delay[natural gas combined cycle w CCS es\
		] > 0,
	      (CCaMC BAU Construction Cost per Unit Capacity With One Year Delay[natural gas combined cycle w CCS es\
		] - BAU Last Year Soft Costs per Unit Capacity
	[natural gas combined cycle w CCS es])
	      * BAU This Year CCS Cost as Fraction of Last Year CCS Cost
	      + CCaMC BAU Soft Costs per Unit Capacity[natural gas combined cycle w CCS es],
	
	      (BAU Last Year Construction Cost per Unit Capacity before Construction Subsidies\
		[natural gas combined cycle w CCS es
] - BAU Last Year Soft Costs per Unit Capacity
	[natural gas combined cycle w CCS es])
	      * BAU This Year CCS Cost as Fraction of Last Year CCS Cost
	      + CCaMC BAU Soft Costs per Unit Capacity[natural gas combined cycle w CCS es]
	   )
	) ~~|
BAU Construction Cost per Unit Capacity before Construction Subsidies[biomass w CCS es\
		]=
	IF THEN ELSE(
	  CCaMC BAU Construction Cost per Unit Capacity[biomass w CCS es] > 0,
	
	  CCaMC BAU Construction Cost per Unit Capacity[biomass w CCS es],
	
	  IF THEN ELSE(
	    CCaMC BAU Construction Cost per Unit Capacity With One Year Delay[biomass w CCS es\
		] > 0,
	      (CCaMC BAU Construction Cost per Unit Capacity With One Year Delay[biomass w CCS es\
		] - BAU Last Year Soft Costs per Unit Capacity
	[biomass w CCS es])
	      * BAU This Year CCS Cost as Fraction of Last Year CCS Cost
	      + CCaMC BAU Soft Costs per Unit Capacity[biomass w CCS es],
	
	      (BAU Last Year Construction Cost per Unit Capacity before Construction Subsidies\
		[biomass w CCS es] - BAU Last Year Soft Costs per Unit Capacity
	[biomass w CCS es])
	      * BAU This Year CCS Cost as Fraction of Last Year CCS Cost
	      + CCaMC BAU Soft Costs per Unit Capacity[biomass w CCS es]
	   )
	) ~~|
BAU Construction Cost per Unit Capacity before Construction Subsidies[lignite w CCS es\
		]=
	IF THEN ELSE(
	  CCaMC BAU Construction Cost per Unit Capacity[lignite w CCS es] > 0,
	
	  CCaMC BAU Construction Cost per Unit Capacity[lignite w CCS es],
	
	  IF THEN ELSE(
	    CCaMC BAU Construction Cost per Unit Capacity With One Year Delay[lignite w CCS es\
		] > 0,
	      (CCaMC BAU Construction Cost per Unit Capacity With One Year Delay[lignite w CCS es\
		] - BAU Last Year Soft Costs per Unit Capacity
	[lignite w CCS es])
	      * BAU This Year CCS Cost as Fraction of Last Year CCS Cost
	      + CCaMC BAU Soft Costs per Unit Capacity[lignite w CCS es],
	
	      (BAU Last Year Construction Cost per Unit Capacity before Construction Subsidies\
		[lignite w CCS es] - BAU Last Year Soft Costs per Unit Capacity
	[lignite w CCS es])
	      * BAU This Year CCS Cost as Fraction of Last Year CCS Cost
	      + CCaMC BAU Soft Costs per Unit Capacity[lignite w CCS es]
	   )
	)
	~	$/MW
	~	To use endogenous learning for onshore wind, offshore wind, solar PV, \
		and/or plant types equipped with CCS, leave zeroes in CCaMC for \
		construction cost in all years after the first modeled year.  If the model \
		sees a non-zero construction cost value in CCaMC for any given year, it \
		will use that value in that year, overriding the endogenous learning \
		calculations.
	|

BAU Correction for Difference in Input vs Calculated BAU Components Energy Use[Building Type\
		,Building Fuel,Building Component] :EXCEPT:     [Building Type,Building Fuel,envelope\
		]=
	BCEU BAU Components Energy Use[Building Type,Building Fuel,Building Component]
	- BAU Components Energy Use Before Correction Factor[Building Type,Building Fuel,Building Component\
		] ~~|
BAU Correction for Difference in Input vs Calculated BAU Components Energy Use[Building Type\
		,Building Fuel,envelope]=
	0
	~	BTU
	~		|

BAU Cost of Capacity Construction before Construction Subsidies[Electricity Source]=
	BAU New Generation Capacity Excluding Retrofit Capacity[Electricity Source]
	* BAU Construction Cost per Unit Capacity before Construction Subsidies[Electricity Source\
		]
	
	+ BAU New Hybrid Grid Battery Storage Capacity[Electricity Source]
	* BAU Total Battery Cost per Unit Capacity
	~	$
	~		|

BAU Cost of Capacity Retrofitting before Construction Subsidies[Electricity Source]=
	BAU Retrofit Capacity after Quantization[Electricity Source]
	* CCaMC Power Plant CCS Retrofitting Costs[Electricity Source]
	~	$
	~		|

BAU Cost of Green Hydrogen Electricity Capacity Construction[Electricity Source]=
	BAU New Off Grid Capacity for Green Hydrogen Demand[Electricity Source]
	* BAU Construction Cost per Unit Capacity before Construction Subsidies[Electricity Source\
		]
	~	$
	~		|

BAU Cost of Providing Demand Response by Recipient[Cash Flow Entity]=
	BAU This Year DR Capacity by Provider[Cash Flow Entity]
	* DRCo Annual Cost per Unit Demand Response Capacity[Cash Flow Entity]
	~	$
	~		|

BAU Cost per MW for CCUS Retrofits Excluding Subsidies[Electricity Source] :EXCEPT:     \
		[CCUS Electricity Source]=
	9999 ~~|
BAU Cost per MW for CCUS Retrofits Excluding Subsidies[CCUS Electricity Source]=
	BAU Change in Annualized Fixed Costs per Unit Retrofitted Capacity[CCUS Electricity Source\
		]
	~	$/MW
	~		|

BAU Cost per Unit Distributed Solar Capacity=
	(BAU Last Year Cost per Unit Distributed Solar Capacity - Last Year Soft Costs per Unit Distributed Solar Capacity\
		)
	* BAU This Year Solar and Wind Hard Costs as Fraction of Last Year Hard Costs[solar PV es\
		]
	
	+ CpUDSC Soft Costs per Unit Distributed Solar Capacity
	~	$/MW
	~		|

BAU Cost per Unit New Elec Output Using Expected Capacity Factors[Electricity Source]\
		=
	BAU Annualized Fixed Costs per Unit New Elec Output Using Expected Capacity Factors[\
		Electricity Source]
	+ BAU Variable Costs per Unit New Elec Output[Electricity Source]
	~	$/(MW*hour)
	~		|

BAU Cost per Unit New Hydrogen Production[Hydrogen Production Pathway]=
	BAU Cost per Unit New Hydrogen Production Before Subsidies[Hydrogen Production Pathway\
		]
	- (BSfHPbP BAU Subsidy for Hydrogen Production by Pathway[Hydrogen Production Pathway\
		]
	    * Discount Factor to Levelize Subsidy)
	~	$/BTU
	~		|

BAU Cost per Unit New Hydrogen Production Before Carbon Tax Rebate[Hydrogen Production Pathway\
		] :EXCEPT:    [natural gas reforming with CCS
]=
	BAU Cost per Unit New Hydrogen Production before CCS[Hydrogen Production Pathway] ~~|
BAU Cost per Unit New Hydrogen Production Before Carbon Tax Rebate[natural gas reforming with CCS\
		]=
	BAU Cost per Unit New Hydrogen Production before CCS[natural gas reforming with CCS]
	+ BAU CCS Cost per Ton Blue Hydrogen Produced
	~	$/BTU
	~		|

BAU Cost per Unit New Hydrogen Production before CCS[Hydrogen Production Pathway] :EXCEPT:\
		                [electrolysis with guaranteed clean electricity
]=
	ZIDZ(
	  HPEC Hydrogen Production Equipment CapEx[Hydrogen Production Pathway],
	  Discount Factor to Levelize Capital Costs
	)
	
	+ HPEC Hydrogen Production Equipment OpEx[Hydrogen Production Pathway]
	
	+ 
	
	SUM(FIoHP Fuel Intensity of Hydrogen Production[Hydrogen Production Pathway,Industrial Fuel\
		!]
	  * BAU Hydrogen Fuel Cost per Unit Energy[Industrial Fuel!]) ~~|
BAU Cost per Unit New Hydrogen Production before CCS[electrolysis with guaranteed clean electricity\
		]=
	ZIDZ(
	  HPEC Hydrogen Production Equipment CapEx[electrolysis with guaranteed clean electricity\
		],
	  Discount Factor to Levelize Capital Costs
	)
	+ HPEC Hydrogen Production Equipment OpEx[electrolysis with guaranteed clean electricity\
		]
	
	+ 
	
	SUM(FIoHP Fuel Intensity of Hydrogen Production[electrolysis with guaranteed clean electricity\
		,Industrial Fuel!])
	* 
	SUM(BAU Cost per Unit New Elec Output Using Expected Capacity Factors[Electricity Source\
		!] 
	  * BAU Share of Off Grid Electricity Demand That is New This Year Met by Power Plant Type\
		[Electricity Source!])
	* MWh per BTU
	
	+
	
	SUM(FIoHP Fuel Intensity of Hydrogen Production[electrolysis with guaranteed clean electricity\
		,Industrial Fuel!])
	* 
	SUM(
	  ZIDZ(BAU Share of Off Grid Electricity Demand That is New This Year Met by Power Plant Type\
		[Electricity Source!],
	  BAU Expected Capacity Factor x Hours per Year for Plants Built This Year[Electricity Source\
		!])
	)
	* TCCpUNEC Transmission Construction Cost per Unit New Electricity Capacity
	* MWh per BTU
	~	$/BTU
	~		|

BAU Cost per Unit New Hydrogen Production Before Subsidies[Hydrogen Production Pathway\
		] :EXCEPT: [natural gas reforming with CCS]=
	BAU Cost per Unit New Hydrogen Production Before Carbon Tax Rebate[Hydrogen Production Pathway\
		] ~~|
BAU Cost per Unit New Hydrogen Production Before Subsidies[natural gas reforming with CCS\
		]=
	BAU Cost per Unit New Hydrogen Production Before Carbon Tax Rebate[natural gas reforming with CCS\
		]
	
	- SUM(FIoHP Fuel Intensity of Hydrogen Production[natural gas reforming with CCS,Industrial Fuel\
		!] * BAU Hydrogen Fuel Carbon Tax Amount per Unit Energy[Industrial Fuel!])
	~	$/BTU
	~		|

BAU Cumulative Battery Capacity Deployed=
	BAU Cumulative EV Battery Capacity Deployed as of Last Year
	+ BAU Last Year Grid Battery Storage Capacity Including Hybrid Batteries
	+ BAU Last Year Cumulative Policy Mandated Grid Battery Storage
	~	MW*hr
	~		|

BAU Cumulative CCS Retrofit Capacity Built During Model Run[Industry Category,Emissions Type\
		]=
	BAU Last Year Cumulative CCS Retrofit Capacity Built During Model Run[Industry Category\
		,Emissions Type]
	+ BAU CCS Retrofit Capacity in Conveyor[Industry Category,Emissions Type]
	~	Dmnl
	~		|

BAU Cumulative EV Battery Capacity Deployed as of Last Year=
	SUM(
	  BAU Cumulative Vehicles Deployed as of Last Year[Vehicle Type!,Cargo Type!,Vehicle Technology\
		!]
	  * This Year Battery Capacity by Vehicle Type[Cargo Type!,Vehicle Type!,Vehicle Technology\
		!]
	)
	/ kWh per MWh
	~	MW*hr
	~		|

BAU Cumulative New Capacity Added or Retrofitted due to Elec Portfolio Stds[Electricity Source\
		,Clean Elec Requirement]=
	BAU Last Year Cumulative New Capacity Added or Retrofitted due to Elec Portfolio Stds\
		[Electricity Source,Clean Elec Requirement]
	+ BAU New Capacity Added or Retrofitted due to Elec Portfolio Stds[Electricity Source\
		,Clean Elec Requirement]
	~	MW
	~		|

BAU Cumulative Retired Generation Capacity[Electricity Source]= INTEG (
	BAU Retiring Generation Capacity[Electricity Source]
	/One Year,
		0)
	~	MW
	~		|

BAU Cumulative Retired Generation Excluding Capacity Payment[Electricity Source]= INTEG\
		 (
	BAU Retiring Generation Capacity Excluding Capacity Payment[Electricity Source]
	/One Year,
		0)
	~	MW
	~		|

BAU Cumulative Vehicles Deployed as of Last Year[Vehicle Type,Cargo Type,Vehicle Technology\
		]=
	BAU Cumulative Vehicles Deployed as of Two Years Ago[Vehicle Type,Cargo Type,Vehicle Technology\
		]
	+ BAU New Vehicles Last Year[Vehicle Type,Cargo Type,Vehicle Technology] * One Year
	~	vehicles
	~		|

BAU Cumulative Vehicles Deployed as of Two Years Ago[Vehicle Type,Cargo Type,Vehicle Technology\
		]= INTEG (
	BAU New Vehicles Last Year[Vehicle Type,Cargo Type,Vehicle Technology],
		SYVbT Start Year Vehicles by Technology[Vehicle Type,Cargo Type,Vehicle Technology]\
		)
	~	vehicles
	~		|

BAU Curtailed Electricity Output[Electricity Source]=
	MAX(
	  0,
	
	  BAU Annual Maximum Potential Electricity Output[Electricity Source]
	  - BAU Electricity Generation by Type [Electricity Source]
	)
	~	MW*hour
	~		|

BAU Curtailed Variable Renewable Electricity by Hour[Electricity Timeslice,Hour]=
	MAX(
	  0,
	
	   SUM(BAU Electricity Generation Capacity[Variable Renewable Electricity Source!]*BAU Weighted Average Expected Capacity Factors by Hour without RAF\
		[Variable Renewable Electricity Source!,Electricity Timeslice,Hour] * One Hour)
	  - SUM(BAU Total Electricity Dispatched by Hour by Plant Type[Electricity Timeslice\
		,Hour,Variable Renewable Electricity Source
	!])
	)
	~	MW*hr
	~		~	:SUPPLEMENTARY 
	|

BAU Daily Average Hourly Spare Potential Output from Surviving Capacity[Electricity Timeslice\
		]=
	SUM(BAU Spare Potential Output from Surviving Capacity by Hour after Seasonal Net Peak Load Reduction\
		[Electricity Timeslice,Hour!])
	/ ELMCOUNT(Hour)
	~	MW*hr
	~		|

BAU Daily Decrease in Demand for Seasonal Net Peak Load Reduction[Electricity Timeslice\
		]=
	ZIDZ(BAU Aggregate Decrease in Demand by Timeslice for Seasonal Net Peak Load Reduction\
		[Electricity Timeslice],SHELF Days per Electricity Timeslice[Electricity Timeslice]\
		)
	~	MW*hr
	~		|

BAU Daily Exported Electricity=
	EIaE BAU Exported Electricity/Days per Year
	~	MW*hr
	~		|

BAU Daily Hours of Charged or Discharged Generation[Hybrid Electricity Source,Electricity Timeslice\
		]=
	MIN(GBSC Diurnal Grid Battery Daily Storage Duration*HESBCpUEC Hybrid Electricity Source Battery Capacity per Unit Electricity Capacity\
		,
	      BAU Expected Daily Electricity Output by Electricity Timeslice[Hybrid Electricity Source\
		,Electricity Timeslice]*HESBCpUEC Hybrid Electricity Source Battery Capacity per Unit Electricity Capacity
	   )
	~	hours
	~		|

BAU Daily Imported Electricity=
	BAU Imported Electricity/Days per Year
	~	MW*hr
	~		|

BAU Daily Increase in Demand for Seasonal Net Peak Load Reduction[Electricity Timeslice\
		]=
	ZIDZ(BAU Aggregate Increase in Demand by Timeslice for Seasonal Net Peak Load Reduction\
		[Electricity Timeslice], SHELF Days per Electricity Timeslice[Electricity Timeslice\
		])
	~	MW*hr
	~		|

BAU Daily Net Imported Electricity=
	BAU Daily Imported Electricity
	-BAU Daily Exported Electricity
	~	MW*hr
	~		|

BAU Data Center Load=
	IF THEN ELSE( DCLGA Data Center Load Growth Assumption=0, BDCL BAU Data Center Load Mid\
		, 
	IF THEN ELSE( DCLGA Data Center Load Growth Assumption=1, BDCL BAU Data Center Load Low\
		, BDCL BAU Data Center Load High)
	)
	~	MW*hour
	~		|

BAU Decline in Grid Battery Costs=
	BAU Difference Between This Year and First Year Battery Cost
	/ RPfFESCC Repayment Period for Financed Electricity Sector Capital Costs
	*ESTRTE Grid Battery Round Trip Efficiency
	*One Year
	~	$/(MW*hour)
	~		|

BAU Decommissioning Costs=
	SUM(BAU Retiring Generation Capacity[Electricity Source!]*DCpUC Decommissioning Cost per Unit Capacity\
		[Electricity Source
	!])
	~	$
	~		|

BAU Decrease in Capacity from CCUS Retrofits[Electricity Source] :EXCEPT: [hard coal es\
		],[natural gas combined cycle es],[biomass es],[lignite es]=
	0 ~~|
BAU Decrease in Capacity from CCUS Retrofits[hard coal es]=
	BAU Retrofit Capacity after Quantization[hard coal w CCS es] ~~|
BAU Decrease in Capacity from CCUS Retrofits[natural gas combined cycle es]=
	BAU Retrofit Capacity after Quantization[natural gas combined cycle w CCS es] ~~|
BAU Decrease in Capacity from CCUS Retrofits[biomass es]=
	BAU Retrofit Capacity after Quantization[biomass w CCS es] ~~|
BAU Decrease in Capacity from CCUS Retrofits[lignite es]=
	BAU Retrofit Capacity after Quantization[lignite w CCS es]
	~	MW
	~		|

BAU Decrease in Capacity from Mandated CCUS Retrofits[Electricity Source] :EXCEPT:    \
		[hard coal es],[natural gas combined cycle es],[biomass es],[lignite es]=
	0 ~~|
BAU Decrease in Capacity from Mandated CCUS Retrofits[hard coal es]=
	BPMCRS BAU Policy Mandated Capacity Retrofit Schedule[hard coal w CCS es] ~~|
BAU Decrease in Capacity from Mandated CCUS Retrofits[natural gas combined cycle es]=
	BPMCRS BAU Policy Mandated Capacity Retrofit Schedule[natural gas combined cycle w CCS es\
		] ~~|
BAU Decrease in Capacity from Mandated CCUS Retrofits[biomass es]=
	BPMCRS BAU Policy Mandated Capacity Retrofit Schedule[biomass w CCS es] ~~|
BAU Decrease in Capacity from Mandated CCUS Retrofits[lignite es]=
	BPMCRS BAU Policy Mandated Capacity Retrofit Schedule[lignite w CCS es]
	~	MW
	~		|

BAU Decrease in Demand by Hour for Diurnal Net Peak Load Reduction and RPS Compliance\
		[Electricity Timeslice,Hour]=
	BAU Decrease in Demand by Hour for Diurnal Net Peak Load Reduction excluding Hybrid Batteries\
		[Electricity Timeslice
	,Hour]
	~	MW*hr
	~		|

BAU Decrease in Demand by Hour for Diurnal Net Peak Load Reduction excluding Hybrid Batteries\
		[Electricity Timeslice,Hour]=
	BAU Shortfall in Electricity vs Daily Average by Hour after Seasonal Net Peak Load Reduction\
		[Electricity Timeslice,Hour]
	* MIN(
	    1,
	
	    ZIDZ(
	      SUM(BAU Increase in Demand by Hour for Diurnal Net Peak Load Reduction excluding Hybrid Batteries\
		[Electricity Timeslice,Hour!])
	        * BAU Weighted Average Round Trip Efficiency for Diurnal Shifting Excluding Hybrid Batteries\
		[Electricity Timeslice]
	      + BAU Maximum Daily Quantity of Electricity Reduced by Demand Response Programs for Net Peak Load Reduction\
		[Electricity Timeslice],
	
	      SUM(BAU Shortfall in Electricity vs Daily Average by Hour after Seasonal Net Peak Load Reduction\
		[Electricity Timeslice,Hour!])
	    )
	  )
	~	MW*hr
	~		|

BAU Decrease in Demand by Hour for Seasonal Net Peak Load Reduction[Electricity Timeslice\
		,Hour]=
	BAU Daily Decrease in Demand for Seasonal Net Peak Load Reduction[Electricity Timeslice\
		]
	* ZIDZ(
	    BAU Shortfall in Potenial Output from Surviving Capacity vs Annual Average by Hour\
		[Electricity Timeslice,Hour],
	    SUM(BAU Shortfall in Potenial Output from Surviving Capacity vs Annual Average by Hour\
		[Electricity Timeslice,Hour!])
	  )
	~	MW*hr
	~		|

BAU Demand for CCS Not Already Existing or In Progress[Industry Category,Emissions Type\
		]=
	MAX(
	  BAU CCS Retrofit Capacity Desired[Industry Category,Emissions Type]
	  - BAU Last Year Total Deployed and Under Construction CCS[Industry Category,Emissions Type\
		],
	
	  0
	)
	~	Dmnl
	~		|

BAU Demand Responsive Electricity Capacity for Electrolyzers=
	BAU Hydrogen Production by Pathway[electrolysis]
	* HPPECbP Hydrogen Production Percent Excess Capacity by Pathway[electrolysis]
	/ EHPpUC Electrolyzer Hydrogen Production per Unit Capacity
	
	 + BAU Hydrogen Production by Pathway[electrolysis with guaranteed clean electricity\
		]
	  * HPPECbP Hydrogen Production Percent Excess Capacity by Pathway[electrolysis with guaranteed clean electricity\
		]
	  / EHPpUC Electrolyzer Hydrogen Production per Unit Capacity
	~	MW
	~		|

BAU Desired Cost Driven Capacity Retirements[Electricity Source,Optimization Pass]=
	BAU Average Three Year Prior Net Loss per Unit Output[Electricity Source,Optimization Pass\
		]
	* CRpUNL Capacity Retired per Unit Net Loss[Electricity Source]
	~	MW
	~		|

BAU Desired Cost Driven Capacity Retirements Excluding Capacity Payment[Electricity Source\
		]=
	BAU Average Three Year Prior Net Loss per Unit Output Excluding Capacity Payment[Electricity Source\
		]
	* CRpUNL Capacity Retired per Unit Net Loss[Electricity Source]
	~	MW
	~		|

BAU Difference Between This Year and First Year Battery Cost=
	(First Year Battery Energy Cost per Unit Capacity
	  + First Year Battery Power Cost per Unit Capacity
	  / GBSC Diurnal Grid Battery Daily Storage Duration
	)
	
	- BAU Total Battery Cost per Unit Capacity
	~	$/(MW*hour)
	~		|

BAU Direct Components Pollutant Emissions[Building Type,Building Fuel,Pollutant]=
	SUM(BAU Building Components Energy Use[Building Type,Building Fuel,Building Component\
		!])
	* Buildings Fuel Pollutant Emissions Intensities This Year[Pollutant,Building Fuel]
	~	g pollutant
	~		|

BAU Dispatch Cost per Unit Electricity Output[Electricity Source]=
	BAU Dispatch Cost per Unit Electricity Output before Subsidies[Electricity Source]
	- BAU Variable Subsidies per Unit Electricity Output[Electricity Source]
	~	$/(MW*hour)
	~		|

BAU Dispatch Cost per Unit Electricity Output before Subsidies[Electricity Source]=
	BAU Weighted Average Electricity Fuel Cost per Unit Electricity Output[Electricity Source\
		]
	+ BAU Weighted Average Variable OM Cost per Unit Electricity Output[Electricity Source\
		]
	~	$/(MW*hour)
	~		|

BAU Dispatch or Opportunity Cost per Unit Electricity Output[Electricity Source] :EXCEPT:\
		    [hydro es]=
	BAU Dispatch Cost per Unit Electricity Output[Electricity Source] ~~|
BAU Dispatch or Opportunity Cost per Unit Electricity Output[hydro es]=
	HOC Hydro Opportunity Cost
	~	$/(MW*hr)
	~		|

BAU Distributed Electricity Source Capacity[Building Type,Electricity Source] :EXCEPT:\
		  [Building Type,solar PV es]=
	BDESC BAU Distributed Electricity Source Capacity[Building Type,Electricity Source] ~~|
BAU Distributed Electricity Source Capacity[Building Type,solar PV es]=
	MIN(
	  BDESC BAU Distributed Electricity Source Capacity[Building Type,solar PV es],
	
	  MDSC Maximum Distributed Solar Capacity[Building Type,solar PV es]
	)
	~	MW
	~		|

BAU Distribution Construction Costs=
	BAU Change in Peak Load*DCCpUIiPL Distribution Construction Cost per Unit Increase in Peak Load
	~	$
	~		|

BAU Distribution OM Costs=
	BAU Peak Electricity Load Growth Relative to Start Year
	* SYTaDC Start Year Distribution OM Costs
	~	$
	~		|

BAU District Heat and Hydrogen Fuel Other Tax or Subsidy Amount per Unit Energy[Industrial Fuel\
		]=
	BAU Fuel Tax by Sector[industrial fuel within all fuels,district heat and hydrogen sector\
		]
	~	$/BTU
	~		|

BAU District Heat and Hydrogen Sector Other Fuel Tax Revenue=
	SUM(
	  (BAU Fuel Used to Generate Heat[Industrial Fuel!]
	    + BAU Hydrogen Sector Fuel Use[Industrial Fuel!]
	  )
	  * BAU District Heat and Hydrogen Fuel Other Tax or Subsidy Amount per Unit Energy[\
		Industrial Fuel!]
	)
	~	$
	~		|

BAU District Heat Electricity Demand=
	BAU Fuel Used to Generate Heat[electricity if]
	* MWh per BTU
	~	MW*hr
	~		|

BAU District Heat Fuel Carbon Tax Amount per Unit Energy[Industrial Fuel]=
	BCTR BAU Carbon Tax Rate[district heat and hydrogen sector]
	/ Grams per Metric Ton CO2e
	* BAU District Heat Fuel Taxable CO2e Emissions Intensity[Industrial Fuel]
	~	$/BTU
	~	We need this subscripted only by fuel type, not industry type, for use \
		calculating percentage differences from BAU.  Carbon intensity of fuels \
		should not vary significantly based on which industry burns those fuels, \
		as CCS is not considered here.  Accordingly, we use the cement industry as \
		our model, as cement is produced worldwide, is a major emitter, and has \
		unique process emissions, and therefore is unlikely to be repurposed as \
		another industry in an EPS adaptation.
	|

BAU District Heat Fuel Cost per Unit Energy[Industrial Fuel]=
	MAX(BAU Pretax Fuel Price by Sector Including Endogenous Electricity Prices[industrial fuel within all fuels\
		,district heat and hydrogen sector]
	  + BAU District Heat Fuel Total Tax or Subsidy Amount per Unit Energy[Industrial Fuel\
		],
	0
	)
	~	$/BTU
	~		|

BAU District Heat Fuel Taxable CO2e Emissions Intensity[Industrial Fuel]=
	SUM(
	  Industrial Fuel Pollutant Emissions Intensities This Year[cement and other nonmetallic minerals 239\
		,Pollutant!,Industrial Fuel
	]
	  * GWP by Pollutant[Pollutant!]
	  * BPTbCP BAU District Heat Pollutants Taxed by Carbon Pricing[Pollutant!]
	)
	~	g CO2e/BTU
	~		|

BAU District Heat Fuel Total Tax or Subsidy Amount per Unit Energy[Industrial Fuel]=
	BAU District Heat Fuel Carbon Tax Amount per Unit Energy[Industrial Fuel]
	+ BAU District Heat and Hydrogen Fuel Other Tax or Subsidy Amount per Unit Energy[Industrial Fuel\
		]
	~	$/BTU
	~		|

BAU District Heat Provided by Dedicated Facilities[Industrial Fuel]=
	BAU Total District Heat Use by Fuel before CHP[Industrial Fuel]
	* (1 - BFoHfC BAU Fraction of Heat from CHP[Industrial Fuel])
	~	BTU
	~		|

BAU District Heat Sector Carbon Tax Revenue=
	SUM(
	  BAU Fuel Used to Generate Heat[Industrial Fuel!]
	  * BAU District Heat Fuel Carbon Tax Amount per Unit Energy[Industrial Fuel!]
	)
	~	$
	~		|

BAU District Heating Pollutant Emissions[Pollutant,Industrial Fuel]=
	BAU Fuel Used to Generate Heat[Industrial Fuel]
	  * Industrial Fuel Pollutant Emissions Intensities This Year[cement and other nonmetallic minerals 239\
		,Pollutant,Industrial Fuel]
	~	g pollutant
	~	District heating isn't an industry, but it uses industrial sector fuel \
		emissions intensities.  Since the emissions intensities are subscripted by \
		industry, we must choose an industry to use, though the emissions \
		intensities may be the same for all industries.  We use the cement \
		industry as our model, as cement is produced all over the world, is a \
		major emitter, and therefore is unlikely to be repurposed as another \
		industry in EPS model adaptations.
	|

BAU District Heating Pollutant Emissions Summed Across Fuels[Pollutant]=
	SUM(BAU District Heating Pollutant Emissions[Pollutant,Industrial Fuel!])
	~	g pollutant
	~		~	:SUPPLEMENTARY 
	|

BAU Domestic Content Share of Consumption by ISIC Code from Exogenous Data[ISIC Code]\
		=
	BDCSoCbIC BAU Domestic Content Share of Consumption by ISIC Code[ISIC Code]
	* (1 + BPCiDCSbIC BAU Percent Change in Domestic Content Share by ISIC Code[ISIC Code\
		])
	~	Dmnl
	~		|

BAU Domestic Employee Compensation by ISIC Code[ISIC Code]=
	BEaCP BAU Total Employee Compensation
	* ZIDZ(
	  BAU Employee Compensation by ISIC Code by Year[ISIC Code],
	
	  SUM(BAU Employee Compensation by ISIC Code by Year[ISIC Code!])
	  )
	~	$
	~		|

BAU Domestic Employment by Demographic Trait[Demographic Trait]=
	SUM(
	  BAU Domestic Employment by ISIC Code[ISIC Code!]
	  * DoEbIC Demographics of Employees by ISIC Code[ISIC Code!,Demographic Trait]
	)
	~	jobs
	~		|

BAU Domestic Employment by ISIC Code[ISIC Code]=
	BEaCP BAU Number of Employees
	* ZIDZ(
	  BAU Employment by ISIC Code by Year[ISIC Code],
	
	  SUM(BAU Employment by ISIC Code by Year[ISIC Code!])
	  )
	~	jobs
	~		|

BAU Domestic Energy Revenue by Producing ISIC Code[ISIC Code]=
	SUM(
	  BAU Fuel Industry After Tax Revenue by Fuel[All Fuels!]
	  * FtPICM Fuel to Producing ISIC Code Map[All Fuels!,ISIC Code]
	  * BAU Domestic Content Share of Consumption by ISIC Code from Exogenous Data[ISIC Code\
		]
	  * Share of Fuel Production by Fuel within ISIC Code[All Fuels!,ISIC Code]
	)
	~	$
	~		|

BAU Domestic Jobs by Union Status[union]=
	QUANTUM(
	  SUM(
	    BAU Domestic Employment by ISIC Code[ISIC Code!]
	    * URPbIC Union Representation Percentage by ISIC Code[ISIC Code!]
	  ),
	
	  Quantization Size for Jobs
	) ~~|
BAU Domestic Jobs by Union Status[nonunion]=
	QUANTUM(
	  SUM(
	    BAU Domestic Employment by ISIC Code[ISIC Code!]
	    * (1 - URPbIC Union Representation Percentage by ISIC Code[ISIC Code!])
	  ),
	
	  Quantization Size for Jobs
	)
	~	jobs
	~		|

BAU Domestically Produced Energy by Producing ISIC Code[ISIC Code]=
	BAU Total Primary Energy Use by Producing ISIC Code[ISIC Code]
	* BAU Domestic Content Share of Consumption by ISIC Code from Exogenous Data[ISIC Code\
		]
	~	BTU
	~		|

BAU Duration Multiplier for Subsidies for Carbon Sequestration[Electricity Source]=
	ZIDZ(
	  (1/(1-ACTR Average Corporate Tax Rate))
	  *BAU Capital Recovery Factor for Power Plants[Electricity Source],
	  BAU Capital Recovery Factor for Subisides per Unit Electricity Output[Electricity Source\
		]
	)
	~	Dmnl
	~		|

BAU Duration Multiplier for Subsidies per Unit Electricity Output[Electricity Source]\
		=
	ZIDZ(
	  (1/(1-ACTR Average Corporate Tax Rate))
	  *BAU Capital Recovery Factor for Power Plants[Electricity Source],
	  BAU Capital Recovery Factor for Subsidies per Unit Electricity Output[Electricity Source\
		]
	)
	~	Dmnl
	~		|

BAU Economic Capacity Retirements by Optimization Pass[Electricity Source,Optimization Pass\
		]=
	QUANTUM(
	  MIN(BAU Desired Cost Driven Capacity Retirements[Electricity Source,Optimization Pass\
		],
	    BAU Max Capacity that Can be Retired Economically by Plant Type[Electricity Source\
		]),
	
	  MPPC Minimum Power Plant Capacity[Electricity Source]
	 )
	~	MW
	~	If the same power plant is scheduled to retire and is also uneconomic to \
		operate, that plant retires only once, not twice.  Therefore, we must use \
		a MAX() function here instead of adding the capacity that meets each \
		retirement condition.
	|

BAU Economic Capacity Retirements Excluding Capacity Payment[Electricity Source]=
	QUANTUM(
	  MIN(BAU Desired Cost Driven Capacity Retirements Excluding Capacity Payment[Electricity Source\
		],
	    BAU Max Capacity that Can be Retired Economically by Plant Type[Electricity Source\
		]),
	
	  MPPC Minimum Power Plant Capacity[Electricity Source]
	 )
	~	MW
	~		|

BAU Elec Portfolio Percentage that Would be Achieved with Only Surviving Plants[Clean Elec Requirement\
		]=
	ZIDZ(
	  BAU Surviving Potential Elec Portfolio Qualifying Output[Clean Elec Requirement],
	
	  SUM(BAU Total Electricity Demand by Hour After Demand Altering Technologies Excluding New Hybrid Batteries\
		[Electricity Timeslice!,Hour!]
	      *SHELF Days per Electricity Timeslice[Electricity Timeslice!])
	)
	~	Dmnl
	~		|

BAU Elec Portfolio Percentage to Seek This Year[Clean Elec Requirement]=
	MIN(
	
	  0.9999,
	
	  MAX(
	    0,
	
	    MAX(
	      BAU Legally Required Elec Portfolio Percentage[Clean Elec Requirement],
	
	      BAU Elec Portfolio Percentage with Foresight[Clean Elec Requirement]
	      * BESHFoFRV Boolean Electricity Suppliers Have Foresight of Future RPS Values
	    )
	  )
	)
	~	Dmnl
	~		|

BAU Elec Portfolio Percentage with Foresight[Clean Elec Requirement]=
	BAU Elec Portfolio Percentage that Would be Achieved with Only Surviving Plants[Clean Elec Requirement\
		]
	+ VMAX(BAU Slope of Line Approaching Future Elec Portfolio Percentages by Year[Future Year\
		!,Clean Elec Requirement])
	~	Dmnl
	~		|

BAU Elec Portfolio Std Achieved This Year[Clean Elec Requirement]=
	SUM(
	  BAU Electricity Generation by Type[Electricity Source!]
	  * Elec Portfolio Qualifying Sources[Electricity Source!,Clean Elec Requirement]
	)
	/ SUM(BAU Electricity Generation by Type[Electricity Source!])
	~	Dmnl
	~		~	:SUPPLEMENTARY 
	|

BAU Elec Supplier Fixed OM Costs[Electricity Source]=
	BAU Electricity Generation Capacity[Electricity Source]
	* BAU Weighted Average Annual Fixed OM Cost per Unit Capacity[Electricity Source]
	~	$
	~		|

BAU Elec Supplier Variable OM Costs[Electricity Source]=
	BAU Electricity Generation by Type[Electricity Source]
	* BAU Weighted Average Variable OM Cost per Unit Electricity Output[Electricity Source\
		]
	~	$
	~		|

BAU Electricity Demand by Industry[Industry Category]=
	BAU Industrial Fuel Use for Energy Purposes[Industry Category,electricity if]
	* MWh per BTU
	~	MW*hour
	~		|

BAU Electricity Demand Mapped to ElecDemand[Electricity Timeslice,Hour,ElecDemand]=
	BAU Unmet Electricity Demand After RPS Dispatch[Electricity Timeslice,Hour]
	~	(MW*hr)
	~		|

BAU Electricity Dispatch Required to Satisfy Elec Portfolio Stds[Electricity Timeslice\
		,Hour,Clean Elec Requirement]=
	BAU Total Electricity Demand by Hour After Demand Altering Technologies[Electricity Timeslice
	,Hour]
	* BAU Legally Required Elec Portfolio Percentage[Clean Elec Requirement]
	~	MW*hr
	~		|

BAU Electricity Dispatched by Guaranteed Dispatch by Hour[Electricity Source,Electricity Timeslice\
		,Hour]=
	IF THEN ELSE(
	 SUM(BAU First Pass Electricity Dispatched by Guaranteed Dispatch by Hour[Electricity Source\
		!,Electricity Timeslice,Hour]) > BAU Total Electricity Demand by Hour After Demand Altering Technologies\
		[Electricity Timeslice,Hour],
	
	 BAU First Pass Electricity Dispatched by Guaranteed Dispatch by Hour[Electricity Source\
		,Electricity Timeslice,Hour]
	 * MIN(
	     1,
	     BAU Total Electricity Demand by Hour After Demand Altering Technologies[Electricity Timeslice\
		,Hour]/
	     SUM(BAU First Pass Electricity Dispatched by Guaranteed Dispatch by Hour[Electricity Source\
		!,Electricity Timeslice,Hour])
	     ),
	 BAU First Pass Electricity Dispatched by Guaranteed Dispatch by Hour[Electricity Source\
		,Electricity Timeslice,Hour]
	)
	~	MW*hr
	~	If the amount of guaranteed dispatch after the first pass still exceeds \
		the total amount of electricity demand in a given hour, the first tier \
		sources of guaranteed dispatch are scaled back proportionately so that \
		total hourly demand is not exceeded.
	|

BAU Electricity Dispatched by Least Cost by Hour[Electricity Timeslice,Hour,Electricity Source\
		]=
	IF THEN ELSE(
	     BAU Unmet Electricity Demand After RPS Dispatch[Electricity Timeslice,Hour]*MWhr Tolerance Unit Correction Factor\
		<
	Tolerance,
	     0,
	     SUPPLY AT PRICE(
	       BAU Available Capacity for Least Cost Dispatch Mapped[Electricity Timeslice,Hour\
		,Electricity Source
	],
	       BAU Power Plant Least Cost Dispatch Parameters as Vector[Electricity Source,ptype\
		],
	       BAU Electricity Market Price Adjusted for Zero Least Cost Dispatch Hours[Electricity Timeslice\
		,Hour])
	
	  )
	~	MW*hr
	~	Although "last pass" is intended to contain a single element, we must sum \
		across it becuase it is technically a subrange.
	|

BAU Electricity Dispatched to Meet Elec Portfolio Stds[Electricity Timeslice,Hour,Electricity Source\
		]=
	BAU Zero and Negative Cost Electricity Dispatched to Meet RPS[Electricity Timeslice,\
		Hour,Electricity Source]
	+ BAU Positive Cost Electricity Dispatched to Meet RPS[Electricity Timeslice,Hour,Electricity Source\
		]
	+ BAU Zero and Negative Cost Electricity Dispatched to Meet CES[Electricity Source,Electricity Timeslice\
		,Hour]
	+ BAU Positive Cost Electricity Dispatched to Meet CES[Electricity Timeslice,Hour,Electricity Source\
		]
	~	MW*hr
	~		|

BAU Electricity Exports by Hour[Electricity Timeslice,Hour,pass1]=
	IF THEN ELSE(BAU Daily Net Imported Electricity>=0,0,
	  MAX(MaMHEIaE Minimum Hourly Exports,MIN(MaMHEIaE Maximum Hourly Exports,
	    -BAU Daily Net Imported Electricity*BAU Share of Exports by Hour by Optimization Pass\
		[Electricity Timeslice,Hour,pass1]
	   )
	  )
	) ~~|
BAU Electricity Exports by Hour[Electricity Timeslice,Hour,current pass]=
	IF THEN ELSE(BAU Daily Net Imported Electricity>=0,0,
	MAX(MaMHEIaE Minimum Hourly Exports,MIN(MaMHEIaE Maximum Hourly Exports,
	  BAU Remaining Electricity Exports by Electricity Timeslice by Optimization Pass[Electricity Timeslice\
		,preceeding pass
	]
	  *BAU Share of Exports by Hour by Optimization Pass[Electricity Timeslice,Hour,current pass\
		]
	  + BAU Electricity Exports by Hour[Electricity Timeslice,Hour,preceeding pass]
	   )
	 )
	)
	~	MW*hour
	~		|

BAU Electricity Fuel Carbon Tax Amount per Unit Energy[Electricity Source]=
	BCTR BAU Carbon Tax Rate[electricity sector]
	/ Grams per Metric Ton CO2e
	* BAU Electricity Fuel Taxable CO2e Emissions Intensity[Electricity Source]
	~	$/BTU
	~		|

BAU Electricity Fuel Cost per Unit Energy[Electricity Source]=
	MAX(BAU Pretax Fuel Price by Sector Including Endogenous Electricity Prices[electricity source within all fuels\
		,electricity sector]
	    * (1 + FSPbPPT Fuel Surcharge Percentage by Power Plant Type[Electricity Source]\
		)
	
	  + BAU Electricity Fuel Total Tax or Subsidy Amount per Unit Energy[Electricity Source\
		],
	0
	)
	~	$/BTU
	~	We apply the fuel surcharge to the fuel cost but not to the fuel taxes.  \
		Fuel taxes are based on energy content and on GHG emissions, while the \
		surcharge is based on purchased quantity and cadence, and so should not \
		affect the amount of tax.
	|

BAU Electricity Fuel Other Tax or Subsidy Amount per Unit Energy[Electricity Source]=
	BAU Fuel Tax by Sector[electricity source within all fuels,electricity sector]
	~	$/BTU
	~		|

BAU Electricity Fuel Pollutant Emissions Intensity per MWh[Electricity Source,Pollutant\
		]=
	Electricity Fuel Pollutant Emissions Intensities This Year[Pollutant,Electricity Source\
		]
	* BAU Weighted Average Heat Rate by Electricity Fuel[Electricity Source]
	~	g pollutant/(MW*hour)
	~		|

BAU Electricity Fuel Taxable CO2e Emissions Intensity[Electricity Source]=
	SUM(
	  Electricity Fuel Pollutant Emissions Intensities This Year[Pollutant!,Electricity Source\
		]
	  * GWP by Pollutant[Pollutant!]
	  * BPTbCP BAU Electricity Pollutants Taxed by Carbon Pricing[Electricity Source,Pollutant\
		!]
	)
	~	g CO2e/BTU
	~		|

BAU Electricity Fuel Total Tax or Subsidy Amount per Unit Energy[Electricity Source]=
	BAU Electricity Fuel Carbon Tax Amount per Unit Energy[Electricity Source]
	+ BAU Electricity Fuel Other Tax or Subsidy Amount per Unit Energy[Electricity Source\
		]
	~	$/BTU
	~		|

BAU Electricity Fuel Use[Electricity Source]=
	BAU Electricity Generation by Type[Electricity Source]
	  * BAU Weighted Average Heat Rate by Electricity Fuel[Electricity Source]
	~	BTU
	~		|

BAU Electricity Generation by Type[Electricity Source]=
	QUANTUM(
	  BAU Annual Electricity Dispatched by Guaranteed Dispatch[Electricity Source]
	  + BAU Annual Electricity Dispatched by Least Cost[Electricity Source]
	  + BAU Annual Electricity Dispatched to Meet Elec Portfolio Stds[Electricity Source\
		],
	
	  Quantization Size for Annual Dispatch
	)
	~	MW*hour
	~		|

BAU Electricity Generation by Type Including Distributed Generation[Electricity Source\
		]=
	BAU Electricity Generation by Type[Electricity Source]
	+ BAU Annual Output from Distributed Electricity Capacity[Electricity Source]
	~	MW*hour
	~		|

BAU Electricity Generation Capacity[Electricity Source]=
	IF THEN ELSE(
	
	 SUM(BAU Electricity Generation Capacity by Vintage[Electricity Source,Modeled Vintage\
		!]) < MPPC Minimum Power Plant Capacity[Electricity Source] * 0.1,
	
	 0,
	
	 SUM(BAU Electricity Generation Capacity by Vintage[Electricity Source,Modeled Vintage\
		!])
	)
	~	MW
	~	To avoid cases where quantized planned retirements leave only a small \
		fraction of one plant online,we round down to 0 in cases where less than \
		10% of the minimum power plant capacity is remaining across vintages for a \
		given plant type.
	|

BAU Electricity Generation Capacity before Dispatchable CES Additions[Electricity Source\
		]=
	BAU Surviving Electricity Generation Capacity before Economic Retirements[Electricity Source\
		]
	+BAU New Policy Mandated Capacity[Electricity Source]
	~	MW
	~		|

BAU Electricity Generation Capacity before Reliability Additions[Electricity Source]=
	BAU Surviving Electricity Generation Capacity before Economic Retirements[Electricity Source\
		]
	+BAU New Generation Capacity before Reliability Additions[Electricity Source]
	~	MW
	~		|

BAU Electricity Generation Capacity by Type Including Distributed Generation[Electricity Source\
		]=
	BAU Electricity Generation Capacity[Electricity Source]
	+ SUM(BAU Distributed Electricity Source Capacity[Building Type!,Electricity Source]\
		)
	~	MW
	~		|

BAU Electricity Generation Capacity by Type Including Distributed Generation as of Two Years Ago\
		[Electricity Source]= DELAY FIXED (
	BAU Last Year Electricity Generation Capacity by Type Including Distributed Generation\
		[Electricity Source],
	1,
	Start Year Electricity Generation Capacity Summed Across Vintages[Electricity Source\
		] + SUM(Start Year Distributed Electricity Capacity
	[Building Type!,Electricity Source]))
	~	MW
	~		|

BAU Electricity Generation Capacity by Vintage[Electricity Source,Modeled Vintage]=
	BAU Last Year Electricity Generation Capacity by Vintage[Electricity Source,Modeled Vintage\
		]
	- BAU Capacity Retirements by Vintage[Electricity Source,Modeled Vintage] * One Year
	+ BAU New Generation Capacity[Electricity Source]
	    * This Year Modeled Vintage Flag[Modeled Vintage]
	~	MW
	~		|

BAU Electricity Generation Capacity Relative to Start Year=
	SUM(BAU Electricity Generation Capacity[Electricity Source!])
	/ SUM(BHRaSYC Start Year Electricity Generation Capacity by Vintage[Electricity Source\
		!,Modeled Vintage!])
	~	Dmnl
	~		|

BAU Electricity Imports by Hour[Electricity Timeslice,Hour,pass1]=
	IF THEN ELSE(BAU Daily Net Imported Electricity<=0,0,
	  MAX(MaMHEIaE Minimum Hourly Imports,MIN(MaMHEIaE Maximum Hourly Imports,
	  BAU Daily Net Imported Electricity*BAU Share of Imports by Hour by Optimization Pass\
		[Electricity Timeslice,Hour,pass1]
	   )
	  )
	) ~~|
BAU Electricity Imports by Hour[Electricity Timeslice,Hour,current pass]=
	IF THEN ELSE(BAU Daily Net Imported Electricity<=0,0,
	MAX(MaMHEIaE Minimum Hourly Imports,MIN(MaMHEIaE Maximum Hourly Imports,
	  BAU Remaining Electricity Imports by Electricity Timeslice and Optimization Pass[Electricity Timeslice\
		,preceeding pass
	]*BAU Share of Imports by Hour by Optimization Pass
	[Electricity Timeslice,Hour,current pass]+ BAU Electricity Imports by Hour
	[Electricity Timeslice,Hour,preceeding pass]
	 )
	)
	)
	~	MW*hr
	~		|

BAU Electricity Market Price[Electricity Timeslice,Hour]=
	FIND MARKET PRICE(
	 BAU Electricity Demand Mapped to ElecDemand[Electricity Timeslice,Hour,demand1],
	 Fixed Electricity Demand Vector[demand1,ptype],
	 BAU Available Capacity for Least Cost Dispatch Mapped[Electricity Timeslice,Hour,hard coal es\
		],
	 BAU Power Plant Least Cost Dispatch Parameters as Vector[hard coal es,ptype]
	)
	~	$/(MW*hr)
	~		|

BAU Electricity Market Price Adjusted for Zero Least Cost Dispatch Hours[Electricity Timeslice\
		,Hour]=
	IF THEN ELSE(BAU Electricity Demand Mapped to ElecDemand[Electricity Timeslice,Hour,\
		demand1]*MWhr Tolerance Unit Correction Factor<Tolerance,0,BAU Electricity Market Price
	[Electricity Timeslice,Hour])
	~	$/(MW*hr)
	~		|

BAU Electricity Sector Carbon Tax Rebate due to CCS[Electricity Source]=
	BAU Amount of CO2 Sequestered by Electricity Sector[Electricity Source]
	* BCTR BAU Carbon Tax Rate[electricity sector]
	~	$
	~		|

BAU Electricity Sector Carbon Tax Revenue=
	SUM(BAU Electricity Fuel Use[Electricity Source!]
	* BAU Electricity Fuel Carbon Tax Amount per Unit Energy[Electricity Source!])
	~	$
	~		|

BAU Electricity Sector CCS Transportation and Storage Costs[Electricity Source]=
	BAU Electricity Sector CCS Transportation and Storage Costs per MWh[Electricity Source\
		]
	* BAU Electricity Generation by Type[Electricity Source]
	~	$
	~		|

BAU Electricity Sector CCS Transportation and Storage Costs per MWh[Electricity Source\
		]=
	(CCSTaSC CCS Transportation and Storage Costs
	- CCSTaSC CCS Transportation and Storage Subsidies)
	
	* BAU Metric Tons CO2 Stored per MWh[Electricity Source]
	~	$/(MW*hour)
	~		|

BAU Electricity Sector CCS Transportation and Storage Subsidies[Electricity Source]=
	BAU Electricity Generation by Type[Electricity Source]
	* BAU Metric Tons CO2 Stored per MWh[Electricity Source]
	
	* CCSTaSC CCS Transportation and Storage Subsidies
	~	$
	~		|

BAU Electricity Sector CO2e Emissions=
	SUM(
	  BAU Electricity Sector Pollutant Emissions[Pollutant!,Electricity Source!]
	  * GWP by Pollutant[Pollutant!]
	)
	~	g CO2e
	~		~	:SUPPLEMENTARY 
	|

BAU Electricity Sector Other Fuel Tax Revenue=
	SUM(BAU Electricity Fuel Use[Electricity Source!]
	* BAU Electricity Fuel Other Tax or Subsidy Amount per Unit Energy[Electricity Source\
		!])
	~	$
	~		|

BAU Electricity Sector Pollutant Emissions[Pollutant,Electricity Source] :EXCEPT:    \
		[CO2,biomass es],[CO2,biomass w CCS es]=
	MAX(
	  0,
	
	  (
	    BAU Electricity Sector Pollutant Emissions before CCS[Pollutant,Electricity Source\
		]
	    - BAU This Year Pollutants Sequestered by Electricity Sector[Pollutant,Electricity Source\
		]
	  )
	  * (1 + BAU Perc Change in In Scope Emissions due to Electricity Exports)
	  + BAU Absolute Change in In Scope Emissions due to Electricity Imports[Pollutant,Electricity Source\
		]
	) ~~|
BAU Electricity Sector Pollutant Emissions[CO2,biomass es]=
	(
	  BAU Electricity Sector Pollutant Emissions before CCS[CO2,biomass es]
	  - BAU This Year Pollutants Sequestered by Electricity Sector[CO2,biomass es]
	)
	* (1 + BAU Perc Change in In Scope Emissions due to Electricity Exports)
	+ BAU Absolute Change in In Scope Emissions due to Electricity Imports[CO2,biomass es\
		] ~~|
BAU Electricity Sector Pollutant Emissions[CO2,biomass w CCS es]=
	(
	  BAU Electricity Sector Pollutant Emissions before CCS[CO2,biomass w CCS es]
	  - BAU This Year Pollutants Sequestered by Electricity Sector[CO2,biomass w CCS es]
	)
	* (1 + BAU Perc Change in In Scope Emissions due to Electricity Exports)
	+ BAU Absolute Change in In Scope Emissions due to Electricity Imports[CO2,biomass w CCS es\
		]
	~	g pollutant
	~	CO2 emissions from biomass are the only emissions type that is allowed to \
		be negative.
	|

BAU Electricity Sector Pollutant Emissions before CCS[Pollutant,Electricity Source]=
	BAU Electricity Generation by Type[Electricity Source]
	  * BAU Electricity Fuel Pollutant Emissions Intensity per MWh[Electricity Source,Pollutant\
		]
	~	g pollutant
	~		|

BAU Electricity Supplier Costs Recovered through Electricity Rates per Unit Electricity Delivered\
		=
	(BAU Electricity Supplier Recoverable OM and Other Expenditures
	   +BAU Wholesale Energy Market Costs
	   +BAU This Year Capacity Market Repayment*One Year
	   +BAU This Year Ongoing CES Costs
	   +SYTaDC Start Year Transmission Capital Costs
	   +SYTaDC Start Year Distribution Capital Costs
	)/
	
	   BAU Total Electricity Demand Plus Exports in BTU
	~	$/BTU
	~		|

BAU Electricity Supplier Costs Recovered through Electricity Rates per Unit Electricity Delivered for Cost of Service Rates\
		=
	QUANTUM(
	  BAU Total Annual Recoverable Costs for Cost of Service Rates
	  /BAU Total Electricity Demand in BTU,
	
	  Quantization Size for Dollars
	)
	~	$/BTU
	~		|

BAU Electricity Supplier Other Expenditures=
	SUM(BAU Cost of Providing Demand Response by Recipient[Cash Flow Entity!])
	+ BAU Amortized Decommissioning Costs
	~	$
	~		|

BAU Electricity Supplier Recoverable OM and Other Expenditures=
	BAU Repayment of Financing for Change in Electricity Sector Capital Expenditures including Construction Subsidies
	+BAU Amount Spent on Importing Electricity
	+BAU Electricity Transmission and Distribution OM Expenditures
	+BAU Electricity Supplier Other Expenditures
	{-BAU Amount Received from Exporting Electricity}
	-SUM(BAU Electricity Sector Carbon Tax Rebate due to CCS[Electricity Source!])
	~	$
	~		|

BAU Electricity Transmission and Distribution OM Expenditures=
	BAU Distribution OM Costs
	+BAU Transmission OM Costs
	~	$
	~		|

BAU Employee Compensation by ISIC Code by Year[ISIC Code]=
	BECbIC BAU Employee Compensation by ISIC Code[ISIC Code]
	* (1 + BAU Percent Change in Employment and EE Compensation by ISIC Code[ISIC Code])
	~	$
	~		|

BAU Employment by ISIC Code by Year[ISIC Code]=
	BEbIC BAU Employment by ISIC Code[ISIC Code]
	* (1 + BAU Percent Change in Employment and EE Compensation by ISIC Code[ISIC Code])
	~	jobs
	~		|

BAU Energy Exports including Electricity[All Fuels] :EXCEPT: [electricity]=
	QUANTUM(
	  BAU Fuel Production Imports and Exports[All Fuels,exports],
	  QSfE Quantization Size for Energy
	) ~~|
BAU Energy Exports including Electricity[electricity]=
	EIaE BAU Exported Electricity
	/ MWh per BTU
	~	BTU
	~		~	:SUPPLEMENTARY 
	|

BAU Energy Imports including Electricity[All Fuels] :EXCEPT:  [electricity]=
	QUANTUM(
	  BAU Fuel Production Imports and Exports[All Fuels,imports],
	  QSfE Quantization Size for Energy
	) ~~|
BAU Energy Imports including Electricity[electricity]=
	BAU Imported Electricity
	/ MWh per BTU
	~	BTU
	~		|

BAU Energy Intensity of Industrial Production by Fuel and Process for New Equipment in Electricity Equivalent\
		[Industry Category
,Industrial Fuel,Industrial Process]=
	Start Year Energy Intensity of Industrial Production by Fuel and Process in Electricity Equivalent\
		[Industry Category,Industrial Fuel,Industrial Process]
	* BAU New Industrial Equipment Energy Intensity[Industry Category,Industrial Fuel,Industrial Process\
		]
	/ SYIEUEFbIPaF Start Year Industrial Equipment Unit Energy Factor by Industrial Process and Fuel\
		[Industrial Fuel,Industrial Process]
	~	BTU/$
	~		|

BAU Energy Intensity of Industrial Production by Fuel for New Equipment in Electricity Equivalent\
		[Industry Category,Industrial Fuel]=
	SUM(BAU Energy Intensity of Industrial Production by Fuel and Process for New Equipment in Electricity Equivalent\
		[Industry Category,Industrial Fuel,Industrial Process!])
	~	BTU/$
	~		|

BAU Energy Production including Energy Carriers[All Fuels] :EXCEPT:    [electricity],\
		[heat],[hydrogen]=
	QUANTUM(
	  BAU Fuel Production Imports and Exports[All Fuels,production],
	  QSfE Quantization Size for Energy
	) ~~|
BAU Energy Production including Energy Carriers[electricity]=
	SUM(BAU Electricity Generation by Type[Electricity Source!])
	/ MWh per BTU ~~|
BAU Energy Production including Energy Carriers[heat]=
	QUANTUM(
	  BAU Total District Heat Use,
	  QSfE Quantization Size for Energy
	) ~~|
BAU Energy Production including Energy Carriers[hydrogen]=
	QUANTUM(
	  SUM(BAU Hydrogen Production by Pathway[Hydrogen Production Pathway!]),
	  QSfE Quantization Size for Energy
	)
	~	BTU
	~		|

BAU Energy Production per Unit Output[ISIC Code]=
	ZIDZ(
	
	  BAU Fuel Production Mapped to ISIC Codes[ISIC Code],
	
	  BAU Output by ISIC Code by Year[ISIC Code]
	)
	~	BTU/$
	~		|

BAU Excess Electricity vs Daily Average by Hour after Seasonal Net Peak Load Reduction\
		[Electricity Timeslice,Hour]=
	MAX(
	  0,
	
	  BAU Spare Potential Output from Surviving Capacity by Hour after Seasonal Net Peak Load Reduction\
		[Electricity Timeslice,Hour]
	  - BAU Daily Average Hourly Spare Potential Output from Surviving Capacity[Electricity Timeslice\
		]
	)
	~	MW*hr
	~		|

BAU Excess Potenial Output from Surviving Capacity vs Annual Average by Hour[Electricity Timeslice\
		,Hour]=
	MAX(
	  0,
	
	  BAU Spare Potential Output from Surviving Capacity by Hour[Electricity Timeslice,Hour\
		]
	  - BAU Annual Average Hourly Spare Potential Output from Surviving Capacity
	)
	~	MW*hr
	~		|

BAU Expected Achievable Annual CES by Optimization Pass[Optimization Pass]=
	SUM(
	  MIN(
	    BAU Expected Hourly Output from CES Qualifying Resources Irrespective of Electricity Demand\
		[Electricity Timeslice
	!,Hour!,Optimization Pass],
	   BAU Total Qualifying CES Electricity Demand by Hour After Demand Altering Technologies\
		[Electricity Timeslice
	!,Hour!]
	  )
	  * SHELF Days per Electricity Timeslice[Electricity Timeslice!]
	)
	/ SUM(
	    BAU Total Qualifying CES Electricity Demand by Hour After Demand Altering Technologies\
		[Electricity Timeslice!,Hour!]
	    * SHELF Days per Electricity Timeslice[Electricity Timeslice!]
	  )
	~	Dmnl
	~		|

BAU Expected Achievable Annual RPS by Optimization Pass[Optimization Pass]=
	SUM(
	  MIN(
	    BAU Expected Hourly Output from RPS Qualifying Resources Irrespective of Electricity Demand\
		[Electricity Timeslice
	!,Hour!,Optimization Pass],
	   BAU Total Qualifying RPS Electricity Demand by Hour After Demand Altering Technologies\
		[Electricity Timeslice
	!,Hour!]
	  )
	  * SHELF Days per Electricity Timeslice[Electricity Timeslice!]
	)
	/ SUM(
	    BAU Total Qualifying RPS Electricity Demand by Hour After Demand Altering Technologies\
		[Electricity Timeslice!,Hour!]
	    * SHELF Days per Electricity Timeslice[Electricity Timeslice!]
	  )
	~	Dmnl
	~		|

BAU Expected Capacity After Guaranteed Dispatch[Electricity Source,Electricity Timeslice\
		,Hour]=
	MAX(0,
	  BAU Expected Capacity by Hour[Electricity Source,Electricity Timeslice,Hour]
	  -BAU Electricity Dispatched by Guaranteed Dispatch by Hour[Electricity Source,Electricity Timeslice\
		,Hour]/One Hour
	 )
	~	MW
	~		|

BAU Expected Capacity by Hour[Electricity Source, Electricity Timeslice, Hour]=
	BAU Electricity Generation Capacity[Electricity Source]
	* BAU Weighted Average Expected Capacity Factors by Hour Without Hypothetical Adjustments\
		[Electricity Source,Electricity Timeslice,Hour]
	* (1 - BAU Share of Electricity Generation Capacity Built This Year[Electricity Source\
		] * TACFMfPBTY Time Adjusted Capacity Factor Multiplier for Plants Built This Year
	[Electricity Source])
	~	MW
	~		|

BAU Expected Capacity Factor x Hours per Year for Plants Built This Year[Electricity Source\
		]=
	IF THEN ELSE(ABS(BAU Last Year Electricity Generation Capacity[Electricity Source
	])*MW Tolerance Unit Correction Factor < Tolerance,
	                      SUM(BAU Three Year Weighted Average Hypothetical Electricity Capacity Factor\
		[Electricity Timeslice
	!,Hour!,Electricity Source]
	                     * SHELF Days per Electricity Timeslice[Electricity Timeslice!]
	                     * One Hour
	                   
	                ),
	            SUM(BAU Expected Capacity Factors by Hour for Plants Built This Year[Electricity Source
	,Electricity Timeslice!,Hour!]
	                * SHELF Days per Electricity Timeslice[Electricity Timeslice!]
	                * One Hour
	            )
	 )
	~	hours
	~		|

BAU Expected Capacity Factor x Hours per Year for Plants Built This Year Without Hypothetical Calculations\
		[Electricity Source]=
	SUM(
	  BAU Expected Capacity Factors by Hour for Plants Built This Year Without Hypothetical Calculations\
		[Electricity Source,Electricity Timeslice!,Hour!]
	  * SHELF Days per Electricity Timeslice[Electricity Timeslice!]
	  * One Hour
	)
	~	hours
	~		|

BAU Expected Capacity Factors by Hour for Hybrid Plants Built This Year[Hybrid Electricity Source\
		,Electricity Timeslice,Hour]=
	BAU Expected Capacity Factors by Hour for Plants Built This Year[Hybrid Electricity Source\
		,Electricity Timeslice,Hour]
	-BAU Battery Charging Allocation[Hybrid Electricity Source,Electricity Timeslice,Hour\
		]
	+BAU Battery Discharging Allocation[Hybrid Electricity Source,Electricity Timeslice,\
		Hour]
	~	Dmnl
	~		|

BAU Expected Capacity Factors by Hour for Plants Built This Year[Electricity Source,Electricity Timeslice\
		,Hour]=
	IF THEN ELSE(ABS(BAU Last Year Electricity Generation Capacity[Electricity Source
	])*MW Tolerance Unit Correction Factor < Tolerance,
	   MAX(0.001,
	      BAU Three Year Weighted Average Hypothetical Electricity Capacity Factor[Electricity Timeslice\
		,Hour,Electricity Source
	]),
	   IF THEN ELSE(Time=INITIAL TIME,Start Year Seasonal Expected Hourly Electricity Capacity Factors after RAF\
		[Electricity Source
	,Electricity Timeslice,Hour]
	   * (1 + IiCFfNPdtTI Increase in Capacity Factors for New Plants due to Technological Improvements\
		[Electricity Source
	]),
	   BAU Three Year Weighted Average Hypothetical Electricity Capacity Factor[Electricity Timeslice\
		,Hour,Electricity Source
	]
	 )
	)
	~	Dmnl
	~		|

BAU Expected Capacity Factors by Hour for Plants Built This Year Without Hypothetical Calculations\
		[Electricity Source,Electricity Timeslice,Hour]=
	Start Year Seasonal Expected Hourly Electricity Capacity Factors after RAF[Electricity Source\
		,Electricity Timeslice,Hour
	]
	* (1 + IiCFfNPdtTI Increase in Capacity Factors for New Plants due to Technological Improvements\
		[Electricity Source])
	~	Dmnl
	~		|

BAU Expected CES Qualifying Hourly Output from Mandated and Required Clean Dispatchable Capacity\
		[Electricity Timeslice,Hour]=
	SUM(((
	   BAU New Generation Capacity before Cost Effectiveness Additions[Electricity Source\
		!]
	  * BAU Expected Capacity Factors by Hour for Plants Built This Year[Electricity Source\
		!,Electricity Timeslice,Hour]
	  )
	
	+(
	   BAU Retrofit Capacity for Clean Dispatchable Reliability[Electricity Source!]
	  * BAU Expected Capacity Factors by Hour for Plants Built This Year[Electricity Source\
		!,Electricity Timeslice,Hour]
	  )
	) * Elec Portfolio Qualifying Sources[Electricity Source!,CES]
	)
	
	* One Hour
	~	MW*hr
	~		|

BAU Expected CES Qualifying Hourly Output from New Cost Effective Capacity[Electricity Timeslice\
		,Hour,Optimization Pass]=
	SUM((
	  BAU Total New and Retrofit Capacity Desired due to Cost Effectiveness by CES Optimization Pass\
		[Electricity Source!,Optimization Pass
	]
	  * BAU Last Year Hourly Bid Electricity Capacity Factors by Plant Type[Electricity Timeslice\
		,Hour,Electricity Source!]
	  * Elec Portfolio Qualifying Sources[Electricity Source!,CES]
	)
	
	* One Hour
	
	)
	~	MW*hr
	~		|

BAU Expected CES Qualifying Hourly Output from Surviving Capacity[Electricity Timeslice\
		,Hour]=
	SUM((
	  BAU Surviving Electricity Generation Capacity before Economic Retirements[Electricity Source\
		!]
	  * BAU Last Year Weighted Average Expected Capacity Factors by Hour[Electricity Source\
		!,Electricity Timeslice,Hour]
	) * Elec Portfolio Qualifying Sources[Electricity Source!,CES]
	)
	
	* One Hour
	~	MW*hr
	~		|

BAU Expected CES Qualifying Output After Guaranteed and RPS Dispatch[Electricity Source\
		,Electricity Timeslice,Hour]=
	(BAU Expected Capacity After Guaranteed Dispatch[Electricity Source,Electricity Timeslice\
		,Hour]*One Hour
	- BAU Zero and Negative Cost Electricity Dispatched to Meet RPS[Electricity Timeslice\
		,Hour,Electricity Source]
	- BAU Positive Cost Electricity Dispatched to Meet RPS[Electricity Timeslice,Hour,Electricity Source\
		])
	* Elec Portfolio Qualifying Sources[Electricity Source,CES]
	~	MW*hour
	~		|

BAU Expected Curtailed Capacity by Hour for Plants Built This Year[Electricity Source\
		,Electricity Timeslice,Hour]=
	BAU Expected Capacity Factors by Hour for Plants Built This Year Without Hypothetical Calculations\
		[Electricity Source,Electricity Timeslice,Hour]
	- BAU Expected Capacity Factors by Hour for Plants Built This Year[Electricity Source\
		,Electricity Timeslice,Hour]
	~	Dmnl
	~		|

BAU Expected Daily Electricity Output by Electricity Timeslice[Electricity Source,Electricity Timeslice\
		]=
	SUM(
	  BAU Expected Capacity Factors by Hour for Plants Built This Year[Electricity Source\
		,Electricity Timeslice,Hour!]
	  + BAU Salvageable Curtailed Capacity by Hour for Hybrid Power Plants[Electricity Source\
		,Electricity Timeslice,Hour!]
	)
	* One Hour
	~	hours
	~		|

BAU Expected Elec Portfolio Qualifying Dispatch from Last Year Capacity and This Year Mandated Change in Capacity\
		[RPS]=
	SUM(BAU Last Year Capacity and This Year Mandated Change in Capacity Qualifying for Elec Portfolio Std\
		[Electricity Source!,RPS]
	  * BAU Weighted Average Expected Capacity Factors by Hour Without Hypothetical Adjustments\
		[Electricity Source!,Electricity Timeslice
	!,Hour!]
	  * SHELF Days per Electricity Timeslice[Electricity Timeslice!]
	  * One Hour
	  ) ~~|
BAU Expected Elec Portfolio Qualifying Dispatch from Last Year Capacity and This Year Mandated Change in Capacity\
		[CES]=
	SUM(BAU Last Year Capacity and This Year Mandated Change in Capacity Qualifying for Elec Portfolio Std\
		[Electricity Source!,CES]
	  * BAU Weighted Average Expected Capacity Factors by Hour Without Hypothetical Adjustments\
		[Electricity Source!,Electricity Timeslice
	!,Hour!]
	  * SHELF Days per Electricity Timeslice[Electricity Timeslice!]
	  * One Hour
	  )
	~	MW*hour
	~		|

BAU Expected Hourly Output from CES Qualifying Resources Irrespective of Electricity Demand\
		[Electricity Timeslice,Hour,Optimization Pass]=
	BAU Expected CES Qualifying Hourly Output from Surviving Capacity[Electricity Timeslice\
		,Hour]
	+ BAU Expected CES Qualifying Hourly Output from Mandated and Required Clean Dispatchable Capacity\
		[Electricity Timeslice
	,Hour]
	+ BAU Expected CES Qualifying Hourly Output from New Cost Effective Capacity[Electricity Timeslice\
		,Hour
	,Optimization Pass]
	~	MW*hr
	~		|

BAU Expected Hourly Output from RPS Qualifying Resources Irrespective of Electricity Demand\
		[Electricity Timeslice,Hour,Optimization Pass]=
	BAU Expected RPS Qualifying Hourly Output from Surviving Capacity[Electricity Timeslice\
		,Hour]
	+ BAU Expected RPS Qualifying Hourly Output from Mandated and Required Clean Dispatchable Capacity\
		[Electricity Timeslice
	,Hour]
	+ BAU Expected RPS Qualifying Hourly Output from New Cost Effective Capacity[Electricity Timeslice\
		,Hour
	,Optimization Pass]
	~	MW*hr
	~		|

BAU Expected RPS Qualifying Capacity After Guaranteed Dispatch[Electricity Timeslice,\
		Hour,Electricity Source]=
	BAU Expected Capacity After Guaranteed Dispatch[Electricity Source,Electricity Timeslice\
		,Hour]
	* Elec Portfolio Qualifying Sources[Electricity Source,RPS]
	~	MW
	~		|

BAU Expected RPS Qualifying Capacity After Zero and Negative Cost RPS Dispatch[Electricity Timeslice\
		,Hour,Electricity Source]=
	MAX(
	  0,
	
	  BAU Expected RPS Qualifying Capacity After Guaranteed Dispatch[Electricity Timeslice\
		,Hour,Electricity Source]
	  - BAU Zero and Negative Cost Electricity Dispatched to Meet RPS[Electricity Timeslice\
		,Hour,Electricity Source]/One Hour
	)
	~	MW
	~		|

BAU Expected RPS Qualifying Hourly Output from Mandated and Required Clean Dispatchable Capacity\
		[Electricity Timeslice,Hour]=
	SUM(((
	   BAU New Generation Capacity before Cost Effectiveness Additions[Electricity Source\
		!]
	  * BAU Expected Capacity Factors by Hour for Plants Built This Year[Electricity Source\
		!,Electricity Timeslice,Hour]
	  )
	
	+(
	   BAU Retrofit Capacity for Clean Dispatchable Reliability[Electricity Source!]
	  * BAU Expected Capacity Factors by Hour for Plants Built This Year[Electricity Source\
		!,Electricity Timeslice,Hour]
	  )
	) * Elec Portfolio Qualifying Sources[Electricity Source!,RPS]
	)
	
	* One Hour
	~	MW*hr
	~		|

BAU Expected RPS Qualifying Hourly Output from New Cost Effective Capacity[Electricity Timeslice\
		,Hour,Optimization Pass]=
	SUM((
	  BAU Total New and Retrofit Capacity Desired due to Cost Effectiveness by RPS Optimization Pass\
		[Electricity Source!,Optimization Pass
	]
	  * BAU Last Year Hourly Bid Electricity Capacity Factors by Plant Type[Electricity Timeslice\
		,Hour,Electricity Source!]
	  * Elec Portfolio Qualifying Sources[Electricity Source!,RPS]
	)
	
	* One Hour
	
	)
	~	MW*hr
	~		|

BAU Expected RPS Qualifying Hourly Output from Surviving Capacity[Electricity Timeslice\
		,Hour]=
	SUM((
	  BAU Surviving Electricity Generation Capacity before Economic Retirements[Electricity Source\
		!]
	  * BAU Last Year Weighted Average Expected Capacity Factors by Hour[Electricity Source\
		!,Electricity Timeslice,Hour]
	) * Elec Portfolio Qualifying Sources[Electricity Source!,RPS]
	)
	
	* One Hour
	~	MW*hr
	~		|

BAU Expected Total Revenue per Unit Capacity by Plant Type Excluding Subsidies[Electricity Source\
		,Optimization Pass]=
	BAU Last Year Annual Net Energy Market Revenue per MW by Plant Type[Electricity Source\
		]
	+ BAU Predicted Capacity Payment by Plant Type for Existing Plants[Electricity Source\
		,Optimization Pass]
	+ BAU Last Year Revenue from CES Credits per Unit Electricity Output by Plant Type[Electricity Source\
		]
	~	$/MW
	~		|

BAU Expected Total Revenue per Unit Capacity by Plant Type Excluding Subsidies and Predicted Capacity Payment\
		[Electricity Source]=
	BAU Last Year Annual Net Energy Market Revenue per MW by Plant Type[Electricity Source\
		]
	+ BAU Last Year Revenue from CES Credits per Unit Electricity Output by Plant Type[Electricity Source\
		]
	~	$/MW
	~		|

BAU Exports[ISIC Code]=
	BAU Output by ISIC Code by Year[ISIC Code]
	* BESoP BAU Export Share of Production[ISIC Code]
	~	$
	~		|

BAU First Pass Electricity Dispatched by Guaranteed Dispatch by Hour[Electricity Source\
		,Electricity Timeslice,Hour]=
	IF THEN ELSE(
	 
	 SUM(BAU Guaranteed Dispatch Amount[Electricity Source!,Electricity Timeslice,Hour])\
		 > BAU Total Electricity Demand by Hour After Demand Altering Technologies[Electricity Timeslice\
		,Hour],
	
	 BAU First Tier Guaranteed Dispatch Amount[Electricity Source,Electricity Timeslice,\
		Hour]
	
	 + BAU Second Tier Guaranteed Dispatch Amount[Electricity Source,Electricity Timeslice\
		,Hour]
	   * MIN( 
	         1,
	         MAX(
	           0,  
	           ZIDZ((BAU Total Electricity Demand by Hour After Demand Altering Technologies\
		[Electricity Timeslice,Hour] - SUM(BAU First Tier Guaranteed Dispatch Amount[Electricity Source\
		!,Electricity Timeslice,Hour])),
	           SUM(BAU Second Tier Guaranteed Dispatch Amount[Electricity Source!,Electricity Timeslice\
		,Hour])
	               )
	             )
	        ),
	
	 BAU Guaranteed Dispatch Amount[Electricity Source,Electricity Timeslice,Hour]
	)
	~	MW*hour
	~	If the amount of guaranteed dispatch exceeds the total amount of \
		electricity demand in a given hour, the first pass scales back the second \
		tier sources of guaranteed dispatch are proportionately (to a maximum of \
		zero).
	|

BAU First Tier Guaranteed Dispatch Amount[Electricity Source,Electricity Timeslice,Hour\
		]=
	BAU Guaranteed Dispatch Amount[Electricity Source,Electricity Timeslice,Hour]
	* DPbES Dispatch Priority by Electricity Source[Electricity Source]
	~	MW*hour
	~		|

BAU Five Year Average Annual Expected Dispatch Costs by Power Plant Type[Electricity Source\
		]=
	ZIDZ(SUM(BAU Five Year Average Hourly Expected Dispatch Costs by Power Plant Type[Electricity Timeslice\
		!,Hour!,Electricity Source]*SHELF Days per Electricity Timeslice[Electricity Timeslice\
		!]),BAU Electricity Generation Capacity[Electricity Source])
	~	$/MW
	~		|

BAU Five Year Average Annual Net Energy Market Revenue per MW by Power Plant Type[Electricity Source\
		]=
	ZIDZ(SUM(BAU Five Year Average Hourly Net Energy Market Revenue from Total Electricity Dispatched by Power Plant Type\
		[Electricity Timeslice!,Hour!,Electricity Source]*SHELF Days per Electricity Timeslice\
		[Electricity Timeslice!]),BAU Electricity Generation Capacity[Electricity Source])
	~	$/MW
	~		|

BAU Five Year Average Dispatch Cost per Unit Electricity Output[Electricity Source]=
	BAU Five Year Average Dispatch Cost per Unit Electricity Output before Subsidies[Electricity Source\
		]
	- BAU Variable Subsidies per Unit Electricity Output[Electricity Source]
	~	$/(MW*hour)
	~		|

BAU Five Year Average Dispatch Cost per Unit Electricity Output before Subsidies[Electricity Source\
		]=
	BAU Five Year Forward Weighted Average Electricity Fuel Cost per Unit Electricity Output\
		[Electricity Source]
	+ BAU Weighted Average Variable OM Cost per Unit Electricity Output[Electricity Source\
		]
	~	$/(MW*hour)
	~		|

BAU Five Year Average Dispatch or Opportunity Cost per Unit Electricity Output[Electricity Source\
		] :EXCEPT:    [hydro es]=
	BAU Five Year Average Dispatch Cost per Unit Electricity Output[Electricity Source] ~~|
BAU Five Year Average Dispatch or Opportunity Cost per Unit Electricity Output[hydro es\
		]=
	HOC Hydro Opportunity Cost
	-BAU Variable Subsidies per Unit Electricity Output[hydro es]
	~	$/(MW*hr)
	~		|

BAU Five Year Average Electricity Dispatched by Least Cost by Hour[Electricity Timeslice\
		,Hour,Electricity Source]=
	IF THEN ELSE(
	    BAU Unmet Electricity Demand After RPS Dispatch[Electricity Timeslice,Hour]*MWhr Tolerance Unit Correction Factor\
		<Tolerance
	,
	    0,
	    SUPPLY AT PRICE(
	       BAU Available Capacity for Least Cost Dispatch Mapped[Electricity Timeslice,Hour\
		,Electricity Source
	],
	       BAU Five Year Average Power Plant Dispatch Parameters as Vector[Electricity Source\
		,ptype],
	       BAU Five Year Average Electricity Market Price Adjusted for Zero Least Cost Dispatch Hours\
		[Electricity Timeslice
	,Hour])
	  )
	~	MW*hr
	~		|

BAU Five Year Average Electricity Market Price[Electricity Timeslice,Hour]=
	FIND MARKET PRICE(
	 BAU Electricity Demand Mapped to ElecDemand[Electricity Timeslice,Hour,demand1],Fixed Electricity Demand Vector
	[demand1,ptype],
	BAU Available Capacity for Least Cost Dispatch Mapped[Electricity Timeslice,Hour,hard coal es\
		],BAU Five Year Average Power Plant Dispatch Parameters as Vector
	[hard coal es,ptype])
	~	$/(MW*hour)
	~		|

BAU Five Year Average Electricity Market Price Adjusted for Zero Least Cost Dispatch Hours\
		[Electricity Timeslice,Hour]=
	IF THEN ELSE(BAU Electricity Demand Mapped to ElecDemand[Electricity Timeslice,Hour,\
		demand1]*MWhr Tolerance Unit Correction Factor<Tolerance,0,BAU Five Year Average Electricity Market Price
	[Electricity Timeslice,Hour])
	~	$/(MW*hour)
	~		|

BAU Five Year Average Hourly CDF Values for Total Dispatch by Power Plant Type[Electricity Source\
		,Electricity Timeslice,Hour]=
	IF THEN ELSE(BAU Five Year Average Hourly Z Score by Power Plant Type for Total Dispatch\
		[Electricity Source,Electricity Timeslice,Hour]>=0,
	
	  1 - BAU Five Year Average Hourly PDF Values for Total Dispatch by Power Plant Type\
		[Electricity Source,Electricity Timeslice,Hour] * (Abramowitz and Stegun Values for CDF
	[a1]*BAU Five Year Average Hourly T Values for Total Dispatch by Power Plant Type[Electricity Source
	  ,Electricity Timeslice,Hour] + Abramowitz and Stegun Values for CDF[a2]*BAU Five Year Average Hourly T Values for Total Dispatch by Power Plant Type
	[Electricity Source,Electricity Timeslice,Hour
	]^2
	   +Abramowitz and Stegun Values for CDF[a3]*BAU Five Year Average Hourly T Values for Total Dispatch by Power Plant Type\
		[Electricity Source,
	Electricity Timeslice,Hour]^3+Abramowitz and Stegun Values for CDF
	  [a4]*BAU Five Year Average Hourly T Values for Total Dispatch by Power Plant Type[\
		Electricity Source,Electricity Timeslice,Hour]^4+Abramowitz and Stegun Values for CDF
	[a5]*BAU Five Year Average Hourly T Values for Total Dispatch by Power Plant Type[Electricity Source
	  ,Electricity Timeslice,Hour]^5),
	
	  1-(1 - BAU Five Year Average Hourly PDF Values for Total Dispatch by Power Plant Type\
		[Electricity Source,Electricity Timeslice,Hour] * (Abramowitz and Stegun Values for CDF
	[a1]*BAU Five Year Average Hourly T Values for Total Dispatch by Power Plant Type[Electricity Source
	  ,Electricity Timeslice,Hour] + Abramowitz and Stegun Values for CDF[a2]*BAU Five Year Average Hourly T Values for Total Dispatch by Power Plant Type
	[Electricity Source,Electricity Timeslice,Hour
	]^2
	   +Abramowitz and Stegun Values for CDF[a3]*BAU Five Year Average Hourly T Values for Total Dispatch by Power Plant Type\
		[Electricity Source,
	Electricity Timeslice,Hour]^3+Abramowitz and Stegun Values for CDF
	  [a4]*BAU Five Year Average Hourly T Values for Total Dispatch by Power Plant Type[\
		Electricity Source,Electricity Timeslice,Hour]^4+Abramowitz and Stegun Values for CDF
	[a5]*BAU Five Year Average Hourly T Values for Total Dispatch by Power Plant Type[Electricity Source
	  ,Electricity Timeslice,Hour]^5)))
	~	Dmnl
	~		|

BAU Five Year Average Hourly Expected Dispatch Cost per Unit Total Electricity Dispatched by Power Plant Type\
		[Electricity Source
,Electricity Timeslice,Hour]=
	BAU Five Year Average Dispatch Cost per Unit Electricity Output before Subsidies[Electricity Source\
		]
	  -(BAU Five Year Average Standard Deviation of Dispatch Costs[Electricity Source])
	
	*ZIDZ(
	  BAU Five Year Average Hourly PDF Values for Total Dispatch by Power Plant Type[Electricity Source\
		,Electricity Timeslice,Hour]
	  ,BAU Five Year Average Hourly CDF Values for Total Dispatch by Power Plant Type[Electricity Source\
		,Electricity Timeslice,Hour]
	)
	~	$/(MW*hour)
	~		|

BAU Five Year Average Hourly Expected Dispatch Costs by Power Plant Type[Electricity Timeslice\
		,Hour,Electricity Source]=
	BAU Five Year Average Hourly Expected Dispatch Cost per Unit Total Electricity Dispatched by Power Plant Type\
		[Electricity Source
	,Electricity Timeslice,Hour]*BAU Total Electricity Dispatched by Hour by Plant Type Using Five Year Averages\
		[Electricity Timeslice,Hour,Electricity Source]
	~	$
	~		|

BAU Five Year Average Hourly Net Energy Market Revenue from Total Electricity Dispatched by Power Plant Type\
		[Electricity Timeslice,Hour,Electricity Source]=
	BAU Five Year Average Hourly Revenue from Total Electricity Dispatched by Power Plant Type\
		[Electricity Timeslice,Hour,Electricity Source]
	-BAU Five Year Average Hourly Expected Dispatch Costs by Power Plant Type[Electricity Timeslice\
		,Hour,Electricity Source]
	~	$
	~		|

BAU Five Year Average Hourly PDF Values for Total Dispatch by Power Plant Type[Electricity Source\
		,Electricity Timeslice,Hour]=
	(1/sqrt(2*3.14159))*exp(-BAU Five Year Average Hourly Z Score by Power Plant Type for Total Dispatch\
		[Electricity Source,Electricity Timeslice,Hour]^2/2)
	~	Dmnl
	~		|

BAU Five Year Average Hourly Revenue from Total Electricity Dispatched by Power Plant Type\
		[Electricity Timeslice,Hour,Electricity Source]=
	BAU Five Year Average Marginal Dispatch Cost by Hour[Electricity Timeslice,Hour]
	*BAU Total Electricity Dispatched by Hour by Plant Type Using Five Year Averages[Electricity Timeslice\
		,Hour,Electricity Source]
	~	$
	~		|

BAU Five Year Average Hourly T Values for Total Dispatch by Power Plant Type[Electricity Source\
		,Electricity Timeslice,Hour]=
	1/(1+0.231642*ABS(BAU Five Year Average Hourly Z Score by Power Plant Type for Total Dispatch\
		[Electricity Source,Electricity Timeslice,Hour]))
	~	Dmnl
	~		|

BAU Five Year Average Hourly Z Score by Power Plant Type for Total Dispatch[Electricity Source\
		, Electricity Timeslice, Hour]=
	ZIDZ((BAU Five Year Average Marginal Dispatch Cost by Hour[Electricity Timeslice,Hour\
		]-BAU Five Year Average Dispatch Cost per Unit Electricity Output
	[Electricity Source]),BAU Five Year Average Standard Deviation of Dispatch Costs[Electricity Source\
		])
	~	Dmnl
	~		|

BAU Five Year Average Marginal Dispatch Cost by Hour[Electricity Timeslice, Hour]=
	IF THEN ELSE(ABS(SUM(BAU Total Electricity Dispatched by Hour by Plant Type Using Five Year Averages\
		[Electricity Timeslice
	,
	Hour,Electricity Source!]))*MWhr Tolerance Unit Correction Factor < Tolerance,
	  EIaE Imported Electricity Price,
	
	  IF THEN ELSE(
	    ABS(
	      BAU Five Year Average Electricity Market Price Adjusted for Zero Least Cost Dispatch Hours\
		[Electricity Timeslice,
	Hour]
	    )
	    *Dollar per MWhr Tolerance Unit Correction Factor 
	    < Tolerance
	
	    :OR: 
	
	    ABS(
	      SUM(
	        BAU Five Year Average Electricity Dispatched by Least Cost by Hour[Electricity Timeslice\
		,Hour,Electricity Source
	!]
	      )
	      *MWhr Tolerance Unit Correction Factor
	    )
	    
	   < Tolerance,
	 
	    SUM(BAU Five Year Average Dispatch Cost per Unit Electricity Output[Electricity Source\
		!]*BAU Share of Total Electricity Dispatched by Hour by Plant Type[Electricity Timeslice\
		,Hour,Electricity Source!]),
	
	    BAU Five Year Average Electricity Market Price Adjusted for Zero Least Cost Dispatch Hours\
		[Electricity Timeslice,Hour
	]
	  )
	)
	~	$/(MW*hour)
	~		|

BAU Five Year Average Power Plant Dispatch Parameters as Vector[Electricity Source,ptype\
		]=
	3 ~~|
BAU Five Year Average Power Plant Dispatch Parameters as Vector[Electricity Source,ppriority\
		]=
	BAU Five Year Average Dispatch or Opportunity Cost per Unit Electricity Output[Electricity Source
	] ~~|
BAU Five Year Average Power Plant Dispatch Parameters as Vector[Electricity Source,pwidth\
		]=
	MAX(
	  ABS(
	    MAX(NSDoDC Normalized Standard Deviation of Dispatch Costs[Electricity Source],0.01\
		)
	    *(BAU Five Year Average Dispatch or Opportunity Cost per Unit Electricity Output\
		[Electricity Source]
	    + BAU Variable Subsidies per Unit Electricity Output[Electricity Source])
	  ),
	
	  0.01
	) ~~|
BAU Five Year Average Power Plant Dispatch Parameters as Vector[Electricity Source,pextra\
		]=
	0
	~	$/(MW*hour)
	~		|

BAU Five Year Average Power Plant Dispatch Parameters as Vector for New Plants[Electricity Source\
		,ptype]=
	3 ~~|
BAU Five Year Average Power Plant Dispatch Parameters as Vector for New Plants[Electricity Source\
		,ppriority]=
	BAU Five Year Average Dispatch or Opportunity Cost per Unit Electricity Output[Electricity Source
	]
	+ BAU Variable Subsidies per Unit Electricity Output[Electricity Source]
	- BAU Total Subsidies per Unit Electricity Output Adjusted for Lifetime[Electricity Source\
		] ~~|
BAU Five Year Average Power Plant Dispatch Parameters as Vector for New Plants[Electricity Source\
		,pwidth]=
	MAX(
	  ABS(MAX(NSDoDC Normalized Standard Deviation of Dispatch Costs[Electricity Source]\
		,0.01)
	    *(BAU Five Year Average Dispatch or Opportunity Cost per Unit Electricity Output\
		[Electricity Source]
	    + BAU Variable Subsidies per Unit Electricity Output[Electricity Source])
	  ),
	
	  0.01
	) ~~|
BAU Five Year Average Power Plant Dispatch Parameters as Vector for New Plants[Electricity Source\
		,pextra]=
	0
	~	$/(MW*hour)
	~		|

BAU Five Year Average Standard Deviation of Dispatch Costs[Electricity Source]=
	ABS(BAU Five Year Average Dispatch Cost per Unit Electricity Output[Electricity Source\
		]*NSDoDC Normalized Standard Deviation of Dispatch Costs[Electricity Source])
	~	$/(MW*hour)
	~		|

BAU Five Year Foresight Elec Portfolio Values for Reliability Check[Clean Elec Requirement\
		]=
	MAX(
	  SUM(BAU Weighted Average Elec Portfolio Percentage by Year[Future Year!,Clean Elec Requirement\
		]
	  * This Year Flag for Five Year Reliability Check[Future Year!]),
	
	  SUM(BAU Weighted Average Elec Portfolio Percentage by Year[Future Year!,Clean Elec Requirement\
		]
	  * This Year Flag[Future Year!])
	)
	~	Dmnl
	~		|

BAU Five Year Forward Average Electricity Fuel Cost per Unit Energy[Electricity Source\
		]=
	MAX(BAU Five Year Forward Average Pretax Fuel Price by Sector[electricity source within all fuels\
		,electricity sector]
	    * (1 + FSPbPPT Fuel Surcharge Percentage by Power Plant Type[Electricity Source]\
		)
	
	  + BAU Five Year Forward Average Electricity Fuel Other Tax or Subsidy Amount per Unit Energy\
		[Electricity Source]
	  +BAU Electricity Fuel Carbon Tax Amount per Unit Energy[Electricity Source],
	0
	)
	~	$/BTU
	~		|

BAU Five Year Forward Average Electricity Fuel Other Tax or Subsidy Amount per Unit Energy\
		[Electricity Source]=
	BAU Five Year Forward Average Fuel Tax by Sector[electricity source within all fuels\
		,electricity sector]
	~	$/BTU
	~		|

BAU Five Year Forward Average Fuel Tax by Sector[All Fuels,Sectors]=
	SUM(BFPaT BAU Fuel Tax by Sector[All Fuels,Sectors,Future Year!]*Five Year Forward Future Year to Year Mapping\
		[Future Year!])/5
	~	$/BTU
	~		|

BAU Five Year Forward Average Pretax Fuel Price by Sector[All Fuels, Sectors]=
	SUM(BFPAT BAU Pretax Fuel Price by Sector[All Fuels,Sectors,Future Year!]*Five Year Forward Future Year to Year Mapping\
		[Future Year!])/5
	~	$/BTU
	~		|

BAU Five Year Forward Pretax Fuel Cost per Unit Energy by Sector with Sensitivity Analysis Adjustment\
		[All Fuels,Sectors]=
	BAU Five Year Forward Average Pretax Fuel Price by Sector[All Fuels,Sectors]
	* Fuel Price Multiplier for Sensitivity Analysis Runs[All Fuels]
	~	$/BTU
	~		|

BAU Five Year Forward Weighted Average Electricity Fuel Cost per Unit Electricity Output\
		[Electricity Source]=
	BAU Five Year Forward Average Electricity Fuel Cost per Unit Energy[Electricity Source\
		]
	* BAU Weighted Average Heat Rate by Electricity Fuel[Electricity Source]
	~	$/(MW*hr)
	~		|

BAU Fleet Avg Fuel Economy[Vehicle Type,Cargo Type,Vehicle Technology]=
	MAX(
	  0,
	
	  BAU Last Year Fleet Avg Fuel Economy[Vehicle Type,Cargo Type,Vehicle Technology]
	  * (1 + BAU Percentage Change in Fleet Avg Fuel Economy[Vehicle Type,Cargo Type,Vehicle Technology\
		])
	)
	~	thing*miles/BTU
	~		|

BAU Four Year Average Net Energy Market Revenue by Plant Type Excluding Subsidies for Hybrid Power Plants\
		[Hybrid Electricity Source]=
	DEPRECIATE STRAIGHTLINE(
	 BAU One Year Average Net Energy Market Revenue by Plant Type Excluding Subsidies for Hybrid Power Plants\
		[Hybrid Electricity Source],
	 4,
	 1,
	 0
	)
	~	$/MW
	~		|

BAU Four Year Average Total Predicted Net Energy Market Revenue per MW[Electricity Source\
		]=
	DEPRECIATE STRAIGHTLINE(
	 BAU Last Year Total Five Year Average Net Energy Market Revenue per MW[Electricity Source\
		], 
	 4, 
	 1, 
	 0
	)
	~	$/MW
	~		|

BAU Fraction of All Preexisting Equipment Retired[Industry Category,Industrial Process\
		]=
	IF THEN ELSE(
	  BIISRP Boolean Use Individual Industrial Site Retirement Profile[Industry Category\
		] = 0,
	
	  IESD Fraction of Preexisting Equipment Retired Naturally by Age[Industrial Process\
		],
	
	  BIISRP BAU Individual Industrial Site Retirement Profile[Industry Category]
	)
	~	Dmnl
	~		|

BAU Fraction of Buildable Capacity Actually Built[Electricity Source]=
	XIDZ(
	  BAU New Generation Capacity[Electricity Source],
	
	  BAU Max Capacity Buildable This Year[Electricity Source],
	
	  1
	)
	~	Dmnl
	~		~	:SUPPLEMENTARY 
	|

BAU Fraction of CO2 Captured by Industry[Industry Category,Emissions Type]=
	Start Year BAU Fraction of CCS Potential Achieved by Industry Sector[Industry Category\
		,Emissions Type]
	+ BAU Cumulative CCS Retrofit Capacity Built During Model Run[Industry Category,Emissions Type\
		]
	~	Dmnl
	~		|

BAU Fraction of Expected Capacity Factors Achieved[Electricity Source]=
	ZIDZ(
	  SUM(BAU Achieved Capacity Factors by Hour[Electricity Timeslice!,Hour!,Electricity Source\
		]*Hours per Year*SHELF Days per Electricity Timeslice[Electricity Timeslice!]),
	  SUM(BAU Weighted Average Expected Capacity Factors by Hour without RAF[Electricity Source\
		,Electricity Timeslice!,Hour!]*Hours per Year*SHELF Days per Electricity Timeslice[\
		Electricity Timeslice!])
	 )
	~	Dmnl
	~		~	:SUPPLEMENTARY 
	|

BAU Fuel Cost per Unit Cargo Dist[Vehicle Type,Cargo Type,Vehicle Technology]=
	ZIDZ(
	  BAU Weighted Avg Fuel Cost per Unit Energy by Vehicle Technology[Vehicle Type,Cargo Type\
		,Vehicle Technology],
	
	  BAU Last Year Fleet Avg Fuel Economy[Vehicle Type,Cargo Type,Vehicle Technology]
	)
	~	$/(thing*mile)
	~		|

BAU Fuel Cost per Unit Output for Plants Built This Year[Electricity Source]=
	BAU Heat Rate by Electricity Fuel for Plants Built This Year[Electricity Source]
	* BAU Electricity Fuel Cost per Unit Energy[Electricity Source]
	~	$/(MW*hour)
	~		|

BAU Fuel Export Revenue[All Fuels]=
	BAU Fuel Production Imports and Exports[All Fuels,exports]
	* IMFPbFT International Market Fuel Price by Fuel Type[All Fuels]
	~	$
	~		|

BAU Fuel Export Revenue including Exported Electricity[All Fuels] :EXCEPT: [electricity\
		]=
	BAU Fuel Export Revenue[All Fuels] ~~|
BAU Fuel Export Revenue including Exported Electricity[electricity]=
	BAU Amount Received from Exporting Electricity
	~	$
	~		|

BAU Fuel Industry After Tax Revenue by Fuel[All Fuels]=
	BAU Fuel Industry Revenue by Fuel[All Fuels]
	- BAU Taxes Paid by Fuel[All Fuels]
	~	$
	~		|

BAU Fuel Industry Revenue by Fuel[All Fuels] :EXCEPT:     [electricity]=
	BAU Amount Spent on Transportation Fuels Mapped to All Fuels Subscript[All Fuels]
	+ BAU Amount Spent on Electricity Fuels Mapped to All Fuels Subscript[All Fuels]
	+ BAU Amount Spent on Buildings Fuels Mapped to All Fuels Subscript[All Fuels]
	+ BAU Amount Spent on Industry Fuels Mapped to All Fuels Subscript[All Fuels]
	+ BAU Amount Spent on District Heating Fuels Mapped to All Fuels Subscript[All Fuels\
		]
	+ BAU Amount Spent on Hydrogen Sector Fuels Mapped to All Fuels Subscript[All Fuels]
	+ BAU Fuel Export Revenue including Exported Electricity[All Fuels] ~~|
BAU Fuel Industry Revenue by Fuel[electricity]=
	BAU Amount Spent on Transportation Fuels Mapped to All Fuels Subscript[electricity]
	+ BAU Amount Spent on Electricity Fuels Mapped to All Fuels Subscript[electricity]
	+ BAU Amount Spent on Buildings Fuels Mapped to All Fuels Subscript[electricity]
	+ BAU Amount Spent on Industry Fuels Mapped to All Fuels Subscript[electricity]
	+ BAU Amount Spent on District Heating Fuels Mapped to All Fuels Subscript[electricity\
		]
	+ BAU Amount Spent on Hydrogen Sector Fuels Mapped to All Fuels Subscript[electricity\
		]
	+ BAU Fuel Export Revenue including Exported Electricity[electricity]
	+ SUM(BAU This Year CCS Subsidies Paid[Electricity Source!])
	+ SUM(BAU This Year Ongoing Subsidies Paid per Unit Electricity Output[Electricity Source\
		!])
	+ SUM(BAU ZEC Subsidies Paid[Electricity Source!])
	+ SUM(BAU Capacity Construction Subsidies Paid[Electricity Source!])
	~	$
	~		|

BAU Fuel Production Imports and Exports[All Fuels,production]=
	IF THEN ELSE(
	  FPIEBP Fuel Production Import Export Balancing Priorities[All Fuels,production] = \
		3,
	
	  MAX(
	    0,
	
	    BAU Fuel Production Imports and Exports after Second Priority Balancing[All Fuels\
		,production]
	      - Fuel Imbalance after Second Priority Balancing[All Fuels]
	  ),
	
	  BAU Fuel Production Imports and Exports after Second Priority Balancing[All Fuels,\
		production]
	) ~~|
BAU Fuel Production Imports and Exports[All Fuels,imports]=
	IF THEN ELSE(
	  FPIEBP Fuel Production Import Export Balancing Priorities[All Fuels,imports] = 3,
	
	  MAX(
	    0,
	
	    BAU Fuel Production Imports and Exports after Second Priority Balancing[All Fuels\
		,imports]
	      - Fuel Imbalance after Second Priority Balancing[All Fuels]
	  ),
	
	  BAU Fuel Production Imports and Exports after Second Priority Balancing[All Fuels,\
		imports]
	) ~~|
BAU Fuel Production Imports and Exports[All Fuels,exports]=
	IF THEN ELSE(
	  FPIEBP Fuel Production Import Export Balancing Priorities[All Fuels,exports] = 3,
	
	  MAX(
	    0,
	
	    BAU Fuel Production Imports and Exports after Second Priority Balancing[All Fuels\
		,exports]
	      + Fuel Imbalance after Second Priority Balancing[All Fuels]
	  ),
	
	  BAU Fuel Production Imports and Exports after Second Priority Balancing[All Fuels,\
		exports]
	)
	~	BTU
	~		|

BAU Fuel Production Imports and Exports after First Priority Balancing[All Fuels,production\
		]=
	IF THEN ELSE(
	  FPIEBP Fuel Production Import Export Balancing Priorities[All Fuels,production] = \
		1,
	
	  MAX(
	    0,
	
	    BAU Total Energy Use[All Fuels]
	      - BAU Fuel Production Imports and Exports after GDP Adjustment[All Fuels,imports\
		]
	      + BAU Fuel Production Imports and Exports after GDP Adjustment[All Fuels,exports\
		]
	  ),
	
	  BAU Fuel Production Imports and Exports after GDP Adjustment[All Fuels,production]
	) ~~|
BAU Fuel Production Imports and Exports after First Priority Balancing[All Fuels,imports\
		]=
	IF THEN ELSE(
	  FPIEBP Fuel Production Import Export Balancing Priorities[All Fuels,imports] = 1,
	
	  MAX(
	    0,
	
	    BAU Total Energy Use[All Fuels]
	      - BAU Fuel Production Imports and Exports after GDP Adjustment[All Fuels,production\
		]
	      + BAU Fuel Production Imports and Exports after GDP Adjustment[All Fuels,exports\
		]
	  ),
	
	  BAU Fuel Production Imports and Exports after GDP Adjustment[All Fuels,imports]
	) ~~|
BAU Fuel Production Imports and Exports after First Priority Balancing[All Fuels,exports\
		]=
	IF THEN ELSE(
	  FPIEBP Fuel Production Import Export Balancing Priorities[All Fuels,exports] = 1,
	
	  MAX(
	    0,
	
	    BAU Fuel Production Imports and Exports after GDP Adjustment[All Fuels,production\
		]
	      - BAU Total Energy Use[All Fuels]
	      + BAU Fuel Production Imports and Exports after GDP Adjustment[All Fuels,imports\
		]
	  ),
	
	  BAU Fuel Production Imports and Exports after GDP Adjustment[All Fuels,exports]
	)
	~	BTU
	~	P = C - I + E
		I = C - P + E
		E = P - C + I
	|

BAU Fuel Production Imports and Exports after GDP Adjustment[All Fuels,Fuel Balancing Mode\
		] :EXCEPT: [transportation fuel within all fuels,Fuel Balancing Mode]=
	BFPIaE BAU Fuel Production Imports and Exports[All Fuels,Fuel Balancing Mode]
	* (1 + Perc Change in Sectoral Energy Use due to Exogenous GDP Adjustment[electricity sector\
		]) ~~|
BAU Fuel Production Imports and Exports after GDP Adjustment[transportation fuel within all fuels\
		,Fuel Balancing Mode] :EXCEPT: [natural gas,Fuel Balancing Mode]=
	BFPIaE BAU Fuel Production Imports and Exports[transportation fuel within all fuels,\
		Fuel Balancing Mode]
	* (1 + Perc Change in Sectoral Energy Use due to Exogenous GDP Adjustment[transportation sector\
		]) ~~|
BAU Fuel Production Imports and Exports after GDP Adjustment[natural gas,Fuel Balancing Mode\
		]=
	BFPIaE BAU Fuel Production Imports and Exports[natural gas,Fuel Balancing Mode]
	* (1 + Perc Change in Sectoral Energy Use due to Exogenous GDP Adjustment[electricity sector\
		])
	~	BTU
	~		|

BAU Fuel Production Imports and Exports after Second Priority Balancing[All Fuels,production\
		]=
	IF THEN ELSE(
	  FPIEBP Fuel Production Import Export Balancing Priorities[All Fuels,production] = \
		2,
	
	  MAX(
	    0,
	
	    BAU Fuel Production Imports and Exports after First Priority Balancing[All Fuels\
		,production]
	      - Fuel Imbalance after First Priority Balancing[All Fuels]
	  ),
	
	  BAU Fuel Production Imports and Exports after First Priority Balancing[All Fuels,production\
		]
	) ~~|
BAU Fuel Production Imports and Exports after Second Priority Balancing[All Fuels,imports\
		]=
	IF THEN ELSE(
	  FPIEBP Fuel Production Import Export Balancing Priorities[All Fuels,imports] = 2,
	
	  MAX(
	    0,
	
	    BAU Fuel Production Imports and Exports after First Priority Balancing[All Fuels\
		,imports]
	      - Fuel Imbalance after First Priority Balancing[All Fuels]
	  ),
	
	  BAU Fuel Production Imports and Exports after First Priority Balancing[All Fuels,imports\
		]
	) ~~|
BAU Fuel Production Imports and Exports after Second Priority Balancing[All Fuels,exports\
		]=
	IF THEN ELSE(
	  FPIEBP Fuel Production Import Export Balancing Priorities[All Fuels,exports] = 2,
	
	  MAX(
	    0,
	
	    BAU Fuel Production Imports and Exports after First Priority Balancing[All Fuels\
		,exports]
	      + Fuel Imbalance after First Priority Balancing[All Fuels]
	  ),
	
	  BAU Fuel Production Imports and Exports after First Priority Balancing[All Fuels,exports\
		]
	)
	~	BTU
	~		|

BAU Fuel Production Mapped to ISIC Codes[ISIC Code] :EXCEPT:     [Fossil and Energy Utility ISIC Code\
		]=
	0 ~~|
BAU Fuel Production Mapped to ISIC Codes[ISIC 05]=
	SUM(BAU Fuel Production Imports and Exports[coal mining industry fuel within all fuels\
		!,production]) ~~|
BAU Fuel Production Mapped to ISIC Codes[ISIC 06]=
	BAU Fuel Production Imports and Exports[natural gas,production]
	  +BAU Fuel Production Imports and Exports[crude oil,production] ~~|
BAU Fuel Production Mapped to ISIC Codes[ISIC 19]=
	SUM(BAU Fuel Production Imports and Exports[secondary petroleum product within all fuels\
		!,production]) ~~|
BAU Fuel Production Mapped to ISIC Codes[ISIC 352T353]=
	BAU Fuel Production Imports and Exports[natural gas,production]
	  +BAU Fuel Production Imports and Exports[heat,production]
	  +BAU Fuel Production Imports and Exports[natural gas,imports] ~~|
BAU Fuel Production Mapped to ISIC Codes[ISIC 351]=
	SUM(BAU Electricity Generation by Type[Electricity Source!])
	/ MWh per BTU
	~	BTU
	~		|

BAU Fuel Tax by Sector[All Fuels,Sectors]=
	SUM(BFPaT BAU Fuel Tax by Sector[All Fuels,Sectors,Future Year!]*Future Year to Year Mapping\
		[Future Year!])
	~	$/BTU
	~		|

BAU Fuel that would be Used by Regulated Vehicle Types in Absence of LCFS with Elec Eff Adj\
		[Vehicle Type,Cargo Type
,Vehicle Technology,Transportation Fuel] :EXCEPT: [Vehicle Type,Cargo Type,Vehicle Technology\
		,electricity tf]=
	BAU Transportation Sector Fuel that would be Used in Absence of LCFS by Regulated Vehicle Types\
		[Vehicle Type,Cargo Type,Vehicle Technology,Transportation Fuel] ~~|
BAU Fuel that would be Used by Regulated Vehicle Types in Absence of LCFS with Elec Eff Adj\
		[Vehicle Type,Cargo Type
,Vehicle Technology,electricity tf]=
	BAU Transportation Sector Fuel that would be Used in Absence of LCFS by Regulated Vehicle Types\
		[Vehicle Type,Cargo Type
	,Vehicle Technology,electricity tf]
	/ (1 - PTFURfE Percentage Transportation Fuel Use Reduction for Electricity[Vehicle Type\
		,Cargo Type])
	~	BTU
	~		|

BAU Fuel Type Shares from Input Data in Electricity Equivalent[Industry Category,Industrial Fuel\
		]=
	ZIDZ(
	  SUM(BAU Industrial Equipment Energy Use from Input Data by Industrial Process in Electricity Equivalent\
		[Industry Category,Industrial Fuel,Industrial Process!]),
	  SUM(BAU Industrial Equipment Energy Use from Input Data by Industrial Process in Electricity Equivalent\
		[Industry Category,Industrial Fuel!,Industrial Process!])
	)
	~	Dmnl
	~		|

BAU Fuel Use for Energy Purposes in Electricity Equivalent[Industry Category]=
	SUM(Total BAU Fuel Use for Energy Purposes by Industrial Process in Electricity Equivalent\
		[Industry Category,Industrial Process!])
	~	BTU
	~		|

BAU Fuel Use for Green Hydrogen Production[Industrial Fuel] :EXCEPT:   [biomass if]=
	0 ~~|
BAU Fuel Use for Green Hydrogen Production[biomass if]=
	BAU Off Grid Electricity Demand for Green Hydrogen by Power Plant Type[biomass es]
	* BAU Weighted Average Heat Rate by Electricity Fuel[biomass es]
	
	+ BAU Off Grid Electricity Demand for Green Hydrogen by Power Plant Type[municipal solid waste es\
		]
	* BAU Weighted Average Heat Rate by Electricity Fuel[municipal solid waste es]
	~	BTU
	~	This variable is set to 0 for all fossil resources and hydrogen power \
		plants, as they cannot qualify for the green hydrogen production pathway. \
		There will also be 0 fuel use associated with wind, solar, hydro, and \
		geothermal resources. Therefore, we only calculate biomass values as the \
		sum of the biomass and municipal solid waste plant types, if applicable.
	|

BAU Fuel Used for CCS by Hydrogen Sector[Industrial Fuel]=
	CC Energy Use per Ton Hydrogen Sector CO2 Sequestered[Industrial Fuel]
	  * BAU Last Year Pollutants Sequestered by Hydrogen Sector[CO2]
	~	BTU
	~		|

BAU Fuel Used for CCS by Industry Sector[Industrial Fuel,Industry Category]=
	SUM(CC Energy Use per Ton Industry CO2 Sequestered[Industry Category,Industrial Fuel\
		,Emissions Type!]  
	  * BAU Last Year Pollutants Sequestered by Industry Sector[Industry Category,CO2,Emissions Type\
		!]
	)
	~	BTU
	~		|

BAU Fuel Used to Generate Heat[Industrial Fuel]=
	ZIDZ(
	  BAU District Heat Provided by Dedicated Facilities[Industrial Fuel],
	
	  EoCtUH Efficiency of Conversion to Usable Heat[Industrial Fuel]
	)
	~	BTU
	~		|

BAU Generation Capacity Kept Online due to Predicted Capacity Payment[Electricity Source\
		]=
	BAU Cumulative Retired Generation Capacity[Electricity Source]
	- BAU Cumulative Retired Generation Excluding Capacity Payment[Electricity Source]
	~	MW
	~		|

BAU Generation Costs=
	SUM(BAU Amount Spent on Electricity Fuels[Electricity Source!]
	+BAU Elec Supplier Variable OM Costs[Electricity Source!]
	+BAU Elec Supplier Fixed OM Costs[Electricity Source!])
	~	$
	~		|

BAU Geoengineering CapEx and OM Spending This Year=
	BAU CO2 Captured via DAC
	* DACD Direct Air Capture Amortized CapEx and OM
	
	+ BAU CO2 Captured via Enhanced Rock Weathering
	* ERWD Enhanced Rock Weathering Amortized CapEx and OM
	~	$
	~		|

BAU Geoengineering Fuel Cost per Unit Energy[Industrial Fuel]=
	MAX(BAU Pretax Fuel Price by Sector Including Endogenous Electricity Prices[industrial fuel within all fuels\
		,geoengineering sector]
	  + BAU Geoengineering Fuel Total Tax or Subsidy Amount per Unit Energy[Industrial Fuel\
		],
	0
	)
	~	$/BTU
	~		~	:SUPPLEMENTARY 
	|

BAU Geoengineering Fuel Other Tax or Subsidy Amount per Unit Energy[Industrial Fuel]=
	BAU Fuel Tax by Sector[industrial fuel within all fuels,geoengineering sector]
	~	$/BTU
	~		|

BAU Geoengineering Fuel Total Tax or Subsidy Amount per Unit Energy[Industrial Fuel]=
	BAU Geoengineering Fuel Other Tax or Subsidy Amount per Unit Energy[Industrial Fuel]
	~	$/BTU
	~		|

BAU Geoengineering Sector Carbon Tax Revenue=
	SUM(BAU Geoengineering Sector Energy Use[Industrial Fuel!]
	  * BAU Industrial Fuel Carbon Tax Amount per Unit Energy[cement and other nonmetallic minerals 239\
		,Industrial Fuel!])
	~	$
	~		|

BAU Geoengineering Sector Electricity Demand=
	BAU Geoengineering Sector Energy Use[electricity if]
	* MWh per BTU
	~	MW*hr
	~		|

BAU Geoengineering Sector Energy Use[Industrial Fuel]=
	BAU CO2 Captured via DAC
	* DACD Direct Air Capture Energy Intensity[Industrial Fuel]
	
	+ BAU CO2 Captured via Enhanced Rock Weathering
	* ERWD Enhanced Rock Weathering Energy Intensity[Industrial Fuel]
	~	BTU
	~		|

BAU Geoengineering Sector Other Fuel Tax Revenue=
	SUM(BAU Geoengineering Sector Energy Use[Industrial Fuel!]
	* BAU Industrial Fuel Other Tax or Subsidy Amount per Unit Energy[Industrial Fuel!])
	~	$
	~		|

BAU Geoengineering Sector Pollutant Emissions[Pollutant] :EXCEPT:  [CO2]=
	SUM(
	  BAU Geoengineering Sector Pollutant Emissions Excluding Captured CO2[Pollutant,Industrial Fuel\
		!]
	) ~~|
BAU Geoengineering Sector Pollutant Emissions[CO2]=
	SUM(
	  BAU Geoengineering Sector Pollutant Emissions Excluding Captured CO2[CO2,Industrial Fuel\
		!]
	)
	- BAU CO2 Captured via DAC in Grams
	~	g pollutant
	~		|

BAU Geoengineering Sector Pollutant Emissions Excluding Captured CO2[Pollutant,Industrial Fuel\
		]=
	BAU Geoengineering Sector Energy Use[Industrial Fuel]
	* Industrial Fuel Pollutant Emissions Intensities This Year[cement and other nonmetallic minerals 239\
		,Pollutant,Industrial Fuel]
	~	g pollutant
	~		|

BAU Green Hydrogen Demand=
	SUM(BAU Green Hydrogen Demand by Sector[Sectors!])
	~	BTU
	~		|

BAU Green Hydrogen Demand by Sector[Sectors] :EXCEPT:       [industry sector],[geoengineering sector\
		],[district heat and hydrogen sector]=
	BAU Hydrogen Demand by Sector[Sectors]
	* SoHDTiGaLCbS Share of Hydrogen Demand That is Green by Sector[Sectors] ~~|
BAU Green Hydrogen Demand by Sector[industry sector]=
	SUM(BAU Industrial Fuel Use[green hydrogen if,Industry Category!]) ~~|
BAU Green Hydrogen Demand by Sector[geoengineering sector]=
	BAU Geoengineering Sector Energy Use[green hydrogen if] ~~|
BAU Green Hydrogen Demand by Sector[district heat and hydrogen sector]=
	BAU Fuel Used to Generate Heat[green hydrogen if]
	~	BTU
	~		|

BAU Green Hydrogen Electricity Capacity Construction Subsidies Paid[Electricity Source\
		]=
	BAU Off Grid Capacity for Green Hydrogen Demand[Electricity Source]
	* BAU Subsidy per Unit Electricity Capacity Built[Electricity Source]
	~	$
	~		|

BAU Green Hydrogen Electricity Fixed OM Costs[Electricity Source]=
	BAU Off Grid Capacity for Green Hydrogen Demand[Electricity Source]
	* BAU Weighted Average Annual Fixed OM Cost per Unit Capacity[Electricity Source]
	~	$
	~		|

BAU Green Hydrogen Electricity Generation Subsidies Paid[Electricity Source]=
	BAU Off Grid Electricity Demand for Green Hydrogen by Power Plant Type[Electricity Source\
		]
	* BAU Subsidy per Unit Electricity Output Adjusted for Subsidy Duration[Electricity Source\
		]
	~	$
	~		|

BAU Green Hydrogen Electricity Variable OM Costs[Electricity Source]=
	BAU Off Grid Electricity Demand for Green Hydrogen by Power Plant Type[Electricity Source\
		]
	* BAU Weighted Average Variable OM Cost per Unit Electricity Output[Electricity Source\
		]
	~	$
	~		|

BAU Grid Batteries Capacity Market Revenue for Seasonal Dispatchable Reliability per Unit Elec Output\
		[Optimization Pass]=
	MAX(0,
	  BAU Capacity Market Price for Seasonal Dispatchable Reliability by Optimization Pass\
		[Optimization Pass]
	  * (1 - BAU Battery Storage Usage Factor Discount in Binding Peak Hour)
	  * Days per Year
	  * One Day)
	 
	*ESTRTE Grid Battery Round Trip Efficiency
	/GBSC Diurnal Grid Battery Daily Storage Duration
	~	$/(MW*hr)
	~		|

BAU Grid Batteries Net Energy Market Revenue per Unit Elec Output=
	MAX(
	  0,
	
	  BAU Weighted Average Discharging Revenue for Grid Batteries after Subsidies
	  - BAU Weighted Average Charging Cost for Diurnal Technologies
	)
	
	+ BAU Decline in Grid Battery Costs
	~	$/(MW*hr)
	~		|

BAU Gross Domestic Product by ISIC Code[ISIC Code]=
	BGDP BAU Gross Domestic Product
	* ZIDZ(
	  BAU Value Added by ISIC Code by Year[ISIC Code],
	
	  SUM(BAU Value Added by ISIC Code by Year[ISIC Code!])
	  )
	~	$
	~		|

BAU Guaranteed Dispatch Amount[Electricity Source,Electricity Timeslice,Hour]=
	MAX(
	
	BAU RPS Qualifying Guaranteed Dispatch Amount[Electricity Source,Electricity Timeslice\
		,Hour,RPS]
	+ BAU Non RPS Qualifying Guaranteed Dispatch Amount after RPS Policy[Electricity Source\
		,Electricity Timeslice,Hour,RPS],
	
	BAU RPS Qualifying Guaranteed Dispatch Amount[Electricity Source,Electricity Timeslice\
		,Hour,CES]
	+ BAU Non RPS Qualifying Guaranteed Dispatch Amount after RPS Policy[Electricity Source\
		,Electricity Timeslice,Hour,CES]
	)
	~	MW*hr
	~		|

BAU Guaranteed Dispatch Percentage for Elec Portfolio Std Qualifying Resources[Electricity Source\
		,RPS]=
	RQSD RPS Qualifying Source Definitions[Electricity Source]
	* BGDPbES BAU Guaranteed Dispatch Percentage by Electricity Source[Electricity Source\
		] ~~|
BAU Guaranteed Dispatch Percentage for Elec Portfolio Std Qualifying Resources[Electricity Source\
		,CES]=
	RQSD CES Qualifying Source Definitions[Electricity Source]
	* BGDPbES BAU Guaranteed Dispatch Percentage by Electricity Source[Electricity Source\
		]
	~	Dmnl
	~		|

BAU Heat Rate by Electricity Fuel for Plants Built This Year[Electricity Source]=
	SUM(
	  BHRaSYC BAU Heat Rates[Electricity Source,Modeled Vintage!]
	  * This Year Modeled Vintage Flag[Modeled Vintage!]
	)
	~	BTU/(MW*hour)
	~		|

BAU Hourly Bid Electricity Capacity Factors by Plant Type[Electricity Source,Electricity Timeslice\
		,Hour]=
	IF THEN ELSE(
	  BDTPTUMCF Boolean Does This Plant Type Use Maximum Capacity Factor[Electricity Source\
		] > 0,
	
	  BAU Maximum Capacity Factor after RAF[Electricity Source],
	
	  BAU Weighted Average Expected Capacity Factors by Hour Without Hypothetical Adjustments\
		[Electricity Source,Electricity Timeslice,Hour]
	)
	~	Dmnl
	~		|

BAU Hourly Bid Electricity Factors for Plants Built This Year[Electricity Timeslice,Hour\
		,Electricity Source] :EXCEPT:          [
peak day electricity timeslice,Hour,Electricity Source]=
	IF THEN ELSE(
	  BDTPTUMCF Boolean Does This Plant Type Use Maximum Capacity Factor[Electricity Source\
		] > 0,
	
	  Maximum Capacity Factor after RAF[Electricity Source],
	
	  BAU Expected Capacity Factors by Hour for Plants Built This Year Without Hypothetical Calculations\
		[Electricity Source,Electricity Timeslice,Hour]
	) ~~|
BAU Hourly Bid Electricity Factors for Plants Built This Year[peak day electricity timeslice\
		,Hour,Electricity Source]=
	IF THEN ELSE(
	  BDTPTUMCF Boolean Does This Plant Type Use Maximum Capacity Factor[Electricity Source\
		] > 0,
	
	  MCF Maximum Capacity Factor[Electricity Source],
	
	  BAU Expected Capacity Factors by Hour for Plants Built This Year Without Hypothetical Calculations\
		[Electricity Source,peak day electricity timeslice,Hour]
	)
	~	Dmnl
	~		|

BAU Hourly CDF Values for Total Dispatch by Power Plant Type[Electricity Source,Electricity Timeslice\
		,Hour]=
	IF THEN ELSE(BAU Hourly Z Score by Power Plant Type for Total Dispatch[Electricity Source\
		,Electricity Timeslice,Hour]>=0,
	
	  1 - BAU Hourly PDF Values for Total Dispatch by Power Plant Type[Electricity Source\
		,Electricity Timeslice,Hour] * (Abramowitz and Stegun Values for CDF
	[a1]*BAU Hourly T Values for Total Dispatch by Power Plant Type[Electricity Source
	  ,Electricity Timeslice,Hour] + Abramowitz and Stegun Values for CDF[a2]*BAU Hourly T Values for Total Dispatch by Power Plant Type
	[Electricity Source,Electricity Timeslice,Hour
	]^2
	   +Abramowitz and Stegun Values for CDF[a3]*BAU Hourly T Values for Total Dispatch by Power Plant Type\
		[Electricity Source,
	Electricity Timeslice,Hour]^3+Abramowitz and Stegun Values for CDF
	  [a4]*BAU Hourly T Values for Total Dispatch by Power Plant Type[Electricity Source\
		,Electricity Timeslice,Hour]^4+Abramowitz and Stegun Values for CDF
	[a5]*BAU Hourly T Values for Total Dispatch by Power Plant Type[Electricity Source
	  ,Electricity Timeslice,Hour]^5),
	
	  1-(1 - BAU Hourly PDF Values for Total Dispatch by Power Plant Type[Electricity Source\
		,Electricity Timeslice,Hour] * (Abramowitz and Stegun Values for CDF
	[a1]*BAU Hourly T Values for Total Dispatch by Power Plant Type[Electricity Source
	  ,Electricity Timeslice,Hour] + Abramowitz and Stegun Values for CDF[a2]*BAU Hourly T Values for Total Dispatch by Power Plant Type
	[Electricity Source,Electricity Timeslice,Hour
	]^2
	   +Abramowitz and Stegun Values for CDF[a3]*BAU Hourly T Values for Total Dispatch by Power Plant Type\
		[Electricity Source,
	Electricity Timeslice,Hour]^3+Abramowitz and Stegun Values for CDF
	  [a4]*BAU Hourly T Values for Total Dispatch by Power Plant Type[Electricity Source\
		,Electricity Timeslice,Hour]^4+Abramowitz and Stegun Values for CDF
	[a5]*BAU Hourly T Values for Total Dispatch by Power Plant Type[Electricity Source
	  ,Electricity Timeslice,Hour]^5)))
	~	Dmnl
	~		|

BAU Hourly Energy Market Revenue from Total Electricity Dispatched by Power Plant Type\
		[Electricity Timeslice,Hour,Electricity Source]=
	BAU Marginal Dispatch Cost by Hour[Electricity Timeslice,Hour]
	*BAU Total Electricity Dispatched by Hour by Plant Type[Electricity Timeslice,Hour,Electricity Source\
		]
	~	$
	~		|

BAU Hourly Expected Dispatch Cost per Unit Total Electricity Dispatched by Power Plant Type\
		[Electricity Source,Electricity Timeslice,Hour]=
	BAU Dispatch Cost per Unit Electricity Output before Subsidies[Electricity Source]
	  -(BAU Dispatch Cost per Unit Electricity Output[Electricity Source]*NSDoDC Normalized Standard Deviation of Dispatch Costs
	[Electricity Source])*ZIDZ(BAU Hourly PDF Values for Total Dispatch by Power Plant Type\
		[Electricity Source,Electricity Timeslice
	,Hour],BAU Hourly CDF Values for Total Dispatch by Power Plant Type[Electricity Source\
		,Electricity Timeslice,Hour])
	~	$/(MW*hour)
	~		|

BAU Hourly Expected Dispatch Costs by Power Plant Type[Electricity Timeslice,Hour,Electricity Source\
		]=
	BAU Hourly Expected Dispatch Cost per Unit Total Electricity Dispatched by Power Plant Type\
		[Electricity Source,Electricity Timeslice,Hour]*BAU Total Electricity Dispatched by Hour by Plant Type\
		[Electricity Timeslice,Hour,Electricity Source]
	~	$
	~		|

BAU Hourly Net Energy Market Revenue from Total Electricity Dispatched by Power Plant Type\
		[Electricity Timeslice,Hour,Electricity Source]=
	BAU Hourly Energy Market Revenue from Total Electricity Dispatched by Power Plant Type\
		[Electricity Timeslice,Hour,Electricity Source]
	-BAU Hourly Expected Dispatch Costs by Power Plant Type[Electricity Timeslice,Hour,Electricity Source\
		]
	~	$
	~		|

BAU Hourly Output from Distributed Electricity Capacity[Electricity Source,Electricity Timeslice\
		,Hour]=
	SUM(BAU Hourly Output from Distributed Electricity Capacity by Building Type[Electricity Source\
		,Electricity Timeslice,Hour,Building Type!])
	~	MW*hr
	~		|

BAU Hourly Output from Distributed Electricity Capacity by Building Type[Electricity Source\
		,Electricity Timeslice,Hour,Building Type] :EXCEPT:    [solar PV es,Electricity Timeslice\
		,Hour,Building Type]=
	SYSHECF Start year Seasonal Expected Capacity Factor for Distributed Sources[Electricity Source\
		,Electricity Timeslice,Hour
	]
	  * BAU Distributed Electricity Source Capacity[Building Type,Electricity Source]
	  *One Hour ~~|
BAU Hourly Output from Distributed Electricity Capacity by Building Type[solar PV es,\
		Electricity Timeslice,Hour,Building Type]=
	MIN(
	
	  SYSHECF Start year Seasonal Expected Capacity Factor for Distributed Sources[solar PV es\
		,Electricity Timeslice,Hour]
	  * BAU Distributed Electricity Source Capacity[Building Type,solar PV es]
	  *One Hour,
	
	  SUM(BAU Buildings Sector Electricity Demand[Building Type,Building Component!])
	)
	~	MW*hr
	~		|

BAU Hourly PDF Values for Total Dispatch by Power Plant Type[Electricity Source,Electricity Timeslice\
		,Hour]=
	(1/sqrt(2*3.14159))*exp(-BAU Hourly Z Score by Power Plant Type for Total Dispatch[Electricity Source\
		,Electricity Timeslice,Hour]^2/2)
	~	Dmnl
	~		|

BAU Hourly Share of Battery Capacity That Can be Charged[Hybrid Electricity Source,Electricity Timeslice\
		,Hour]=
	MIN( 
	  BAU Expected Capacity Factors by Hour for Plants Built This Year[Hybrid Electricity Source\
		,Electricity Timeslice,Hour],
	  HESBCpUEC Hybrid Electricity Source Battery Capacity per Unit Electricity Capacity
	 )
	~	Dmnl
	~		|

BAU Hourly Share of Capacity that Can be Shifted[Hybrid Electricity Source,Electricity Timeslice\
		,Hour]=
	HESBCpUEC Hybrid Electricity Source Battery Capacity per Unit Electricity Capacity
	~	Dmnl
	~		|

BAU Hourly T Values for Total Dispatch by Power Plant Type[Electricity Source,Electricity Timeslice\
		,Hour]=
	1/(1+0.231642*ABS(BAU Hourly Z Score by Power Plant Type for Total Dispatch[Electricity Source\
		,Electricity Timeslice,Hour]))
	~	Dmnl
	~		|

BAU Hourly Z Score by Power Plant Type for Total Dispatch[Electricity Source, Electricity Timeslice\
		, Hour]=
	ZIDZ((BAU Marginal Dispatch Cost by Hour[Electricity Timeslice,Hour]-BAU Dispatch Cost per Unit Electricity Output
	[Electricity Source]),ABS(NSDoDC Normalized Standard Deviation of Dispatch Costs[Electricity Source\
		]*BAU Dispatch Cost per Unit Electricity Output
	[Electricity Source]))
	~	Dmnl
	~		|

BAU Hybrid Battery Cost per Unit Power Plant Capacity=
	(BAU Battery Energy Cost per Unit Capacity
	      * GBSC Diurnal Grid Battery Daily Storage Duration
	      + BAU Battery Power Cost per Unit Capacity
	    )
	    
	    * HESBCpUEC Hybrid Electricity Source Battery Capacity per Unit Electricity Capacity
	~	$/MW
	~		|

BAU Hybrid Battery Cost per Unit Power Plant Capacity after Construction Subsidies=
	BAU Hybrid Battery Cost per Unit Power Plant Capacity
	* (1 - BPSpUGBCD BAU Percent Subsidy per Unit Grid Battery Capacity Deployed)
	~	$/MW
	~		|

BAU Hydrogen Demand by Sector[transportation sector]=
	SUM(BAU Transportation Sector Fuel Used[Vehicle Type!,Cargo Type!,Vehicle Technology\
		!,hydrogen tf]) ~~|
BAU Hydrogen Demand by Sector[electricity sector]=
	BAU Last Year Electricity Fuel Use[hydrogen combustion turbine es]
	+ BAU Last Year Electricity Fuel Use[hydrogen combined cycle es] ~~|
BAU Hydrogen Demand by Sector[residential buildings sector]=
	SUM(BAU Building Components Energy Use[urban residential,hydrogen bf,Building Component\
		!])
	+ SUM(BAU Building Components Energy Use[rural residential,hydrogen bf,Building Component\
		!]) ~~|
BAU Hydrogen Demand by Sector[commercial buildings sector]=
	SUM(BAU Building Components Energy Use[commercial,hydrogen bf,Building Component!]) ~~|
BAU Hydrogen Demand by Sector[industry sector]=
	SUM(BAU Industrial Fuel Use[hydrogen if,Industry Category!])
	+ SUM(BAU Industrial Fuel Use[green hydrogen if,Industry Category!])
	+ SUM(BAU Industrial Fuel Use[low carbon hydrogen if,Industry Category!]) ~~|
BAU Hydrogen Demand by Sector[district heat and hydrogen sector]=
	BAU Fuel Used to Generate Heat[hydrogen if]
	+ BAU Fuel Used to Generate Heat[green hydrogen if]
	+ BAU Fuel Used to Generate Heat[low carbon hydrogen if] ~~|
BAU Hydrogen Demand by Sector[LULUCF sector]=
	0 ~~|
BAU Hydrogen Demand by Sector[geoengineering sector]=
	BAU Geoengineering Sector Energy Use[hydrogen if]
	+ BAU Geoengineering Sector Energy Use[green hydrogen if]
	+ BAU Geoengineering Sector Energy Use[low carbon hydrogen if]
	~	BTU
	~		|

BAU Hydrogen Fuel Carbon Tax Amount per Unit Energy[Industrial Fuel]=
	BCTR BAU Carbon Tax Rate[district heat and hydrogen sector]
	/ Grams per Metric Ton CO2e
	* BAU Hydrogen Fuel Taxable CO2e Emissions Intensity[Industrial Fuel]
	~	$/BTU
	~		|

BAU Hydrogen Fuel Cost per Unit Energy[Industrial Fuel]=
	MAX(BAU Pretax Fuel Price by Sector Including Endogenous Electricity Prices[industrial fuel within all fuels\
		,district heat and hydrogen sector
	]
	  + BAU Hydrogen Fuel Total Tax or Subsidy Amount per Unit Energy[Industrial Fuel],
	0
	)
	~	$/BTU
	~		|

BAU Hydrogen Fuel Taxable CO2e Emissions Intensity[Industrial Fuel]=
	SUM(
	  Industrial Fuel Pollutant Emissions Intensities This Year[cement and other nonmetallic minerals 239\
		,Pollutant!,Industrial Fuel]
	  * GWP by Pollutant[Pollutant!]
	  * BPTbCP BAU Hydrogen Pollutants Taxed by Carbon Pricing[Pollutant!]
	)
	~	g CO2e/BTU
	~		|

BAU Hydrogen Fuel Total Tax or Subsidy Amount per Unit Energy[Industrial Fuel]=
	BAU Hydrogen Fuel Carbon Tax Amount per Unit Energy[Industrial Fuel]
	+ BAU District Heat and Hydrogen Fuel Other Tax or Subsidy Amount per Unit Energy[Industrial Fuel\
		]
	~	$/BTU
	~		|

BAU Hydrogen Production by Pathway[Hydrogen Production Pathway]=
	BAU New Hydrogen Production Capacity[Hydrogen Production Pathway] * One Year
	
	+ BAU Surviving Capacity Used for Hydrogen Production[Hydrogen Production Pathway]
	~	BTU
	~		|

BAU Hydrogen Production Capacity[Hydrogen Production Pathway]=
	BAU Hydrogen Production Capacity Installed During Model Run[Hydrogen Production Pathway\
		]
	+ BAU Surviving Preexisting Hydrogen Production Capacity[Hydrogen Production Pathway\
		]
	~	BTU
	~		|

BAU Hydrogen Production Capacity Factors by Pathway[Hydrogen Production Pathway]=
	ZIDZ(
	  BAU Hydrogen Production by Pathway[Hydrogen Production Pathway],
	  BAU Hydrogen Production Capacity[Hydrogen Production Pathway]
	)
	~	Dmnl
	~		|

BAU Hydrogen Production Capacity Installed During Model Run[Hydrogen Production Pathway\
		]=
	BAU Surviving Hydrogen Production Capacity Installed During Model Run[Hydrogen Production Pathway\
		]
	+ BAU New Hydrogen Production Capacity[Hydrogen Production Pathway] * One Year
	~	BTU
	~		|

BAU Hydrogen Production Dispatch Cost[Hydrogen Production Pathway]=
	BAU Cost per Unit New Hydrogen Production[Hydrogen Production Pathway]
	- 
	ZIDZ(
	  HPEC Hydrogen Production Equipment CapEx[Hydrogen Production Pathway],
	  Discount Factor to Levelize Capital Costs
	)
	- HPEC Hydrogen Production Equipment OpEx[Hydrogen Production Pathway]
	~	$/BTU
	~		|

BAU Hydrogen Production Dispatch Cost Parameters as Vector[Hydrogen Production Pathway\
		,ptype]=
	3 ~~|
BAU Hydrogen Production Dispatch Cost Parameters as Vector[Hydrogen Production Pathway\
		,ppriority]=
	BAU Hydrogen Production Dispatch Cost[Hydrogen Production Pathway] * One BTU / One Dollar\
		 ~~|
BAU Hydrogen Production Dispatch Cost Parameters as Vector[Hydrogen Production Pathway\
		,pwidth]=
	ABS(BAU Normalized Standard Deviation of Dispatch Costs Mapped to Hydrogen Production Pathways\
		[Hydrogen Production Pathway]*BAU Hydrogen Production Dispatch Cost[Hydrogen Production Pathway\
		] * One BTU / One Dollar) ~~|
BAU Hydrogen Production Dispatch Cost Parameters as Vector[Hydrogen Production Pathway\
		,pextra]=
	0
	~	Dmnl
	~		|

BAU Hydrogen Production Subsidies Expiring This Year[Hydrogen Production Pathway]= DELAY FIXED\
		 (
	BAU Hydrogen Production Subsidies for Newly Built Plants[Hydrogen Production Pathway\
		],
	HPSD Hydrogen Production Subsidy Duration,
	0)
	~	$/Year
	~		|

BAU Hydrogen Production Subsidies for Newly Built Plants[Hydrogen Production Pathway]\
		=
	BAU New Hydrogen Production Capacity[Hydrogen Production Pathway]
	* BSfHPbP BAU Subsidy for Hydrogen Production by Pathway[Hydrogen Production Pathway\
		]
	~	$/Year
	~		|

BAU Hydrogen Production Subsidy Payments[Hydrogen Production Pathway]=
	(BAU Hydrogen Production Subsidies for Newly Built Plants[Hydrogen Production Pathway\
		] * One Year
	  + BAU Last Year Hydrogen Production Subsidy Payments[Hydrogen Production Pathway]
	  - BAU Hydrogen Production Subsidies Expiring This Year[Hydrogen Production Pathway\
		] * One Year)
	
	* BAU Hydrogen Production Capacity Factors by Pathway[Hydrogen Production Pathway]
	~	$
	~		|

BAU Hydrogen Sector Carbon Tax Rebate due to CCS=
	BAU Amount of CO2 Sequestered by Hydrogen Sector
	* BCTR BAU Carbon Tax Rate[district heat and hydrogen sector]
	~	$
	~		|

BAU Hydrogen Sector Carbon Tax Revenue=
	SUM(
	  BAU Hydrogen Sector Fuel Use[Industrial Fuel!]
	  * BAU Hydrogen Fuel Carbon Tax Amount per Unit Energy[Industrial Fuel!]
	)
	~	$
	~		|

BAU Hydrogen Sector CCS Transportation and Storage Costs=
	BAU This Year Pollutants Sequestered by Hydrogen Sector[CO2]
	/ Grams per Metric Ton CO2e
	/ Grams Pollutant per Gram CO2e Unit Converter
	
	* (CCSTaSC CCS Transportation and Storage Costs
	  - CCSTaSC CCS Transportation and Storage Subsidies)
	~	$
	~		|

BAU Hydrogen Sector CCS Transportation and Storage Subsidies=
	BAU This Year Pollutants Sequestered by Hydrogen Sector[CO2]
	/ Grams per Metric Ton CO2e
	/ Grams Pollutant per Gram CO2e Unit Converter
	
	* 
	CCSTaSC CCS Transportation and Storage Subsidies
	~	$
	~		|

BAU Hydrogen Sector CO2e Emissions=
	SUM(
	  BAU Hydrogen Sector Pollutant Emissions[Pollutant!]
	  * GWP by Pollutant[Pollutant!]
	)
	~	g CO2e
	~		~	:SUPPLEMENTARY 
	|

BAU Hydrogen Sector Electricity Demand=
	BAU Hydrogen Sector Fuel Use Before Green Hydrogen[electricity if]
	* MWh per BTU
	~	MW*hr
	~		|

BAU Hydrogen Sector Fuel Use[Industrial Fuel]=
	BAU Hydrogen Sector Fuel Use Before Green Hydrogen[Industrial Fuel]
	+ BAU Fuel Use for Green Hydrogen Production[Industrial Fuel]
	~	BTU
	~		|

BAU Hydrogen Sector Fuel Use Before Green Hydrogen[Industrial Fuel]=
	SUM(BAU Hydrogen Sector Fuel Use by Pathway[Hydrogen Production Pathway!,Industrial Fuel\
		])
	+ BAU Fuel Used for CCS by Hydrogen Sector[Industrial Fuel]
	~	BTU
	~		|

BAU Hydrogen Sector Fuel Use by Pathway[Hydrogen Production Pathway,Industrial Fuel]=
	BAU Hydrogen Production by Pathway[Hydrogen Production Pathway]
	
	* FIoHP Fuel Intensity of Hydrogen Production[Hydrogen Production Pathway,Industrial Fuel\
		]
	~	BTU
	~		|

BAU Hydrogen Sector Grid Electricity Demand=
	BAU Hydrogen Sector Electricity Demand
	- BAU Hydrogen Sector Off Grid Electricity Demand for Green Hydrogen
	~	MW*hour
	~		|

BAU Hydrogen Sector Off Grid Electricity Demand for Green Hydrogen=
	BAU Hydrogen Sector Electricity Demand
	  * ZIDZ(
	      BAU Hydrogen Sector Fuel Use by Pathway[electrolysis with guaranteed clean electricity\
		,electricity if],
	
	      (BAU Hydrogen Sector Fuel Use by Pathway[electrolysis with guaranteed clean electricity\
		,electricity if]
	        + BAU Hydrogen Sector Fuel Use by Pathway[electrolysis,electricity if]
	       )
	    )
	~	MW*hour
	~		|

BAU Hydrogen Sector Off Grid Electricity Demand for Green Hydrogen That is New This Year\
		=
	MAX(
	  BAU Hydrogen Sector Off Grid Electricity Demand for Green Hydrogen
	  - BAU Last Year Hydrogen Sector Off Grid Electricity Demand for Green Hydrogen,
	
	  0
	)
	~	MW*hour
	~		|

BAU Hydrogen Sector Pollutant Emissions[Pollutant]=
	SUM(
	  BAU Hydrogen Sector Fuel Use[Industrial Fuel!]
	  * Industrial Fuel Pollutant Emissions Intensities This Year[cement and other nonmetallic minerals 239\
		,Pollutant,Industrial Fuel
	!]
	)
	- BAU This Year Pollutants Sequestered by Hydrogen Sector[Pollutant]
	~	g pollutant
	~	Hydrogen supply isn't an industry, but it uses industrial sector fuel \
		emissions intensities.  Since the emissions intensities are subscripted by \
		industry, we must choose an industry to use, though the emissions \
		intensities may be the same for all industries.  We use the cement \
		industry as our model, as cement is produced all over the world, is a \
		major emitter, and therefore is unlikely to be repurposed as another \
		industry in EPS model adaptations.
	|

BAU Hypothetical Annual Costs for Plant Types with No Capacity[Electricity Source]=
	SUM(BAU Five Year Average Hourly Expected Dispatch Cost per Unit Total Electricity Dispatched by Power Plant Type\
		[Electricity Source
	,Electricity Timeslice!,Hour!]*SHELF Days per Electricity Timeslice[Electricity Timeslice\
		!]*BAU Hypothetical Hourly Electricity Capacity Factor
	[Electricity Timeslice!,Hour!,Electricity Source])
	* One Hour
	~	$/MW
	~		|

BAU Hypothetical Annual Revenue for Plant Types with No Capacity[Electricity Source]=
	SUM(BAU Five Year Average Marginal Dispatch Cost by Hour[Electricity Timeslice!,Hour\
		!]*BAU Hypothetical Hourly Electricity Capacity Factor
	[Electricity Timeslice!,Hour!,Electricity Source]*SHELF Days per Electricity Timeslice\
		[Electricity Timeslice!])
	* One Hour
	~	$/MW
	~		|

BAU Hypothetical Fraction of Capacity Dispatched Through Elec Portfolio Dispatch[Electricity Source\
		,Electricity Timeslice
,Hour,RPS]=
	IF THEN ELSE(
	
	  BAU Total Electricity Demand Including TnD Losses
	  * BAU Elec Portfolio Percentage to Seek This Year[RPS] <
	
	  BAU Expected Elec Portfolio Qualifying Dispatch from Last Year Capacity and This Year Mandated Change in Capacity\
		[RPS
	],
	
	  0,
	
	  MAX(
	  BAU Marginal Capacity Factor by Hour[Electricity Source,Electricity Timeslice,Hour\
		,RPS]
	  * RQSD RPS Qualifying Source Definitions[Electricity Source]
	  
	  - BAU Weighted Average Expected Capacity Factors by Hour Without Hypothetical Adjustments\
		[Electricity Source,Electricity Timeslice
	,Hour]
	  * BAU Guaranteed Dispatch Percentage for Elec Portfolio Std Qualifying Resources[Electricity Source\
		,RPS],
	
	  0
	 )
	) ~~|
BAU Hypothetical Fraction of Capacity Dispatched Through Elec Portfolio Dispatch[Electricity Source\
		,Electricity Timeslice
,Hour,CES]=
	IF THEN ELSE(
	
	  BAU Total Electricity Demand Including TnD Losses
	  * BAU Elec Portfolio Percentage to Seek This Year[CES] <
	
	  BAU Expected Elec Portfolio Qualifying Dispatch from Last Year Capacity and This Year Mandated Change in Capacity\
		[CES
],
	
	  0,
	
	  MAX(
	  BAU Marginal Capacity Factor by Hour[Electricity Source,Electricity Timeslice,Hour\
		,CES]
	  * RQSD CES Qualifying Source Definitions[Electricity Source]
	  
	  - BAU Weighted Average Expected Capacity Factors by Hour Without Hypothetical Adjustments\
		[Electricity Source,Electricity Timeslice
	,Hour]
	  * BAU Guaranteed Dispatch Percentage for Elec Portfolio Std Qualifying Resources[Electricity Source\
		,CES],
	
	  0
	 )
	)
	~	Dmnl
	~		|

BAU Hypothetical Fraction of Capacity Dispatched Through Guaranteed Dispatch[Electricity Source\
		,Electricity Timeslice,Hour]=
	IF THEN ELSE(
	
	  BAU Total Electricity Demand by Hour After Demand Altering Technologies[Electricity Timeslice\
		,Hour] <
	
	  SUM(BAU Last Year Capacity and This Year Mandated Change in Capacity by Electricity Source\
		[Electricity Source!]
	  * BAU Weighted Average Expected Capacity Factors by Hour Without Hypothetical Adjustments\
		[Electricity Source!,Electricity Timeslice,Hour]
	  * BGDPbES BAU Guaranteed Dispatch Percentage by Electricity Source[Electricity Source\
		!]
	  * One Hour
	  ),
	
	  0,
	
	  BAU Expected Capacity Factors by Hour for Plants Built This Year Without Hypothetical Calculations\
		[Electricity Source
	,Electricity Timeslice,Hour]
	  * BGDPbES BAU Guaranteed Dispatch Percentage by Electricity Source[Electricity Source\
		]
	)
	~	Dmnl
	~		|

BAU Hypothetical Hourly Electricity Capacity Factor[Electricity Timeslice,Hour,Electricity Source\
		]=
	MIN(
	  BAU Hourly Bid Electricity Factors for Plants Built This Year[Electricity Timeslice\
		,Hour,Electricity Source],
	
	  BAU Hypothetical Hourly Electricity Capacity Factor for Least Cost Dispatch[Electricity Timeslice\
		,Hour,Electricity Source
	]
	  + MAX(BAU Hypothetical Fraction of Capacity Dispatched Through Elec Portfolio Dispatch\
		[Electricity Source,Electricity Timeslice
	,Hour,RPS],
	        BAU Hypothetical Fraction of Capacity Dispatched Through Elec Portfolio Dispatch\
		[Electricity Source,Electricity Timeslice
	,Hour,CES]
	    )
	  + BAU Hypothetical Fraction of Capacity Dispatched Through Guaranteed Dispatch[Electricity Source\
		,Electricity Timeslice,Hour
	]
	)
	~	Dmnl
	~		|

BAU Hypothetical Hourly Electricity Capacity Factor for Least Cost Dispatch[Electricity Timeslice\
		,Hour,Electricity Source]=
	SUPPLY AT PRICE(
	    BAU Hourly Bid Electricity Factors for Plants Built This Year[Electricity Timeslice\
		,Hour,Electricity Source],
	    BAU Five Year Average Power Plant Dispatch Parameters as Vector for New Plants[Electricity Source\
		,ptype],
	    BAU Five Year Average Marginal Dispatch Cost by Hour[Electricity Timeslice,Hour]\
		)
	~	Dmnl
	~		|

BAU Hypothetical Net Revenue for Plant Types with No Capacity per MW[Electricity Source\
		]=
	BAU Hypothetical Annual Revenue for Plant Types with No Capacity[Electricity Source]
	-BAU Hypothetical Annual Costs for Plant Types with No Capacity[Electricity Source]
	~	$/MW
	~		|

BAU IFTQfS Industrial Fuel Types Qualifying for Clean Heat Production Subsidy[Industrial Fuel\
		]=
	GET DIRECT CONSTANTS(
	   'InputData/indst/IFTQfS/IFTQfS-production.csv',
	   ',',
	   'B2*'
	)
	~	Dmnl
	~		|

BAU Imported Electricity=
	SUM(EIaE BAU Imported Electricity by Electricity Source[Electricity Source!])
	~	MW*hr
	~		|

BAU Imported Output by ISIC Code[ISIC Code]=
	MAX(
	  0,
	
	  ZIDZ(
	    BAU Output by ISIC Code by Year[ISIC Code],
	
	    BAU Domestic Content Share of Consumption by ISIC Code from Exogenous Data[ISIC Code\
		]
	  )
	  - BAU Output by ISIC Code by Year[ISIC Code]
	)
	~	$
	~		|

BAU Imported Output Shifted to In Region Suppliers by ISIC Code[ISIC Code] :EXCEPT: [\
		Industry Category ISIC Code]=
	0 ~~|
BAU Imported Output Shifted to In Region Suppliers by ISIC Code[Industry Category ISIC Code\
		]=
	BAU Imported Output by ISIC Code[Industry Category ISIC Code]
	* Fraction of Imported Industrial Outputs Shifted to In Region Suppliers This Year[Industry Category\
		]
	~	$
	~		|

BAU Increase in Demand by Hour for Diurnal Net Peak Load Reduction and RPS Compliance\
		[Electricity Timeslice, Hour]=
	BAU Increase in Demand by Hour for Diurnal Net Peak Load Reduction excluding Hybrid Batteries\
		[Electricity Timeslice
	,Hour]
	~	MW*hr
	~		|

BAU Increase in Demand by Hour for Diurnal Net Peak Load Reduction excluding Hybrid Batteries\
		[Electricity Timeslice,Hour]=
	BAU Excess Electricity vs Daily Average by Hour after Seasonal Net Peak Load Reduction\
		[Electricity Timeslice,Hour]
	* MIN(
	    1,
	
	    ZIDZ(
	      BAU Maximum Daily Quantity of Electricity Absorbed for Diurnal Net Peak Load Reduction Excluding Hybrid Batteries\
		[Electricity Timeslice],
	      SUM(BAU Excess Electricity vs Daily Average by Hour after Seasonal Net Peak Load Reduction\
		[Electricity Timeslice,Hour!])
	    )
	)
	~	MW*hr
	~		|

BAU Increase in Demand by Hour for Seasonal Net Peak Load Reduction[Electricity Timeslice\
		,Hour]=
	BAU Daily Increase in Demand for Seasonal Net Peak Load Reduction[Electricity Timeslice\
		]
	* ZIDZ(
	    BAU Excess Potenial Output from Surviving Capacity vs Annual Average by Hour[Electricity Timeslice\
		,Hour],
	    SUM(BAU Excess Potenial Output from Surviving Capacity vs Annual Average by Hour\
		[Electricity Timeslice,Hour!])
	  )
	~	MW*hr
	~		|

BAU Incremental Costs from Substitute Fuel Production due to LCFS=
	SUM(
	  BAU Change in Fuel Use by Fuel and Technology due to LCFS with Elec Eff Adj[Vehicle Type\
		!,Cargo Type!,Vehicle Technology!
	,Transportation Fuel!]
	  * ICtPSFfL Incremental Cost to Produce Substitute Fuel for LCFS[Transportation Fuel\
		!]
	)
	~	$
	~		|

BAU Incremental Revenue for Cost Effective CCUS Retrofits[CCUS Electricity Source, Optimization Pass\
		,RPS]=
	MAX(0,
	  BAU Total Change in Energy Market and CES Revenue for CCUS Retrofits[CCUS Electricity Source\
		,Optimization Pass,RPS]
	  -(BAU Cost per MW for CCUS Retrofits Excluding Subsidies[CCUS Electricity Source]
	     * SoCtMbCtbDP Share of Costs that Must be Covered to Be Deemed Profitable[CCUS Electricity Source\
		]
	  )
	) ~~|
BAU Incremental Revenue for Cost Effective CCUS Retrofits[CCUS Electricity Source,Optimization Pass\
		,CES]=
	MAX(0,
	  BAU Total Change in Energy Market and CES Revenue for CCUS Retrofits[CCUS Electricity Source\
		,Optimization Pass,CES]
	  -(BAU Cost per MW for CCUS Retrofits Excluding Subsidies[CCUS Electricity Source]
	     * SoCtMbCtbDP Share of Costs that Must be Covered to Be Deemed Profitable[CCUS Electricity Source\
		]
	  )
	)
	~	$/MW
	~		|

BAU Incremental Revenue for Cost Effective CCUS Retrofits without CES[CCUS Electricity Source\
		]=
	MAX(0,
	  BAU Predicted Change in Energy Market Revenue for CCUS Retrofits[CCUS Electricity Source\
		]
	  -(BAU Cost per MW for CCUS Retrofits Excluding Subsidies[CCUS Electricity Source]
	     * SoCtMbCtbDP Share of Costs that Must be Covered to Be Deemed Profitable[CCUS Electricity Source\
		]
	  )
	)
	~	$/MW
	~		|

BAU Incremental Revenue for Cost Effectiveness Additions[Electricity Source,Optimization Pass\
		,RPS]=
	MAX(0,
	  BAU Total Energy Market and CES Revenue and Variable Subsidies by Optimization Pass\
		[Electricity Source,Optimization Pass,RPS]
	  -(BAU Annualized Fixed Costs per Unit New Capacity[Electricity Source]
	     * SoCtMbCtbDP Share of Costs that Must be Covered to Be Deemed Profitable[Electricity Source\
		]
	  )
	) ~~|
BAU Incremental Revenue for Cost Effectiveness Additions[Electricity Source,Optimization Pass\
		,CES]=
	MAX(0,
	  BAU Total Energy Market and CES Revenue and Variable Subsidies by Optimization Pass\
		[Electricity Source,Optimization Pass,CES]
	  -(BAU Annualized Fixed Costs per Unit New Capacity[Electricity Source]
	     * SoCtMbCtbDP Share of Costs that Must be Covered to Be Deemed Profitable[Electricity Source\
		]
	  )
	)
	~	$/MW
	~		|

BAU Incremental Revenue for Cost Effectiveness Additions for Hybrid Power Plants[Hybrid Electricity Source\
		,Optimization Pass,RPS]=
	MAX(0,
	  BAU Total Energy Market and CES Revenue and Variable Subsidies by Optimization Pass for Hybrid Power Plants\
		[Hybrid Electricity Source
	,Optimization Pass,RPS]
	  -(BAU Annualized Fixed Costs per Unit New Capacity[Hybrid Electricity Source]+BAU Annual Financing Repayment per Unit Storage Capacity for Hybrid Power Plants
	[Hybrid Electricity Source])
	    * SoCtMbCtbDP Share of Costs that Must be Covered to Be Deemed Profitable[Hybrid Electricity Source\
		]
	  ) ~~|
BAU Incremental Revenue for Cost Effectiveness Additions for Hybrid Power Plants[Hybrid Electricity Source\
		,Optimization Pass,CES]=
	MAX(0,
	  BAU Total Energy Market and CES Revenue and Variable Subsidies by Optimization Pass for Hybrid Power Plants\
		[Hybrid Electricity Source
	,Optimization Pass,CES]
	  -(BAU Annualized Fixed Costs per Unit New Capacity[Hybrid Electricity Source]+BAU Annual Financing Repayment per Unit Storage Capacity for Hybrid Power Plants
	[Hybrid Electricity Source])
	    * SoCtMbCtbDP Share of Costs that Must be Covered to Be Deemed Profitable[Hybrid Electricity Source\
		]
	  )
	~	$/MW
	~		|

BAU Incremental Revenue for Cost Effectiveness Additions for Hybrid Power Plants without CES\
		[Hybrid Electricity Source]=
	MAX(0,
	  BAU Average Four Year Prior Net Energy Market Revenue by Plant Type Excluding Subsidies for Hybrid Power Plants\
		[Hybrid Electricity Source
	]
	  -(BAU Annualized Fixed Costs per Unit New Capacity[Hybrid Electricity Source]+ BAU Annual Financing Repayment per Unit Storage Capacity for Hybrid Power Plants
	[Hybrid Electricity Source])
	    * SoCtMbCtbDP Share of Costs that Must be Covered to Be Deemed Profitable[Hybrid Electricity Source\
		]
	  )
	~	$/MW
	~		|

BAU Incremental Revenue for Cost Effectiveness Additions without CES[Electricity Source\
		]=
	MAX(0,
	 BAU Average Four Year Prior Total Predicted Net Energy Market Revenue per MW[Electricity Source\
		]
	  -(BAU Annualized Fixed Costs per Unit New Capacity[Electricity Source]
	     * SoCtMbCtbDP Share of Costs that Must be Covered to Be Deemed Profitable[Electricity Source\
		]
	  )
	)
	~	$/MW
	~		|

BAU Industrial Clean Heat Production Subsidy Amount Paid[Industry Category]=
	SUM(
	  BAU Clean Industrial Heat Production Subsidy Rate by Equipment Vintage[Industrial Fuel\
		!,industrial heating process!,Model Run Vintage
	!]
	  * BAU Output from Industrial Equipment Installed During Model Run[Industry Category\
		,industrial heating process!,Model Run Vintage
	!]
	  * BAU Last Year Industrial Equipment Fuel Type Shares in Electricity Equivalent by Vintage\
		[Industry Category,industrial heating process
	!,Industrial Fuel!,Model Run Vintage!]
	  * BAU Last Year Energy Intensity of Industrial Production in Electricity Equivalent by Vintage\
		[Industry Category,
	Industrial Fuel!,Model Run Vintage!]
	)
	
	+ 
	
	SUM(
	  BAU Clean Industrial Heat Subsidy Rate by Fuel Type[Industrial Fuel!,industrial heating process\
		!]
	  * BAU Output from New Industrial Equipment[Industry Category,industrial heating process\
		!]
	  * BAU Share of New Industrial Equipment Allocated by Fuel Type in Electricity Equivalent\
		[Industry Category,Industrial Fuel
	!,industrial heating process!]
	  * BAU Energy Intensity of Industrial Production by Fuel for New Equipment in Electricity Equivalent\
		[Industry Category
	,Industrial Fuel!]
	)
	~	$
	~		|

BAU Industrial Emissions per Unit Output[Industry Category]=
	ZIDZ(
	  BAU Industrial Sector CO2e Emissions[Industry Category],
	
	  BAU Output by ISIC Code by Year[Industry Category ISIC Code]
	)
	/ Grams per Metric Ton CO2e
	~	metric tons CO2e/$
	~		|

BAU Industrial Energy Related Emissions Excluding Fuels to Power CCS[Industrial Fuel,\
		Industry Category,Pollutant]=
	BAU Industrial Fuel Use for Energy before CCS and Methane Capture[Industrial Fuel,Industry Category\
		]
	* Industrial Fuel Pollutant Emissions Intensities This Year[Industry Category,Pollutant\
		,Industrial Fuel]
	~	g pollutant
	~		|

BAU Industrial Energy Use by Fuel Type and Process[Industry Category,Industrial Fuel
,Industrial Process] :EXCEPT:                  [Industry Category,electricity if,Industrial Process\
		]=
	ZIDZ(
	  SUM(
	    BAU Output from Industrial Equipment Installed During Model Run[Industry Category\
		,Industrial Process,Model Run Vintage
	!]
	    * BAU Last Year Industrial Equipment Fuel Type Shares in Electricity Equivalent by Vintage\
		[Industry Category,Industrial Process
	,Industrial Fuel,Model Run Vintage!]
	    * BAU Last Year Energy Intensity of Industrial Production in Electricity Equivalent by Vintage\
		[Industry Category,Industrial Fuel,Model Run Vintage!]
	  )
	
	  + BAU Output from New Industrial Equipment[Industry Category,Industrial Process]
	  * BAU Share of New Industrial Equipment Allocated by Fuel Type in Electricity Equivalent\
		[Industry Category,Industrial Fuel
	,Industrial Process]
	  * BAU Energy Intensity of Industrial Production by Fuel for New Equipment in Electricity Equivalent\
		[Industry Category
	,Industrial Fuel]
	
	  + BAU Output from Preexisting Industrial Equipment[Industry Category,Industrial Process\
		]
	  * Start Year BAU Fuel Type Shares in Electricity Equivalent[Industry Category,Industrial Process\
		,Industrial Fuel]
	  * Start Year Energy Intensity of Industrial Production in Electricity Equivalent[Industry Category\
		],
	  1 - PIFURfE Percentage Industry Fuel Use Reduction for Electricity[Industry Category\
		,Industrial Process]
	) ~~|
BAU Industrial Energy Use by Fuel Type and Process[Industry Category,electricity if
,Industrial Process]=
	SUM(
	  BAU Output from Industrial Equipment Installed During Model Run[Industry Category,\
		Industrial Process,Model Run Vintage
	!]
	  * BAU Last Year Industrial Equipment Fuel Type Shares in Electricity Equivalent by Vintage\
		[Industry Category,Industrial Process
	,electricity if,Model Run Vintage!]
	  * BAU Last Year Energy Intensity of Industrial Production in Electricity Equivalent by Vintage\
		[Industry Category,electricity if,Model Run Vintage!]
	)
	
	+ BAU Output from New Industrial Equipment[Industry Category,Industrial Process]
	* BAU Share of New Industrial Equipment Allocated by Fuel Type in Electricity Equivalent\
		[Industry Category,electricity if
	,Industrial Process]
	* BAU Energy Intensity of Industrial Production by Fuel for New Equipment in Electricity Equivalent\
		[Industry Category,electricity if
	]
	
	+ BAU Output from Preexisting Industrial Equipment[Industry Category,Industrial Process\
		]
	* Start Year BAU Fuel Type Shares in Electricity Equivalent[Industry Category,Industrial Process\
		,electricity if]
	* Start Year Energy Intensity of Industrial Production in Electricity Equivalent[Industry Category\
		]
	~	BTU
	~	"Industrial Equipment Fuel Type Shares in Electricity Equivalent by \
		Vintage" add to 1 for each industry category, so that variable is \
		expecting to be multiplied by total output of each industry category.
	|

BAU Industrial Equipment Annual Costs and Annual Financing Repayment per Unit Energy in Electricity Equivalent\
		[Industry Category,Industrial Fuel,Industrial Process] :EXCEPT:     [Industry Category\
		,electricity if,Industrial Process]=
	BAU Present Value of Industrial Equipment Costs per Unit Energy[Industry Category,Industrial Fuel\
		,Industrial Process]
	/ (1 - PIFURfE Percentage Industry Fuel Use Reduction for Electricity[Industry Category\
		,Industrial Process]) ~~|
BAU Industrial Equipment Annual Costs and Annual Financing Repayment per Unit Energy in Electricity Equivalent\
		[Industry Category,electricity if,Industrial Process]=
	BAU Present Value of Industrial Equipment Costs per Unit Energy[Industry Category,electricity if\
		,Industrial Process]
	~	$/BTU
	~		|

BAU Industrial Equipment Annual Costs and Annual Financing Repayment per Unit Industrial Output in Electricity Equivalent\
		[Industry Category
,Industrial Fuel,Industrial Process]=
	MAX(
	BAU Industrial Equipment Annual Costs and Annual Financing Repayment per Unit Energy in Electricity Equivalent\
		[Industry Category
	,Industrial Fuel,Industrial Process]
	* BAU Energy Intensity of Industrial Production by Fuel for New Equipment in Electricity Equivalent\
		[Industry Category,Industrial Fuel],
	0
	)
	~	$/$
	~	The unit $/$ here refers to dollars of industrial output (in the \
		numerator) per dollar spent on fuel (in the denominator).
	|

BAU Industrial Equipment Annual Financing Repayment per Unit Energy[Industry Category\
		,Industrial Fuel,Industrial Process]=
	BAU Industrial Equipment Capital Cost per Unit Energy After Subsidy[Industry Category\
		,Industrial Fuel,Industrial Process]
	* BAU Capital Recovery Factor by Industry Fuel and Process[Industry Category,Industrial Fuel\
		,Industrial Process]
	~	$/BTU
	~		|

BAU Industrial Equipment Annual Financing Repayment per Unit Energy in Future Years[Industry Category\
		,Industrial Fuel,Industrial Process,Future Year]=
	IF THEN ELSE(
	
	  Numerical Future Year Definitions[Future Year] - Time < 0,
	  0, 
	  IF THEN ELSE(
	    Numerical Future Year Definitions[Future Year] - Time >= RPfFISCC Repayment Period for Financed Industry Sector Capital Costs\
		[Industrial Process], 
	    0,
	    BAU Industrial Equipment Annual Financing Repayment per Unit Energy[Industry Category\
		,Industrial Fuel,Industrial Process]
	  )
	)
	~	$/BTU
	~		|

BAU Industrial Equipment Capital Cost per Unit Energy After Subsidy[Industry Category\
		,Industrial Fuel,Industrial Process] :EXCEPT:   [Industry Category,Industrial Fuel,\
		industrial heating process]=
	BAU Industrial Equipment Capital Cost per Unit Energy Before Subsidy[Industry Category\
		,Industrial Fuel,Industrial Process] ~~|
BAU Industrial Equipment Capital Cost per Unit Energy After Subsidy[Industry Category\
		,Industrial Fuel,industrial heating process]=
	BAU Industrial Equipment Capital Cost per Unit Energy Before Subsidy[Industry Category\
		,Industrial Fuel,industrial heating process]
	- BAU Clean Industrial Heat Investment Subsidy Rate[industrial heating process,Industrial Fuel\
		]
	~	$/BTU
	~		|

BAU Industrial Equipment Capital Cost per Unit Energy Before Subsidy[Industry Category\
		,Industrial Fuel,Industrial Process] :EXCEPT:   [Industry Category,Industrial Fuel,\
		other nonprocess]=
	IECCpUAEU Industrial Equipment Capital Cost per Unit Annual Energy Use[Industrial Fuel\
		,Industrial Process] ~~|
BAU Industrial Equipment Capital Cost per Unit Energy Before Subsidy[Industry Category\
		,Industrial Fuel,other nonprocess]=
	IECCpUAEU Industrial Equipment Capital Cost per Unit Annual Energy Use[Industrial Fuel\
		,other nonprocess]
	* (1 - PoONEUTiMEbIC Perc of Other Nonprocess Eqpt E Use That is Mobile Eqpt by Indst Category\
		[Industry Category])
	
	+
	
	IECCpUAEU Industrial Eqpt Capital Cost per Unit Annual E Use for Mobile Eqpt[Industrial Fuel\
		]
	* PoONEUTiMEbIC Perc of Other Nonprocess Eqpt E Use That is Mobile Eqpt by Indst Category\
		[Industry Category]
	~	$/BTU
	~		|

BAU Industrial Equipment Energy Use from Input Data by Industrial Process[Industry Category\
		,Industrial Fuel,Industrial Process]=
	BAU Industrial Fuel Use for Energy from Input Data before CCS after Adjustments[Industry Category\
		,Industrial Fuel]
	* BAU Percentage Fuel Use by Industrial Process with Fallback Data[Industry Category\
		,Industrial Fuel,Industrial Process]
	~	BTU
	~		|

BAU Industrial Equipment Energy Use from Input Data by Industrial Process in Electricity Equivalent\
		[Industry Category,Industrial Fuel,Industrial Process] :EXCEPT:    [Industry Category\
		,electricity if,Industrial Process]=
	BAU Industrial Equipment Energy Use from Input Data by Industrial Process[Industry Category\
		,Industrial Fuel,Industrial Process]
	* (1 - PIFURfE Percentage Industry Fuel Use Reduction for Electricity[Industry Category\
		,Industrial Process]) ~~|
BAU Industrial Equipment Energy Use from Input Data by Industrial Process in Electricity Equivalent\
		[Industry Category,electricity if,Industrial Process]=
	BAU Industrial Equipment Energy Use from Input Data by Industrial Process[Industry Category\
		,electricity if,Industrial Process]
	~	BTU
	~		|

BAU Industrial Feedstock Use after Adjustments[Industry Category,Industrial Fuel] :EXCEPT:\
		    [energy industries within industry category
,Industrial Fuel]=
	BIFU BAU Industrial Fuel Use as Feedstock[Industry Category,Industrial Fuel]
	* (1 + Perc Change in Sectoral Energy Use due to Exogenous GDP Adjustment[industry sector\
		]) ~~|
BAU Industrial Feedstock Use after Adjustments[energy industries within industry category\
		,Industrial Fuel]=
	BIFU BAU Industrial Fuel Use as Feedstock[energy industries within industry category\
		,Industrial Fuel]
	* (1 + Last Year BAU Percent Change in Fuel Production from Calculated Fuel Demand[energy industries within industry category\
		])
	~	BTU
	~		|

BAU Industrial Fuel Carbon Tax Amount per Unit Energy[Industry Category,Industrial Fuel\
		]=
	BCTR BAU Carbon Tax Rate[industry sector]
	/ Grams per Metric Ton CO2e
	* BAU Industrial Fuel Taxable CO2e Emissions Intensity[Industry Category,Industrial Fuel\
		]
	* BFoICStCT BAU Fraction of Industry Category Subject to Carbon Tax[Industry Category\
		]
	~	$/BTU
	~		|

BAU Industrial Fuel Carbon Tax Amount per Unit Energy in Future Years[Industry Category\
		,Industrial Fuel,Future Year]=
	BAU Constant Reading of BCTR[industry sector,Future Year]
	/ Grams per Metric Ton CO2e
	* BAU Industrial Fuel Taxable CO2e Emissions Intensity[Industry Category,Industrial Fuel\
		]
	* BFoICStCT BAU Fraction of Industry Category Subject to Carbon Tax[Industry Category\
		]
	~	$/BTU
	~		|

BAU Industrial Fuel Cost per Unit Energy[Industry Category, Industrial Fuel] :EXCEPT:\
		   [Industry Category,hydrogen if],[Industry Category,green hydrogen if],[Industry Category\
		,low carbon hydrogen if]=
	MAX(BAU Pretax Fuel Price by Sector Including Endogenous Electricity Prices[industrial fuel within all fuels\
		,industry sector
	]
	  + BAU Industrial Fuel Total Tax or Subsidy Amount per Unit Energy[Industry Category\
		,Industrial Fuel],
	0
	) ~~|
BAU Industrial Fuel Cost per Unit Energy[Industry Category,hydrogen if]=
	MAX(BAU This Year Other Hydrogen Cost
	  + BAU Industrial Fuel Total Tax or Subsidy Amount per Unit Energy[Industry Category\
		,hydrogen if],
	0
	) ~~|
BAU Industrial Fuel Cost per Unit Energy[Industry Category,green hydrogen if]=
	MAX(BAU This Year Green Hydrogen Cost
	  + BAU Industrial Fuel Total Tax or Subsidy Amount per Unit Energy[Industry Category\
		,green hydrogen if],
	0
	) ~~|
BAU Industrial Fuel Cost per Unit Energy[Industry Category,low carbon hydrogen if]=
	MAX(BAU This Year Low Carbon Hydrogen Cost
	  + BAU Industrial Fuel Total Tax or Subsidy Amount per Unit Energy[Industry Category\
		,low carbon hydrogen if],
	0
	)
	~	$/BTU
	~		|

BAU Industrial Fuel Other Tax or Subsidy Amount per Unit Energy[Industrial Fuel]=
	BAU Fuel Tax by Sector[industrial fuel within all fuels,industry sector]
	~	$/BTU
	~		|

BAU Industrial Fuel Taxable CO2e Emissions Intensity[Industry Category,Industrial Fuel\
		]=
	SUM(
	  Industrial Fuel Pollutant Emissions Intensities This Year[Industry Category,Pollutant\
		!,Industrial Fuel]
	  * GWP by Pollutant[Pollutant!]
	  * BPTbCP BAU Industry Pollutants Taxed by Carbon Pricing[Industry Category,Pollutant\
		!]
	)
	~	g CO2e/BTU
	~		|

BAU Industrial Fuel Total Tax or Subsidy Amount per Unit Energy[Industry Category,Industrial Fuel\
		]=
	BAU Industrial Fuel Carbon Tax Amount per Unit Energy[Industry Category,Industrial Fuel\
		]
	+ BAU Industrial Fuel Other Tax or Subsidy Amount per Unit Energy[Industrial Fuel]
	~	$/BTU
	~		|

BAU Industrial Fuel Use[Industrial Fuel,Industry Category]=
	BAU Industrial Fuel Use for Energy Purposes[Industry Category,Industrial Fuel]
	+ BAU Industrial Feedstock Use after Adjustments[Industry Category,Industrial Fuel]
	~	BTU
	~		|

BAU Industrial Fuel Use for Energy before CCS and Methane Capture[Industrial Fuel,Industry Category\
		]=
	SUM(BAU Industrial Energy Use by Fuel Type and Process[Industry Category,Industrial Fuel\
		,Industrial Process!])
	~	BTU
	~		|

BAU Industrial Fuel Use for Energy from Input Data before CCS after Adjustments[Industry Category\
		,Industrial Fuel] :EXCEPT:    [energy industries within industry category
,Industrial Fuel]=
	BIFU BAU Industrial Fuel Use for Energy[Industry Category,Industrial Fuel]
	* (1 + Perc Change in Sectoral Energy Use due to Exogenous GDP Adjustment[industry sector\
		]) ~~|
BAU Industrial Fuel Use for Energy from Input Data before CCS after Adjustments[energy industries within industry category\
		,Industrial Fuel]=
	BIFU BAU Industrial Fuel Use for Energy[energy industries within industry category,Industrial Fuel\
		]*
	(1+Last Year BAU Percent Change in Fuel Production from Calculated Fuel Demand[energy industries within industry category\
		])
	~	BTU
	~		|

BAU Industrial Fuel Use for Energy Purposes[Industry Category,Industrial Fuel]=
	BAU Industrial Fuel Use for Energy before CCS and Methane Capture[Industrial Fuel,Industry Category\
		]
	+ BAU Fuel Used for CCS by Industry Sector[Industrial Fuel,Industry Category]
	~	BTU
	~		|

BAU Industrial Sector CO2e Emissions[Industry Category]=
	SUM(BAU Industrial Sector Pollutant Emissions[Industry Category,Pollutant!]
	    * GWP by Pollutant[Pollutant!])
	~	g CO2e
	~		|

BAU Industrial Sector Electricity Demand=
	SUM(BAU Electricity Demand by Industry[Industry Category!])
	~	MW*hour
	~		|

BAU Industrial Sector Emissions from Fuels Used to Power CCS[Industrial Fuel,Industry Category\
		,Pollutant]=
	BAU Fuel Used for CCS by Industry Sector[Industrial Fuel,Industry Category]
	* Industrial Fuel Pollutant Emissions Intensities This Year[Industry Category,Pollutant\
		,Industrial Fuel]
	~	g pollutant
	~		|

BAU Industrial Sector Energy Related Emissions after CCS[Industrial Fuel,Industry Category\
		,Pollutant]=
	BAU Industrial Sector Energy Related Emissions before CCS[Industrial Fuel,Industry Category\
		,Pollutant]
	- BAU This Year Energy Related Pollutants Sequestered by Industry Sector[Industry Category\
		,Pollutant]
	  * ZIDZ(
	      BAU Industrial Sector Energy Related Emissions before CCS[Industrial Fuel,Industry Category\
		,Pollutant],
	
	      SUM(BAU Industrial Sector Energy Related Emissions before CCS[Industrial Fuel!\
		,Industry Category,Pollutant])
	    )
	~	g pollutant
	~	We maintain the "Industrial Fuel" subscript here (allocating sequestered \
		CO2 by fuel type proportionate to CO2 emissions from each fuel type) to \
		support one of the output graphs, which shows energy-related CO2 emissions \
		by fuel type.
	|

BAU Industrial Sector Energy Related Emissions before CCS[Industrial Fuel,Industry Category\
		,Pollutant]=
	BAU Industrial Energy Related Emissions Excluding Fuels to Power CCS[Industrial Fuel\
		,Industry Category,Pollutant]
	+ BAU Industrial Sector Emissions from Fuels Used to Power CCS[Industrial Fuel,Industry Category\
		,Pollutant]
	~	g pollutant
	~		|

BAU Industrial Sector Pollutant Emissions[Industry Category,Pollutant]=
	SUM(BAU Industrial Sector Energy Related Emissions after CCS[Industrial Fuel!,Industry Category\
		,Pollutant])
	+ BAU Process Emissions after CCS[Industry Category,Pollutant]
	~	g pollutant
	~		|

BAU Industry Sector Carbon Tax Rebate due to CCS[Industry Category]=
	Amount of CO2 Sequestered by Industry Sector[Industry Category]
	* Carbon Tax Rate[industry sector]
	* Fraction of Industry Category Subject to Carbon Tax[Industry Category]
	~	$
	~		|

BAU Industry Sector Carbon Tax Revenue[Industry Category]=
	SUM(BAU Industrial Fuel Use for Energy Purposes[Industry Category,Industrial Fuel!]
	* BAU Industrial Fuel Carbon Tax Amount per Unit Energy[Industry Category,Industrial Fuel\
		!])
	
	+ BAU Carbon Tax on Process Emissions by Industry[Industry Category]
	~	$
	~		|

BAU Industry Sector CCS Transportation and Storage Costs[Industry Category]=
	SUM(BAU This Year Pollutants Sequestered by Industry Sector[Industry Category,CO2,Emissions Type\
		!])
	/ Grams per Metric Ton CO2e
	/ Grams Pollutant per Gram CO2e Unit Converter
	
	* (CCSTaSC CCS Transportation and Storage Costs
	  - CCSTaSC CCS Transportation and Storage Subsidies)
	~	$
	~		|

BAU Industry Sector CCS Transportation and Storage Subsidies[Industry Category]=
	SUM(BAU This Year Pollutants Sequestered by Industry Sector[Industry Category,CO2,Emissions Type\
		!])
	/ Grams per Metric Ton CO2e
	/ Grams Pollutant per Gram CO2e Unit Converter
	
	* CCSTaSC CCS Transportation and Storage Subsidies
	~	$
	~		|

BAU Industry Sector Final Energy Use by Industry[All Fuels,Industry Category] :EXCEPT:\
		    [industrial fuel within all fuels
,Industry Category]=
	0 ~~|
BAU Industry Sector Final Energy Use by Industry[industrial fuel within all fuels,Industry Category\
		] :EXCEPT: [hydrogen,Industry Category]=
	BAU Industrial Fuel Use[Industrial Fuel,Industry Category]
	- BAU Industrial Feedstock Use after Adjustments[Industry Category,Industrial Fuel] ~~|
BAU Industry Sector Final Energy Use by Industry[hydrogen,Industry Category]=
	BAU Industrial Fuel Use[hydrogen if,Industry Category]
	- BAU Industrial Feedstock Use after Adjustments[Industry Category,hydrogen if]
	
	+ BAU Industrial Fuel Use[green hydrogen if,Industry Category]
	- BAU Industrial Feedstock Use after Adjustments[Industry Category,green hydrogen if\
		]
	
	+ BAU Industrial Fuel Use[low carbon hydrogen if,Industry Category]
	- BAU Industrial Feedstock Use after Adjustments[Industry Category,low carbon hydrogen if\
		]
	~	BTU
	~		|

BAU Industry Sector Other Fuel Tax Revenue=
	SUM(BAU Industrial Fuel Use[Industrial Fuel!,Industry Category!]
	* BAU Industrial Fuel Other Tax or Subsidy Amount per Unit Energy[Industrial Fuel!]
	* (1 - SoFCTiBoSFbI Share of Fuel Consumption That is Byproduct or Secondary Fuels by Industry\
		[Industry Category!,Industrial Fuel!])
	)
	~	$
	~		|

BAU Initial Domestically Produced Energy by Producing ISIC Code[ISIC Code]= INITIAL(
	BAU Domestically Produced Energy by Producing ISIC Code[ISIC Code])
	~	BTU
	~		|

BAU Initial Guess at CES Price=
	MAX(BAU Last Year Optimized CES Credit Price,
	  MAX(5,
	    ZIDZ(
	      SUM(
	        BAU Cost per Unit New Elec Output Using Expected Capacity Factors[Electricity Source\
		!]
	        *BAU Last Year Electricity Generation Capacity[Electricity Source!] 
	        * Elec Portfolio Qualifying Sources[Electricity Source!,CES]
	      ),
	
	      SUM(Elec Portfolio Qualifying Sources[Electricity Source!,CES]*BAU Last Year Electricity Generation Capacity\
		[Electricity Source
	!])
	    )
	  )
	)
	~	$/(MW*hr)
	~	We use a maximum of $5/MWh or the calculated price.
	|

BAU Initial Guess at RPS Price=
	MAX(BAU Last Year Optimized RPS Credit Price,
	  MAX(5,
	    ZIDZ(
	      SUM(
	        BAU Cost per Unit New Elec Output Using Expected Capacity Factors[Electricity Source\
		!]
	        *BAU Last Year Electricity Generation Capacity[Electricity Source!]
	        * Elec Portfolio Qualifying Sources[Electricity Source!,RPS]
	      ),
	
	      SUM(Elec Portfolio Qualifying Sources[Electricity Source!,RPS]*BAU Last Year Electricity Generation Capacity\
		[Electricity Source
	!])
	    )
	  )
	)
	~	$/(MW*hr)
	~	We use a maximum of $5/MWh or the calculated price.
	|

BAU Initial Output by Industry Category and Process[Industry Category,Industrial Process\
		]= INITIAL(
	Start Year Output by ISIC Code by Year[Industry Category ISIC Code]
	*
	Total BAU Fuel Use for Energy Purposes by Industrial Process in Electricity Equivalent\
		[Industry Category,Industrial Process]
	/ SUM(Total BAU Fuel Use for Energy Purposes by Industrial Process in Electricity Equivalent\
		[Industry Category,Industrial Process!]))
	~	$
	~		|

BAU Interregional Electricity Trade Costs=
	BAU Amount Spent on Importing Electricity
	-BAU Amount Received from Exporting Electricity
	~	$
	~		|

BAU Inverted Spare Potential Output from Surviving Capacity by Hour by Optimization Pass\
		[Electricity Timeslice,Hour,pass1]=
	MAX(0,ZIDZ(1,BAU Total Electricity Demand by Hour before Net Imports[Electricity Timeslice\
		,Hour])) ~~|
BAU Inverted Spare Potential Output from Surviving Capacity by Hour by Optimization Pass\
		[Electricity Timeslice,Hour,current pass]=
	MAX(0,ZIDZ(1,BAU Total Electricity Demand by Hour before Net Imports[Electricity Timeslice\
		,Hour]))
	  *IF THEN ELSE(BAU Share of Max Hourly Exports Met[Electricity Timeslice,Hour,preceeding pass\
		]=1,0,1)
	~	1/(MW*hr)
	~		|

BAU Last Year Achieved Capacity Factors by Hour[Electricity Timeslice,Hour,Electricity Source\
		]= DELAY FIXED (
	BAU Achieved Capacity Factors by Hour[Electricity Timeslice,Hour,Electricity Source]\
		, 1 , Start Year Seasonal Expected Hourly Electricity Capacity Factors after RAF[Electricity Source\
		,Electricity Timeslice,Hour])
	~	Dmnl
	~		|

BAU Last Year Annual Net Energy Market Revenue per MW by Plant Type[Electricity Source\
		]= DELAY FIXED (
	BAU Annual Net Energy Market Revenue per MW by Power Plant Type[Electricity Source],\
		 
	1, 
	0)
	~	$/MW
	~		|

BAU Last Year Annual Recurring Costs by Plant Type[Electricity Source]=
	BAU Last Year Weighted Average Annual Capital Cost per Unit Capacity[Electricity Source\
		]
	
	+BAU Last Year Weighted Average Annual Fixed OM Costs per Unit Capacity[Electricity Source\
		]
	~	$/MW
	~		|

BAU Last Year Battery Energy Cost per Unit Capacity= DELAY FIXED (
	BAU Battery Energy Cost per Unit Capacity,
	1,
	First Year Battery Energy Cost per Unit Capacity)
	~	$/(MW*hr)
	~		|

BAU Last Year Battery Manufacturing Price=
	DELAY FIXED(BAU This Year Battery Manufacturing Price Before Subsidies,
	1,
	SYBPP Start Year Battery Pack Price
	)
	~	$/(kW*hr)
	~		|

BAU Last Year Battery Power Cost per Unit Capacity=
	DELAY FIXED(
	BAU Battery Power Cost per Unit Capacity,
	1,
	First Year Battery Power Cost per Unit Capacity
	)
	~	$/MW
	~		|

BAU Last Year Battery Storage Affecting Learning=
	BAU Last Year Cumulative Battery Capacity Deployed
	+ Last Year Battery Storage Capacity Outside Modeled Region Affecting Learning
	~	MW*hr
	~		|

BAU Last Year Capacity and This Year Mandated Change in Capacity by Electricity Source\
		[Electricity Source]=
	BAU Last Year Electricity Generation Capacity[Electricity Source]
	 - BCRbQ BAU Capacity Retirements before Quantization[Electricity Source]
	 - BAU Decrease in Capacity from Mandated CCUS Retrofits[Electricity Source]
	 + BPMCCS BAU Policy Mandated Capacity Construction Schedule[Electricity Source]
