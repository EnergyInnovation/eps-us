Geoengineering Fuel Cost per Unit Energy[Industrial Fuel]=
	MAX(Pretax Fuel Cost per Unit Energy by Sector after Fuel Price Deregulation[industrial fuel within all fuels\
		,geoengineering sector]
	  + Geoengineering Fuel Total Tax or Subsidy Amount per Unit Energy[Industrial Fuel]\
		,
	0
	)
	~	$/BTU
	~		|

Geoengineering Fuel Other Tax or Subsidy Amount per Unit Energy[Industrial Fuel]=
	Fuel Tax or Subsidy by Sector[industrial fuel within all fuels,geoengineering sector\
		]
	~	$/BTU
	~		|

Geoengineering Fuel Total Tax or Subsidy Amount per Unit Energy[Industrial Fuel]=
	Geoengineering Fuel Other Tax or Subsidy Amount per Unit Energy[Industrial Fuel]
	~	$/BTU
	~		|

Geoengineering Sector Carbon Tax Revenue=
	SUM(Geoengineering Sector Energy Use[Industrial Fuel!]
	  * Industrial Fuel Carbon Tax Amount per Unit Energy[cement and other nonmetallic minerals 239\
		,Industrial Fuel!])
	~	$
	~	We need this subscripted only by fuel type, not industry type.  Carbon \
		intensity of fuels should not vary significantly based on which industry \
		burns those fuels.  Accordingly, we use the cement industry as our model, \
		as cement is produced worldwide and is a major emitter, and therefore is \
		unlikely to be repurposed as another industry in EPS model adaptations.
	|

Geoengineering Sector Change in Energy Expenditures by Entity[Cash Flow Entity] :EXCEPT:\
		  [government]=
	0 ~~|
Geoengineering Sector Change in Energy Expenditures by Entity[government]=
	SUM(Change in Amount Spent on Geoengineering Fuels[Industrial Fuel!])
	~	$
	~		|

Geoengineering Sector Change in Fuel Industry Cash Flow[Industrial Fuel]=
	(Amount Spent on Geoengineering Fuels[Industrial Fuel]
	 - Taxes Paid on Geoengineering Fuels[Industrial Fuel])
	
	-
	
	(BAU Amount Spent on Geoengineering Fuels[Industrial Fuel]
	 - BAU Taxes Paid on Geoengineering Fuels[Industrial Fuel])
	~	$
	~		|

Geoengineering Sector Change in Fuel Industry Cash Flow Mapped to All Fuels Subscript\
		[All Fuels] :EXCEPT: [industrial fuel within all fuels]=
	0 ~~|
Geoengineering Sector Change in Fuel Industry Cash Flow Mapped to All Fuels Subscript\
		[industrial fuel within all fuels] :EXCEPT: [hydrogen]=
	Geoengineering Sector Change in Fuel Industry Cash Flow[Industrial Fuel] ~~|
Geoengineering Sector Change in Fuel Industry Cash Flow Mapped to All Fuels Subscript\
		[hydrogen]=
	Geoengineering Sector Change in Fuel Industry Cash Flow[hydrogen if]
	+ Geoengineering Sector Change in Fuel Industry Cash Flow[green hydrogen if]
	+ Geoengineering Sector Change in Fuel Industry Cash Flow[low carbon hydrogen if]
	~	$
	~		|

Geoengineering Sector Change in Nonenergy Expenditures by Entity[Cash Flow Entity] :EXCEPT:\
		 [government]=
	0 ~~|
Geoengineering Sector Change in Nonenergy Expenditures by Entity[government]=
	Change in Geoengineering CapEx and OM Spending This Year
	~	$
	~		|

Geoengineering Sector Change in Nonenergy Industry Revenue by ISIC Code[ISIC Code] :EXCEPT:\
		   [ISIC 28]=
	0 ~~|
Geoengineering Sector Change in Nonenergy Industry Revenue by ISIC Code[ISIC 28]=
	Change in Geoengineering CapEx and OM Spending This Year
	~	$
	~		|

Geoengineering Sector Change in Revenue by Entity[government]=
	SUM(Change in Taxes Paid on Geoengineering Fuels[Industrial Fuel!]) ~~|
Geoengineering Sector Change in Revenue by Entity[nonenergy industries]=
	SUM(Geoengineering Sector Change in Nonenergy Industry Revenue by ISIC Code[ISIC Code\
		!]) ~~|
Geoengineering Sector Change in Revenue by Entity[labor and consumers]=
	0 ~~|
Geoengineering Sector Change in Revenue by Entity[foreign entities]=
	0 ~~|
Geoengineering Sector Change in Revenue by Entity[electricity suppliers]=
	Geoengineering Sector Change in Fuel Industry Cash Flow[electricity if] ~~|
Geoengineering Sector Change in Revenue by Entity[coal suppliers]=
	Geoengineering Sector Change in Fuel Industry Cash Flow[hard coal if] ~~|
Geoengineering Sector Change in Revenue by Entity[natural gas and petroleum suppliers\
		]=
	Geoengineering Sector Change in Fuel Industry Cash Flow[natural gas if]
	+ Geoengineering Sector Change in Fuel Industry Cash Flow[petroleum diesel if]
	+ Geoengineering Sector Change in Fuel Industry Cash Flow[crude oil if]
	+ Geoengineering Sector Change in Fuel Industry Cash Flow[heavy or residual fuel oil if\
		]
	+ Geoengineering Sector Change in Fuel Industry Cash Flow[LPG propane or butane if] ~~|
Geoengineering Sector Change in Revenue by Entity[biomass and biofuel suppliers]=
	Geoengineering Sector Change in Fuel Industry Cash Flow[biomass if] ~~|
Geoengineering Sector Change in Revenue by Entity[other energy suppliers]=
	Geoengineering Sector Change in Fuel Industry Cash Flow[heat if]
	+ Geoengineering Sector Change in Fuel Industry Cash Flow[hydrogen if]
	~	$
	~		|

Geoengineering Sector Electricity Demand=
	Geoengineering Sector Energy Use[electricity if]
	* MWh per BTU
	~	MW*hour
	~		|

Geoengineering Sector Energy Use[Industrial Fuel]=
	CO2 Captured via DAC
	* DACD Direct Air Capture Energy Intensity[Industrial Fuel]
	
	+ CO2 Captured via Enhanced Rock Weathering
	* ERWD Enhanced Rock Weathering Energy Intensity[Industrial Fuel]
	~	BTU
	~		|

Geoengineering Sector Other Fuel Tax Revenue=
	SUM(Geoengineering Sector Energy Use[Industrial Fuel!]
	* Industrial Fuel Other Tax or Subsidy Amount per Unit Energy[Industrial Fuel!])
	~	$
	~		|

Geoengineering Sector Pollutant Emissions[Pollutant] :EXCEPT:  [CO2]=
	SUM(
	  Geoengineering Sector Pollutant Emissions Excluding Captured CO2[Pollutant,Industrial Fuel\
		!]
	) ~~|
Geoengineering Sector Pollutant Emissions[CO2]=
	SUM(
	  Geoengineering Sector Pollutant Emissions Excluding Captured CO2[CO2,Industrial Fuel\
		!]
	)
	- CO2 Captured via DAC in Grams
	~	g pollutant
	~		|

Geoengineering Sector Pollutant Emissions Excluding Captured CO2[Pollutant,Industrial Fuel\
		]=
	Geoengineering Sector Energy Use[Industrial Fuel]
	* Industrial Fuel Pollutant Emissions Intensities This Year[cement and other nonmetallic minerals 239\
		,Pollutant,Industrial Fuel]
	~	g pollutant
	~	We need this subscripted only by fuel type, not industry type.  Carbon \
		intensity of fuels should not vary significantly based on which industry \
		burns those fuels.  Accordingly, we use the cement industry as our model, \
		as cement is produced worldwide and is a major emitter.
	|

