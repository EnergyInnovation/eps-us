Curtailed Electricity Output[Electricity Source]=
	MAX(
	  0,
	
	  Annual Maximum Potential Electricity Output[Electricity Source]
	  - Electricity Generation by Type[Electricity Source]
	)
	~	MW*hour
	~		|

Curtailed Variable Renewable Electricity by Hour[Electricity Timeslice,Hour]=
	MAX(
	  0,
	
	   SUM(Electricity Generation Capacity[Variable Renewable Electricity Source!]*Weighted Average Expected Capacity Factors by Hour without RAF\
		[Variable Renewable Electricity Source!,Electricity Timeslice,Hour] * One Hour)
	  - SUM(Total Electricity Dispatched by Hour by Plant Type[Electricity Timeslice,Hour\
		,Variable Renewable Electricity Source
	!])
	)
	~	MW*hr
	~		|

Curtailed Variable Renewable Electricity by Hour on Peak Summer Day[Hour]=
	SUM(Curtailed Variable Renewable Electricity by Hour[peak summer day electricity timeslice\
		!,Hour])
	/ ELMCOUNT(peak summer day electricity timeslice)
	~	MW*hr
	~		|

Curtailed Variable Renewable Electricity by Hour on Peak Winter Day[Hour]=
	SUM(Curtailed Variable Renewable Electricity by Hour[peak winter day electricity timeslice\
		!,Hour])
	/ ELMCOUNT(peak winter day electricity timeslice)
	~	MW*hr
	~		|

