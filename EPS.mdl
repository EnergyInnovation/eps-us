Cumulative Battery Capacity Deployed=
	Cumulative EV Battery Capacity Deployed as of Last Year
	+ Last Year Grid Battery Storage Capacity Including Hybrid Batteries
	+ Last Year Cumulative Policy Mandated Grid Battery Storage
	~	MW*hr
	~		|

Cumulative CCS Retrofit Capacity Built During Model Run[Industry Category,Emissions Type\
		]=
	Last Year Cumulative CCS Retrofit Capacity Built During Model Run[Industry Category,\
		Emissions Type]
	+ CCS Retrofit Capacity in Conveyor[Industry Category,Emissions Type]
	~	Dmnl
	~		|

Cumulative Change in Household Savings=
	Last Year Cumulative Change in Household Savings
	+ Change in Household Savings * One Year
	~	$
	~		~	:SUPPLEMENTARY 
	|

Cumulative Change in Land Value from Land Use Policies[Land Use Policy]=
	Cumulative Total Land Area Affected by Policy[Land Use Policy]
	* CiLVpUAAbP Change in Land Value per Unit Area Affected by Policy[Land Use Policy]
	~	$
	~		~	:SUPPLEMENTARY 
	|

Cumulative Change in National Debt=
	Last Year Cumulative Change in National Debt
	+ Change in Budget Deficit * One Year
	~	$
	~		|

Cumulative EV Battery Capacity Deployed as of Last Year=
	SUM(
	  Cumulative Vehicles Deployed as of Last Year[Vehicle Type!,Cargo Type!,Vehicle Technology\
		!]
	  * This Year Battery Capacity by Vehicle Type[Cargo Type!,Vehicle Type!,Vehicle Technology\
		!]
	)/kWh per MWh
	~	MW*hr
	~		|

Cumulative New Capacity Added or Retrofitted due to Elec Portfolio Stds[Electricity Source\
		,Clean Elec Requirement]=
	Last Year Cumulative New Capacity Added or Retrofitted due to Elec Portfolio Stds[Electricity Source\
		,Clean Elec Requirement]
	+ New Capacity Added or Retrofitted due to Elec Portfolio Stds[Electricity Source,Clean Elec Requirement\
		]
	~	MW
	~		|

Cumulative Retired Generation Capacity[Electricity Source]= INTEG (
	Retiring Generation Capacity[Electricity Source]
	/One Year,
		0)
	~	MW
	~		|

Cumulative Retired Generation Excluding Capacity Payment[Electricity Source]= INTEG (
	Retiring Generation Capacity Excluding Capacity Payment[Electricity Source]
	/One Year,
		0)
	~	MW
	~		|

Cumulative Total CO2e Emissions Excluding LULUCF Last Year=
	DELAY FIXED(Output Cumulative Total CO2e Emissions Excluding LULUCF This Year,
	1,
	Output Total CO2e Emissions Excluding LULUCF Last Year
	)
	~	mass output unit
	~		|

Cumulative Total CO2e Emissions Last Year
	=
	DELAY FIXED(Output Cumulative Total CO2e Emissions This Year,
	1,
	Output Total CO2e Emissions Last Year
	)
	~	mass output unit
	~		|

Cumulative Total Distributed Solar Capacity Caused by Policies[Building Type]=
	Last Year Cumulative Total Distributed Solar Capacity Caused by Policies[Building Type\
		]
	+ Distributed Solar Capacity Caused by Policies This Year[Building Type] * One Year
	~	MW
	~		|

Cumulative Total Land Area Affected by Policy[Land Use Policy]=
	Last Year Cumulative Total Land Area Affected by Policy[Land Use Policy]
	+ Land Area Newly Affected by Policy[Land Use Policy] * One Year
	~	acres
	~		|

Cumulative Vehicles Deployed as of Last Year[Vehicle Type,Cargo Type,Vehicle Technology\
		]=
	Cumulative Vehicles Deployed as of Two Years Ago[Vehicle Type,Cargo Type,Vehicle Technology\
		]
	+ New Vehicles Last Year[Vehicle Type,Cargo Type,Vehicle Technology] * One Year
	~	vehicles
	~		|

Cumulative Vehicles Deployed as of Two Years Ago[Vehicle Type,Cargo Type,Vehicle Technology\
		]= INTEG (
	New Vehicles Last Year[Vehicle Type,Cargo Type,Vehicle Technology],
		SYVbT Start Year Vehicles by Technology[Vehicle Type,Cargo Type,Vehicle Technology]\
		)
	~	vehicles
	~		|

