Boolean Plant Types that May Not be Built due to Having Been Retired to Zero[Electricity Source\
		]=
	IF THEN ELSE(
	  Start Year Electricity Generation Capacity Summed Across Vintages[Electricity Source\
		] > 0,
	
	  IF THEN ELSE(
	   Planned and Policy Mandated Capacity Retirements[Electricity Source]
	    >= Last Year Electricity Generation Capacity[Electricity Source],
	
	    1,
	
	    0
	  ),
	
	  0
	)
	~	Dmnl
	~		|

