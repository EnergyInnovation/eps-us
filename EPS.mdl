Compensation per Employee by ISIC Code[ISIC Code]=
	ZIDZ(
	  Domestic Employee Compensation by ISIC Code[ISIC Code],
	
	  Domestic Employment by ISIC Code[ISIC Code]
	)
	~	$/job
	~		|

Components Energy Use after Macroeconomic Feedbacks[Building Type,Building Fuel,Building Component\
		]=
	Components Energy Use after Price Demand Feedbacks[Building Type,Building Fuel,Building Component\
		]
	~	BTU
	~	We previously adjusted building energy demand based on the percent change \
		in the construction ISIC code's contribution to output. However, that ISIC \
		code is predominately affected by policies that affect power plant \
		construction, which is not a good proxy for what we want to represent \
		here. Similar to the transportation sector, we conservatively assume 0 \
		feedback effects for consumer and commercial energy demand based on \
		changes in income.
	|

Components Energy Use after Price Demand Feedbacks[Building Type,Building Fuel,Building Component\
		]=
	Components Potential Energy Use[Building Type,Building Fuel,Building Component]
	* (1 + Perc Change in All Components Energy Use due to Price Demand Feedbacks[Building Type\
		,Building Fuel,Building Component
	])
	~	BTU
	~		|

Components Energy Use after Retrofitting Preexisting Buildings[Building Type,Building Fuel\
		,Building Component]=
	Components Energy Use after Macroeconomic Feedbacks[Building Type,Building Fuel,Building Component\
		]
	* (1 - Percent Reduction in All Existing Buildings Energy Use due to Retrofitting Preexisting Buildings\
		[Building Type,Building Component])
	~	BTU
	~		|

Components Potential Energy Use[Building Type,Building Fuel,Building Component]=
	Last Year Components Potential Energy Use[Building Type,Building Fuel,Building Component\
		]
	+ New Components Potential Energy Use after Envelope Effects[Building Type,Building Fuel\
		,Building Component] * One Year
	- Retiring Components Potential Energy Use[Building Type,Building Fuel,Building Component\
		] * One Year
	~	BTU
	~		|

Constant Reading of BCTR[Sectors,Future Year]=
	GET DIRECT CONSTANTS(
	   'InputData/fuels/BCTR/BCTR.csv',
	   ',',
	   'B2'
	)
	~	$/metric ton CO2e
	~		|

Construction Cost per Unit Capacity after Construction Subsidies and Spur Line Construction\
		[Electricity Source]=
	MAX(
	  0,
	
	  Construction Cost per Unit Capacity before Construction Subsidies[Electricity Source\
		]
	    - Subsidy per Unit Electricity Capacity Built[Electricity Source]
	)
	
	+ CCaMC Spur Line Construction Cost per Unit Capacity[Electricity Source]
	~	$/MW
	~		|

Construction Cost per Unit Capacity before Construction Subsidies[Electricity Source]\
		 :EXCEPT:             [onshore wind es
]
,
[
solar PV es
],[offshore wind es],[hard coal w CCS es],[natural gas combined cycle w CCS es],[biomass w CCS es\
		],[lignite w CCS es]=
	CCaMC BAU Construction Cost per Unit Capacity[Electricity Source]
	* (1 - RnD Electricity Capital Cost Perc Reduction This Year[Electricity Source]) ~~|
Construction Cost per Unit Capacity before Construction Subsidies[onshore wind es]=
	IF THEN ELSE(
	  CCaMC BAU Construction Cost per Unit Capacity[onshore wind es] > 0,
	
	  (CCaMC BAU Construction Cost per Unit Capacity[onshore wind es] - CCaMC BAU Soft Costs per Unit Capacity\
		[onshore wind es
	])
	  * (1 - RnD Electricity Capital Cost Perc Reduction This Year[onshore wind es])
	  + Soft Costs per Unit Capacity[onshore wind es],
	
	  IF THEN ELSE(
	    CCaMC BAU Construction Cost per Unit Capacity With One Year Delay[onshore wind es\
		] > 0,
	      (CCaMC BAU Construction Cost per Unit Capacity With One Year Delay[onshore wind es\
		] - BAU Last Year Soft Costs per Unit Capacity
	[onshore wind es])
	      * This Year Solar and Wind Hard Costs as Fraction of Last Year Hard Costs[onshore wind es\
		]
	      * (1 - RnD Electricity Capital Cost Perc Reduction This Year[onshore wind es])
	      + Soft Costs per Unit Capacity[onshore wind es],
	
	      (Last Year Construction Cost per Unit Capacity before Construction Subsidies[onshore wind es\
		] - BAU Last Year Soft Costs per Unit Capacity[onshore wind es])
	      * This Year Solar and Wind Hard Costs as Fraction of Last Year Hard Costs[onshore wind es\
		]
	      * (1 - RnD Electricity Capital Cost Perc Reduction This Year[onshore wind es])
	      + Soft Costs per Unit Capacity[onshore wind es]
	   )
	) ~~|
Construction Cost per Unit Capacity before Construction Subsidies[solar PV es]=
	IF THEN ELSE(
	  CCaMC BAU Construction Cost per Unit Capacity[solar PV es] > 0,
	
	  (CCaMC BAU Construction Cost per Unit Capacity[solar PV es] - CCaMC BAU Soft Costs per Unit Capacity\
		[solar PV es
	])
	  * (1 - RnD Electricity Capital Cost Perc Reduction This Year[solar PV es])
	  + Soft Costs per Unit Capacity[solar PV es],
	
	  IF THEN ELSE(
	    CCaMC BAU Construction Cost per Unit Capacity With One Year Delay[solar PV es] >\
		 0,
	      (CCaMC BAU Construction Cost per Unit Capacity With One Year Delay[solar PV es\
		] - BAU Last Year Soft Costs per Unit Capacity
	[solar PV es])
	      * This Year Solar and Wind Hard Costs as Fraction of Last Year Hard Costs[solar PV es\
		]
	      * (1 - RnD Electricity Capital Cost Perc Reduction This Year[solar PV es])
	      + Soft Costs per Unit Capacity[solar PV es],
	
	      (Last Year Construction Cost per Unit Capacity before Construction Subsidies[solar PV es\
		] - BAU Last Year Soft Costs per Unit Capacity[solar PV es])
	      * This Year Solar and Wind Hard Costs as Fraction of Last Year Hard Costs[solar PV es\
		]
	      * (1 - RnD Electricity Capital Cost Perc Reduction This Year[solar PV es])
	      + Soft Costs per Unit Capacity[solar PV es]
	   )
	) ~~|
Construction Cost per Unit Capacity before Construction Subsidies[offshore wind es]=
	IF THEN ELSE(
