Normalized Standard Deviation of Dispatch Costs Mapped to Hydrogen Production Pathways\
		[electrolysis]=
	SUM(
	  NSDoDC Normalized Standard Deviation of Dispatch Costs[Electricity Source!]
	  * Last Year Electricity Generation by Type[Electricity Source!]
	)
	/
	SUM(Last Year Electricity Generation by Type[Electricity Source!]) ~~|
Normalized Standard Deviation of Dispatch Costs Mapped to Hydrogen Production Pathways\
		[natural gas reforming]=
	NSDoDC Normalized Standard Deviation of Dispatch Costs[natural gas combined cycle es\
		] ~~|
Normalized Standard Deviation of Dispatch Costs Mapped to Hydrogen Production Pathways\
		[coal gasification]=
	NSDoDC Normalized Standard Deviation of Dispatch Costs[hard coal es] ~~|
Normalized Standard Deviation of Dispatch Costs Mapped to Hydrogen Production Pathways\
		[biomass gasification]=
	NSDoDC Normalized Standard Deviation of Dispatch Costs[biomass es] ~~|
Normalized Standard Deviation of Dispatch Costs Mapped to Hydrogen Production Pathways\
		[hydrocarbon partial oxidation]=
	NSDoDC Normalized Standard Deviation of Dispatch Costs[heavy or residual fuel oil es\
		] ~~|
Normalized Standard Deviation of Dispatch Costs Mapped to Hydrogen Production Pathways\
		[electrolysis with guaranteed clean electricity]=
	SUM(NSDoDC Normalized Standard Deviation of Dispatch Costs[Electricity Source!]*Share of Off Grid Electricity Demand That is New This Year Met by Power Plant Type
	[Electricity Source!]) ~~|
Normalized Standard Deviation of Dispatch Costs Mapped to Hydrogen Production Pathways\
		[natural gas reforming with CCS]=
	Normalized Standard Deviation of Dispatch Costs Mapped to Hydrogen Production Pathways\
		[natural gas reforming]
	~	Dmnl
	~		|

NPV of Lifetime Annual Expenditures for a Vehicle Sold This Year[Vehicle Type,Cargo Type\
		,Vehicle Technology]=
	Total Annual Vehicle Costs[Vehicle Type,Cargo Type,Vehicle Technology]
	* (
	    (1 - (1 + VBDR Vehicle Buyer Discount Rate[Vehicle Type]) ^ (- AVOP Average Vehicle Ownership Period\
		[Vehicle Type,Cargo Type]/One Year
	))
	    / VBDR Vehicle Buyer Discount Rate[Vehicle Type]
	  )
	~	$/vehicle
	~		|

NPV of Lifetime Vehicle Cost[Vehicle Type,Cargo Type,Vehicle Technology]=
	New Vehicle Price Including EV Shadow Costs[Vehicle Type,Cargo Type,Vehicle Technology\
		]
	+ NPV of Lifetime Annual Expenditures for a Vehicle Sold This Year[Vehicle Type,Cargo Type\
		,Vehicle Technology]
	~	$/vehicle
	~		|

