	* FoICStCT Fraction of Industry Category Subject to Carbon Tax[Industry Category]
	
	-
	
	BCTR BAU Carbon Tax Rate[industry sector]
	* BFoICStCT BAU Fraction of Industry Category Subject to Carbon Tax[Industry Category\
		]
	~	$/metric ton CO2e
	~		|

Incremental Costs from Substitute Fuel Production due to LCFS=
	SUM(
	  Change in Fuel Use by Fuel and Technology due to LCFS with Elec Eff Adj[Vehicle Type\
		!,Cargo Type!,Vehicle Technology!,Transportation Fuel!]
	  * ICtPSFfL Incremental Cost to Produce Substitute Fuel for LCFS[Transportation Fuel\
		!]
	)
	~	$
	~		|

Incremental Revenue for Cost Effective CCUS Retrofits[CCUS Electricity Source,Optimization Pass\
		,RPS]=
	MAX(0,
	  Total Change in Energy Market and CES Revenue for CCUS Retrofits[CCUS Electricity Source\
		,Optimization Pass,RPS]
	  -(Cost per MW for CCUS Retrofits Excluding Subsidies[CCUS Electricity Source]
	    * SoCtMbCtbDP Share of Costs that Must be Covered to Be Deemed Profitable[CCUS Electricity Source\
		]
	  )
	) ~~|
Incremental Revenue for Cost Effective CCUS Retrofits[CCUS Electricity Source,Optimization Pass\
		,CES]=
	MAX(0,
	  Total Change in Energy Market and CES Revenue for CCUS Retrofits[CCUS Electricity Source\
		,Optimization Pass,CES]
	  -(Cost per MW for CCUS Retrofits Excluding Subsidies[CCUS Electricity Source]
	    * SoCtMbCtbDP Share of Costs that Must be Covered to Be Deemed Profitable[CCUS Electricity Source\
		]
	  )
	)
	~	$/MW
	~		|

Incremental Revenue for Cost Effective CCUS Retrofits without CES[CCUS Electricity Source\
		]=
	MAX(0,
	  Predicted Change in Energy Market Revenue for CCUS Retrofits[CCUS Electricity Source\
		]
	  -(Cost per MW for CCUS Retrofits Excluding Subsidies[CCUS Electricity Source]
	    * SoCtMbCtbDP Share of Costs that Must be Covered to Be Deemed Profitable[CCUS Electricity Source\
		]
	  )
	)
	~	$/MW
	~		|

Incremental Revenue for Cost Effectiveness Additions[Electricity Source,Optimization Pass\
		,RPS]=
	MAX(0,
	  Total Energy Market and CES Revenue and Variable Subsidies by Optimization Pass[Electricity Source\
		,Optimization Pass,RPS]
	  -(Annualized Fixed Costs per Unit New Capacity[Electricity Source]
	     * SoCtMbCtbDP Share of Costs that Must be Covered to Be Deemed Profitable[Electricity Source\
		]
	  )
	) ~~|
Incremental Revenue for Cost Effectiveness Additions[Electricity Source,Optimization Pass\
		,CES]=
	MAX(0,
	  Total Energy Market and CES Revenue and Variable Subsidies by Optimization Pass[Electricity Source\
		,Optimization Pass,CES]
	  -(Annualized Fixed Costs per Unit New Capacity[Electricity Source]
	     * SoCtMbCtbDP Share of Costs that Must be Covered to Be Deemed Profitable[Electricity Source\
		]
	  )
	)
	~	$/MW
	~		|

Incremental Revenue for Cost Effectiveness Additions for Hybrid Power Plants[Hybrid Electricity Source\
		,Optimization Pass,RPS]=
	MAX(0,
	  Total Energy Market and CES Revenue and Variable Subsidies by Optimization Pass for Hybrid Power Plants\
		[Hybrid Electricity Source
	,Optimization Pass,RPS]
	  -(Annualized Fixed Costs per Unit New Capacity[Hybrid Electricity Source]+Annual Financing Repayment per Unit Storage Capacity for Hybrid Power Plants
	[Hybrid Electricity Source]
	)
	    * SoCtMbCtbDP Share of Costs that Must be Covered to Be Deemed Profitable[Hybrid Electricity Source\
		]
	  ) ~~|
Incremental Revenue for Cost Effectiveness Additions for Hybrid Power Plants[Hybrid Electricity Source\
		,Optimization Pass,CES]=
	MAX(0,
	  Total Energy Market and CES Revenue and Variable Subsidies by Optimization Pass for Hybrid Power Plants\
		[Hybrid Electricity Source
	,Optimization Pass,CES]
	  -(Annualized Fixed Costs per Unit New Capacity[Hybrid Electricity Source]+Annual Financing Repayment per Unit Storage Capacity for Hybrid Power Plants
	[Hybrid Electricity Source])
	    * SoCtMbCtbDP Share of Costs that Must be Covered to Be Deemed Profitable[Hybrid Electricity Source\
		]
	  )
	~	$/MW
	~		|

Incremental Revenue for Cost Effectiveness Additions for Hybrid Power Plants without CES\
		[Hybrid Electricity Source]=
	MAX(0,
	  Average Four Year Prior Net Energy Market Revenue by Plant Type Excluding Subsidies for Hybrid Power Plants\
		[Hybrid Electricity Source
	]
	  -(Annualized Fixed Costs per Unit New Capacity[Hybrid Electricity Source]+Annual Financing Repayment per Unit Storage Capacity for Hybrid Power Plants
	[Hybrid Electricity Source])
	    * SoCtMbCtbDP Share of Costs that Must be Covered to Be Deemed Profitable[Hybrid Electricity Source\
		]
	  )
	~	$/MW
	~		|

Incremental Revenue for Cost Effectiveness Additions without CES[Electricity Source]=
	MAX(0,
	      Average Four Year Prior Total Predicted Net Energy Market Revenue per MW[Electricity Source\
		]
	      -(Annualized Fixed Costs per Unit New Capacity[Electricity Source]
	         * SoCtMbCtbDP Share of Costs that Must be Covered to Be Deemed Profitable
	[Electricity Source]
	      )
	    )
	~	$/MW
	~		|

Indirect and Induced Change in Domestic Output for Non Industry Category ISIC Codes[ISIC Code\
		] :EXCEPT:  [Industry Category ISIC Code]=
	Indirect Change in Domestic Output by ISIC Code[ISIC Code]
	+ Induced Change in Domestic Output by ISIC Code[ISIC Code] ~~|
Indirect and Induced Change in Domestic Output for Non Industry Category ISIC Codes[Industry Category ISIC Code\
		]=
	0
	~	$
	~		|

Indirect Buildings CO2e Emissions by End Use[Building Type,Building Component]=
	SUM(Indirect Buildings Pollutant Emissions[Building Type,Building Component,Building Fuel\
		!,Pollutant!]
	* GWP by Pollutant[Pollutant!])
	~	g CO2e
	~		|

Indirect Buildings Pollutant Emissions[Building Type,Building Component,Building Fuel\
		,Pollutant] :EXCEPT:    [Building Type
,Building Component,electricity bf,Pollutant],[Building Type,Building Component,heat bf\
		,Pollutant],[Building Type,Building Component
,hydrogen bf,Pollutant]=
	0 ~~|
Indirect Buildings Pollutant Emissions[Building Type,Building Component,electricity bf\
		,Pollutant]=
	(Total Energy Related Emissions[electricity sector,Pollutant]
	 * Share of Energy Carrier Use by Sector[residential buildings sector,electricity]
	
	 + Total Energy Related Emissions[electricity sector,Pollutant]
	 * Share of Energy Carrier Use by Sector[commercial buildings sector,electricity]
	)
	
	* Share of Buildings Sector Energy Use by Building Component[Building Type,electricity bf\
		,Building Component] ~~|
Indirect Buildings Pollutant Emissions[Building Type,Building Component,heat bf,Pollutant\
		]=
	(SUM(District Heating Pollutant Emissions[Pollutant,Industrial Fuel!])
	  * Share of Energy Carrier Use by Sector[residential buildings sector,heat]
	  + SUM(District Heating Pollutant Emissions[Pollutant,Industrial Fuel!])
	  * Share of Energy Carrier Use by Sector[commercial buildings sector,heat]
	)
	
	* Share of Buildings Sector Energy Use by Building Component[Building Type,heat bf,Building Component\
		] ~~|
Indirect Buildings Pollutant Emissions[Building Type,Building Component,hydrogen bf,Pollutant\
		]=
	(SUM(Hydrogen Sector Pollutant Emissions[Pollutant,Industrial Fuel!])
	  * Share of Energy Carrier Use by Sector[residential buildings sector,hydrogen]
	  + SUM(Hydrogen Sector Pollutant Emissions[Pollutant,Industrial Fuel!])
	  * Share of Energy Carrier Use by Sector[commercial buildings sector,hydrogen]
	)
	
	* Share of Buildings Sector Energy Use by Building Component[Building Type,hydrogen bf\
		,Building Component]
	~	g pollutant
	~		|

Indirect Change in Domestic Compensation by ISIC Code[Source ISIC Code]=
	QUANTUM(
	
	  Indirect Change in Domestic Jobs after Productivity Effects by ISIC Code[Source ISIC Code\
		]
	  * Within Industry Compensation per Employed Person[Source ISIC Code],
	
	  QSfCF Quantization Size for Cash Flows
	)
	~	$
	~		|

Indirect Change in Domestic Jobs after Productivity Effects by ISIC Code[ISIC Code]=
	QUANTUM(
	  Indirect Change in Domestic Jobs by ISIC Code[ISIC Code]
	  / (1 + LPGRbIC Labor Productivity Growth Rate by ISIC Code[ISIC Code])^(Dimensionless Time\
		 - Initial Time Dimensionless),
	
	  Quantization Size for Jobs
	)
	~	jobs
	~		|

Indirect Change in Domestic Jobs by ISIC Code[Source ISIC Code] :EXCEPT:           [Fossil and Energy Utility ISIC Code\
		]=
	SUM(
	  Industry Contribution to Change in Domestic Output by ISIC Code[Target ISIC Code!]
	  * Domestic Job Requirements by Industry per Unit Output by Industry Excluding Direct Impacts\
		[Source ISIC Code,Target ISIC Code
	!]
	) ~~|
Indirect Change in Domestic Jobs by ISIC Code[Fossil and Energy Utility Source ISIC Code\
		]=
	SUM(
	  Industry Contribution to Change in Domestic Output by ISIC Code[Fossil and Energy Utility Target ISIC Code
	!]
	  * Domestic Job Requirements by Industry per Unit Output by Industry Excluding Direct Impacts\
		[Fossil and Energy Utility Source ISIC Code
	,Fossil and Energy Utility Target ISIC Code
	!]
	)
	* (1 - FoPTaFbIC Fractions of Products That are Fuels by ISIC Code[Fossil and Energy Utility Source ISIC Code\
		])
	
	+ ZIDZ(
	  SUM(
	    Industry Contribution to Change in Domestic Output by ISIC Code[Fossil and Energy Utility Target ISIC Code
	!]
	    * Domestic Job Requirements by Industry per Unit Output by Industry Excluding Direct Impacts\
		[Fossil and Energy Utility Source ISIC Code
	,Fossil and Energy Utility Target ISIC Code!]
	  )
	  * Energy Production per Unit Output[Fossil and Energy Utility Source ISIC Code]
	  * FoPTaFbIC Fractions of Products That are Fuels by ISIC Code[Fossil and Energy Utility Source ISIC Code\
		],
	  BAU Energy Production per Unit Output[Fossil and Energy Utility Source ISIC Code]
	)
	~	jobs
	~		|

Indirect Change in Domestic Output by ISIC Code[ISIC Code]=
	ZIDZ(
	  Indirect Change in Domestic Value Added by ISIC Code[ISIC Code],
	
	  Within Industry Value Added per Unit Output[ISIC Code]
	)
	~	$
	~		|

Indirect Change in Domestic Value Added by ISIC Code[Source ISIC Code] :EXCEPT:    [Fossil and Energy Utility Source ISIC Code\
		]=
	QUANTUM(
	  SUM(
	    (
	      Industry Contribution to Change in Domestic Output by ISIC Code[Target ISIC Code\
		!
	]
	      + Domestic Nonenergy Industry Expenses Passed Through to Buyers by Producer ISIC Code\
		[Target ISIC Code!]
	    )
	    * Domestic Value Added Requirements by Industry per Unit Output by Industry Excluding Direct Impacts\
		[Source ISIC Code
	,Target ISIC Code!]
	  ),
	
	  QSfCF Quantization Size for Cash Flows
	) ~~|
Indirect Change in Domestic Value Added by ISIC Code[Fossil and Energy Utility Source ISIC Code\
		]=
	QUANTUM(
	SUM(
	  Industry Contribution to Change in Domestic Output by ISIC Code[Fossil and Energy Utility Target ISIC Code
	!]
	  * Domestic Value Added Requirements by Industry per Unit Output by Industry Excluding Direct Impacts\
		[Fossil and Energy Utility Source ISIC Code
	,Fossil and Energy Utility Target ISIC Code
	!]
	)
	* (1 - FoPTaFbIC Fractions of Products That are Fuels by ISIC Code[Fossil and Energy Utility Source ISIC Code\
		])
	
	+ ZIDZ(
	  SUM(
	    Industry Contribution to Change in Domestic Output by ISIC Code[Fossil and Energy Utility Target ISIC Code
	!]
	    * Domestic Value Added Requirements by Industry per Unit Output by Industry Excluding Direct Impacts\
		[Fossil and Energy Utility Source ISIC Code
	,Fossil and Energy Utility Target ISIC Code!]
	  )
	  * Last Year Energy Production per Unit Output[Fossil and Energy Utility Source ISIC Code\
		]
	  * FoPTaFbIC Fractions of Products That are Fuels by ISIC Code[Fossil and Energy Utility Source ISIC Code\
		],
	  BAU Last Year Energy Production per Unit Output[Fossil and Energy Utility Source ISIC Code\
		]
	),
	
	QSfCF Quantization Size for Cash Flows
	)
	~	$
	~		|

Indirect Change in Domestic Value Added by ISIC Code Excluding Passthrough Expenses[Source ISIC Code\
		]=
	SUM(
	  Industry Contribution to Change in Domestic Output by ISIC Code[Target ISIC Code!]
	  * Domestic Value Added Requirements by Industry per Unit Output by Industry Excluding Direct Impacts\
		[Source ISIC Code,Target ISIC Code!]
	)
	~	$
	~		|

Induced Change in Domestic Compensation by ISIC Code[Source ISIC Code]=
	QUANTUM(
	
	  Induced Change in Domestic Jobs after Productivity Effects by ISIC Code[Source ISIC Code\
		]
	  * Within Industry Compensation per Employed Person[Source ISIC Code],
	
	  QSfCF Quantization Size for Cash Flows
	)
	~	$
	~		|

Induced Change in Domestic Jobs after Productivity Effects by ISIC Code[ISIC Code]=
	QUANTUM(
	  Induced Change in Domestic Jobs by ISIC Code[ISIC Code]
	  / (1 + LPGRbIC Labor Productivity Growth Rate by ISIC Code[ISIC Code])^(Dimensionless Time\
		 - Initial Time Dimensionless),
	
	  Quantization Size for Jobs
	)
	~	jobs
	~		|

Induced Change in Domestic Jobs by ISIC Code[Source ISIC Code] :EXCEPT:  [Fossil and Energy Utility Source ISIC Code\
		]=
	SUM(
	  Household and Government Contribution to Change in Domestic Output by ISIC Code[Target ISIC Code\
		!]
	  * Domestic Job Requirements by Industry per Unit Output by Industry[Source ISIC Code\
		,Target ISIC Code!]
	) ~~|
Induced Change in Domestic Jobs by ISIC Code[Fossil and Energy Utility Source ISIC Code\
		]=
	SUM(
	  Household and Government Contribution to Change in Domestic Output by ISIC Code[Fossil and Energy Utility Target ISIC Code\
		!]
	  * Domestic Job Requirements by Industry per Unit Output by Industry[Fossil and Energy Utility Source ISIC Code\
		,Fossil and Energy Utility Target ISIC Code!]
	)
	* (1 - FoPTaFbIC Fractions of Products That are Fuels by ISIC Code[Fossil and Energy Utility Source ISIC Code\
		])
	
	+ ZIDZ(
	
	  SUM(
	    Household and Government Contribution to Change in Domestic Output by ISIC Code[\
		Fossil and Energy Utility Target ISIC Code!]
	    * Domestic Job Requirements by Industry per Unit Output by Industry[Fossil and Energy Utility Source ISIC Code\
		,Fossil and Energy Utility Target ISIC Code!]
	  )
	  * (FoPTaFbIC Fractions of Products That are Fuels by ISIC Code[Fossil and Energy Utility Source ISIC Code\
		])
	  * Energy Production per Unit Output[Fossil and Energy Utility Source ISIC Code],
	  BAU Energy Production per Unit Output[Fossil and Energy Utility Source ISIC Code]
	)
	~	jobs
	~		|

Induced Change in Domestic Output by ISIC Code[ISIC Code]=
	ZIDZ(
	  Induced Change in Domestic Value Added by ISIC Code[ISIC Code],
	
	  Within Industry Value Added per Unit Output[ISIC Code]
	)
	~	$
	~		|

Induced Change in Domestic Value Added by ISIC Code[Source ISIC Code] :EXCEPT:   [Fossil and Energy Utility Source ISIC Code\
		]=
	QUANTUM(
	  SUM(
	    Household and Government Contribution to Change in Domestic Output by ISIC Code[\
		Target ISIC Code!]
	    * Domestic Value Added Requirements by Industry per Unit Output by Industry[Source ISIC Code\
		,Target ISIC Code!]
	  ),
	
	  QSfCF Quantization Size for Cash Flows
	) ~~|
Induced Change in Domestic Value Added by ISIC Code[Fossil and Energy Utility Source ISIC Code\
		]=
	QUANTUM(
	SUM(
	  Household and Government Contribution to Change in Domestic Output by ISIC Code[Fossil and Energy Utility Target ISIC Code\
		!]
	  * Domestic Value Added Requirements by Industry per Unit Output by Industry[Fossil and Energy Utility Source ISIC Code\
		,Fossil and Energy Utility Target ISIC Code!]
	)
	* (1 - FoPTaFbIC Fractions of Products That are Fuels by ISIC Code[Fossil and Energy Utility Source ISIC Code\
		])
	
	+ ZIDZ(
	
	  SUM(
	    Household and Government Contribution to Change in Domestic Output by ISIC Code[\
		Fossil and Energy Utility Target ISIC Code!]
	    * Domestic Value Added Requirements by Industry per Unit Output by Industry[Fossil and Energy Utility Source ISIC Code\
		,Fossil and Energy Utility Target ISIC Code!]
	  )
	  * (FoPTaFbIC Fractions of Products That are Fuels by ISIC Code[Fossil and Energy Utility Source ISIC Code\
		])
	  * Last Year Energy Production per Unit Output[Fossil and Energy Utility Source ISIC Code\
		],
	  BAU Last Year Energy Production per Unit Output[Fossil and Energy Utility Source ISIC Code\
		]
	),
	
	QSfCF Quantization Size for Cash Flows
	)
	~	$
	~		|

Induced Foreign Emissions[Industry Category,Pollutant]=
	(BAU Industrial Sector Pollutant Emissions[Industry Category,Pollutant]
	 - Industrial Sector Pollutant Emissions[Industry Category,Pollutant])
	* FLRbI Foreign Leakage Rate by Industry[Industry Category]
	~	g pollutant
	~	We estimate induced forgiegn emissions.  Although the emissions indices \
		for pollutants might be different for non-modeled regions, we estimate \
		them assuming the same emissions indices as the modeled region.
	~	:SUPPLEMENTARY 
	|

Industrial CCS Transportation and Storage Subsidy=
	CCSTaSC CCS Transportation and Storage Subsidies
	
	+
	
	(CCSTaSC CCS Transportation and Storage Costs
	 - CCSTaSC CCS Transportation and Storage Subsidies)
	* Perc Subsidy for Industry Sector CCS Transport and Storage Costs This Year
	~	$/metric ton CO2e
	~		|

Industrial Clean Heat Production Subsidy Amount Paid[Industry Category]=
	SUM(
	  Clean Industrial Heat Production Subsidy Rate by Equipment Vintage[Industrial Fuel\
		!,industrial heating process!,Model Run Vintage!]
	  * Output from Industrial Equipment Installed During Model Run[Industry Category,industrial heating process\
		!,Model Run Vintage
	!]
	  * Last Year Industrial Equipment Fuel Type Shares in Electricity Equivalent by Vintage NEW\
		[Industry Category,industrial heating process
	!,Industrial Fuel!,Model Run Vintage!]
	  * Last Year Energy Intensity of Industrial Production by Fuel and Vintage in Electricity Equivalent\
		[Industry Category
	,Industrial Fuel!,Model Run Vintage!]
	  * (1 - This Year Reduction in Industrial Energy Consumption for Heat Generation due to Waste Heat Recovery\
		[Industry Category])
	  * This Year Industrial Energy Use Reduction Due to Process Improvements[Industry Category\
		,Industrial Fuel!]
	)
	
	+ 
	
	SUM(
	  Clean Industrial Heat Subsidy Rate by Fuel Type[Industrial Fuel!,industrial heating process\
		!]
	  * Output from New Industrial Equipment[Industry Category,industrial heating process\
		!]
	  * Share of New Industrial Equipment by Fuel Type and Process in Electricity Equivalent\
		[Industry Category,Industrial Fuel
	!,industrial heating process!]
	  * Energy Intensity of Industrial Production by Fuel for New Equipment in Electricity Equivalent\
		[Industry Category,Industrial Fuel
	!]
	  * (1 - This Year Reduction in Industrial Energy Consumption for Heat Generation due to Waste Heat Recovery\
		[Industry Category])
	  * This Year Industrial Energy Use Reduction Due to Process Improvements[Industry Category\
		,Industrial Fuel!]
	)
	~	$
	~		|

Industrial Emissions per Unit Output[Industry Category]=
	ZIDZ(
	  Industrial Sector CO2e Emissions[Industry Category],
	
	  Last Year Output by ISIC Code[Industry Category ISIC Code]
	)
	/ Grams per Metric Ton CO2e
	~	metric tons CO2e/$
	~		|

Industrial Energy Related Emissions Excluding Fuels to Power CCS[Industrial Fuel,Industry Category\
		,Pollutant]=
	Industrial Fuel Use for Energy before CCS and Methane Capture[Industrial Fuel,Industry Category\
		]
	* Industrial Fuel Pollutant Emissions Intensities This Year[Industry Category,Pollutant\
		,Industrial Fuel]
	~	g pollutant
	~		|

Industrial Equipment Annual Costs and Annual Financing Repayment per Unit Energy in Electricity Equivalent\
		[Industry Category,Industrial Fuel,Industrial Process] :EXCEPT:     [Industry Category\
		,electricity if,Industrial Process]=
	Present Value of Industrial Equipment Costs per Unit Energy[Industry Category,Industrial Fuel\
		,Industrial Process]
	/ (1 - PIFURfE Percentage Industry Fuel Use Reduction for Electricity[Industry Category\
		,Industrial Process]) ~~|
Industrial Equipment Annual Costs and Annual Financing Repayment per Unit Energy in Electricity Equivalent\
		[Industry Category,electricity if,Industrial Process]=
	Present Value of Industrial Equipment Costs per Unit Energy[Industry Category,electricity if\
		,Industrial Process]
	~	$/BTU
	~		|

Industrial Equipment Annual Costs and Annual Financing Repayment per Unit Industrial Output in Electricity Equivalent\
		[Industry Category
,Industrial Fuel,Industrial Process]=
	MAX(
	0,
	Industrial Equipment Annual Costs and Annual Financing Repayment per Unit Energy in Electricity Equivalent\
		[Industry Category
	,Industrial Fuel,Industrial Process]
	* Energy Intensity of Industrial Production by Fuel for New Equipment in Electricity Equivalent\
		[Industry Category,Industrial Fuel]
	)
	~	$/$
	~	The unit $/$ here refers to dollars of industrial output (in the \
		numerator) per dollar spent on fuel (in the denominator).
	|

Industrial Equipment Annualized Capital Costs per Unit Energy[Industry Category,Industrial Fuel\
		,Industrial Process]=
	Industrial Equipment Capital Cost per Unit Annual Energy Use[Industry Category,Industrial Fuel\
		,Industrial Process]
	* Capital Recovery Factor by Industry Fuel and Process[Industry Category,Industrial Fuel\
		,Industrial Process]
	~	$/BTU
	~		|

Industrial Equipment Annualized Capital Costs per Unit Energy in Future Years[Industry Category\
		,Industrial Fuel,Industrial Process,Future Year]=
	IF THEN ELSE(
	
	  Numerical Future Year Definitions[Future Year] - Time < 0,
	  0, 
	  IF THEN ELSE(
	    Numerical Future Year Definitions[Future Year] - Time >= RPfFISCC Repayment Period for Financed Industry Sector Capital Costs\
		[Industrial Process], 
	    0,
	    Industrial Equipment Annualized Capital Costs per Unit Energy[Industry Category,\
		Industrial Fuel,Industrial Process]
	  )
	)
	~	$/BTU
	~		|

Industrial Equipment Capital Cost per Unit Annual Energy Use[Industry Category,Industrial Fuel\
		,Industrial Process] :EXCEPT:   [Industry Category,Industrial Fuel,industrial heating process\
		]=
	Industrial Equipment Capital Cost per Unit Energy Before Clean Heat Subsidy[Industry Category\
		,Industrial Fuel,Industrial Process] ~~|
Industrial Equipment Capital Cost per Unit Annual Energy Use[Industry Category,Industrial Fuel\
		,industrial heating process]=
	MAX(
	  0,
	  Industrial Equipment Capital Cost per Unit Energy Before Clean Heat Subsidy[Industry Category\
		,Industrial Fuel,industrial heating process]
	  - Clean Industrial Heat Investment Subsidy Rate[Industry Category,industrial heating process\
		,Industrial Fuel]
	)
	~	$/BTU
	~		|

Industrial Equipment Capital Cost per Unit Energy Before Clean Heat Subsidy[Industry Category\
		,Industrial Fuel,Industrial Process]=
	Industrial Equipment Capital Cost per Unit Energy Before Efficiency Standards[Industry Category\
		,Industrial Fuel,Industrial Process]
	* (1 + Price Increase for New Indst Eqpt Due to Eff Standards[Industry Category,Industrial Fuel\
		,Industrial Process])
	~	$/BTU
	~		|

Industrial Equipment Capital Cost per Unit Energy Before Efficiency Standards[Industry Category\
		,Industrial Fuel,Industrial Process] :EXCEPT:  [Industry Category,Industrial Fuel,other nonprocess\
		]=
	IECCpUAEU Industrial Equipment Capital Cost per Unit Annual Energy Use[Industrial Fuel\
		,Industrial Process]
	* (1 - RnD Industry Capital Cost Perc Reduction This Year[Industrial Process,Industrial Fuel\
		]) ~~|
Industrial Equipment Capital Cost per Unit Energy Before Efficiency Standards[Industry Category\
		,Industrial Fuel,other nonprocess]=
	(1 - PoONEUTiMEbIC Perc of Other Nonprocess Eqpt E Use That is Mobile Eqpt by Indst Category\
		[Industry Category])
	* 
	IECCpUAEU Industrial Equipment Capital Cost per Unit Annual Energy Use[Industrial Fuel\
		,other nonprocess]
	
	+
	
	(PoONEUTiMEbIC Perc of Other Nonprocess Eqpt E Use That is Mobile Eqpt by Indst Category\
		[Industry Category])
	* IECCpUAEU Industrial Eqpt Capital Cost per Unit Annual E Use for Mobile Eqpt[Industrial Fuel\
		]
	~	$/BTU
	~		|

Industrial Equipment Energy Use by Fuel Type and Process[Industry Category,Industrial Fuel\
		,Industrial Process]=
	Industrial Equipment Energy Use by Fuel Type and Process before Process Improvements\
		[Industry Category,Industrial Fuel,Industrial Process]
	* This Year Industrial Energy Use Reduction Due to Process Improvements[Industry Category\
		,Industrial Fuel]
	~	BTU
	~		|

Industrial Equipment Energy Use by Fuel Type and Process before Process Improvements[\
		Industry Category,Industrial Fuel,Industrial Process] :EXCEPT: [Industry Category,Industrial Fuel\
		,industrial heating process]=
	Industrial Equipment Energy Use by Fuel Type and Process before Waste Heat Recovery[\
		Industry Category,Industrial Fuel,Industrial Process] ~~|
Industrial Equipment Energy Use by Fuel Type and Process before Process Improvements[\
		Industry Category,Industrial Fuel,industrial heating process]=
	Industrial Equipment Energy Use by Fuel Type and Process before Waste Heat Recovery[\
		Industry Category,Industrial Fuel,industrial heating process]
	* (1 - This Year Reduction in Industrial Energy Consumption for Heat Generation due to Waste Heat Recovery\
		[Industry Category])
	~	BTU
	~		|

Industrial Equipment Energy Use by Fuel Type and Process before Waste Heat Recovery[Industry Category\
		,Industrial Fuel,
Industrial Process] :EXCEPT:                  [Industry Category,electricity if,Industrial Process\
		]=
	ZIDZ(
	  SUM(
	    Output from Industrial Equipment Installed During Model Run[Industry Category,Industrial Process\
		,Model Run Vintage!
	]
	    * Last Year Industrial Equipment Fuel Type Shares in Electricity Equivalent by Vintage NEW\
		[Industry Category,Industrial Process
	,Industrial Fuel,Model Run Vintage!]
	    * Last Year Energy Intensity of Industrial Production by Fuel and Vintage in Electricity Equivalent\
		[Industry Category,Industrial Fuel,Model Run Vintage!]
	  )
	    
	  +
	
	  Output from New Industrial Equipment[Industry Category,Industrial Process]
	  * Share of New Industrial Equipment by Fuel Type and Process in Electricity Equivalent\
		[Industry Category,Industrial Fuel
	,Industrial Process]
	  * Energy Intensity of Industrial Production by Fuel for New Equipment in Electricity Equivalent\
		[Industry Category,Industrial Fuel
	]
	
	  + 
	
	  Output from Preexisting Industrial Equipment[Industry Category,Industrial Process]
	  * Preexisting Industrial Equipment Fuel Type Shares in Electricity Equivalent Adjusted by Early Retirement Policy\
		[Industry Category
	,Industrial Process,Industrial Fuel]
	  * Start Year Energy Intensity of Industrial Production in Electricity Equivalent[Industry Category\
		]
	  ,
	  1 - PIFURfE Percentage Industry Fuel Use Reduction for Electricity[Industry Category\
		,Industrial Process]
	) ~~|
Industrial Equipment Energy Use by Fuel Type and Process before Waste Heat Recovery[Industry Category\
		,electricity if,Industrial Process]=
	SUM(
	  Output from Industrial Equipment Installed During Model Run[Industry Category,Industrial Process\
		,Model Run Vintage!]
	  * Last Year Industrial Equipment Fuel Type Shares in Electricity Equivalent by Vintage NEW\
		[Industry Category,Industrial Process
	,electricity if,Model Run Vintage!]
	  * Last Year Energy Intensity of Industrial Production by Fuel and Vintage in Electricity Equivalent\
		[Industry Category,electricity if,Model Run Vintage!]
	)
	
	+ 
	
	Output from New Industrial Equipment[Industry Category,Industrial Process]
	* Share of New Industrial Equipment by Fuel Type and Process in Electricity Equivalent\
		[Industry Category,electricity if
	,Industrial Process]
	* Energy Intensity of Industrial Production by Fuel for New Equipment in Electricity Equivalent\
		[Industry Category,electricity if
	]
	
	+
	
	Output from Preexisting Industrial Equipment[Industry Category,Industrial Process]
	* Preexisting Industrial Equipment Fuel Type Shares in Electricity Equivalent Adjusted by Early Retirement Policy\
		[Industry Category
	,Industrial Process,electricity if]
	* Start Year Energy Intensity of Industrial Production in Electricity Equivalent[Industry Category\
		]
	~	BTU
	~	"Industrial Equipment Fuel Type Shares in Electricity Equivalent by \
		Vintage" add to 1 for each industry category, so that variable is \
		expecting to be multiplied by total output of each industry category.
	|

Industrial Fuel:
	electricity if,
	hard coal if,
	natural gas if,
	biomass if,
	petroleum diesel if,
	heat if,
	crude oil if,
	heavy or residual fuel oil if,
	LPG propane or butane if,
	hydrogen if,
	green hydrogen if,
	low carbon hydrogen if
	-> industrial fuel within all fuels
	~	
	~		|

Industrial Fuel Carbon Tax Amount per Unit Energy[Industry Category,Industrial Fuel]=
	Carbon Tax Rate[industry sector]
	/ Grams per Metric Ton CO2e
	* Industrial Fuel Taxable CO2e Emissions Intensity[Industry Category,Industrial Fuel\
		]
	* Fraction of Industry Category Subject to Carbon Tax[Industry Category]
	~	$/BTU
	~		|

Industrial Fuel Carbon Tax Amount per Unit Energy in Future Years[Industry Category,Industrial Fuel\
		,Future Year]=
	Carbon Price in Future Years[industry sector,Future Year]
	/ Grams per Metric Ton CO2e
	* Industrial Fuel Taxable CO2e Emissions Intensity[Industry Category,Industrial Fuel\
		]
	* Fraction of Industry Category Subject to Carbon Tax[Industry Category]
	~	$/BTU
	~		|

Industrial Fuel Cost per Unit Energy[Industry Category,Industrial Fuel] :EXCEPT:     \
		[Industry Category,hydrogen if],[Industry Category,green hydrogen if],[Industry Category\
		,low carbon hydrogen if]=
	MAX(Pretax Fuel Cost per Unit Energy by Sector after Fuel Price Deregulation[industrial fuel within all fuels\
		,industry sector
	]
	  + Industrial Fuel Total Tax or Subsidy Amount per Unit Energy[Industry Category,Industrial Fuel\
		],
	0
	) ~~|
Industrial Fuel Cost per Unit Energy[Industry Category,hydrogen if]=
	MAX(This Year Other Hydrogen Cost
	  + Industrial Fuel Total Tax or Subsidy Amount per Unit Energy[Industry Category,hydrogen if\
		],
	0
	) ~~|
Industrial Fuel Cost per Unit Energy[Industry Category,green hydrogen if]=
	MAX(This Year Green Hydrogen Cost
	  + Industrial Fuel Total Tax or Subsidy Amount per Unit Energy[Industry Category,green hydrogen if\
		],
	0
	) ~~|
Industrial Fuel Cost per Unit Energy[Industry Category,low carbon hydrogen if]=
	MAX(This Year Low Carbon Hydrogen Cost
	  + Industrial Fuel Total Tax or Subsidy Amount per Unit Energy[Industry Category,low carbon hydrogen if\
		],
	0
	)
	~	$/BTU
	~	We need this subscripted only by fuel type, not industry type, for use \
		calculating percentage differences from BAU.  Carbon intensity of fuels \
		should not vary significantly based on which industry burns those fuels, \
		as CCS is not considered here.  Accordingly, we use the cement industry as \
		our model, as cement is produced worldwide, is a major emitter, and has \
		unique process emissions, and therefore is unlikely to be repurposed as \
		another industry in an EPS adaptation.
	|

Industrial Fuel Other Tax or Subsidy Amount per Unit Energy[Industrial Fuel]=
	Fuel Tax or Subsidy by Sector[industrial fuel within all fuels,industry sector]
	~	$/BTU
	~		|

Industrial Fuel Pollutant Emissions Intensities This Year[Industry Category,Pollutant\
		,Industrial Fuel]=
	PEI Industrial Fuel Pollutant Emissions Intensities[Pollutant,Industrial Fuel]
	  * (1 - PEIIR Industrial Fuel Pollutant Emissions Intensity Improvement Rate[Pollutant\
		,Industrial Fuel])
	    ^(Dimensionless Time - Initial Time Dimensionless)
	~	g pollutant/BTU
	~		|

Industrial Fuel Taxable CO2e Emissions Intensity[Industry Category,Industrial Fuel]=
	SUM(
	  Industrial Fuel Pollutant Emissions Intensities This Year[Industry Category,Pollutant\
		!,Industrial Fuel]
	  * GWP by Pollutant[Pollutant!]
	  * Industry Pollutants Taxed by Carbon Pricing[Industry Category,Pollutant!]
	)
	~	g CO2e/BTU
	~		|

Industrial Fuel Total Tax or Subsidy Amount per Unit Energy[Industry Category,Industrial Fuel\
		]=
	Industrial Fuel Carbon Tax Amount per Unit Energy[Industry Category,Industrial Fuel]
	+ Industrial Fuel Other Tax or Subsidy Amount per Unit Energy[Industrial Fuel]
	~	$/BTU
	~		|

Industrial Fuel Use[Industrial Fuel,Industry Category]=
	Industrial Fuel Use for Non Energy Purposes[Industry Category,Industrial Fuel]
	+ Industrial Fuel Use for Energy Purposes[Industrial Fuel,Industry Category]
	~	BTU
	~		|

Industrial Fuel Use for Energy before CCS and Methane Capture[Industrial Fuel,Industry Category\
		]=
	SUM(Industrial Equipment Energy Use by Fuel Type and Process[Industry Category,Industrial Fuel
	,Industrial Process!])
	~	BTU
	~		|

Industrial Fuel Use for Energy Purposes[Industrial Fuel,Industry Category] :EXCEPT:  \
		[natural gas if,Industry Category]=
	Industrial Fuel Use for Energy before CCS and Methane Capture[Industrial Fuel,Industry Category\
		]
	+ Fuel Used for CCS by Industry Sector[Industrial Fuel,Industry Category] ~~|
Industrial Fuel Use for Energy Purposes[natural gas if,Industry Category]=
	MAX(
	  0,
	
	  Industrial Fuel Use for Energy before CCS and Methane Capture[natural gas if,Industry Category\
		]
	  + Fuel Used for CCS by Industry Sector[natural gas if,Industry Category]
	  - Change in Methane Captured by Industry[Industry Category]
	)
	~	BTU
	~		|

Industrial Fuel Use for Non Energy Purposes[Industry Category,Target Industrial Fuel]\
		=
	Industrial Fuel Use for Non Energy Purposes Before Feedstock Shifting[Industry Category\
		,Target Industrial Fuel]
	* (1 - Fraction of Feedstock Shifted This Year[Industry Category,Target Industrial Fuel\
		])
	
	+ SUM(Industrial Fuel Use for Non Energy Purposes Before Feedstock Shifting[Industry Category\
		,Source Industrial Fuel!]
	  * IFSR Industrial Fuel Shifting Ratio[Industry Category,Source Industrial Fuel!]
	  * Fraction of Feedstock Shifted This Year[Industry Category,Source Industrial Fuel\
		!]
	  * IFSRF Industrial Feedstock Shifting Recipient Fuel[Source Industrial Fuel!,Target Industrial Fuel\
		]
	  )
	~	BTU
	~		|

Industrial Fuel Use for Non Energy Purposes Before Feedstock Shifting[Industry Category\
		,Industrial Fuel]=
	BAU Industrial Feedstock Use after Adjustments[Industry Category,Industrial Fuel]
	* (1 + Percent Change in Production due to Policies[Industry Category])
	~	BTU
	~		|

industrial fuel within all fuels:
	electricity,
	hard coal,
	natural gas,
	biomass,
	petroleum diesel,
	heat,
	crude oil,
	heavy or residual fuel oil,
	LPG propane or butane,
	hydrogen,
	hydrogen,
	hydrogen
	-> Industrial Fuel
	~	
	~		|

industrial heating process:
	boilers,
	nonboiler low temp,
	nonboiler med temp,
	nonboiler high temp
	~	
	~		|

Industrial Process:
	boilers,
	nonboiler low temp,
	nonboiler med temp,
	nonboiler high temp,
	cooling,
	machine drive,
	other processes,
	facility HVAC,
	facility lighting,
	other nonprocess
	~	
	~		|

Industrial Sector CO2e Emissions[Industry Category]=
	SUM(Industrial Sector Pollutant Emissions[Industry Category,Pollutant!]
	    * GWP by Pollutant[Pollutant!])
	~	g CO2e
	~		|

Industrial Sector Electricity Demand=
	SUM(Electricity Demand by Industry[Industry Category!])
	~	MW*hour
	~		|

Industrial Sector Emissions from Fuels Used to Power CCS[Industrial Fuel,Industry Category\
		,Pollutant]=
	Fuel Used for CCS by Industry Sector[Industrial Fuel,Industry Category]
	* Industrial Fuel Pollutant Emissions Intensities This Year[Industry Category,Pollutant\
		,Industrial Fuel]
	~	g pollutant
	~		|

Industrial Sector Energy Related Emissions after CCS[Industrial Fuel,Industry Category\
		,Pollutant]=
	Industrial Sector Energy Related Emissions before CCS[Industrial Fuel,Industry Category\
		,Pollutant]
	- This Year Energy Related Pollutants Sequestered by Industry Sector[Industry Category\
		,Pollutant]
	  * ZIDZ(
	      Industrial Sector Energy Related Emissions before CCS[Industrial Fuel,Industry Category\
		,Pollutant],
	
	      SUM(Industrial Sector Energy Related Emissions before CCS[Industrial Fuel!,Industry Category\
		,Pollutant])
	    )
	~	g pollutant
	~	We maintain the "Industrial Fuel" subscript here (allocating sequestered \
		CO2 by fuel type proportionate to CO2 emissions from each fuel type) to \
		support one of the output graphs, which shows energy-related CO2 emissions \
		by fuel type.
	|

Industrial Sector Energy Related Emissions before CCS[Industrial Fuel,Industry Category\
		,Pollutant]=
	Industrial Energy Related Emissions Excluding Fuels to Power CCS[Industrial Fuel,Industry Category\
		,Pollutant]
	+ Industrial Sector Emissions from Fuels Used to Power CCS[Industrial Fuel,Industry Category\
		,Pollutant]
	~	g pollutant
	~		|

Industrial Sector Pollutant Emissions[Industry Category,Pollutant]=
	SUM(Industrial Sector Energy Related Emissions after CCS[Industrial Fuel!,Industry Category\
		,Pollutant])
	+ Process Emissions after CCS[Industry Category,Pollutant]
	~	g pollutant
	~		|

