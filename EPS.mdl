	~	$/vehicle
	~		|

Net Electricity Clean Firm Demand Relative to Available Clean Firm Supply by Hour before Additions\
		[Hour,peak day electricity timeslice]=
	QUANTUM(
	    Total Electricity Demand by Hour Before Demand Altering Technologies Plus Reserve Margin Required from Clean Dispatchable Resource
	[peak day electricity timeslice,Hour]
	    
	      - SUM(
	    
	          Electricity Generation Capacity before Dispatchable CES Additions[Clean Dispatchable Electricity Source\
		!]
	          * Last Year Hourly Bid Electricity Capacity Factors by Plant Type[peak day electricity timeslice\
		,Hour,Clean Dispatchable Electricity Source
	!])
	          * One Hour
	
	      - Total Demand Shifting Capacity in MW[peak day electricity timeslice,Hour],
	     
	    Minimum Incremental Clean Firm Demand Requirement)
	~	MW*hr
	~		|

Net Electricity Clean Firm Demand Relative to Available Clean Firm Supply by Hour by Optimization Pass for Seasonal Dispatchable Reliability under CES\
		[Optimization Pass]=
	QUANTUM(
	    SUM(Total Electricity Demand by Hour Before Demand Altering Technologies Plus Reserve Margin Required from Clean Dispatchable Resource\
		[peak day electricity timeslice!,Hour!]*Binding Peak Hour for Clean Dispatchable Reliability\
		[peak day electricity timeslice!,Hour!])
	           - Maximum Potential Binding Hour Peak Seasonal Day Electricity Output by Optimization Pass for Dispatchable Reliability under CES\
		[Optimization Pass],
	
	  Minimum Incremental Clean Firm Demand Requirement)
	~	MW*hr
	~		|

Net Electricity Demand Relative to Available Supply by Hour before Reliability Additions\
		[peak day electricity timeslice,Hour]=
	Total Electricity Demand by Hour Before Demand Altering Technologies Plus Reserve Margin\
		[peak day electricity timeslice
	,Hour]
	
	  - SUM(Electricity Generation Capacity before Reliability Additions[Electricity Source\
		!]*Last Year Hourly Bid Electricity Capacity Factors by Plant Type
	[peak day electricity timeslice,Hour,Electricity Source!])*One Hour
	~	MW*hour
	~		|

Net Electricity Demand Relative to Available Supply in Binding Hour by Optimization Pass\
		[Optimization Pass]=
	SUM(Total Electricity Demand by Hour Before Demand Altering Technologies Plus Reserve Margin\
		[peak day electricity timeslice!,
	Hour!]*Binding Peak Hour for Reliability Additions[peak day electricity timeslice!,Hour\
		!])
	- Maximum Potential Binding Hour Electricity Output by Hour for Dispatchable Reliability\
		[Optimization Pass]
	~	MW*hr
	~		|

Net Imports of Electricity=
	Imported Electricity
	- Exported Electricity
	~	MW*hour
	~		|

Net Loss per Unit Capacity[Electricity Source,Optimization Pass]=
	MAX(
	  0,
	
	  Last Year Annual Recurring Costs by Plant Type[Electricity Source]
	  * SoFCtMbCtPR Share of Forward Costs that Must Be Covered to Prevent Retirement[Electricity Source\
		]
	  - Expected Total Revenue per Unit Capacity by Plant Type Excluding Subsidies[Electricity Source\
		,Optimization Pass]
	)
	~	$/MW
	~		|

Net Loss per Unit Capacity Excluding Predicted Capacity Payment[Electricity Source]=
	MAX(
	  0,
	
	  Last Year Annual Recurring Costs by Plant Type[Electricity Source]
	  * SoFCtMbCtPR Share of Forward Costs that Must Be Covered to Prevent Retirement[Electricity Source\
		]
	  - Expected Total Revenue per Unit Capacity by Plant Type Excluding Subsidies and Predicted Capacity Payment\
		[Electricity Source]
	)
	~	$/MW
	~		|

New and Retrofit Generation Capacity[Electricity Source]=
	New Generation Capacity Excluding Retrofit Capacity[Electricity Source]
	+ Retrofit Capacity after Quantization[Electricity Source]
	~	MW
	~		|

New Capacity Added due to Elec Portfolio Stds for Hybrid Power Plants[Electricity Source\
		,Clean Elec Requirement]=
	New Capacity Desired due to Cost Effectiveness for Hybrid Power Plants[Electricity Source\
		,Clean Elec Requirement]
	-New Capacity Desired due to Cost Effectivness for Hybrid Power Plants without CES[Electricity Source\
		]
	~	MW
	~		|

New Capacity Added or Retrofitted due to Elec Portfolio Stds[Electricity Source,Clean Elec Requirement\
		]=
	New Capacity Added due to Elec Portfolio Stds for Hybrid Power Plants[Electricity Source\
		,Clean Elec Requirement]
	+ New Capacity Added or Retrofitted due to Elec Portfolio Stds excluding Hybrid Power Plants\
		[Electricity Source,Clean Elec Requirement]
	~	MW
	~		|

New Capacity Added or Retrofitted due to Elec Portfolio Stds excluding Hybrid Power Plants\
		[Electricity Source,Clean Elec Requirement]=
	New Capacity Desired due to Cost Effectiveness[Electricity Source,Clean Elec Requirement\
		]
	+Retrofit Capacity Desired due to Cost Effectiveness[Electricity Source,Clean Elec Requirement\
		]
	-New Capacity Desired due to Cost Effectivness without CES[Electricity Source]
	-Retrofitted Capacity Desired due to Cost Effectiveness without CES[Electricity Source\
		]
	~	MW
	~		|

New Capacity Desired due to Cost Effectiveness[Electricity Source,RPS]=
	MAX(0,
	  
	  SUM(New Capacity Desired due to Cost Effectivness by Optimization Pass[Electricity Source\
		,last pass!,RPS])
	  -New Dispatchable Only Clean Capacity Desired for Seasonal Reliability[Electricity Source\
		]
	
	 ) ~~|
New Capacity Desired due to Cost Effectiveness[Electricity Source,CES]=
	MAX(0,
	  
	  SUM(New Capacity Desired due to Cost Effectivness by Optimization Pass[Electricity Source\
		,last pass!,CES])
	  -New Dispatchable Only Clean Capacity Desired for Seasonal Reliability[Electricity Source\
		]
	
	 )
	~	MW
	~	Although "last pass" is intended to contain a single element, we must sum \
		across it becuase it is technically a subrange.
	|

New Capacity Desired due to Cost Effectiveness for Hybrid Power Plants[Electricity Source\
		,Clean Elec Requirement] :EXCEPT:      [Hybrid Electricity Source,Clean Elec Requirement\
		]=
	0 ~~|
New Capacity Desired due to Cost Effectiveness for Hybrid Power Plants[Hybrid Electricity Source\
		,RPS]=
	SUM(New Capacity Desired due to Cost Effectivness by Optimization Pass for Hybrid Power Plants\
		[Hybrid Electricity Source
	,last pass!,RPS]) ~~|
New Capacity Desired due to Cost Effectiveness for Hybrid Power Plants[Hybrid Electricity Source\
		,CES]=
	SUM(New Capacity Desired due to Cost Effectivness by Optimization Pass for Hybrid Power Plants\
		[Hybrid Electricity Source
	,last pass!,CES])
	~	MW
	~	Although "last pass" is intended to contain a single element, we must sum \
		across it becuase it is technically a subrange.
	|

New Capacity Desired due to Cost Effectivness by Optimization Pass[Electricity Source\
		, Optimization Pass,RPS]=
	QUANTUM(
	  MIN(
	    Max Capacity Buildable after Mandated and Required Clean Dispatchable Additions[\
		Electricity Source],
	
	    Profitable Capacity for Cost Effectiveness Additions[Electricity Source,Optimization Pass\
		,RPS]
	    * CSCSoCECBiaSY Share of Cost Effective Capacity Built in a Single Year[Electricity Source\
		]
	  ),
	  MPPC Minimum Power Plant Capacity[Electricity Source]
	) ~~|
New Capacity Desired due to Cost Effectivness by Optimization Pass[Electricity Source\
		,Optimization Pass,CES]=
	QUANTUM(
	  MIN(
	    Max Capacity Buildable after Mandated and Required Clean Dispatchable Additions[\
		Electricity Source],
	
	    Profitable Capacity for Cost Effectiveness Additions[Electricity Source,Optimization Pass\
		,CES]
	    * CSCSoCECBiaSY Share of Cost Effective Capacity Built in a Single Year[Electricity Source\
		]
	  ),
	  MPPC Minimum Power Plant Capacity[Electricity Source]
	)
	~	MW
	~		|

New Capacity Desired due to Cost Effectivness by Optimization Pass for Hybrid Power Plants\
		[Electricity Source, Optimization Pass,Clean Elec Requirement] :EXCEPT:     [Hybrid Electricity Source\
		, Optimization Pass,Clean Elec Requirement]=
	0 ~~|
New Capacity Desired due to Cost Effectivness by Optimization Pass for Hybrid Power Plants\
		[Hybrid Electricity Source,Optimization Pass,RPS]=
	QUANTUM(
	  MIN(
	    Max Capacity Buildable after Mandated and Required Clean Dispatchable Additions[\
		Hybrid Electricity Source]
	    - New Capacity Desired due to Cost Effectivness by Optimization Pass[Hybrid Electricity Source\
		,Optimization Pass,RPS],
	
	    Profitable Capacity for Cost Effectiveness Additions for Hybrid Power Plants[Hybrid Electricity Source\
		,Optimization Pass,RPS
	]
	    * CSCSoCECBiaSY Share of Cost Effective Capacity Built in a Single Year[Hybrid Electricity Source\
		]
	  ),
	  MPPC Minimum Power Plant Capacity[Hybrid Electricity Source]
	) ~~|
New Capacity Desired due to Cost Effectivness by Optimization Pass for Hybrid Power Plants\
		[Hybrid Electricity Source,Optimization Pass,CES]=
	QUANTUM(
	  MIN(
	    Max Capacity Buildable after Mandated and Required Clean Dispatchable Additions[\
		Hybrid Electricity Source]
	    - New Capacity Desired due to Cost Effectivness by Optimization Pass[Hybrid Electricity Source\
		,Optimization Pass,CES],
	
	    Profitable Capacity for Cost Effectiveness Additions for Hybrid Power Plants[Hybrid Electricity Source\
		,Optimization Pass,CES
	]
	    * CSCSoCECBiaSY Share of Cost Effective Capacity Built in a Single Year[Hybrid Electricity Source\
		]
	  ),
	  MPPC Minimum Power Plant Capacity[Hybrid Electricity Source]
	)
	~	MW
	~		|

New Capacity Desired due to Cost Effectivness for Hybrid Power Plants without CES[Electricity Source\
		] :EXCEPT:     [Hybrid Electricity Source
]=
	0 ~~|
New Capacity Desired due to Cost Effectivness for Hybrid Power Plants without CES[Hybrid Electricity Source\
		]=
	QUANTUM(MIN(
	  Max Capacity Buildable after Mandated and Required Clean Dispatchable Additions[Hybrid Electricity Source\
		]
	  - New Capacity Desired due to Cost Effectivness without CES[Hybrid Electricity Source\
		],
	
	  Profitable Capacity for Cost Effectiveness Additions for Hybrid Power Plants Without CES\
		[Hybrid Electricity Source]
	  * CSCSoCECBiaSY Share of Cost Effective Capacity Built in a Single Year[Hybrid Electricity Source\
		]
	),
	 MPPC Minimum Power Plant Capacity[Hybrid Electricity Source]
	)
	~	MW
	~		|

New Capacity Desired due to Cost Effectivness without CES[Electricity Source]=
	QUANTUM(
	  MIN(
	    Max Capacity Buildable after Mandated and Required Clean Dispatchable Additions[\
		Electricity Source],
	
	    Profitable Capacity for Cost Effectiveness Additions without CES[Electricity Source\
		]
	    * CSCSoCECBiaSY Share of Cost Effective Capacity Built in a Single Year[Electricity Source\
		]
	  ),
	 MPPC Minimum Power Plant Capacity[Electricity Source]
	)
	~	MW
	~		|

New Capacity Desired for Seasonal Clean Dispatchable Reliability by Optimization Pass\
		[Clean Dispatchable Electricity Source,Optimization Pass]=
	QUANTUM(
	  MAX(0,MIN(
	    Max Capacity Buildable after Mandated Additions[Clean Dispatchable Electricity Source\
		],
	
	    (
	      Profitable Capacity for Seasonal Dispatchable Clean Reliability Additions[Clean Dispatchable Electricity Source\
		,Optimization Pass]
	      * CSCSoCECBiaSY Share of Cost Effective Capacity Built in a Single Year[Clean Dispatchable Electricity Source\
		]
	    )
	
	  )
	  ),
	  MPPC Minimum Power Plant Capacity[Clean Dispatchable Electricity Source]
	)
	~	MW
	~		|

New Capacity Desired for Seasonal Dispatchable Reliability by Optimization Pass[Electricity Source\
		,Optimization Pass]=
	QUANTUM(
	  MAX(0,MIN(
	    Max Capacity Buildable after Cost Effective and RPS Additions[Electricity Source\
		,CES
	],
	
	    (
	      Profitable Capacity for Seasonal Dispatchable Reliability Additions[Electricity Source\
		,Optimization Pass
	]
	      * CSCSoCECBiaSY Share of Cost Effective Capacity Built in a Single Year[Electricity Source
	]
	    )
	    - Total New Capacity Desired due to Cost Effectiveness[Electricity Source,CES]
	    - New Dispatchable Only Clean Capacity Desired for Seasonal Reliability[Electricity Source\
		]
	  )
	  )
	   * IF THEN ELSE(
	       Five Year Foresight Elec Portfolio Values for Reliability Check[RPS]=1,
	       Elec Portfolio Qualifying Sources[Electricity Source,RPS],
	       IF THEN ELSE(
	         Five Year Foresight Elec Portfolio Values for Reliability Check[CES]=1,
	         Elec Portfolio Qualifying Sources[Electricity Source,CES],
	         1
	       )
	     ),
	  MPPC Minimum Power Plant Capacity[Electricity Source]
	)
	~	MW
	~		|

New Cargo Dist Transported[Vehicle Type,Cargo Type]=
	SUM(New Cargo Dist Transported Allocated by Last Year Vehicle Technologies[Vehicle Type\
		,Cargo Type,Vehicle Technology!])
	~	thing*miles
	~		|

New Cargo Dist Transported Allocated by Last Year Vehicle Technologies[Vehicle Type,Cargo Type\
		,Vehicle Technology]=
	Cargo Dist Transported Allocated by Last Year Vehicle Technologies[Vehicle Type,Cargo Type\
		,Vehicle Technology]
	* SoCDTtiNTY Share of Cargo Dist Transported that is New This Year[Vehicle Type,Cargo Type\
		,Vehicle Technology]
	~	thing*miles
	~		|

New Component Energy Use Shifted to Electricity[Building Type,Source Building Fuel,Building Component\
		] :EXCEPT: [Building Type,electricity bf,Building Component]=
	-Changes in New Components Energy Use due to Fuel Shifting[Building Type,Source Building Fuel\
		,Building Component]
	* RBFF Recipient Buildings Fuel Fractions[Source Building Fuel,electricity bf] ~~|
New Component Energy Use Shifted to Electricity[Building Type,electricity bf,Building Component\
		]=
	0
	~	BTU
	~		|

New Components Potential Energy Use after Envelope Effects[Building Type,Building Fuel\
		,heating]=
	New Components Potential Energy Use after Fuel Shifting[Building Type,Building Fuel,\
		heating]
	* New Components Potential Energy Use after Fuel Shifting[Building Type,Building Fuel\
		,envelope]
	* Envelope Multiplier Unit Correction Factor
	/ One Year ~~|
New Components Potential Energy Use after Envelope Effects[Building Type,Building Fuel\
		,cooling and ventilation]=
	New Components Potential Energy Use after Fuel Shifting[Building Type,Building Fuel,\
		cooling and ventilation]
	* New Components Potential Energy Use after Fuel Shifting[Building Type,Building Fuel\
		,envelope]
	* Envelope Multiplier Unit Correction Factor
	/ One Year ~~|
New Components Potential Energy Use after Envelope Effects[Building Type,Building Fuel\
		,envelope]=
	0 ~~|
New Components Potential Energy Use after Envelope Effects[Building Type,Building Fuel\
		,lighting]=
	New Components Potential Energy Use after Fuel Shifting[Building Type,Building Fuel,\
		lighting]
	/ One Year ~~|
New Components Potential Energy Use after Envelope Effects[Building Type,Building Fuel\
		,appliances]=
	New Components Potential Energy Use after Fuel Shifting[Building Type,Building Fuel,\
		appliances]
	/ One Year ~~|
New Components Potential Energy Use after Envelope Effects[Building Type,Building Fuel\
		,other component]=
	New Components Potential Energy Use after Fuel Shifting[Building Type,Building Fuel,\
		other component]
	/ One Year
	~	BTU/Year
	~		|

New Components Potential Energy Use after Envelope Effects after Lifetime[Building Type\
		,Building Fuel,Building Component]= DELAY FIXED (
	New Components Potential Energy Use after Envelope Effects[Building Type,Building Fuel\
		,Building Component],
	CL Component Lifetime[Building Type,Building Component],
	0)
	~	BTU/Year
	~		|

New Components Potential Energy Use after Fuel Shifting[Building Type,electricity bf,\
		Building Component] :EXCEPT: [Building Type,electricity bf,envelope]=
	{Remove fuel use in accordance with policy setting.}
	
	New Components Potential Energy Use after Price Efficiency Feedbacks[Building Type,electricity bf\
		,Building Component]
	* (1 - Fraction of New Bldg Components Shifted to Other Fuels This Year[Building Component\
		,Building Type])
	
	
	{Add all fuels shifting to electricity with an efficiency adjustment.}
	
	+ SUM(
	    New Components Potential Energy Use after Price Efficiency Feedbacks[Building Type\
		,Source Building Fuel!,Building Component]
	    * Fraction of New Bldg Components Shifted to Other Fuels This Year[Building Component\
		,Building Type]
	    * RBFF Recipient Buildings Fuel Fractions[Source Building Fuel!,electricity bf]
	  )
	  * (1 - PCFURfE Percentage Components Fuel Use Reduction for Electricity[Building Component\
		])
	
	
	{Electricity that was removed and returned as electricity (unchanged) shouldn't have an efficiency adjustment.
	This section adds back in the electricity that was removed due to the efficiency adjustment applied to electricity that remained electricity.}
	
	+ New Components Potential Energy Use after Price Efficiency Feedbacks[Building Type\
		,electricity bf,Building Component]
	  * Fraction of New Bldg Components Shifted to Other Fuels This Year[Building Component\
		,Building Type]
	  * RBFF Recipient Buildings Fuel Fractions[electricity bf,electricity bf]
	  * PCFURfE Percentage Components Fuel Use Reduction for Electricity[Building Component\
		] ~~|
New Components Potential Energy Use after Fuel Shifting[Building Type,Target Building Fuel\
		,Building Component] :EXCEPT: [Building Type,Target Building Fuel,envelope],[Building Type\
		,electricity bf,Building Component]=
	{Remove fuel use in accordance with policy setting.}
	
	New Components Potential Energy Use after Price Efficiency Feedbacks[Building Type,Target Building Fuel\
		,Building Component]
	* (1 - Fraction of New Bldg Components Shifted to Other Fuels This Year[Building Component\
		,Building Type])
	
	
	{Add all fuels without an efficiency adjustment.}
	
	+ SUM(
	    New Components Potential Energy Use after Price Efficiency Feedbacks[Building Type\
		,Source Building Fuel!,Building Component]
	    * Fraction of New Bldg Components Shifted to Other Fuels This Year[Building Component\
		,Building Type]
	    * RBFF Recipient Buildings Fuel Fractions[Source Building Fuel!,Target Building Fuel\
		]
	  )
	
	
	{Electricity that was shifted to a non-electricity fuel needs an efficiency adjustment.
	This section adds the extra fuel needed to provide similar useful work as electricity used to provide.}
	
	+ New Components Potential Energy Use after Price Efficiency Feedbacks[Building Type\
		,electricity bf,Building Component]
	  * Fraction of New Bldg Components Shifted to Other Fuels This Year[Building Component\
		,Building Type]
	  * RBFF Recipient Buildings Fuel Fractions[electricity bf,Target Building Fuel]
	  * (
	      1 / (1 - PCFURfE Percentage Components Fuel Use Reduction for Electricity[Building Component\
		])
	      - 1
	    ) ~~|
New Components Potential Energy Use after Fuel Shifting[Building Type,Target Building Fuel\
		,envelope]=
	New Components Potential Energy Use after Price Efficiency Feedbacks[Building Type,Target Building Fuel\
		,envelope]
	~	BTU
	~	These equations are complicated because we need to apply an efficiency \
		adjustment when fuels shift between electricity and a non-electricity \
		fuel.  We first remove all the fuels that are being shifted (including \
		some that may be staying the same), then we add in all the fuels \
		reallocated to their target fuel types.  When the target fuel is \
		electricity, we apply an efficiency adjustment to all of the added fuels, \
		and then we undo the adjustment for electricitiy that was "shifted" to \
		electricity (i.e. stayed the same).  When the target fuel is not \
		electricity, we add all of the fuels without an efficiency adjustment, and \
		then we add additional fuel to the target fuel if the source fuel was \
		electricity to make the efficiency adjustment.  If you are having trouble \
		understanding these equations, first make sure you understand the simpler \
		examples of fuel shifting code that don't involve electricity efficiency \
		adjustments, which can be found in the calculated variables immediately \
		downstream of the following two input variables: hydgn/RHPF and indst/RIFF.
	|

New Components Potential Energy Use after Labeling and Training[Building Type,Building Fuel\
		,Building Component]=
	"New Components Potential Energy Use after Standards and R&D"[Building Type,Building Fuel\
		,Building Component]
	* (1 - Percentage Eff Improvement due to Improved Labeling[Building Type,Building Component\
		])
	* (1 - Percentage Eff Improvement due to Contractor Edu and Training[Building Component\
		])
	~	BTU
	~		|

New Components Potential Energy Use after Price Efficiency Feedbacks[Building Type,Building Fuel\
		,Building Component] :EXCEPT:   [Building Type,
Building Fuel,envelope]=
	New Components Potential Energy Use after Quality Level Shifts[Building Type,Building Fuel\
		,Building Component]
	* (1 + Perc Change in New Component Energy Use due to Price Efficiency Feedbacks[Building Type\
		,Building Fuel,Building Component]) ~~|
New Components Potential Energy Use after Price Efficiency Feedbacks[Building Type,Building Fuel\
		,envelope]=
	New Components Potential Energy Use after Quality Level Shifts[Building Type,Building Fuel\
		,envelope]
	~	BTU
	~		|

New Components Potential Energy Use after Quality Level Shifts[Building Type,Building Fuel\
		,Building Component]=
	New Components Potential Energy Use after Labeling and Training[Building Type,Building Fuel\
		,Building Component]
	* (1 + Perc Change in Energy Use Due to Quality Level Shifting[Building Type,Building Component\
		])
	~	BTU
	~		|

"New Components Potential Energy Use after Standards and R&D"[Building Type,Building Fuel\
		,Building Component]=
	MAX(
	  0,
	
	  BAU New Components Energy Use[Building Type,Building Fuel,Building Component]
	  * (1 - Reduction in E Use Allowed by Component Eff Std This Year[Building Component\
		,Building Type])
	  * (1 - RnD Building Fuel Use Perc Reduction This Year[Building Component])
	)
	~	BTU
	~		|

New Dispatchable Only Capacity Desired for Seasonal Reliability[Electricity Source]=
	VMAX(New Capacity Desired for Seasonal Dispatchable Reliability by Optimization Pass\
		[Electricity Source,last pass!])
	~	MW
	~		|

New Dispatchable Only Clean Capacity Desired for Seasonal Reliability[Electricity Source\
		] :EXCEPT:        [Clean Dispatchable Electricity Source
]=
	0 ~~|
New Dispatchable Only Clean Capacity Desired for Seasonal Reliability[Clean Dispatchable Electricity Source\
		]=
	SUM(New Capacity Desired for Seasonal Clean Dispatchable Reliability by Optimization Pass\
		[Clean Dispatchable Electricity Source,last pass!])
	~	MW
	~		|

New EV Chargers This Year=
	This Year Number of EV Chargers
	- Last Year Number of EV Chargers
	~	chargers
	~		|

New Generation Capacity after Dispatchable Only Reliability Additions[Electricity Source\
		]=
	New Generation Capacity before Reliability Additions[Electricity Source]
	+New Dispatchable Only Capacity Desired for Seasonal Reliability[Electricity Source]
	~	MW
	~		|

New Generation Capacity before Cost Effectiveness Additions[Electricity Source]=
	New Policy Mandated Capacity[Electricity Source]
	+New Dispatchable Only Clean Capacity Desired for Seasonal Reliability[Electricity Source\
		]
	~	MW
	~		|

New Generation Capacity before Reliability Additions[Electricity Source]=
	New Generation Capacity before Cost Effectiveness Additions[Electricity Source]
	+Total New Capacity Desired due to Cost Effectiveness[Electricity Source,CES]
	~	MW
	~		|

New Generation Capacity Excluding Retrofit Capacity[Electricity Source]=
	New Generation Capacity after Dispatchable Only Reliability Additions[Electricity Source\
		]
	~	MW
	~		|

New Green Hydrogen Production Capacity This Year=
	MAX( 
	  0,
	  Green Hydrogen Demand
	  - Surviving Green Hydrogen Production Capacity
	)
	~	BTU
	~		|

New Grid Battery Capacity=
	New Grid Battery Capacity Deployed before Capacity Market Revenue
	+SUM(New Grid Battery Capacity Deployed for Seasonal Dispatchable Reliability by Optimization Pass\
		[last pass!])
	~	MW*hour
	~		|

New Grid Battery Capacity Deployed before Capacity Market Revenue=
	MAX(
	 GBCGpUNR Grid Battery Capacity Growth per Unit Net Revenue*Grid Batteries Net Energy Market Revenue per Unit Elec Output
	,
	 0
	)
	~	MW*hr
	~		|

New Grid Battery Capacity Deployed for Seasonal Dispatchable Reliability by Optimization Pass\
		[Optimization Pass]=
	MAX(
	 GBCGpUNR Grid Battery Capacity Growth per Unit Net Revenue*
	 (Grid Batteries Net Energy Market Revenue per Unit Elec Output
	  +Grid Batteries Capacity Market Revenue for Seasonal Dispatchable Reliability per Unit Elec Output\
		[Optimization Pass]
	)
	,
	 0
	)
	-New Grid Battery Capacity Deployed before Capacity Market Revenue
	~	MW*hr
	~		|

New Hybrid Grid Battery Storage Capacity[Electricity Source]=
	New Capacity Desired due to Cost Effectivness by Optimization Pass for Hybrid Power Plants\
		[Electricity Source,pass20,CES]
	   *HESBCpUEC Hybrid Electricity Source Battery Capacity per Unit Electricity Capacity
	   *GBSC Diurnal Grid Battery Daily Storage Duration
	~	MW*hour
	~		|

New Hydrogen Production Capacity[Hydrogen Production Pathway] :EXCEPT:  [electrolysis with guaranteed clean electricity\
		]=
	(New Low Carbon Hydrogen Production Capacity This Year[Hydrogen Production Pathway]
	+ New Other Hydrogen Production Capacity This Year[Hydrogen Production Pathway])
	/ One Year ~~|
New Hydrogen Production Capacity[electrolysis with guaranteed clean electricity]=
	(New Green Hydrogen Production Capacity This Year
	+ New Low Carbon Hydrogen Production Capacity This Year[electrolysis with guaranteed clean electricity\
		]
	+ New Other Hydrogen Production Capacity This Year[electrolysis with guaranteed clean electricity\
		])
	/ One Year
	~	BTU/Year
	~		|

New Indst Eqpt Energy Intensity Multiplier due to Changes in Fuel Costs[Industry Category\
		,Industrial Fuel]=
	1 + 
	
	Percent Change in Industrial Fuel Cost per Unit Energy[Industry Category,Industrial Fuel\
		]
	* EoIEECwEC Elasticity of Industrial Equipment Energy Consumption wrt Energy Cost
	~	Dmnl
	~		|

New Indst Eqpt Energy Intensity Multiplier due to Efficiency Adjustments[Industry Category\
		,Industrial Fuel,Industrial Process]=
	IF THEN ELSE(
	  New Industrial Equipment Energy Intensity Multiplier from Efficiency Stds[Industry Category\
		,Industrial Fuel,Industrial Process] < 1,
	
	  MIN(
	    New Indst Eqpt Energy Intensity Multiplier due to Changes in Fuel Costs[Industry Category\
		,Industrial Fuel],
	    New Industrial Equipment Energy Intensity Multiplier from Efficiency Stds[Industry Category\
		,Industrial Fuel,Industrial Process]
	  ),
	
	  New Indst Eqpt Energy Intensity Multiplier due to Changes in Fuel Costs[Industry Category\
		,Industrial Fuel]
	  * New Industrial Equipment Energy Intensity Multiplier from Efficiency Stds[Industry Category\
		,Industrial Fuel,Industrial Process]
	)
	~	Dmnl
	~		|

New Industrial Equipment Capital Cost[Industry Category]=
	SUM(
	  New Industrial Equipment Potential Energy Use by Fuel Type and Process[Industry Category\
		,Industrial Fuel!,Industrial Process
	!]
	  * Industrial Equipment Capital Cost per Unit Energy Before Clean Heat Subsidy[Industry Category\
		,Industrial Fuel!,Industrial Process!]
	)
	~	$
	~		|

New Industrial Equipment Energy Intensity[Industry Category,Industrial Fuel,Industrial Process\
		]=
	MAX(
	
	 BAU New Industrial Equipment Energy Intensity[Industry Category,Industrial Fuel,Industrial Process\
		]
	 * New Indst Eqpt Energy Intensity Multiplier due to Efficiency Adjustments[Industry Category\
		,Industrial Fuel,Industrial Process],
	
	 IEMUEF Industrial Equipment Minimum Unit Energy Factor[Industrial Fuel,Industrial Process\
		]
	)
	~	Dmnl
	~		|

New Industrial Equipment Energy Intensity in Electricity Equivalent[Industry Category\
		,Industrial Fuel,Industrial Process]=
	New Industrial Equipment Energy Intensity[Industry Category,Industrial Fuel,Industrial Process\
		]
	* (1 - PIFURfE Percentage Industry Fuel Use Reduction for Electricity[Industry Category\
		,Industrial Process])
	~	Dmnl
	~		|

New Industrial Equipment Energy Intensity Multiplier from Efficiency Stds[Industry Category\
		,Industrial Fuel,Industrial Process] :EXCEPT:  
[Industry Category,electricity if,Industrial Process]=
	ZIDZ(
	 1,
	 1 + Perc Improvement in Eqpt Efficiency Stds Above BAU for Combustible Fuels This Year\
		[Industry Category,Industrial Process
	]
	) ~~|
New Industrial Equipment Energy Intensity Multiplier from Efficiency Stds[Industry Category\
		,electricity if,Industrial Process]=
	ZIDZ(
	 1,
	 1 + Perc Improvement in Eqpt Efficiency Stds Above BAU for Electricity This Year[Industry Category\
		,Industrial Process]
	)
	~	Dmnl
	~		|

New Industrial Equipment Energy Use by Fuel Type and Process before Process Improvements\
		[Industry Category,Industrial Fuel,Industrial Process] :EXCEPT:  [Industry Category\
		,Industrial Fuel,industrial heating process]=
	New Industrial Equipment Energy Use by Fuel Type and Process before Waste Heat Recovery\
		[Industry Category,Industrial Fuel,Industrial Process] ~~|
New Industrial Equipment Energy Use by Fuel Type and Process before Process Improvements\
		[Industry Category,Industrial Fuel,industrial heating process]=
	New Industrial Equipment Energy Use by Fuel Type and Process before Waste Heat Recovery\
		[Industry Category,Industrial Fuel,industrial heating process]
	* (1 - This Year Reduction in Industrial Energy Consumption for Heat Generation due to Waste Heat Recovery\
		[Industry Category])
	~	BTU
	~		|

New Industrial Equipment Energy Use by Fuel Type and Process before Waste Heat Recovery\
		[Industry Category,Industrial Fuel
,Industrial Process] :EXCEPT:             [Industry Category,electricity if,Industrial Process\
		]=
	ZIDZ(
	  Output from New Industrial Equipment[Industry Category,Industrial Process]
	  * Share of New Industrial Equipment by Fuel Type and Process in Electricity Equivalent\
		[Industry Category,Industrial Fuel,Industrial Process]
	  * Energy Intensity of Industrial Production by Fuel for New Equipment in Electricity Equivalent\
		[Industry Category,Industrial Fuel],
	  1 - PIFURfE Percentage Industry Fuel Use Reduction for Electricity[Industry Category\
		,Industrial Process]
	) ~~|
New Industrial Equipment Energy Use by Fuel Type and Process before Waste Heat Recovery\
		[Industry Category,electricity if
,Industrial Process]=
	Output from New Industrial Equipment[Industry Category,Industrial Process]
	* Share of New Industrial Equipment by Fuel Type and Process in Electricity Equivalent\
		[Industry Category,electricity if,Industrial Process]
	* Energy Intensity of Industrial Production by Fuel for New Equipment in Electricity Equivalent\
		[Industry Category,electricity if]
	~	BTU
	~	"Industrial Equipment Fuel Type Shares in Electricity Equivalent by \
		Vintage" add to 1 for each industry category, so that variable is \
		expecting to be multiplied by total output of each industry category.
	|

New Industrial Equipment Fuel Use for Energy before CCS and Methane Capture[Industrial Fuel\
		,Industry Category]=
	SUM(New Industrial Equipment Energy Use by Fuel Type and Process before Process Improvements\
		[Industry Category,Industrial Fuel,Industrial Process!])
	* This Year Industrial Energy Use Reduction Due to Process Improvements[Industry Category\
		,Industrial Fuel]
	~	BTU
	~		|

New Industrial Equipment Potential Energy Use by Fuel Type and Process[Industry Category\
		,Industrial Fuel,Industrial Process] :EXCEPT:  [Industry Category,electricity if,Industrial Process\
		]=
	New Industrial Equipment Potential Energy Use by Fuel Type and Process in Electricity Equivalent\
		[Industry Category,Industrial Fuel,Industrial Process]
	/ (1 - PIFURfE Percentage Industry Fuel Use Reduction for Electricity[Industry Category\
		,Industrial Process]) ~~|
New Industrial Equipment Potential Energy Use by Fuel Type and Process[Industry Category\
		,electricity if,Industrial Process]=
	New Industrial Equipment Potential Energy Use by Fuel Type and Process in Electricity Equivalent\
		[Industry Category,electricity if,Industrial Process]
	~	BTU
	~		|

New Industrial Equipment Potential Energy Use by Fuel Type and Process in Electricity Equivalent\
		[Industry Category,Industrial Fuel
,Industrial Process]=
	Output from New Industrial Equipment by Fuel Type and Industrial Process[Industry Category\
		,Industrial Fuel,Industrial Process
	]
	* Energy Intensity of Industrial Production by Fuel for New Equipment in Electricity Equivalent\
		[Industry Category,Industrial Fuel]
	~	BTU
	~		|

New Low Carbon Hydrogen Production Capacity Shares This Year[Hydrogen Production Pathway\
		]=
	ZIDZ(
	  HPS Hydrogen Production Shareweights[Hydrogen Production Pathway]
	  * exp(MAX(10^-8, Cost per Unit New Hydrogen Production[Hydrogen Production Pathway\
		] / One Dollar * One BTU)*10^4
	  * HPLC Hydrogen Production Logit Coefficient)
	  * Hydrogen Production Pathways Qualifying as Low Carbon[Hydrogen Production Pathway\
		]
	
	  ,
	
	  SUM(
	    HPS Hydrogen Production Shareweights[Hydrogen Production Pathway!]
	    * exp(MAX(10^-8, Cost per Unit New Hydrogen Production[Hydrogen Production Pathway\
		!] / One Dollar * One BTU)*10^4
	    * HPLC Hydrogen Production Logit Coefficient)
	    * Hydrogen Production Pathways Qualifying as Low Carbon[Hydrogen Production Pathway\
		!]
	  )
	)
	~	Dmnl
	~		|

New Low Carbon Hydrogen Production Capacity This Year[Hydrogen Production Pathway]=
	New Low Carbon Hydrogen Production Capacity Shares This Year[Hydrogen Production Pathway\
		]
	* Total New Low Carbon Hydrogen Production Capacity This Year
	~	BTU
	~		|

New Off Grid Capacity for Green Hydrogen Demand[Electricity Source]=
	QUANTUM(
	  ZIDZ(
	    Off Grid Electricity Demand for Green Hydrogen That is New This Year by Power Plant Type\
		[Electricity Source],
	    Expected Capacity Factor x Hours per Year for Plants Built This Year Without Hypothetical Calculations\
		[Electricity Source]
	  ),
	
	  MPPC Minimum Power Plant Capacity[Electricity Source]
	)
	~	MW
	~		|

New Other Hydrogen Production Capacity Shares This Year[Hydrogen Production Pathway]=
	ZIDZ(
	  HPS Hydrogen Production Shareweights[Hydrogen Production Pathway]
	  * exp(MAX(10^-8, Cost per Unit New Hydrogen Production[Hydrogen Production Pathway\
		] / One Dollar * One BTU)*10^4
	  * HPLC Hydrogen Production Logit Coefficient)
	
	  ,
	
	  SUM(
	    HPS Hydrogen Production Shareweights[Hydrogen Production Pathway!]
	    * exp(MAX(10^-8, Cost per Unit New Hydrogen Production[Hydrogen Production Pathway\
		!] / One Dollar * One BTU)*10^4
	    * HPLC Hydrogen Production Logit Coefficient)
	  )
	)
	~	Dmnl
	~		|

New Other Hydrogen Production Capacity This Year[Hydrogen Production Pathway]=
	New Other Hydrogen Production Capacity Shares This Year[Hydrogen Production Pathway]
	* Total New Other Hydrogen Production Capacity This Year
	~	BTU
	~		|

New Policy Mandated Capacity[Electricity Source]=
	IF THEN ELSE(
	    Boolean Use Non BAU Mandated Capacity Construction Schedule[Electricity Source] \
		> 0,
	
	    PMCCS Policy Mandated Capacity Construction Schedule[Electricity Source],
	
	    BPMCCS BAU Policy Mandated Capacity Construction Schedule[Electricity Source]
	  )
	~	MW
	~		|

New Policy Mandated Retrofits[Electricity Source] :EXCEPT: [CCUS Electricity Source]=
	0 ~~|
New Policy Mandated Retrofits[CCUS Electricity Source]=
	MIN(
	  Max Capacity Available for CCUS Retrofit[CCUS Electricity Source],
	
	  IF THEN ELSE(
	    Boolean Use Non BAU Mandated Capacity Retrofit Schedule[CCUS Electricity Source]\
		 > 0,
	
	    PMCRS Policy Mandated Capacity Retrofit Schedule[CCUS Electricity Source],
	
	    BPMCRS BAU Policy Mandated Capacity Retrofit Schedule[CCUS Electricity Source]
	  )
	)
	~	MW
	~		|

New Solar Capacity Needed to Meet Capacity Requirement This Year=
	MAX(0,
	    Min Allowed Distributed Solar Capacity-
	    SUM(Distributed Solar Capacity Before Capacity Requirement This Year[Building Type\
		!])
	)
	~	MW
	~		|

New Vehicle CO2 Emissions Intensity by Vehicle Technology[Vehicle Type,Cargo Type,Vehicle Technology\
		]=
	ZIDZ(
	  Transportation CO2 Emissions Intensities Weighted by Fuel Type Consumption[Vehicle Type\
		,Cargo Type,Vehicle Technology],
	  New Vehicle Fuel Economy[Vehicle Type,Cargo Type,Vehicle Technology]
	)
	* AVLo Average Vehicle Loading[Vehicle Type,Cargo Type]
	~	g pollutant/mile
	~		|

New Vehicle CO2 Emissions Intensity by Vehicle Type[Vehicle Type,Cargo Type]=
	SUM(
	
	  New Vehicle CO2 Emissions Intensity by Vehicle Technology[Vehicle Type,Cargo Type,\
		Vehicle Technology!]
	
	  * Percent Vehicle Sales by Vehicle Technology[Vehicle Type,Cargo Type,Vehicle Technology\
		!]
	
	)
	~	g pollutant/mile
	~		~	:SUPPLEMENTARY 
	|

New Vehicle Distance Traveled[Vehicle Type,Cargo Type]=
	ZIDZ(
	  New Cargo Dist Transported[Vehicle Type,Cargo Type],
	  AVLo Average Vehicle Loading[Vehicle Type,Cargo Type]
	)
	~	miles
	~		|

New Vehicle Fuel Cost per Unit Cargo Dist[Vehicle Type,Cargo Type,Vehicle Technology]\
		=
	ZIDZ(
	  Weighted Avg Fuel Cost per Unit Energy by Vehicle Technology[Vehicle Type,Cargo Type\
		,Vehicle Technology],
	  New Vehicle Fuel Economy[Vehicle Type,Cargo Type,Vehicle Technology]
	)
	~	$/(thing*mile)
	~		|

New Vehicle Fuel Cost per Unit Vehicle Distance[Vehicle Type,Cargo Type,Vehicle Technology\
		]=
	New Vehicle Fuel Cost per Unit Cargo Dist[Vehicle Type,Cargo Type,Vehicle Technology\
		]
	* AVLo Average Vehicle Loading[Vehicle Type,Cargo Type]
	~	$/mile
	~		|

New Vehicle Fuel Economy[Vehicle Type,Cargo Type,Vehicle Technology]=
	New Vehicle Fuel Economy after Standards[Vehicle Type,Cargo Type,Vehicle Technology]
	* (1 + RnD Transportation Fuel Use Perc Reduction This Year[Vehicle Technology])
	~	thing*miles/BTU
	~		|

New Vehicle Fuel Economy after Feebate[Vehicle Type,Cargo Type,Vehicle Technology] :EXCEPT:\
		 [LDVs,passenger,Vehicle Technology]=
	New Vehicle Fuel Economy after Fuel Price Effects[Vehicle Type,Cargo Type,Vehicle Technology\
		] ~~|
New Vehicle Fuel Economy after Feebate[LDVs,passenger,Vehicle Technology] :EXCEPT: [LDVs\
		,passenger,battery electric vehicle]=
	New Vehicle Fuel Economy after Fuel Price Effects[LDVs,passenger,Vehicle Technology]
	* (1 + Perc Change in New LDV Fuel Economy due to Feebate) ~~|
New Vehicle Fuel Economy after Feebate[LDVs,passenger,battery electric vehicle]=
	New Vehicle Fuel Economy after Fuel Price Effects[LDVs,passenger,battery electric vehicle\
		]
	~	thing*miles/BTU
	~		|

New Vehicle Fuel Economy after Fuel Price Effects[Vehicle Type,Cargo Type,Vehicle Technology\
		]=
	BNVFE BAU New Vehicle Fuel Economy[Vehicle Type,Cargo Type,Vehicle Technology]
	* (1 + Perc Change in Fuel Economy due to Fuel Price Effects Weighted by Fuel Type[Vehicle Type\
		,Vehicle Technology])
	~	thing*miles/BTU
	~		|

New Vehicle Fuel Economy After Lifetime[Vehicle Type,Cargo Type,Vehicle Technology]= \
		DELAY FIXED (
	New Vehicle Fuel Economy[Vehicle Type,Cargo Type,Vehicle Technology],
	AVL Avg Vehicle Lifetime[Cargo Type,Vehicle Type],
	0)
	~	thing*miles/BTU
	~		|

New Vehicle Fuel Economy after Standards[Vehicle Type,Cargo Type,Vehicle Technology]=
	New Vehicle Fuel Economy after Feebate[Vehicle Type,Cargo Type,Vehicle Technology]
	* (1 + Percentage Additional Improvement of Fuel Economy Std This Year[Cargo Type,Vehicle Type\
		])
	  ^VTStFES Vehicle Technologies Subject to Fuel Economy Standard[Vehicle Type,Vehicle Technology\
		]
	~	thing*miles/BTU
	~		|

New Vehicle Price[Vehicle Type,Cargo Type,Vehicle Technology]=
	MAX(
	  New Vehicle Price after RnD[Vehicle Type,Cargo Type,Vehicle Technology]
	   - Vehicle Subsidy[Cargo Type,Vehicle Type,Vehicle Technology],
	
	  0
	)
	~	$/vehicle
	~		|

New Vehicle Price after Endogenous Vehicle Learning[Vehicle Type,Cargo Type,Vehicle Technology\
		]=
	This Year Battery Portion of Vehicle Price[Cargo Type,Vehicle Type,Vehicle Technology\
		]
	  + NBPoNVP Non Battery Portion of New Vehicle Price[Vehicle Type,Cargo Type,Vehicle Technology\
		]
	~	$/vehicle
	~		|

New Vehicle Price after Fuel Economy Effects[Vehicle Type,Cargo Type,Vehicle Technology\
		]=
	New Vehicle Price after Endogenous Vehicle Learning[Vehicle Type,Cargo Type,Vehicle Technology\
		]
	* (1 +
	     Perc Change in New Vehicle Fuel Economy[Vehicle Type,Cargo Type,Vehicle Technology\
		]
	     * EoVPwFE Elasticity of Vehicle Price wrt Fuel Economy
	  )
	~	$/vehicle
	~		|

New Vehicle Price after RnD[Vehicle Type,Cargo Type,Vehicle Technology]=
	New Vehicle Price after Fuel Economy Effects[Vehicle Type,Cargo Type,Vehicle Technology\
		]
	* (1 - RnD Transportation Capital Cost Perc Reduction This Year[Vehicle Technology])
	~	$/vehicle
	~		|

New Vehicle Price after RnD Without Subsidies[Cargo Type,Vehicle Type,Vehicle Technology\
		]=
	New Vehicle Price after RnD[Vehicle Type,Cargo Type,Vehicle Technology]
	+ This Year Battery Subsidy Passed Through to Consumers by Vehicle Type[Cargo Type,Vehicle Type\
		,Vehicle Technology]
	~	$/vehicle
	~		|

New Vehicle Price Including EV Shadow Costs[Vehicle Type,Cargo Type,Vehicle Technology\
		] :EXCEPT:   [LDVs,passenger,battery electric vehicle
]=
	New Vehicle Price[Vehicle Type,Cargo Type,Vehicle Technology] ~~|
New Vehicle Price Including EV Shadow Costs[LDVs,passenger,battery electric vehicle]=
	New Vehicle Price[LDVs,passenger,battery electric vehicle]
	+ Range Anxiety Shadow Cost
	+ Charging Availability Shadow Cost
	~	$/vehicle
	~		|

New Vehicles[Vehicle Type,Cargo Type,Vehicle Technology]=
	QUANTUM(
	  SUM(New Vehicles by Subregion[Subregion!,Vehicle Type,Cargo Type,Vehicle Technology\
		]),
	  QSfV Quantization Size for Vehicles[Vehicle Type,Cargo Type]
	)
	/ One Year
	~	vehicles/Year
	~	If the model wishes to add fewer than +/- VQS vehicles, this is rounding \
		error, and we dampen it to zero.  If we do not, it can throw off the Fleet \
		Average Fuel Economy if the erroneously introduced vehicle (or negative \
		vehicle) is the only vehicle of its type and technology in the model.
	|

New Vehicles After Lifetime[Vehicle Type,Cargo Type,Vehicle Technology]= DELAY FIXED \
		(
	New Vehicles[Vehicle Type,Cargo Type,Vehicle Technology],
	AVL Avg Vehicle Lifetime[Cargo Type,Vehicle Type],
	0)
	~	vehicles/Year
	~		|

New Vehicles Allocated before ZEV Standards[Vehicle Type,Cargo Type,Vehicle Technology\
		]=
	(
	  TTS Transportation Technology Shareweights[Vehicle Type,Cargo Type,Vehicle Technology\
		]
	  * exp(MAX(1, NPV of Lifetime Vehicle Cost[Vehicle Type,Cargo Type,Vehicle Technology\
		]* Vehicle Allocation Unit Correction)/1e+06*TTLE Transportation Technology Logit Exponents\
		[Vehicle Type,Cargo Type])
	)
	/
	(
	  SUM(TTS Transportation Technology Shareweights[Vehicle Type,Cargo Type,Vehicle Technology\
		!]
	  * exp(MAX(1, NPV of Lifetime Vehicle Cost[Vehicle Type,Cargo Type,Vehicle Technology\
		!]* Vehicle Allocation Unit Correction)/1e+06*TTLE Transportation Technology Logit Exponents\
		[Vehicle Type,Cargo Type])
	  )
	)
	* New Vehicles Demanded[Vehicle Type,Cargo Type]
	~	vehicles
	~	Using "Unmodified Logit" function as described at \
		https://jgcri.github.io/gcam-doc/choice.html
	|

New Vehicles before ZEV Standards by Subregion[Subregion,Vehicle Type,Cargo Type,Vehicle Technology\
		]=
	New Vehicles Allocated before ZEV Standards[Vehicle Type,Cargo Type,Vehicle Technology\
		]
	* VSbS Vehicle Shares by Subregion[Subregion,Vehicle Type,Cargo Type]
	~	vehicles
	~		|

New Vehicles by Subregion[Subregion,Vehicle Type,Cargo Type,Vehicle Technology]=
	New Vehicles by Subregion for Vehicle Types without BAU Qualifying Technologies[Subregion\
		,Vehicle Type,Cargo Type,Vehicle Technology]
	+ New Vehicles by Subregion for Vehicle Types with BAU Qualifying Technologies[Subregion\
		,Vehicle Type,Cargo Type,Vehicle Technology]
	~	vehicles
	~		|

New Vehicles by Subregion for Vehicle Types with BAU Qualifying Technologies[Subregion\
		,Vehicle Type,Cargo Type,Vehicle Technology]=
	IF THEN ELSE(Sum of Shareweights by Vehicle and Cargo Type[Vehicle Type,Cargo Type] \
		= 0,
	
	0,
	
	IF THEN ELSE(
	
	  ZEV Sales Share Without ZEV Standard[Subregion,Vehicle Type,Cargo Type]
	  > ZEV Standard by Subregion[Subregion,Vehicle Type,Cargo Type],
	
	
	  New Vehicles before ZEV Standards by Subregion[Subregion,Vehicle Type,Cargo Type,Vehicle Technology\
		],
	
	
	  New Vehicles before ZEV Standards by Subregion[Subregion,Vehicle Type,Cargo Type,Vehicle Technology\
		]
	    * Vehicle Technologies Qualifying as ZEVs[Vehicle Type,Vehicle Technology]
	    * ZIDZ(
	        ZEV Standard by Subregion[Subregion,Vehicle Type,Cargo Type],
	        ZEV Sales Share Without ZEV Standard[Subregion,Vehicle Type,Cargo Type]
	      )
	  + New Vehicles before ZEV Standards by Subregion[Subregion,Vehicle Type,Cargo Type\
		,Vehicle Technology]
	    * (1 - Vehicle Technologies Qualifying as ZEVs[Vehicle Type,Vehicle Technology])
	    * ZIDZ(
	        (1 - ZEV Standard by Subregion[Subregion,Vehicle Type,Cargo Type]),
	        (1 - ZEV Sales Share Without ZEV Standard[Subregion,Vehicle Type,Cargo Type]\
		)
	      )
	)
	)
	~	vehicles
	~	If the ZEV standard is met naturally, we keep the pre-ZEV standard \
		allocation. Otherwise, we scale up ZEVs sales such that the standard is \
		hit and scale down non-ZEV sales so as to avoid changing the total number \
		of vehicles sold.
	|

New Vehicles by Subregion for Vehicle Types without BAU Qualifying Technologies[Subregion\
		,Vehicle Type,Cargo Type,Vehicle Technology]=
	IF THEN ELSE(Sum of Shareweights by Vehicle and Cargo Type[Vehicle Type,Cargo Type] \
		= 0,
	
	
	IF THEN ELSE(
	  
	  ZEV Sales Share Without ZEV Standard[Subregion,Vehicle Type,Cargo Type]
	  > ZEV Standard by Subregion[Subregion,Vehicle Type,Cargo Type],
	
	
	  New Vehicles before ZEV Standards by Subregion[Subregion,Vehicle Type,Cargo Type,Vehicle Technology\
		],
	
	
	  (New Vehicles before ZEV Standards by Subregion[Subregion,Vehicle Type,Cargo Type,\
		Vehicle Technology]
	  * (1 - ZEV Standard by Subregion[Subregion,Vehicle Type,Cargo Type]))
	
	  + 
	
	  SUM(New Vehicles before ZEV Standards by Subregion[Subregion,Vehicle Type,Cargo Type\
		,Vehicle Technology!])
	  * ZEV Standard by Subregion[Subregion,Vehicle Type,Cargo Type]
	  * 
	
	  ((Vehicle Technologies Qualifying as ZEVs[Vehicle Type,Vehicle Technology]
	  * exp(MAX(1, NPV of Lifetime Vehicle Cost[Vehicle Type,Cargo Type,Vehicle Technology\
		]* Vehicle Allocation Unit Correction
	)/1e+06*TTLE Transportation Technology Logit Exponents[Vehicle Type,Cargo Type])
	)
	/
	(
	  SUM(Vehicle Technologies Qualifying as ZEVs[Vehicle Type,Vehicle Technology!]
	  * exp(MAX(1, NPV of Lifetime Vehicle Cost[Vehicle Type,Cargo Type,Vehicle Technology\
		!]* Vehicle Allocation Unit Correction
	)/1e+06*TTLE Transportation Technology Logit Exponents[Vehicle Type,Cargo Type])
	  )
	))
	
	
	)
	
	,0)
	~	vehicles
	~		|

New Vehicles Contribution to Percentage Change to Fleet Avg Fuel Economy[Vehicle Type\
		,Cargo Type,Vehicle Technology]=
	Percentage of Vehicle Stock New This Year[Vehicle Type,Cargo Type,Vehicle Technology\
		]
	* Percentage Difference in New Vehicle vs Fleet Avg Fuel Economy[Vehicle Type,Cargo Type\
		,Vehicle Technology]
	~	Dmnl
	~		|

New Vehicles Demanded[Vehicle Type,Cargo Type]=
	INTEGER(
	 ZIDZ(
	  New Vehicle Distance Traveled[Vehicle Type,Cargo Type],
	
	  Average Annual Dist Traveled by Vehicle Type Weighted by Technology[Vehicle Type,Cargo Type\
		]
	 )
	 +0.999999
	)
	~	vehicles
	~		|

New Vehicles Last Year[Vehicle Type,Cargo Type,Vehicle Technology]= DELAY FIXED (
	New Vehicles[Vehicle Type,Cargo Type,Vehicle Technology],
	1,
	0)
	~	vehicles/Year
	~		|

New Waste Heat Recovery Equipment Capital Expenditures[Industry Category]=
