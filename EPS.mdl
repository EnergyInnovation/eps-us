Excess Changes in Fuel Use Assigned to Imports[All Fuels]=
	Changes in Fuel Use Exceeding Both Caps[All Fuels]
	* ZIDZ(
	    Fuel Import Cap[All Fuels],
	
	    Fuel Production Cap[All Fuels]
	    + Fuel Import Cap[All Fuels]
	  )
	~	BTU
	~		|

Excess Changes in Fuel Use Assigned to Production[All Fuels]=
	Changes in Fuel Use Exceeding Both Caps[All Fuels]
	* ZIDZ(
	    Fuel Production Cap[All Fuels],
	
	    Fuel Production Cap[All Fuels]
	    + Fuel Import Cap[All Fuels]
	  )
	~	BTU
	~		|

Excess Electricity vs Daily Average by Hour after Seasonal Net Peak Load Reduction[Electricity Timeslice\
		,Hour]=
	MAX(
	  0,
	
	  Spare Potential Output from Surviving Capacity by Hour after Seasonal Net Peak Load Reduction\
		[Electricity Timeslice,Hour]
	  - Daily Average Hourly Spare Potential Output from Surviving Capacity[Electricity Timeslice\
		]
	)
	~	MW*hr
	~		|

Excess Potential Output from Surviving Capacity vs Annual Average by Hour[Electricity Timeslice\
		,Hour]=
	MAX(
	  0,
	
	  Spare Potential Output from Surviving Capacity by Hour[Electricity Timeslice,Hour]
	  - Annual Average Hourly Spare Potential Output from Surviving Capacity
	)
	~	MW*hr
	~		|

Exogenous GDP Growth Rate Adjustment=
	EGGRA Exogenous GDP Growth Rate Adjustment
	* EGGRA Boolean Use Exogenous GDP Growth Rate Adjustment This Year
	~	Dmnl
	~		|

Expected Achievable Annual CES by Optimization Pass[Optimization Pass]=
	SUM(
	  MIN(
	    Expected Hourly Output from CES Qualifying Resources Irrespective of Electricity Demand\
		[Electricity Timeslice!,Hour
	!,Optimization Pass],
	  Total Qualifying CES Electricity Demand by Hour After Demand Altering Technologies\
		[Electricity Timeslice!,Hour!])
	  * SHELF Days per Electricity Timeslice[Electricity Timeslice!]
	)
	/ SUM(
	    Total Qualifying CES Electricity Demand by Hour After Demand Altering Technologies\
		[Electricity Timeslice!,Hour!]
	    * SHELF Days per Electricity Timeslice[Electricity Timeslice!]
	  )
	~	Dmnl
	~		|

Expected Achievable Annual RPS by Optimization Pass[Optimization Pass]=
	SUM(
	  MIN(
	    Expected Hourly Output from RPS Qualifying Resources Irrespective of Electricity Demand\
		[Electricity Timeslice!,Hour
	!,Optimization Pass],
	  Total Qualifying RPS Electricity Demand by Hour After Demand Altering Technologies\
		[Electricity Timeslice!,Hour!])
	  * SHELF Days per Electricity Timeslice[Electricity Timeslice!]
	)
	/ SUM(
	    Total Qualifying RPS Electricity Demand by Hour After Demand Altering Technologies\
		[Electricity Timeslice!,Hour!]
	    * SHELF Days per Electricity Timeslice[Electricity Timeslice!]
	  )
	~	Dmnl
	~		|

Expected Capacity After Guaranteed Dispatch[Electricity Source,Electricity Timeslice,\
		Hour]=
	MAX(0,
	  Expected Capacity by Hour[Electricity Source,Electricity Timeslice,Hour]
	  -Electricity Dispatched by Guaranteed Dispatch by Hour[Electricity Source,Electricity Timeslice\
		,Hour]/One Hour
	 )
	~	MW
	~		|

Expected Capacity by Hour[Electricity Source, Electricity Timeslice, Hour]=
	Electricity Generation Capacity[Electricity Source]
	*Weighted Average Expected Capacity Factors by Hour Without Hypothetical Adjustments\
		[Electricity Source,Electricity Timeslice,Hour]
	* (1 - Share of Electricity Generation Capacity Built This Year[Electricity Source] \
		* TACFMfPBTY Time Adjusted Capacity Factor Multiplier for Plants Built This Year
	[Electricity Source])
	~	MW
	~		|

Expected Capacity Factor x Hours per Year for Plants Built This Year[Electricity Source\
		]=
	IF THEN ELSE(ABS(Last Year Electricity Generation Capacity[Electricity Source
	])*MW Tolerance Unit Correction Factor < Tolerance,
	                      SUM(Three Year Weighted Average Hypothetical Electricity Capacity Factor\
		[Electricity Timeslice!,Hour
	!,Electricity Source]
	                     * SHELF Days per Electricity Timeslice[Electricity Timeslice!]
	                     * One Hour
	                   
	                ),
	            SUM(Expected Capacity Factors by Hour for Plants Built This Year[Electricity Source
	,Electricity Timeslice!,Hour!]
	                * SHELF Days per Electricity Timeslice[Electricity Timeslice!]
	                * One Hour
	            )
	 )
	~	hours
	~		|

Expected Capacity Factor x Hours per Year for Plants Built This Year Without Hypothetical Calculations\
		[Electricity Source]=
	SUM(
	 Expected Capacity Factors by Hour for Plants Built This Year Without Hypothetical Calculations\
		[Electricity Source,Electricity Timeslice!,Hour!]
	  * SHELF Days per Electricity Timeslice[Electricity Timeslice!]
	  * One Hour
	)
	~	hours
	~		|

Expected Capacity Factors by Hour for Hybrid Plants Built This Year[Hybrid Electricity Source\
		,Electricity Timeslice,Hour]=
	Expected Capacity Factors by Hour for Plants Built This Year[Hybrid Electricity Source\
		,Electricity Timeslice,Hour]
	-Battery Charging Allocation[Hybrid Electricity Source,Electricity Timeslice,Hour]
	+Battery Discharging Allocation[Hybrid Electricity Source,Electricity Timeslice,Hour\
		]
	~	Dmnl
	~		|

Expected Capacity Factors by Hour for Plants Built This Year[Electricity Source,Electricity Timeslice\
		,Hour]=
	(1 - 
	
	  IF THEN ELSE(
	    ABS(Last Year Electricity Generation Capacity[Electricity Source])*MW Tolerance Unit Correction Factor\
		 < Tolerance,
	
	    MAX(
	      0.001,
	      Three Year Weighted Average Hypothetical Electricity Capacity Factor[Electricity Timeslice\
		,Hour,Electricity Source
	]
	    ),
	
	    IF THEN ELSE(
	      Time=INITIAL TIME,
	      Start Year Seasonal Expected Hourly Electricity Capacity Factors after RAF[Electricity Source\
		,Electricity Timeslice
	,Hour]
	      * (1 + IiCFfNPdtTI Increase in Capacity Factors for New Plants due to Technological Improvements\
		[Electricity Source
	]),
	      Three Year Weighted Average Hypothetical Electricity Capacity Factor[Electricity Timeslice\
		,Hour,Electricity Source
	]
	    )
	  )
	)
	* Percentage Reduction in Plant Downtime This Year[Electricity Source]
	
	+ IF THEN ELSE(
	    ABS(Last Year Electricity Generation Capacity[Electricity Source])*MW Tolerance Unit Correction Factor\
		 < Tolerance,
	     
	    MAX(
	      0.001,
	      Three Year Weighted Average Hypothetical Electricity Capacity Factor[Electricity Timeslice\
		,Hour,Electricity Source
	]
	    ),
	
	    IF THEN ELSE(
	      Time=INITIAL TIME,
	      Start Year Seasonal Expected Hourly Electricity Capacity Factors after RAF[Electricity Source\
		,Electricity Timeslice
	,Hour]
	      * (1 + IiCFfNPdtTI Increase in Capacity Factors for New Plants due to Technological Improvements\
		[Electricity Source
	]),
	      Three Year Weighted Average Hypothetical Electricity Capacity Factor[Electricity Timeslice\
		,Hour,Electricity Source
	]
	    )
	  )
	~	Dmnl
	~		|

Expected Capacity Factors by Hour for Plants Built This Year Without Hypothetical Calculations\
		[Electricity Source,Electricity Timeslice,Hour]=
	(1 - 
	BAU Expected Capacity Factors by Hour for Plants Built This Year Without Hypothetical Calculations\
		[Electricity Source,Electricity Timeslice,Hour]
	)
	* Percentage Reduction in Plant Downtime This Year[Electricity Source]
	+ BAU Expected Capacity Factors by Hour for Plants Built This Year Without Hypothetical Calculations\
		[Electricity Source,Electricity Timeslice,Hour]
	~	Dmnl
	~		|

Expected CES Qualifying Hourly Output from Mandated and Required Clean Dispatchable Capacity\
		[Electricity Timeslice,Hour]=
	SUM(((
	   New Generation Capacity before Cost Effectiveness Additions[Electricity Source!]
	  * Expected Capacity Factors by Hour for Plants Built This Year[Electricity Source!\
		,Electricity Timeslice,Hour]
	  )
	
	+(
	   Retrofit Capacity for Clean Dispatchable Reliability[Electricity Source!]
	  * Expected Capacity Factors by Hour for Plants Built This Year[Electricity Source!\
		,Electricity Timeslice,Hour]
	  )
	) * Elec Portfolio Qualifying Sources[Electricity Source!,CES]
	)
	
	* One Hour
	~	MW*hr
	~		|

Expected CES Qualifying Hourly Output from New Cost Effective Capacity[Electricity Timeslice\
		,Hour,Optimization Pass]=
	SUM((
	  Total New and Retrofit Capacity Desired due to Cost Effectiveness by CES Optimization Pass\
		[Electricity Source!,Optimization Pass
	]
	  * Last Year Hourly Bid Electricity Capacity Factors by Plant Type[Electricity Timeslice\
		,Hour,Electricity Source!]
	  * Elec Portfolio Qualifying Sources[Electricity Source!,CES]
	)
	
	* One Hour
	
	)
	~	MW*hr
	~		|

Expected CES Qualifying Hourly Output from Surviving Capacity[Electricity Timeslice,Hour\
		]=
	SUM((
	  Surviving Electricity Generation Capacity before Economic Retirements[Electricity Source\
		!]
	  * Last Year Weighted Average Expected Capacity Factors by Hour Without Hypothetical Adjustments\
		[Electricity Source!,Electricity Timeslice,Hour]
	  * Elec Portfolio Qualifying Sources[Electricity Source!,CES]
	))
	
	* One Hour
	~	MW*hr
	~		|

Expected CES Qualifying Output After Guaranteed and RPS Dispatch[Electricity Source,Electricity Timeslice\
		,Hour]=
	(Expected Capacity After Guaranteed Dispatch[Electricity Source,Electricity Timeslice\
		,Hour]*One Hour
	- Zero and Negative Cost Electricity Dispatched to Meet RPS[Electricity Timeslice,Hour\
		,Electricity Source]
	- Positive Cost Electricity Dispatched to Meet RPS[Electricity Timeslice,Hour,Electricity Source\
		])
	* Elec Portfolio Qualifying Sources[Electricity Source,CES]
	~	MW*hour
	~		|

Expected Curtailed Capacity by Hour for Plants Built This Year[Electricity Source,Electricity Timeslice\
		,Hour]=
	Expected Capacity Factors by Hour for Plants Built This Year Without Hypothetical Calculations\
		[Electricity Source,Electricity Timeslice
	,Hour]
	- Expected Capacity Factors by Hour for Plants Built This Year[Electricity Source,Electricity Timeslice\
		,Hour]
	~	Dmnl
	~		|

Expected Daily Hours of Electricity Output by Electricity Timeslice[Electricity Source\
		,Electricity Timeslice]=
	SUM(
	  Expected Capacity Factors by Hour for Plants Built This Year[Electricity Source,Electricity Timeslice\
		,Hour!]
	  + Salvageable Curtailed Capacity by Hour for Hybrid Power Plants[Electricity Source\
		,Electricity Timeslice,Hour!]
	)
	* One Hour
	~	hours
	~		|

Expected Elec Portfolio Qualifying Dispatch from Last Year Capacity and This Year Mandated Change in Capacity\
		[RPS]=
	SUM(Last Year Capacity and This Year Mandated Change in Capacity Qualifying for Elec Portfolio Std\
		[Electricity Source!,RPS]
	  * Weighted Average Expected Capacity Factors by Hour Without Hypothetical Adjustments\
		[Electricity Source!,Electricity Timeslice
	!,Hour!]
	  * SHELF Days per Electricity Timeslice[Electricity Timeslice!]
	  * One Hour
	  ) ~~|
Expected Elec Portfolio Qualifying Dispatch from Last Year Capacity and This Year Mandated Change in Capacity\
		[CES]=
	SUM(Last Year Capacity and This Year Mandated Change in Capacity Qualifying for Elec Portfolio Std\
		[Electricity Source!,CES]
	  * Weighted Average Expected Capacity Factors by Hour Without Hypothetical Adjustments\
		[Electricity Source!,Electricity Timeslice
	!,Hour!]
	  * SHELF Days per Electricity Timeslice[Electricity Timeslice!]
	  * One Hour
	  )
	~	MW*hour
	~		|

Expected Hourly Output from CES Qualifying Resources Irrespective of Electricity Demand\
		[Electricity Timeslice,
Hour,
Optimization Pass]=
	Expected CES Qualifying Hourly Output from Surviving Capacity[Electricity Timeslice,\
		Hour]
	+ Expected CES Qualifying Hourly Output from Mandated and Required Clean Dispatchable Capacity\
		[Electricity Timeslice
	,Hour]
	+ Expected CES Qualifying Hourly Output from New Cost Effective Capacity[Electricity Timeslice\
		,Hour
	,Optimization Pass]
	~	MW*hr
	~		|

Expected Hourly Output from RPS Qualifying Resources Irrespective of Electricity Demand\
		[Electricity Timeslice,
Hour,
Optimization Pass]=
	Expected RPS Qualifying Hourly Output from Surviving Capacity[Electricity Timeslice,\
		Hour]
	+ Expected RPS Qualifying Hourly Output from Mandated and Required Clean Dispatchable Capacity\
		[Electricity Timeslice
	,Hour]
	+ Expected RPS Qualifying Hourly Output from New Cost Effective Capacity[Electricity Timeslice\
		,Hour
	,Optimization Pass]
	~	MW*hr
	~		|

Expected RPS Qualifying Capacity After Guaranteed Dispatch[Electricity Timeslice,Hour\
		,Electricity Source]=
	Expected Capacity After Guaranteed Dispatch[Electricity Source, Electricity Timeslice\
		,Hour]
	* Elec Portfolio Qualifying Sources[Electricity Source,RPS]
	~	MW
	~		|

Expected RPS Qualifying Capacity After Zero and Negative Cost RPS Dispatch[Electricity Timeslice\
		,Hour,Electricity Source]=
	MAX(
	  0,
	
	  Expected RPS Qualifying Capacity After Guaranteed Dispatch[Electricity Timeslice,Hour\
		,Electricity Source]
	  - Zero and Negative Cost Electricity Dispatched to Meet RPS[Electricity Timeslice,\
		Hour,Electricity Source]/One Hour
	)
	~	MW
	~		|

Expected RPS Qualifying Hourly Output from Mandated and Required Clean Dispatchable Capacity\
		[Electricity Timeslice,Hour]=
	SUM(
	  ((
	   New Generation Capacity before Cost Effectiveness Additions[Electricity Source!]
	  * Expected Capacity Factors by Hour for Plants Built This Year[Electricity Source!\
		,Electricity Timeslice,Hour]
	  )
	
	+(
	   Retrofit Capacity for Clean Dispatchable Reliability[Electricity Source!]
	  * Expected Capacity Factors by Hour for Plants Built This Year[Electricity Source!\
		,Electricity Timeslice,Hour]
	  )
	) * Elec Portfolio Qualifying Sources[Electricity Source!,RPS]
	)
	
	* One Hour
	~	MW*hr
	~		|

Expected RPS Qualifying Hourly Output from New Cost Effective Capacity[Electricity Timeslice\
		,Hour,Optimization Pass]=
	SUM((
	  Total New and Retrofit Capacity Desired due to Cost Effectiveness by RPS Optimization Pass\
		[Electricity Source!,Optimization Pass
	]
	  * Last Year Hourly Bid Electricity Capacity Factors by Plant Type[Electricity Timeslice\
		,Hour,Electricity Source!]
	  * Elec Portfolio Qualifying Sources[Electricity Source!,RPS]
	)
	
	* One Hour
	
	)
	~	MW*hr
	~		|

Expected RPS Qualifying Hourly Output from Surviving Capacity[Electricity Timeslice,Hour\
		]=
	SUM((
	  Surviving Electricity Generation Capacity before Economic Retirements[Electricity Source\
		!]
	  * Last Year Weighted Average Expected Capacity Factors by Hour Without Hypothetical Adjustments\
		[Electricity Source!,Electricity Timeslice,Hour]
	  * Elec Portfolio Qualifying Sources[Electricity Source!,RPS]
	))
	
	* One Hour
	~	MW*hr
	~		|

Expected Total Revenue per Unit Capacity by Plant Type Excluding Subsidies[Electricity Source\
		,Optimization Pass]=
	Last Year Annual Net Energy Market Revenue per MW by Plant Type[Electricity Source]
	+Predicted Capacity Payment by Plant Type for Existing Plants[Electricity Source,Optimization Pass\
		]
	+ Last Year Revenue from CES Credits per Unit Electricity Output by Plant Type[Electricity Source\
		]
	~	$/MW
	~		|

Expected Total Revenue per Unit Capacity by Plant Type Excluding Subsidies and Predicted Capacity Payment\
		[Electricity Source]=
	Last Year Annual Net Energy Market Revenue per MW by Plant Type[Electricity Source]
	+ Last Year Revenue from CES Credits per Unit Electricity Output by Plant Type[Electricity Source\
		]
	~	$/MW
	~		|

Exported Electricity=
	EIaE BAU Exported Electricity
	* (1 + Percent Change in Electricity Exports This Year)
	* (1 + Perc Change in Sectoral Energy Use due to Exogenous GDP Adjustment[electricity sector\
		])
	~	MW*hour
	~		|

Exported Electricity by Hour on Peak Summer Day[Hour]=
	SUM(Electricity Exports by Hour[peak summer day electricity timeslice!,Hour,last pass\
		!])
	/ ELMCOUNT(peak summer day electricity timeslice)
	~	MW*hr
	~		|

Exported Electricity by Hour on Peak Winter Day[Hour]=
	SUM(Electricity Exports by Hour[peak winter day electricity timeslice!,Hour,last pass\
		!])
	/ ELMCOUNT(peak winter day electricity timeslice)
	~	MW*hr
	~		|

Exports of Nonenergy Products[Industry Category] :EXCEPT: [energy industries within industry category\
		]=
	BAU Exports[Industry Category ISIC Code]
	+ Change in Exports of Nonenergy Products[Industry Category] ~~|
Exports of Nonenergy Products[energy industries within industry category]=
	0
	~	$
	~		|

Financing Interest Rate by Industry[Industry Category,Industrial Fuel,Industrial Process\
		]=
	BCoISC Financing Interest Rate by Industry[Industry Category]
	* 
	(
	  1 - (Perc Decrease in Cost of Capital for Clean Industrial Equipment This Year[Industrial Process\
		,Industry Category]
	    * IFTQfS Industrial Fuel Types Qualifying for Loans[Industrial Fuel]
	  )
	)
	~	Dmnl
	~		|

Financing Repayments for Waste Heat Recovery Equipment[Industry Category]=
	Last Year Financing Repayments for Waste Heat Recovery Equipment[Industry Category]
	- Annual Industrial Equipment Financing Reqayments Expiring After Repayment Period[Industry Category\
		] * One Year
	+ Annual Financing Repayment for Newly Purchased Waste Heat Recovery Equipment[Industry Category\
		] * One Year
	~	$
	~		|

