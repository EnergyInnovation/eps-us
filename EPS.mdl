CES Costs for ACP Compliance[RPS]=
	MAX(0,
	    Elec Portfolio Percentage to Seek This Year[RPS]-SUM(Expected Achievable Annual RPS by Optimization Pass\
		[last pass!])
	  )
	
	* Optimized RPS Credit Price
	* Total Electricity Demand Including TnD Losses ~~|
CES Costs for ACP Compliance[CES]=
	MAX(0,
	    Elec Portfolio Percentage to Seek This Year[CES]-SUM(Expected Achievable Annual CES by Optimization Pass\
		[last pass!])
	  )
	
	* Optimized CES Credit Price
	* Total Electricity Demand Including TnD Losses
	~	$
	~		|

CES Costs for Clean Dispatchable Plants for Reliability=
	(SUM
	    (New Dispatchable Only Clean Capacity Desired for Seasonal Reliability[Electricity Source\
		!]
	    * Capacity Market Price for Seasonal Clean Dispatchable Reliability Adjusted for Availability\
		[Electricity Source!]
	    )
	
	    + SUM(Retrofit Capacity for Clean Dispatchable Reliability[Electricity Source!]
	      * Capacity Market Price for Seasonal Clean Dispatchable Reliability Adjusted for Availability\
		[Electricity Source!
	]
	      )
	   )
	~	$
	~		|

CES Costs for Incremental Capacity Additions[Clean Elec Requirement]=
	CES Costs for Clean Dispatchable Plants for Reliability
	+CES Costs for Market Based CES Mechanism[Clean Elec Requirement]
	~	$
	~		|

CES Costs for Incremental Capacity Additions after Financial Lifetime[Clean Elec Requirement\
		]= DELAY FIXED (
	CES Costs for Incremental Capacity Additions[Clean Elec Requirement], RPfFESCC Repayment Period for Financed Electricity Sector Capital Costs\
		, 0)
	~	$
	~		|

CES Costs for Market Based CES Mechanism[RPS]=
	(SUM(New Capacity Added or Retrofitted due to Elec Portfolio Stds excluding Hybrid Power Plants\
		[Electricity Source!,RPS]
	    *Marginal Capacity Factor by Hour[Electricity Source!,Electricity Timeslice!,Hour\
		!,RPS]
	    *SHELF Days per Electricity Timeslice[Electricity Timeslice!]
	    *Optimized RPS Credit Price
	     )* One Hour
	  )
	
	
	+(SUM(New Capacity Added due to Elec Portfolio Stds for Hybrid Power Plants[Electricity Source\
		!,RPS]
	    *Marginal Capacity Factor by Hour[Electricity Source!,Electricity Timeslice!,Hour\
		!,RPS]
	    *SHELF Days per Electricity Timeslice[Electricity Timeslice!]
	    *Optimized RPS Credit Price
	    *(1-Share of Annual Expected Output that Can be Shifted[Electricity Source!])
	     )* One Hour
	
	  +SUM(New Capacity Added due to Elec Portfolio Stds for Hybrid Power Plants[Electricity Source\
		!,RPS]
	    *Expected Capacity Factors by Hour for Plants Built This Year[Electricity Source\
		!,Electricity Timeslice!,Hour!]
	    *SHELF Days per Electricity Timeslice[Electricity Timeslice!]
	    *Optimized RPS Credit Price
	    *Share of Annual Expected Output that Can be Shifted[Electricity Source!]
	     )* One Hour
	  ) ~~|
CES Costs for Market Based CES Mechanism[CES]=
	(SUM(New Capacity Added or Retrofitted due to Elec Portfolio Stds excluding Hybrid Power Plants\
		[Electricity Source!,CES]
	    *Marginal Capacity Factor by Hour[Electricity Source!,Electricity Timeslice!,Hour\
		!,CES]
	    *SHELF Days per Electricity Timeslice[Electricity Timeslice!]
	    *(Optimized CES Credit Price+Optimized RPS Credit Price)
	     )* One Hour
	  )
	
	
	+(SUM(New Capacity Added due to Elec Portfolio Stds for Hybrid Power Plants[Electricity Source\
		!,CES]
	    *Marginal Capacity Factor by Hour[Electricity Source!,Electricity Timeslice!,Hour\
		!,CES]
	    *SHELF Days per Electricity Timeslice[Electricity Timeslice!]
	    *(Optimized CES Credit Price+Optimized RPS Credit Price)
	    *(1-Share of Annual Expected Output that Can be Shifted[Electricity Source!])
	     )* One Hour
	
	  +SUM(New Capacity Added due to Elec Portfolio Stds for Hybrid Power Plants[Electricity Source\
		!,CES]
	    *Expected Capacity Factors by Hour for Plants Built This Year[Electricity Source\
		!,Electricity Timeslice!,Hour!]
	    *SHELF Days per Electricity Timeslice[Electricity Timeslice!]
	    *(Optimized CES Credit Price+Optimized RPS Credit Price)
	    *Share of Annual Expected Output that Can be Shifted[Electricity Source!]
	     )* One Hour
	  )
	~	$
	~		|

CES Credit Price by Optimization Pass[pass1]=
	Initial Guess at CES Price ~~|
CES Credit Price by Optimization Pass[current pass]=
	MIN(IF THEN ELSE(
	  CES Credit Price by Optimization Pass[preceeding pass] = 0,
	
	  0,
	
	  MAX(
	    0,
	
	    IF THEN ELSE(
	      Expected Achievable Annual CES by Optimization Pass[preceeding pass]
	      < Elec Portfolio Percentage to Seek This Year[CES],
	  
	      CES Credit Price by Optimization Pass[preceeding pass]
	      + CES Optimization Step Size[current pass],
	
	      CES Credit Price by Optimization Pass[preceeding pass]
	      - CES Optimization Step Size[current pass]
	    )
	  )
	), Elec Portfolio Alternative Compliance Payment)
	~	$/(MW*hr)
	~		|

CES Optimization Step Size[pass1]=
	ABS(CES Credit Price by Optimization Pass[pass1])
	/ 2 ~~|
CES Optimization Step Size[current pass]=
	IF THEN ELSE(
	  CES Steps in Same Direction[preceeding pass]
	  > Steps Allowed in Same Direction Without Increasing Step Size,
	
	  CES Optimization Step Size[preceeding pass] * 1.5,
	
	  IF THEN ELSE(
	    CES Steps in Same Direction[preceeding pass]
	    > Steps Allowed in Same Direction With Declining Step Size,
	
	    CES Optimization Step Size[preceeding pass],
	
	    CES Optimization Step Size[preceeding pass]
	    / 2
	  )
	)
	~	$/(MW*hour)
	~		|

CES Revenue at Expected Capacity Factor by Optimization Pass[Electricity Source,Optimization Pass\
		]=
	CES Credit Price by Optimization Pass[Optimization Pass]
	* Expected Capacity Factor x Hours per Year for Plants Built This Year[Electricity Source\
		]
	* Elec Portfolio Qualifying Sources[Electricity Source,CES]
	~	$/MW
	~		|

CES Revenue at Marginal Capacity Factor by Optimization Pass[Optimization Pass, Electricity Source\
		]=
	CES Credit Price by Optimization Pass[Optimization Pass]
	* Marginal Capacity Factor x Hours per Year[Electricity Source,CES]
	* Elec Portfolio Qualifying Sources[Electricity Source,CES]
	~	$/MW
	~		|

CES Steps in Negative Direction[pass1]=
	0 ~~|
CES Steps in Negative Direction[current pass]=
	IF THEN ELSE(
	  Expected Achievable Annual CES by Optimization Pass[preceeding pass]
	  > Elec Portfolio Percentage to Seek This Year[CES],
	
	  CES Steps in Negative Direction[preceeding pass] + 1,
	
	  0
	)
	~	Dmnl
	~		|

CES Steps in Positive Direction[pass1]=
	0 ~~|
CES Steps in Positive Direction[current pass]=
	IF THEN ELSE(
	  Expected Achievable Annual CES by Optimization Pass[preceeding pass]
	  < Elec Portfolio Percentage to Seek This Year[CES],
	
	  CES Steps in Positive Direction[preceeding pass] + 1,
	
	  0
	)
	~	Dmnl
	~		|

CES Steps in Same Direction[Optimization Pass]=
	MAX(
	  CES Steps in Positive Direction[Optimization Pass],
	  CES Steps in Negative Direction[Optimization Pass]
	)
	~	Dmnl
	~		|

