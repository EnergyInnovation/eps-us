BAU Total Hydrogen Demand=
	SUM(BAU Hydrogen Demand by Sector[Sectors!])
	~	BTU
	~		|

BAU Total Industrial Electricity Demand by Hour Before CCS[Electricity Timeslice,Hour\
		,Industry Category] :EXCEPT:    [Electricity Timeslice,Hour,industry categories w industry wide load factors\
		]=
	SUM(
	  BAU Industrial Energy Use by Fuel Type and Process[Industry Category,electricity if\
		,Industrial Process!]
	  * Adjusted Load Factors for Industrial Processes[Electricity Timeslice,Hour,Industrial Process\
		!]
	)
	* MWh per BTU ~~|
BAU Total Industrial Electricity Demand by Hour Before CCS[Electricity Timeslice,Hour\
		,industry categories w industry wide load factors]=
	SUM(
	  BAU Industrial Energy Use by Fuel Type and Process[industry categories w industry wide load factors\
		,electricity if,Industrial Process!]
	)
	* Adjusted Load Factors for Industry Categories[Electricity Timeslice,Hour,Industry Cat w Industry wide Load Factor\
		]
	* MWh per BTU
	~	MW*hour
	~		|

BAU Total New and Retrofit Capacity Desired due to Cost Effectiveness by CES Optimization Pass\
		[Electricity Source, Optimization Pass]=
	BAU New Capacity Desired due to Cost Effectivness by Optimization Pass[Electricity Source\
		,Optimization Pass,CES]
	+ BAU Retrofitted Capacity Desired due to Cost Effectiveness by Optimization Pass[Electricity Source\
		,Optimization Pass,CES]
	+ BAU New Capacity Desired due to Cost Effectivness by Optimization Pass for Hybrid Power Plants\
		[Electricity Source,Optimization Pass,CES]
	~	MW
	~		|

BAU Total New and Retrofit Capacity Desired due to Cost Effectiveness by RPS Optimization Pass\
		[Electricity Source, Optimization Pass]=
	BAU New Capacity Desired due to Cost Effectivness by Optimization Pass[Electricity Source\
		,Optimization Pass,RPS]
	+ BAU Retrofitted Capacity Desired due to Cost Effectiveness by Optimization Pass[Electricity Source\
		,Optimization Pass,RPS]
	+ BAU New Capacity Desired due to Cost Effectivness by Optimization Pass for Hybrid Power Plants\
		[Electricity Source,Optimization Pass,RPS]
	~	MW
	~		|

BAU Total New Capacity Desired due to Cost Effectiveness[Electricity Source,RPS]=
	BAU New Capacity Desired due to Cost Effectiveness[Electricity Source,RPS]
	+ BAU New Capacity Desired due to Cost Effectiveness for Hybrid Power Plants[Electricity Source\
		,RPS] ~~|
BAU Total New Capacity Desired due to Cost Effectiveness[Electricity Source,CES]=
	BAU New Capacity Desired due to Cost Effectiveness[Electricity Source,CES]
	+ BAU New Capacity Desired due to Cost Effectiveness for Hybrid Power Plants[Electricity Source\
		,CES]
	~	MW
	~		|

BAU Total New Capacity for Reliability[Electricity Source]=
	QUANTUM(
	 BAU New Dispatchable Only Capacity Desired for Seasonal Reliability[Electricity Source\
		] ,
	 MPPC Minimum Power Plant Capacity[Electricity Source]
	 )
	~	MW
	~		~	:SUPPLEMENTARY 
	|

BAU Total New Low Carbon Hydrogen Production Capacity This Year=
	MAX(
	  0,
	  BAU Low Carbon Hydrogen Demand - 
	  (BAU Surviving Capacity Available After Green Hydrogen Demand[electrolysis with guaranteed clean electricity\
		]
	  + BAU Surviving Capacity Available After Green Hydrogen Demand[natural gas reforming with CCS\
		])
	)
	~	BTU
	~		|

BAU Total New Other Hydrogen Production Capacity This Year=
	MAX(
	  0,
	  BAU Other Hydrogen Demand - 
	  SUM(BAU Surviving Capacity Available After Low Carbon Hydrogen Demand[Hydrogen Production Pathway\
		!])
	)
	~	BTU
	~		|

BAU Total Other Fuel Tax Revenue=
	BAU Transportation Sector Other Fuel Tax Revenue
	+ BAU Electricity Sector Other Fuel Tax Revenue
	+ BAU Buildings Sector Other Fuel Tax Revenue
	+ BAU Industry Sector Other Fuel Tax Revenue
	+ BAU District Heat and Hydrogen Sector Other Fuel Tax Revenue
	+ BAU Geoengineering Sector Other Fuel Tax Revenue
	~	$
	~		|

BAU Total Pollutant Emissions[Pollutant]=
	SUM(BAU Total Pollutant Emissions by Sector[Sectors!,Pollutant])
	~	g pollutant
	~	Future year BAU emissions projections only available for CO2.  We estimate \
		the BAU non-CO2 pollutant emissions by multiplying the future year BAU CO2 \
		projections by the ratio of BAU emissions of CO2 to BAU emissions of each \
		other pollutant in each future year.
	|

BAU Total Pollutant Emissions by Sector[transportation sector,Pollutant]=
	QUANTUM(
	  BAU Transportation Sector Pollutant Emissions[Pollutant],
	
	  QSfP Quantization Size for Pollutants
	) ~~|
BAU Total Pollutant Emissions by Sector[electricity sector,Pollutant]=
	QUANTUM(
	  SUM(BAU Electricity Sector Pollutant Emissions[Pollutant,Electricity Source!]),
	
	  QSfP Quantization Size for Pollutants
	) ~~|
BAU Total Pollutant Emissions by Sector[residential buildings sector,Pollutant]=
	QUANTUM(
	  BAU Buildings Sector Pollutant Emissions[urban residential,Pollutant]
	  + BAU Buildings Sector Pollutant Emissions[rural residential,Pollutant],
	
	  QSfP Quantization Size for Pollutants
	) ~~|
BAU Total Pollutant Emissions by Sector[commercial buildings sector,Pollutant]=
	QUANTUM(
	  BAU Buildings Sector Pollutant Emissions[commercial,Pollutant],
	
	  QSfP Quantization Size for Pollutants
	) ~~|
BAU Total Pollutant Emissions by Sector[industry sector,Pollutant]=
	QUANTUM(
	  SUM(BAU Industrial Sector Pollutant Emissions[Industry Category!,Pollutant]),
	
	  QSfP Quantization Size for Pollutants
	) ~~|
BAU Total Pollutant Emissions by Sector[district heat and hydrogen sector,Pollutant]=
	QUANTUM(
	  SUM(BAU District Heating Pollutant Emissions[Pollutant,Industrial Fuel!])
	  + BAU Hydrogen Sector Pollutant Emissions[Pollutant],
	
	  QSfP Quantization Size for Pollutants
	) ~~|
BAU Total Pollutant Emissions by Sector[LULUCF sector,Pollutant]=
	QUANTUM(
	  BLAPE BAU LULUCF Anthropogenic Pollutant Emissions[Pollutant],
	
	  QSfP Quantization Size for Pollutants
	) ~~|
BAU Total Pollutant Emissions by Sector[geoengineering sector,Pollutant]=
	QUANTUM(
	  BAU Geoengineering Sector Pollutant Emissions[Pollutant],
	
	  QSfP Quantization Size for Pollutants
	)
	~	g pollutant
	~		|

