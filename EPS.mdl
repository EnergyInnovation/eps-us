Fraction New Components by Quality Level[Building Type,Building Component,Building Component Quality\
		]=
	IF THEN ELSE(
	  Boolean Rebate Program for Efficient Components This Year[Building Component] <> 0\
		,
	
	  BFoCSbQL BAU Fraction of Components Sold by Quality Level[Building Type,Building Component\
		,Building Component Quality]
	  * (1 + MSCdtRPbQL Market Share Changes due to Rebate Program by Quality Level[Building Component Quality\
		]),
	
	  BFoCSbQL BAU Fraction of Components Sold by Quality Level[Building Type,Building Component\
		,Building Component Quality]
	)
	~	Dmnl
	~		|

Fraction of Additional Demand Response Potential Achieved=
	0
	~	Dmnl [0,1]
	~		|

Fraction of Additional Demand Response Potential Achieved This Year=
	Fraction of Additional Demand Response Potential Achieved
	* Selected Policy Implementation Schedule[elec demand response X]
	~	Dmnl
	~		|

Fraction of Afforestation and Reforestation Achieved=
	0
	~	Dmnl [0,1]
	~		|

Fraction of Afforestation and Reforestation Achieved This Year=
	Fraction of Afforestation and Reforestation Achieved
	* Selected Policy Implementation Schedule[land afforestation and reforestation X]
	~	Dmnl
	~		|

Fraction of All Preexisting Industrial Equipment Retired[Industry Category,Industrial Process\
		]=
	IF THEN ELSE(
	  BIISRP Boolean Use Individual Industrial Site Retirement Profile[Industry Category\
		] = 0,
	
	  Fraction of Preexisting Industrial Equipment Retired by Natural Aging Curves[Industry Category\
		,Industrial Process],
	
	  Fraction of Preexisting Industrial Equipment Retired by Industry Specific Retirement Profile\
		[Industry Category,Industrial Process]
	
	)
	~	Dmnl
	~		|

Fraction of Avoided Deforestation Achieved=
	0
	~	Dmnl [0,1]
	~		|

Fraction of Avoided Deforestation Achieved This Year=
	Fraction of Avoided Deforestation Achieved
	* Selected Policy Implementation Schedule[land avoid deforestation X]
	~	Dmnl
	~		|

Fraction of Buildable Capacity Actually Built[Electricity Source]=
	XIDZ(
	  New and Retrofit Generation Capacity[Electricity Source],
	
	  Max Capacity Buildable This Year[Electricity Source],
	
	  1
	)
	~	Dmnl
	~		~	:SUPPLEMENTARY 
	|

Fraction of Buildings Owned by Entity after Allocation to Energy Supplier Entities[Cash Flow Entity\
		,Building Type] :EXCEPT:   [nonenergy industries,commercial],[energy supplier cash flow entity\
		,commercial]=
	FoBObE Fraction of Buildings Owned by Entity[Cash Flow Entity,Building Type] ~~|
Fraction of Buildings Owned by Entity after Allocation to Energy Supplier Entities[nonenergy industries\
		,commercial]=
	FoBObE Fraction of Buildings Owned by Entity[nonenergy industries,commercial]
	* (1 - SUM(Share of Output by Energy Supplier Cash Flow Entity[energy supplier cash flow entity\
		!])) ~~|
Fraction of Buildings Owned by Entity after Allocation to Energy Supplier Entities[energy supplier cash flow entity\
		,commercial]=
	FoBObE Fraction of Buildings Owned by Entity[nonenergy industries,commercial]
	* Share of Output by Energy Supplier Cash Flow Entity[energy supplier cash flow entity\
		]
	~	Dmnl
	~		|

Fraction of Cement Measures Achieved=
	0
	~	Dmnl [0,1]
	~		|

Fraction of Cement Measures Achieved This Year=
	Fraction of Cement Measures Achieved
	* Selected Policy Implementation Schedule[indst cement measures X]
	~	Dmnl
	~		|

Fraction of CO2 Captured by Industry Category[Industry Category,Emissions Type]=
	MAX(
	  Economically Driven Fraction of CO2 Captured by Industry Category[Industry Category\
		,Emissions Type],
	  Industry Sector Minimum Fraction of CCS Achieved This Year[Industry Category,Emissions Type\
		]
	)
	~	Dmnl
	~		|

Fraction of CO2 Storage Through Tillage Practices=
	0
	~	Dmnl [0,1]
	~		|

Fraction of CO2 Storage Through Tillage Practices This Year=
	Fraction of CO2 Storage Through Tillage Practices
	* Selected Policy Implementation Schedule[indst tillage X]
	~	Dmnl
	~		|

Fraction of Cropland and Rice Measures Achieved=
	0
	~	Dmnl [0,1]
	~		|

Fraction of Cropland and Rice Measures Achieved This Year=
	Fraction of Cropland and Rice Measures Achieved
	* Selected Policy Implementation Schedule[indst cropland and rice measures X]
	~	Dmnl
	~		|

Fraction of Direct Air Capture Potential Achieved=
	0
	~	Dmnl [0,1]
	~		|

Fraction of Direct Air Capture Potential Achieved This Year=
	Fraction of Direct Air Capture Potential Achieved
	* Selected Policy Implementation Schedule[geoeng direct air capture X]
	~	Dmnl
	~		|

Fraction of District Heat from CHP[Industrial Fuel]=
	BFoHfC BAU Fraction of Heat from CHP[Industrial Fuel]
	+ (1 - BFoHfC BAU Fraction of Heat from CHP[Industrial Fuel])
	  * Fraction of Non CHP Heat Production Converted to CHP This Year
	~	Dmnl
	~		|

Fraction of District Heat Fuel Use Shifted to Other Fuels=
	0
	~	Dmnl [0,1]
	~		|

Fraction of District Heat Fuel Use Shifted to Other Fuels This Year=
	Fraction of District Heat Fuel Use Shifted to Other Fuels
	* Selected Policy Implementation Schedule[heat fuel type shifting X]
	~	Dmnl
	~		|

Fraction of District Heat Provided by Fuel[Target Industrial Fuel]=
	BFoHPbF BAU Fraction of Heat Provided by Fuel[Target Industrial Fuel]
	* (1 - Fraction of District Heat Fuel Use Shifted to Other Fuels This Year)
	
	+ SUM(
	    BFoHPbF BAU Fraction of Heat Provided by Fuel[Source Industrial Fuel!]
	    * Fraction of District Heat Fuel Use Shifted to Other Fuels This Year
