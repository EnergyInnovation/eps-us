Industry Contribution to Change in Domestic Output by ISIC Code[ISIC Code]=
	Industry Contribution to Change in Domestic Output by ISIC Code before Shifting BAU Imported Output\
		[ISIC Code]
	+ BAU Imported Output Shifted to In Region Suppliers by ISIC Code[ISIC Code]
	~	$
	~		|

Industry Contribution to Change in Domestic Output by ISIC Code before Shifting BAU Imported Output\
		[ISIC Code]=
	Industry Contribution to Change in Global Output by ISIC Code before Passthrough Costs\
		[ISIC Code]
	* Domestic Content Share of Consumption by ISIC Code[ISIC Code]
	
	- Domestic Nonenergy Industry Expenses Passed Through to Buyers by Producer ISIC Code\
		[ISIC Code]
	~	$
	~		|

Industry Contribution to Change in Global Output by ISIC Code before Passthrough Costs\
		[ISIC Code]=
	Change in Nonenergy ISIC Code Revenue After Relinquishing Collected VAT or Sales Tax by ISIC Code\
		[ISIC Code]
	
	+ Government Revenue Change Allocated to Private Businesses by ISIC Code[ISIC Code]
	
	+ Direct Change in Fuel Industry Revenue by ISIC Code[ISIC Code]
	~	$
	~		|

Industry Fuel Use by Fuel[Industrial Fuel]=
	SUM(Industrial Fuel Use[Industrial Fuel,Industry Category!])
	~	BTU
	~		~	:SUPPLEMENTARY 
	|

Industry Pollutants Taxed by Carbon Pricing[Industry Category,Pollutant]=
	IF THEN ELSE(
	  Boolean Non BAU Pollutants Affected by Carbon Tax This Year = 0,
	  BPTbCP BAU Industry Pollutants Taxed by Carbon Pricing[Industry Category,Pollutant\
		],
	  PTbCP Industry Pollutants Taxed by Carbon Pricing[Industry Category,Pollutant]
	)
	~	Dmnl
	~		|

Industry Process Emissions Policy:
	indst methane capture,
	indst methane destruction,
	indst f gas substitution,
	indst f gas destruction,
	indst f gas recovery,
	indst f gas inspct maint retrofit,
	indst cropland and rice measures,
	indst livestock measures,
	indst tillage,
	indst cement measures,
	indst N2O abatement
	~	
	~		|

Industry Process Emissions Policy to Pollutant Mappings[Industry Process Emissions Policy\
		,Pollutant] :EXCEPT:     [indst methane capture,CH4],[indst methane destruction,CH4\
		],[indst f gas substitution,F gases],[indst f gas destruction,F gases],[indst f gas recovery
,F gases],[indst f gas inspct maint retrofit,F gases],[indst cropland and rice measures\
		,CH4],[indst cropland and rice measures
,N2O],[indst livestock measures,CH4],[indst livestock measures,N2O],[indst tillage,CO2\
		],[indst cement measures,CO2],[indst N2O abatement,N2O]=
	0 ~~|
Industry Process Emissions Policy to Pollutant Mappings[indst methane capture,CH4]=
	1 ~~|
Industry Process Emissions Policy to Pollutant Mappings[indst methane destruction,CH4\
		]=
	1 ~~|
Industry Process Emissions Policy to Pollutant Mappings[indst f gas substitution,F gases\
		]=
	1 ~~|
Industry Process Emissions Policy to Pollutant Mappings[indst f gas destruction,F gases\
		]=
	1 ~~|
Industry Process Emissions Policy to Pollutant Mappings[indst f gas recovery,F gases]\
		=
	1 ~~|
Industry Process Emissions Policy to Pollutant Mappings[indst f gas inspct maint retrofit\
		,F gases]=
	1 ~~|
Industry Process Emissions Policy to Pollutant Mappings[indst cropland and rice measures\
		,CH4]=
	ZIDZ(
	  BAU Process Emissions in CO2e[agriculture and forestry 01T03,CH4],
	
	  BAU Process Emissions in CO2e[agriculture and forestry 01T03,CH4]
	  + BAU Process Emissions in CO2e[agriculture and forestry 01T03,N2O]
	) ~~|
Industry Process Emissions Policy to Pollutant Mappings[indst cropland and rice measures\
		,N2O]=
	ZIDZ(
	  BAU Process Emissions in CO2e[agriculture and forestry 01T03,N2O],
	
	  BAU Process Emissions in CO2e[agriculture and forestry 01T03,CH4]
	  + BAU Process Emissions in CO2e[agriculture and forestry 01T03,N2O]
	) ~~|
Industry Process Emissions Policy to Pollutant Mappings[indst livestock measures,CH4]\
		=
	ZIDZ(
	  BAU Process Emissions in CO2e[agriculture and forestry 01T03,CH4],
	
	  BAU Process Emissions in CO2e[agriculture and forestry 01T03,CH4]
	  + BAU Process Emissions in CO2e[agriculture and forestry 01T03,N2O]
	) ~~|
Industry Process Emissions Policy to Pollutant Mappings[indst livestock measures,N2O]\
		=
	ZIDZ(
	  BAU Process Emissions in CO2e[agriculture and forestry 01T03,N2O],
	
	  BAU Process Emissions in CO2e[agriculture and forestry 01T03,CH4]
	  + BAU Process Emissions in CO2e[agriculture and forestry 01T03,N2O]
	) ~~|
Industry Process Emissions Policy to Pollutant Mappings[indst tillage, CO2]=
	1 ~~|
Industry Process Emissions Policy to Pollutant Mappings[indst cement measures,CO2]=
	1 ~~|
Industry Process Emissions Policy to Pollutant Mappings[indst N2O abatement,N2O]=
	1
	~	Dmnl
	~		|

Industry Sector Carbon Tax Rebate due to CCS[Industry Category]=
	BAU Amount of CO2 Sequestered by Industry Sector[Industry Category]
	* BCTR BAU Carbon Tax Rate[industry sector]
	* BFoICStCT BAU Fraction of Industry Category Subject to Carbon Tax[Industry Category\
		]
	~	$
	~		|

Industry Sector Carbon Tax Revenue[Industry Category]=
	SUM(Industrial Fuel Use for Energy Purposes[Industrial Fuel!,Industry Category]
	* Industrial Fuel Carbon Tax Amount per Unit Energy[Industry Category,Industrial Fuel\
		!])
	
	+ Carbon Tax on Process Emissions by Industry[Industry Category]
	~	$
	~		|

Industry Sector CCS Subsidy by Industry Category[Industry Category]=
	IF THEN ELSE(
	
	  Boolean Use Non BAU Industry CCS Subsidies This Year[Industry Category] > 0,
	
	  NBICS Non BAU Industry CCS Subsidy[Industry Category],
	
	  BCS BAU Industry CCS Subsidy
	)
	~	$/metric ton CO2e
	~		|

Industry Sector CCS Transportation and Storage Costs[Industry Category]=
	SUM(This Year Pollutants Sequestered by Industry Sector[Industry Category,CO2,Emissions Type\
		!])
	/ Grams per Metric Ton CO2e
	/ Grams Pollutant per Gram CO2e Unit Converter
	
	* Industry Sector CCS Transportation and Storage Costs per Unit Pollutant Sequestered
	~	$
	~		|

Industry Sector CCS Transportation and Storage Costs per Unit Pollutant Sequestered=
	CCSTaSC CCS Transportation and Storage Costs 
	- Industrial CCS Transportation and Storage Subsidy
	~	$/metric ton CO2e
	~		|

Industry Sector CCS Transportation and Storage Subsidies[Industry Category]=
	SUM(This Year Pollutants Sequestered by Industry Sector[Industry Category,CO2,Emissions Type\
		!])
	/ Grams per Metric Ton CO2e
	/ Grams Pollutant per Gram CO2e Unit Converter
	
	* 
	(
	  CCSTaSC CCS Transportation and Storage Subsidies
	  + 
	  ((CCSTaSC CCS Transportation and Storage Costs - CCSTaSC CCS Transportation and Storage Subsidies\
		)
	    * Perc Subsidy for Industry Sector CCS Transport and Storage Costs This Year
	  )
	)
	~	$
	~		|

Industry Sector Change in Capital and OM Spending[Cash Flow Entity] :EXCEPT:      [nonenergy industries\
		]=
	0 ~~|
Industry Sector Change in Capital and OM Spending[nonenergy industries]=
	SUM(Change in Upfront Capital Expenditures on New Industrial Equipment[Industry Category\
		!])
	 + SUM(New Waste Heat Recovery Equipment Capital Expenditures[Industry Category!])
	 + SUM(Industry Sector Change in CCS New Capital Eqpt Cost[Industry Category!])
	 + SUM(Industry Sector Change in CCS OM Cost[Industry Category!])
	~	$
	~		|

Industry Sector Change in CCS New Capital Eqpt Cost[Industry Category]=
	CCS New Capital Eqpt Cost by Industry[Industry Category]
	- BAU CCS New Capital Eqpt Cost by Industry[Industry Category]
	~	$
	~		|

Industry Sector Change in CCS OM Cost[Industry Category]=
	CCS OM Cost by Industry Sector[Industry Category]
	- BAU CCS OM Cost by Industry Sector[Industry Category]
	~	$
	~		|

Industry Sector Change in CCS Subsidy Amount Paid[Industry Category]=
	CCS Subsidy Amount Paid to Industry Sector[Industry Category]
	 - BAU CCS Subsidy Amount Paid to Industry Sector[Industry Category]
	~	$
	~		|

Industry Sector Change in CCS Transportation and Storage Costs[Industry Category]=
	Industry Sector CCS Transportation and Storage Costs[Industry Category]
	- BAU Industry Sector CCS Transportation and Storage Costs[Industry Category]
	~	$
	~		|

Industry Sector Change in CCS Transportation and Storage Costs by Recipient ISIC Code\
		[ISIC Code]=
	SUM(Industry Sector Change in CCS Transportation and Storage Costs[Industry Category\
		!])
	* SoCTaSCbRIC Share of CCS Transportation and Storage Costs by Recipient ISIC Code[ISIC Code\
		]
	~	$
	~		|

Industry Sector Change in CCS Transportation and Storage Subsidies[Industry Category]\
		=
	Industry Sector CCS Transportation and Storage Subsidies[Industry Category]
	- BAU Industry Sector CCS Transportation and Storage Subsidies[Industry Category]
	~	$
	~		|

Industry Sector Change in Energy Expenditures by Entity[Cash Flow Entity] :EXCEPT: [nonenergy industries\
		],[natural gas and petroleum suppliers],[coal suppliers]=
	0 ~~|
Industry Sector Change in Energy Expenditures by Entity[nonenergy industries]=
	SUM(Change in Amount Spent on Industry Fuels[nonenergy industries within industry category\
		!,Industrial Fuel!]) ~~|
Industry Sector Change in Energy Expenditures by Entity[natural gas and petroleum suppliers\
		]=
	SUM(Change in Amount Spent on Industry Fuels[oil and gas extraction 06,Industrial Fuel\
		!])
	+ SUM(Change in Amount Spent on Industry Fuels[refined petroleum and coke 19,Industrial Fuel\
		!])
	+ SUM(Change in Amount Spent on Industry Fuels[energy pipelines and gas processing 352T353\
		,Industrial Fuel!]) ~~|
Industry Sector Change in Energy Expenditures by Entity[coal suppliers]=
	SUM(Change in Amount Spent on Industry Fuels[coal mining 05,Industrial Fuel!])
	~	$
	~		|

Industry Sector Change in Energy Expenditures for Natural Gas Production=
	Change in Amount Spent on Industry Fuels[oil and gas extraction 06,natural gas if]
	+ Change in Amount Spent on Industry Fuels[energy pipelines and gas processing 352T353\
		,natural gas if]
	~	$
	~	For simplicity, we assume that all natural gas used by the "oil and gas \
		extraction" and "energy pipelines and gas processing" industries is used \
		to help produce, process, and sell natural gas, not crude oil or petroleum \
		products.
	|

Industry Sector Change in Fuel Industry Cash Flow[Industrial Fuel] :EXCEPT: [hard coal if\
		],[natural gas if],[petroleum diesel if],[crude oil if],[heavy or residual fuel oil if\
		],[LPG propane or butane if]=
	SUM(Cash Flow Change for Fuel Industry from Industry Fuel Use[Industry Category!,Industrial Fuel\
		]) ~~|
Industry Sector Change in Fuel Industry Cash Flow[hard coal if]=
	SUM(Cash Flow Change for Fuel Industry from Industry Fuel Use[Industry Category!,hard coal if\
		])
	
	+ Change in Industry Sector Carbon Tax Rebate due to CCS[coal mining 05] ~~|
Industry Sector Change in Fuel Industry Cash Flow[natural gas if]=
	SUM(Cash Flow Change for Fuel Industry from Industry Fuel Use[Industry Category!,natural gas if\
		])
	
	+ Change in Industry Sector Carbon Tax Rebate due to CCS[oil and gas extraction 06]
	  * ZIDZ(
	      Fuel Production[natural gas],
	
	      Fuel Production[natural gas]
	      + Fuel Production[crude oil]
	  )
	
	+ Change in Industry Sector Carbon Tax Rebate due to CCS[energy pipelines and gas processing 352T353\
		] ~~|
Industry Sector Change in Fuel Industry Cash Flow[petroleum diesel if]=
	SUM(Cash Flow Change for Fuel Industry from Industry Fuel Use[Industry Category!,petroleum diesel if\
		])
	
	+ Change in Industry Sector Carbon Tax Rebate due to CCS[refined petroleum and coke 19\
		]
	  * ZIDZ(
	      Fuel Production[petroleum diesel],
	
	      SUM(Fuel Production[secondary petroleum product within all fuels!])
	        - Fuel Production[petroleum gasoline]
	        - Fuel Production[jet fuel or kerosene]
	    ) ~~|
Industry Sector Change in Fuel Industry Cash Flow[crude oil if]=
	SUM(Cash Flow Change for Fuel Industry from Industry Fuel Use[Industry Category!,crude oil if\
		])
	
	+ Change in Industry Sector Carbon Tax Rebate due to CCS[oil and gas extraction 06]
	  * ZIDZ(
	      Fuel Production[crude oil],
	
	      Fuel Production[natural gas]
	      + Fuel Production[crude oil]
	  ) ~~|
Industry Sector Change in Fuel Industry Cash Flow[heavy or residual fuel oil if]=
	SUM(Cash Flow Change for Fuel Industry from Industry Fuel Use[Industry Category!,heavy or residual fuel oil if\
		])
	
	+ Change in Industry Sector Carbon Tax Rebate due to CCS[refined petroleum and coke 19\
		]
	  * ZIDZ(
	      Fuel Production[heavy or residual fuel oil],
	
	      SUM(Fuel Production[secondary petroleum product within all fuels!])
	        - Fuel Production[petroleum gasoline]
	        - Fuel Production[jet fuel or kerosene]
	    ) ~~|
Industry Sector Change in Fuel Industry Cash Flow[LPG propane or butane if]=
	SUM(Cash Flow Change for Fuel Industry from Industry Fuel Use[Industry Category!,LPG propane or butane if\
		])
	
	+ Change in Industry Sector Carbon Tax Rebate due to CCS[refined petroleum and coke 19\
		]
	  * ZIDZ(
	      Fuel Production[LPG propane or butane],
	
	      SUM(Fuel Production[secondary petroleum product within all fuels!])
	        - Fuel Production[petroleum gasoline]
	        - Fuel Production[jet fuel or kerosene]
	    )
	~	$
	~	The carbon tax rebates due to CCS paid to industry categories are revenue \
		for the relevant fuel-supplying industries only (when the rebate is \
		assigned to a fuel-supplying industry).  The rebate amounts paid to \
		non-fuel-supplying industries should not be included in this variable.  Do \
		not be confused by the fact that all industries can use CCS with various \
		industrial fuel types - that is not what we need in this variable.  For \
		the NGPS industry, we divide up their rebate amongst the fuels they \
		produce according to the total production of each such fuel (excluding \
		fuels not in the "Industrial Fuel" subscript - i.e. petroleum gasoline and \
		jet fuel or kerosene).
	|

Industry Sector Change in Fuel Industry Cash Flow Including Subsidies Mapped to All Fuels Subscript\
		[All Fuels] :EXCEPT:    [industrial fuel within all fuels
]=
	0 ~~|
Industry Sector Change in Fuel Industry Cash Flow Including Subsidies Mapped to All Fuels Subscript\
		[industrial fuel within all fuels] :EXCEPT: [hydrogen]=
	Industry Sector Change in Fuel Industry Cash Flow[Industrial Fuel] ~~|
Industry Sector Change in Fuel Industry Cash Flow Including Subsidies Mapped to All Fuels Subscript\
		[hydrogen]=
	Industry Sector Change in Fuel Industry Cash Flow[hydrogen if]
	+ Industry Sector Change in Fuel Industry Cash Flow[green hydrogen if]
	+ Industry Sector Change in Fuel Industry Cash Flow[low carbon hydrogen if]
	~	$
	~		|

Industry Sector Change in Fuel Industry Cash Flow Mapped to All Fuels Subscript[All Fuels\
		] :EXCEPT:  [industrial fuel within all fuels
]=
	0 ~~|
Industry Sector Change in Fuel Industry Cash Flow Mapped to All Fuels Subscript[industrial fuel within all fuels\
		] :EXCEPT:   [hydrogen]=
	SUM(Cash Flow Change for Fuel Industry from Industry Fuel Use[Industry Category!,Industrial Fuel\
		]) ~~|
Industry Sector Change in Fuel Industry Cash Flow Mapped to All Fuels Subscript[hydrogen\
		]=
	SUM(Cash Flow Change for Fuel Industry from Industry Fuel Use[Industry Category!,hydrogen if\
		]
	+ Cash Flow Change for Fuel Industry from Industry Fuel Use[Industry Category!,green hydrogen if\
		]
	+ Cash Flow Change for Fuel Industry from Industry Fuel Use[Industry Category!,low carbon hydrogen if\
		])
	~	$
	~		|

Industry Sector Change in Government Subsidy Amount Paid[Industry Category]=
	Industry Sector Change in CCS Subsidy Amount Paid[Industry Category]
	+ Change in Industrial Clean Heat Investment Subsidies Paid[Industry Category]
	+ Change in Industrial Clean Heat Production Subsidies Paid[Industry Category]
	+ Industry Sector Change in CCS Transportation and Storage Subsidies[Industry Category\
		]
	+ SUM(Government Incentives for Process Emissions Policies Paid to Abating Industries\
		[Industry Category,Industry Process Emissions Policy
	!])
	~	$
	~		|

Industry Sector Change in Government Subsidy Payments by Entity[Cash Flow Entity] :EXCEPT:\
		    [nonenergy industries]=
	0 ~~|
Industry Sector Change in Government Subsidy Payments by Entity[nonenergy industries]\
		=
	SUM(Industry Sector Change in Government Subsidy Amount Paid[Industry Category!])
	~	$
	~		|

Industry Sector Change in Government Subsidy Payments by ISIC Code[ISIC Code] :EXCEPT:\
		  [Industry Category ISIC Code],[ISIC 64T66]=
	0 ~~|
Industry Sector Change in Government Subsidy Payments by ISIC Code[Industry Category ISIC Code\
		]=
	Change in Industrial Clean Heat Production Subsidies Paid[Industry Category]
	+ SUM(Government Incentives for Process Emissions Policies Paid to Abating Industries\
		[Industry Category,Industry Process Emissions Policy!])
	+ Industry Sector Change in CCS Subsidy Amount Paid[Industry Category]
	+ Industry Sector Change in CCS Transportation and Storage Subsidies[Industry Category\
		] ~~|
Industry Sector Change in Government Subsidy Payments by ISIC Code[ISIC 64T66]=
	SUM(Change in Industrial Clean Heat Investment Subsidies Paid[Industry Category!])
	~	$
	~		|

Industry Sector Change in Miscellaneous Expenditures by Entity[Cash Flow Entity] :EXCEPT:\
		        [nonenergy industries],
[coal suppliers],[natural gas and petroleum suppliers]=
	0 ~~|
Industry Sector Change in Miscellaneous Expenditures by Entity[nonenergy industries]=
	SUM(Change in Miscellaneous Expenditures by Industry[nonenergy industries within industry category\
		!]) ~~|
Industry Sector Change in Miscellaneous Expenditures by Entity[coal suppliers]=
	Change in Miscellaneous Expenditures by Industry[coal mining 05] ~~|
Industry Sector Change in Miscellaneous Expenditures by Entity[natural gas and petroleum suppliers\
		]=
	Change in Miscellaneous Expenditures by Industry[oil and gas extraction 06]
	+ Change in Miscellaneous Expenditures by Industry[refined petroleum and coke 19]
	+ Change in Miscellaneous Expenditures by Industry[energy pipelines and gas processing 352T353\
		]
	~	$
	~		|

Industry Sector Change in New CCS Capital Eqpt Costs That Are Financed[Industry Category\
		]=
	Industry Sector Change in CCS New Capital Eqpt Cost[Industry Category]
	* SoICETAF Share of Industry Capital Expenditures That Are Financed[Industry Category\
		]
	~	$
	~		|

Industry Sector Change in New CCS Capital Eqpt Costs That Are Not Financed[Industry Category\
		]=
	Industry Sector Change in CCS New Capital Eqpt Cost[Industry Category]
	* (1 - SoICETAF Share of Industry Capital Expenditures That Are Financed[Industry Category\
		])
	~	$
	~		|

Industry Sector Change in Nonenergy Expenditures by Entity[Cash Flow Entity] :EXCEPT:\
		      [government]=
	Industry Sector Change in Miscellaneous Expenditures by Entity[Cash Flow Entity]
	+ Change in Nonenergy Expenditures by Entity due to Production Changes[Cash Flow Entity\
		]
	+ Change in Nonenergy Expenditures by Entity due to Expense Passthrough[Cash Flow Entity\
		]
	+ Change in Expenditures on Nonenergy Imports and Exports by Entity[Cash Flow Entity\
		]
	+ Industry Sector Change in Upfront Capital Expenditures by Industry[Cash Flow Entity\
		] ~~|
Industry Sector Change in Nonenergy Expenditures by Entity[government]=
	Industry Sector Change in Miscellaneous Expenditures by Entity[government]
	+ Change in Nonenergy Expenditures by Entity due to Production Changes[government]
	+ Change in Nonenergy Expenditures by Entity due to Expense Passthrough[government]
	+ Change in Expenditures on Nonenergy Imports and Exports by Entity[government]
	+ Industry Sector Change in Upfront Capital Expenditures by Industry[government]
	
	+ SUM(Industry Sector Change in Government Subsidy Amount Paid[Industry Category!])
	
	+ SUM(Change in Carbon Tax Rebates[Industry Category!])
	~	$
	~		|

Industry Sector Change in Nonenergy Industry Expenditures by ISIC Code[ISIC Code] :EXCEPT:\
		        [Industry Category ISIC Code
],[Fossil and Energy Utility ISIC Code],[ISIC 64T66]=
	SUM(Change in Nonenergy Industry Revenues due to Production Changes by Purchasing ISIC Code\
		[Industry Category!,ISIC Code
	])
	+ SUM(Nonenergy Industry Expense Passthrough by Purchasing ISIC Code[Industry Category\
		!,ISIC Code])
	+ SUM(Nonenergy Industry Change in Expenditures on Nonenergy Imports by Purchasing ISIC Code\
		[Industry Category!,ISIC Code
	]) ~~|
Industry Sector Change in Nonenergy Industry Expenditures by ISIC Code[Industry Category ISIC Code\
		] :EXCEPT:          [Fossil and Energy Utility ISIC Code
]=
	SUM(Change in Amount Spent on Industry Fuels[Industry Category,Industrial Fuel!])
	
	+ Change in Miscellaneous Expenditures by Industry[Industry Category]
	
	+ SUM(Change in Nonenergy Industry Revenues due to Production Changes by Purchasing ISIC Code\
		[Industry Category!,Industry Category ISIC Code
	])
	+ SUM(Nonenergy Industry Expense Passthrough by Purchasing ISIC Code[Industry Category\
		!,Industry Category ISIC Code])
	+ SUM(Nonenergy Industry Change in Expenditures on Nonenergy Imports by Purchasing ISIC Code\
		[Industry Category!,Industry Category ISIC Code
	])
	+ Change in Upfront Capital Expenditures by Industry for Non Financed Equipment[Industry Category\
		] ~~|
Industry Sector Change in Nonenergy Industry Expenditures by ISIC Code[Fossil and Energy Utility ISIC Code\
		]=
	SUM(Change in Nonenergy Industry Revenues due to Production Changes by Purchasing ISIC Code\
		[Industry Category!,Fossil and Energy Utility ISIC Code
	])
	+ SUM(Nonenergy Industry Expense Passthrough by Purchasing ISIC Code[Industry Category\
		!,Fossil and Energy Utility ISIC Code
	])
	+ SUM(Nonenergy Industry Change in Expenditures on Nonenergy Imports by Purchasing ISIC Code\
		[Industry Category!,Fossil and Energy Utility ISIC Code
	]) ~~|
Industry Sector Change in Nonenergy Industry Expenditures by ISIC Code[ISIC 64T66]=
	SUM(Change in Nonenergy Industry Revenues due to Production Changes by Purchasing ISIC Code\
		[Industry Category!,ISIC 64T66
])
	+ SUM(Nonenergy Industry Expense Passthrough by Purchasing ISIC Code[Industry Category\
		!,ISIC 64T66])
	+ SUM(Nonenergy Industry Change in Expenditures on Nonenergy Imports by Purchasing ISIC Code\
		[Industry Category!,ISIC 64T66
])
	
	+ SUM(Change in Upfront Capital Expenditures by Industry for Financed Equipment[Industry Category\
		!])
	~	$
	~	In this variable, energy industry ISIC codes (fossil and utility ISIC \
		codes) should be treated similarly to ISIC codes without a matching \
		industry category.
	|

Industry Sector Change in Nonenergy Industry Revenue by ISIC Code[ISIC Code] :EXCEPT:\
		                [Industry Category ISIC Code
],[ISIC 64T66]=
	Nonenergy Industry Expenses Passed Through to Buyers by Producer ISIC Code[ISIC Code\
		]
	
	+ Industry Sector Change in Capital and OM Spending[nonenergy industries]
	  * SoCaOMSbRIC Share of Capital and OM Spending by Recipient ISIC Code[ISIC Code]
	
	+ Change in Revenue from Industry Process Emissions Policies by Recipient ISIC Code[\
		ISIC Code]
	
	+ Industry Sector Change in CCS Transportation and Storage Costs by Recipient ISIC Code\
		[ISIC Code] ~~|
Industry Sector Change in Nonenergy Industry Revenue by ISIC Code[Industry Category ISIC Code\
		]=
	Change in Carbon Tax Rebates[Industry Category]
	
	+ SUM(Change in Nonenergy Industry Revenues due to Production Changes by Purchasing Entity\
		[Industry Category,Cash Flow Entity
	!])
	+ Nonenergy Industry Expenses Passed Through to Buyers by Producer ISIC Code[Industry Category ISIC Code\
		]
	
	+ Industry Sector Change in Capital and OM Spending[nonenergy industries]
	  * SoCaOMSbRIC Share of Capital and OM Spending by Recipient ISIC Code[Industry Category ISIC Code\
		]
	
	+ Change in Revenue from Industry Process Emissions Policies by Recipient ISIC Code[\
		Industry Category ISIC Code]
	
	+ Change in Exports of Nonenergy Products[Industry Category]
	
	+ Industry Sector Change in Government Subsidy Payments by ISIC Code[Industry Category ISIC Code\
		]
	
	+ Industry Sector Change in CCS Transportation and Storage Costs by Recipient ISIC Code\
		[Industry Category ISIC Code] ~~|
Industry Sector Change in Nonenergy Industry Revenue by ISIC Code[ISIC 64T66 {Financial and insurance activities}\
		]=
	Nonenergy Industry Expenses Passed Through to Buyers by Producer ISIC Code[ISIC 64T66\
		]
	
	+ Industry Sector Change in Capital and OM Spending[nonenergy industries]
	  * SoCaOMSbRIC Share of Capital and OM Spending by Recipient ISIC Code[ISIC 64T66]
	
	+ Change in Revenue from Industry Process Emissions Policies by Recipient ISIC Code[\
		ISIC 64T66]
	
	+ Industry Sector Change in CCS Transportation and Storage Costs by Recipient ISIC Code\
		[ISIC 64T66]
	
	+ SUM(Change in Financing Repayments for Industrial Equipment[Industry Category!])
	
	+ SUM(Financing Repayments for Waste Heat Recovery Equipment[Industry Category!])
	
	+ SUM(Change in Financing Repayments for Industrial CCS Equipment[Industry Category!\
		])
	
	+ Industry Sector Change in Government Subsidy Payments by ISIC Code[ISIC 64T66]
	~	$
	~	Each Nonenergy Industry Category ISIC Code receives revenue from (#1) any \
		carbon tax rebates to the matching industry, (#2a) the matching industry's \
		revenues from selling non-energy products to any/all cash flow entities, \
		(#2b) any expenses the matching industry passes through in the cost of \
		non-energy products to buyers, and (#3) any revenue from that industry's \
		sales of capital equipment or OM to other industries, (#4) any revenue \
		from industries' implementation of process emissions policies, (#5) \
		revenue from each industry's change in exports.
	|

Industry Sector Change in Nonenergy Industry Revenue by ISIC Code Minus Government Subsidies\
		[ISIC Code]=
	Industry Sector Change in Nonenergy Industry Revenue by ISIC Code[ISIC Code]
	- Industry Sector Change in Government Subsidy Payments by ISIC Code[ISIC Code]
	~	$
	~		|

Industry Sector Change in Revenue by Entity[Cash Flow Entity] :EXCEPT:         [nonenergy industries\
		]=
	Change in Process Emissions Policy Revenue by Entity[Cash Flow Entity]
	+ Industry Sector Change in Capital and OM Spending[Cash Flow Entity]
	+ Other Changes in Industry Sector Tax and Tax Rebate Revenues[Cash Flow Entity]
	+ Change in Industry Sector Fuel Supplier Revenue by Entity[Cash Flow Entity]
	+ Changes in Nonenergy Revenue by Entity due to Production Changes[Cash Flow Entity]
	+ Changes in Nonenergy Revenue by Entity due to Expense Passthrough[Cash Flow Entity\
		]
	+ Change in Nonenergy Industry Product Imports and Exports by Entity[Cash Flow Entity\
		]
	+ Industry Sector Change in Government Subsidy Payments by Entity[Cash Flow Entity] ~~|
Industry Sector Change in Revenue by Entity[nonenergy industries]=
	Change in Process Emissions Policy Revenue by Entity[nonenergy industries]
	+ Industry Sector Change in Capital and OM Spending[nonenergy industries]
	+ Other Changes in Industry Sector Tax and Tax Rebate Revenues[nonenergy industries]
	+ Change in Industry Sector Fuel Supplier Revenue by Entity[nonenergy industries]
	+ Changes in Nonenergy Revenue by Entity due to Production Changes[nonenergy industries\
		]
	+ Changes in Nonenergy Revenue by Entity due to Expense Passthrough[nonenergy industries\
		]
	+ Change in Nonenergy Industry Product Imports and Exports by Entity[nonenergy industries\
		]
	+ Industry Sector Change in Government Subsidy Payments by Entity[nonenergy industries\
		]
	+ SUM(Industry Sector Change in CCS Transportation and Storage Costs[Industry Category\
		!])
	+ SUM(Change in Financing Repayments for Industrial Equipment[Industry Category!])
	+ SUM(Financing Repayments for Waste Heat Recovery Equipment[Industry Category!])
	+ SUM(Change in Financing Repayments for Industrial CCS Equipment[Industry Category!\
		])
	~	$
	~		|

Industry Sector Change in Upfront Capital Expenditures by Industry[Cash Flow Entity] \
		:EXCEPT:  [nonenergy industries],[coal suppliers
],[natural gas and petroleum suppliers]=
	0 ~~|
Industry Sector Change in Upfront Capital Expenditures by Industry[nonenergy industries\
		]=
	SUM(Change in Upfront Capital Expenditures by Industry for Financed Equipment[nonenergy industries within industry category
	!])
	+ SUM(Change in Upfront Capital Expenditures by Industry for Non Financed Equipment[\
		nonenergy industries within industry category!]) ~~|
Industry Sector Change in Upfront Capital Expenditures by Industry[ coal suppliers]=
	Change in Upfront Capital Expenditures by Industry for Financed Equipment[coal mining 05\
		]
	+ Change in Upfront Capital Expenditures by Industry for Non Financed Equipment[coal mining 05\
		] ~~|
Industry Sector Change in Upfront Capital Expenditures by Industry[natural gas and petroleum suppliers\
		]=
	Change in Upfront Capital Expenditures by Industry for Financed Equipment[oil and gas extraction 06\
		]
	+ Change in Upfront Capital Expenditures by Industry for Financed Equipment[refined petroleum and coke 19\
		]
	+ Change in Upfront Capital Expenditures by Industry for Financed Equipment[energy pipelines and gas processing 352T353
	]
	+ Change in Upfront Capital Expenditures by Industry for Non Financed Equipment[oil and gas extraction 06\
		]
	+ Change in Upfront Capital Expenditures by Industry for Non Financed Equipment[refined petroleum and coke 19\
		]
	+ Change in Upfront Capital Expenditures by Industry for Non Financed Equipment[energy pipelines and gas processing 352T353\
		]
	~	$
	~		|

Industry Sector CO2e Emissions[Industry Category,Pollutant]=
	Industrial Sector Pollutant Emissions[Industry Category,Pollutant]
	* GWP by Pollutant[Pollutant]
	~	g CO2e
	~		|

Industry Sector Energy Use by Industry[Industry Category,All Fuels] :EXCEPT:  [Industry Category\
		,industrial fuel within all fuels]=
	0 ~~|
Industry Sector Energy Use by Industry[Industry Category,industrial fuel within all fuels\
		] :EXCEPT: [Industry Category,hydrogen]=
	Industrial Fuel Use[Industrial Fuel,Industry Category] ~~|
Industry Sector Energy Use by Industry[Industry Category,hydrogen]=
	Industrial Fuel Use[hydrogen if,Industry Category]
	+ Industrial Fuel Use[green hydrogen if,Industry Category]
	+ Industrial Fuel Use[low carbon hydrogen if,Industry Category]
	~	BTU
	~		|

Industry Sector Excluding Ag and Waste Pollutant Emissions[Pollutant]=
	SUM(Industrial Sector Pollutant Emissions[Industry Category!,Pollutant])
	  - Industrial Sector Pollutant Emissions[agriculture and forestry 01T03,Pollutant]
	  - Industrial Sector Pollutant Emissions[water and waste 36T39,Pollutant]
	~	g pollutant
	~		|

Industry Sector Final Energy Use by Industry[All Fuels,Industry Category] :EXCEPT:    \
		[industrial fuel within all fuels,Industry Category]=
	0 ~~|
Industry Sector Final Energy Use by Industry[industrial fuel within all fuels,Industry Category\
		] :EXCEPT: [hydrogen,Industry Category]=
	Industrial Fuel Use[Industrial Fuel,Industry Category]
	- Industrial Fuel Use for Non Energy Purposes[Industry Category,Industrial Fuel] ~~|
Industry Sector Final Energy Use by Industry[hydrogen,Industry Category]=
	Industrial Fuel Use[hydrogen if,Industry Category]
	- Industrial Fuel Use for Non Energy Purposes[Industry Category,hydrogen if]
	
	+ Industrial Fuel Use[green hydrogen if,Industry Category]
	- Industrial Fuel Use for Non Energy Purposes[Industry Category,green hydrogen if]
	
	+ Industrial Fuel Use[low carbon hydrogen if,Industry Category]
	- Industrial Fuel Use for Non Energy Purposes[Industry Category,low carbon hydrogen if\
		]
	~	BTU
	~		|

Industry Sector Minimum Fraction of CCS Achieved[Industry Category,Emissions Type]=
	0,	0;	{agriculture and forestry 01T03}
	0,	0;	{coal mining 05}
	0,	0;	{oil and gas extraction 06}
	0,	0;	{other mining and quarrying 07T08}
	0,	0;	{food beverage and tobacco 10T12}
	0,	0;	{textiles apparel and leather 13T15}
	0,	0;	{wood products 16}
	0,	0;	{pulp paper and printing 17T18}
	0,	0;	{refined petroleum and coke 19}
	0,	0;	{chemicals 20}
	0,	0;	{rubber and plastic products 22}
	0,	0;	{glass and glass products 231}
	0,	0;	{cement and other nonmetallic minerals 239}
	0,	0;	{iron and steel 241}
	0,	0;	{other metals 242}
	0,	0;	{metal products except machinery and vehicles 25}
	0,	0;	{computers and electronics 26}
	0,	0;	{appliances and electrical equipment 27}
	0,	0;	{other machinery 28}
	0,	0;	{road vehicles 29}
	0,	0;	{nonroad vehicles 30}
	0,	0;	{other manufacturing 31T33}
	0,	0;	{energy pipelines and gas processing 352T353}
	0,	0;	{water and waste 36T39}
	0,	0;	{construction 41T43}
	{enrgy}	{process}
	~	Dmnl [0,1]
	~		|

Industry Sector Minimum Fraction of CCS Achieved This Year[Industry Category,Emissions Type\
		]=
	Industry Sector Minimum Fraction of CCS Achieved[Industry Category,Emissions Type]
	* VECTOR ELM MAP(
	    Selected Policy Implementation Schedule[indst CCS X agriculture and forestry 01T03 X energy related emissions\
		],
	
	    (Industry Category-1)*ELMCOUNT(Emissions Type) + (Emissions Type-1)
	  )
	~	Dmnl
	~		|

Industry Sector Other Fuel Tax Revenue=
	SUM(Industrial Fuel Use[Industrial Fuel!,Industry Category!]
	* Industrial Fuel Other Tax or Subsidy Amount per Unit Energy[Industrial Fuel!]
	* (1 - SoFCTiBoSFbI Share of Fuel Consumption That is Byproduct or Secondary Fuels by Industry\
		[Industry Category!,Industrial Fuel!]))
	~	$
	~		|

Industry Sector Primary Energy Use by Industry[Industry Category,All Fuels] :EXCEPT:  \
		[Industry Category,primary fuel]=
	0 ~~|
Industry Sector Primary Energy Use by Industry[Industry Category,primary fuel]=
	Industry Sector Energy Use by Industry[Industry Category,primary fuel]
	~	BTU
	~		|

Industry Subtotal Change in Capital Expenditures=
	SUM(Industry Sector Change in CCS New Capital Eqpt Cost[Industry Category!])
	
	+ SUM(Change in Upfront Capital Expenditures on New Industrial Equipment[Industry Category\
		!])
	
	+ SUM(New Waste Heat Recovery Equipment Capital Expenditures[Industry Category!])
	
	+ SUM(Cost of Process Emissions Policies[Industry Category!,Industry Process Emissions Policy\
		!])
	
	+ SUM(Change in Expenditures on Nonenergy Imports by Entity[Industry Category!,Cash Flow Entity\
		!])
	
	{+ SUM(Changes in Nonenergy Expenditures by Entity due to Production Changes[Cash Flow Entity!])}
	~	$
	~	We assume that "Changes in Nonenergy Expenditures by Entity due to \
		Production Changes" are largely capital expenditures, rather than OM \
		expenditures, as we have no great way to divide these expenditures between \
		these two categories.
	|

Industry Subtotal Change in OM Expenditures=
	SUM(Industry Sector Change in CCS OM Cost[Industry Category!])
	
	+ SUM(Industry Sector Change in CCS Transportation and Storage Costs[Industry Category\
		!])
	
	+ SUM(Cost of Process Emissions Policies[Industry Category!,Industry Process Emissions Policy\
		!])
	~	$
	~		|

Industry Subtotal Change in Other Expenditures=
	SUM(Change in Industry Sector Carbon Tax Rebate due to CCS[Industry Category!])
	+ SUM(Industry Sector Change in Government Subsidy Amount Paid[Industry Category!])
	~	$
	~		|

Industry Subtotal Change in Tax Revenues=
	Industry Sector Change in Capital and OM Spending[government]
	+ SUM(Change in Carbon Tax on Process Emissions by Industry[Industry Category!])
	+ SUM(Change in Taxes Paid on Industry Fuels[Industry Category!,Industrial Fuel!])
	~	$
	~		|

Infant Deaths by Demographic Trait[demographic trait excluding age bracket]=
	MAX(
	  0,
	
	  BDbDT BAU Infant Deaths by Demographic Trait[demographic trait excluding age bracket\
		]
	  - Reduction in Infant Premature Mortality by Demographic Trait[demographic trait excluding age bracket\
		]
	)
	~	incidents
	~		|

Initial BAU Energy Imports including Electricity[All Fuels]= INITIAL(
	BAU Energy Imports including Electricity[All Fuels])
	~	BTU
	~		|

Initial BAU Energy Production including Energy Carriers[All Fuels]= INITIAL(
	BAU Energy Production including Energy Carriers[All Fuels])
	~	BTU
	~		|

Initial BAU Fuel Production Imports and Exports[All Fuels,Fuel Balancing Mode]= INITIAL\
		(
	BAU Fuel Production Imports and Exports[All Fuels,Fuel Balancing Mode])
	~	BTU
	~		|

Initial BAU Weighted Average Pretax Fuel Price by Fuel[All Fuels]= INITIAL(
	ZIDZ(
	
	  SUM(
	    BAU Total Energy Use by Sector[Sectors!,All Fuels]
	    * BAU Pretax Fuel Price by Sector Including Endogenous Electricity Prices[All Fuels\
		,Sectors!]
	  )
	  + BAU Fuel Production Imports and Exports[All Fuels,exports]
	    * IMFPbFT International Market Fuel Price by Fuel Type[All Fuels],
	
	  SUM(BAU Total Energy Use by Sector[Sectors!,All Fuels])
	  + BAU Fuel Production Imports and Exports[All Fuels,exports]
	))
	~	$/BTU
	~	This variable helps to adjust within-industry "jobs per unit output" \
		itensities in the I/O model.  We use pretax prices because taxes don't \
		turn into revenue for the fuel industry, so they don't turn into fuel \
		industry jobs.
	|

Initial BAU Weighted Average Pretax Fuel Price by Producing ISIC Code[ISIC Code]= INITIAL\
		(
	ZIDZ(
	  SUM(
	    Initial BAU Weighted Average Pretax Fuel Price by Fuel[All Fuels!]
	    * BAU Total Energy Use by Sector[Sectors!,All Fuels!]
	    * FtPICM Fuel to Producing ISIC Code Map[All Fuels!,ISIC Code]
	  ),
	
	  SUM(
	    BAU Total Energy Use by Sector[Sectors!,All Fuels!]
	    * FtPICM Fuel to Producing ISIC Code Map[All Fuels!,ISIC Code]
	  )
	))
	~	$/BTU
	~	Some ISIC codes supply more than one fuel type, so we need to weight the \
		impact on each ISIC code by the share of each type of fuel it supplies.  \
		We weight using total fuel use (not total fuel production) so that a \
		weighted average price can be computed even in regions with zero or low \
		fuel production, but with fuel imports (for instance, a region that \
		imports and sells natural gas but doesn't produce natural gas, such as \
		some U.S. states).
	|

Initial Domestically Produced Energy by Producing ISIC Code[ISIC Code]= INITIAL(
	Domestically Produced Energy by Producing ISIC Code[ISIC Code])
	~	BTU
	~		|

Initial Guess at Capacity Market Price=
	150
	~	$/(MW*day)
	~		|

Initial Guess at CES Price=
	MAX(Last Year Optimized CES Credit Price,
	  MAX(5,
	    ZIDZ(
	      SUM(
	        Cost per Unit New Elec Output Using Expected Capacity Factors[Electricity Source\
		!]
	        *Last Year Electricity Generation Capacity[Electricity Source!]
	        *Elec Portfolio Qualifying Sources[Electricity Source!,CES]
	      ),
	
	      SUM(Elec Portfolio Qualifying Sources[Electricity Source!,CES]*Last Year Electricity Generation Capacity\
		[Electricity Source
	!])
	    )
	  )
	)
	~	$/(MW*hr)
	~	We use a maximum of $5/MWh or the calculated value.
	|

Initial Guess at RPS Price=
	MAX(Last Year Optimized RPS Credit Price,
	  MAX(5,
	    ZIDZ(
	      SUM(
	        Cost per Unit New Elec Output Using Expected Capacity Factors[Electricity Source\
		!]
	        *Last Year Electricity Generation Capacity[Electricity Source!]
	        * Elec Portfolio Qualifying Sources[Electricity Source!,RPS]
	      ),
	
	      SUM(Elec Portfolio Qualifying Sources[Electricity Source!,RPS]*Last Year Electricity Generation Capacity\
		[Electricity Source
	!])
	    )
	  )
	)
	~	$/(MW*hr)
	~	We use a maximum of $5/MWh or the calculated value.
	|

Initial Output by Industry Category and Process[Industry Category,Industrial Process]\
		= INITIAL(
	Start Year Output by ISIC Code by Year[Industry Category ISIC Code]
	*
	ZIDZ(Total BAU Fuel Use for Energy Purposes by Industrial Process in Electricity Equivalent\
		[Industry Category,Industrial Process],
	  SUM(Total BAU Fuel Use for Energy Purposes by Industrial Process in Electricity Equivalent\
		[Industry Category,Industrial Process!])
	))
	~	$
	~		|

Initial Time Dimensionless=
	INITIAL TIME / One Year
	~	Dmnl
	~		|

Interregional Electricity Trade Costs=
	Amount Spent on Importing Electricity
	-Amount Received from Exporting Electricity
	~	$
	~		|

Inverted Spare Potential Output from Surviving Capacity by Hour by Optimization Pass[\
		Electricity Timeslice,Hour,pass1]=
	MAX(0,ZIDZ(1,Total Electricity Demand by Hour before Net Imports[Electricity Timeslice\
		,Hour])) ~~|
Inverted Spare Potential Output from Surviving Capacity by Hour by Optimization Pass[\
		Electricity Timeslice,Hour,current pass]=
	MAX(0,ZIDZ(1,Total Electricity Demand by Hour before Net Imports[Electricity Timeslice\
		,Hour]))
	  *IF THEN ELSE(Share of Max Hourly Exports Met[Electricity Timeslice,Hour,preceeding pass\
		]=1,0,1)
	~	1/(MW*hr)
	~		|

