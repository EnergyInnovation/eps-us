Change in Crude Exports due to Changes in Secondary Petroleum Product Use=
	MAX(
	  -SUM(
	     Change in Total Fuel Use[secondary petroleum product within all fuels!]
	    * PoFDCtAE Percentage of Fuel Demand Change that Alters Exports[secondary petroleum product within all fuels\
		!,crude oil
	]
	  ),
	
	  -BAU Fuel Production Imports and Exports[crude oil,exports]
	)
	* (1 - Percent Reduction in Fossil Fuel Exports This Year[crude oil])
	~	BTU
	~		|

Change in Decommissioning Costs=
	Amortized Decommissioning Costs - BAU Amortized Decommissioning Costs
	~	$
	~		|

Change in Demand Response Costs by Recipient[Cash Flow Entity]=
	Cost of Providing Demand Response by Recipient[Cash Flow Entity]
	- BAU Cost of Providing Demand Response by Recipient[Cash Flow Entity]
	~	$
	~		|

Change in Distributed Capacity[Building Type, Electricity Source]=
	Distributed Electricity Source Capacity[Building Type,Electricity Source]
	- BAU Distributed Electricity Source Capacity[Building Type,Electricity Source]
	~	MW
	~		|

Change in Distribution Construction Costs=
	DEPRECIATE STRAIGHTLINE(
	
	  (Distribution Construction Costs-BAU Distribution Construction Costs),
	 
	  STfESCE Smoothing Time for Electricity Sector Capital Expenditures,
	
	  1,
	
	  0
	)
	~	$
	~	We use a DEPRECIATE STRAIGHTLINE function to even out price spikes that \
		unrealistically affect the price of electricity, because the costs of \
		construction of new generation assets really would be spread out over a \
		few years.  We use an initial value of zero because prior to the start of \
		the model run, the change in construction costs due to policies is zero \
		(none were in effect).
	|

Change in Distribution Construction Costs by Recipient ISIC Code[ISIC Code]=
	Change in Distribution Construction Costs
	* SoTaCCbIC Share of Transmission and Distribution Capital Costs by ISIC Code[ISIC Code\
		]
	~	$
	~		|

Change in Distribution OM Costs=
	Distribution OM Costs-BAU Distribution OM Costs
	~	$
	~		|

Change in Distribution OM Costs by Recipient ISIC Code[ISIC Code]=
	Change in Transmission OM Costs
	* SoTaDOMCbIC Share of Transmission and Distribution OM Costs by ISIC Code[ISIC Code\
		]
	~	$
	~		|

Change in District Heat Supplier Expenditures per Unit Heat Produced=
	ZIDZ(
	  District Heating Change in Energy Expenditures by Entity[other energy suppliers]
	  + District Heating Change in Nonenergy Expenditures by Entity[other energy suppliers\
		],
	
	  Total District Heat Use
	)
	* MIN(
	    1,
	
	    ZIDZ(
	      Total District Heat Use,
	
	      First Year Total Heat Use
	    )
	  )
	~	$/BTU
	~	The term in the MIN function dampens instability that happens if district \
		heat use approaches zero.
	|

Change in District Heating Pollutant Emissions[Pollutant]=
	SUM(District Heating Pollutant Emissions[Pollutant,Industrial Fuel!])
	- SUM(BAU District Heating Pollutant Emissions[Pollutant,Industrial Fuel!])
	~	g pollutant
	~		~	:SUPPLEMENTARY 
	|

Change in Domestic Consumption of Nonenergy Products[Industry Category]=
	Change in Domestic Output by ISIC Code[Industry Category ISIC Code]
	+ Change in Imports of Nonenergy Products[Industry Category]
	- Change in Exports of Nonenergy Products[Industry Category]
	~	$
	~		|

Change in Domestic Content Share of Consumption by ISIC Code[ISIC Code]=
	Domestic Content Share of Consumption by ISIC Code[ISIC Code]
	- BAU Domestic Content Share of Consumption by ISIC Code from Exogenous Data[ISIC Code\
		]
	~	Dmnl
	~		|

Change in Domestic Employee Compensation by ISIC Code[Target ISIC Code]=
	Direct Change in Domestic Compensation by ISIC Code[Target ISIC Code]
	+ Indirect Change in Domestic Compensation by ISIC Code[Target ISIC Code]
	+ Induced Change in Domestic Compensation by ISIC Code[Target ISIC Code]
	~	$
	~		|

Change in Domestic Individual Income Tax Revenue by ISIC Code[ISIC Code]=
	Change in Domestic Employee Compensation by ISIC Code[ISIC Code]
	* WMITR Worker Marginal Income Tax Rate
	~	$
	~		|

Change in Domestic Jobs after Productivity Effects by ISIC Code[ISIC Code]=
	Direct Change in Domestic Jobs after Productivity Effects by ISIC Code[ISIC Code]
	+ Indirect Change in Domestic Jobs after Productivity Effects by ISIC Code[ISIC Code\
		]
	+ Induced Change in Domestic Jobs after Productivity Effects by ISIC Code[ISIC Code]
	~	jobs
	~		|

Change in Domestic Jobs by Demographic Trait[Demographic Trait]=
	QUANTUM(
	  SUM(
	    Change in Domestic Jobs after Productivity Effects by ISIC Code[ISIC Code!]
	    * DoEbIC Demographics of Employees by ISIC Code[ISIC Code!,Demographic Trait]
	  ),
	
	  Quantization Size for Jobs
	)
	~	jobs
	~		|

Change in Domestic Jobs by Union Status[union]=
	QUANTUM(
	  SUM(
	    Change in Domestic Jobs after Productivity Effects by ISIC Code[ISIC Code!]
	    * URPbIC Union Representation Percentage by ISIC Code[ISIC Code!]
	  ),
	
	  Quantization Size for Jobs
	) ~~|
Change in Domestic Jobs by Union Status[nonunion]=
	QUANTUM(
	  SUM(
	    Change in Domestic Jobs after Productivity Effects by ISIC Code[ISIC Code!]
	    * (1 - URPbIC Union Representation Percentage by ISIC Code[ISIC Code!])
	  ),
	
	  Quantization Size for Jobs
	)
	~	jobs
	~		|

Change in Domestic Output by ISIC Code[ISIC Code]=
	ZIDZ(
	  Change in Domestic Value Added by ISIC Code[ISIC Code],
	
	  Within Industry Value Added per Unit Output[ISIC Code]
	)
	~	$
	~		|

Change in Domestic Value Added by ISIC Code[Target ISIC Code]=
	Direct Change in Domestic Value Added by ISIC Code[Target ISIC Code]
	+ Indirect Change in Domestic Value Added by ISIC Code[Target ISIC Code]
	+ Induced Change in Domestic Value Added by ISIC Code[Target ISIC Code]
	~	$
	~		|

Change in Electricity Demand from Demand Altering Technologies for Net Peak Load Reduction excluding Hybrid Batteries\
		[Electricity Timeslice
,Hour]=
	Increase in Demand by Hour for Seasonal Net Peak Load Reduction[Electricity Timeslice\
		,Hour]
	+ Increase in Demand by Hour for Diurnal Net Peak Load Reduction excluding Hybrid Batteries\
		[Electricity Timeslice,Hour]
	- Decrease in Demand by Hour for Seasonal Net Peak Load Reduction[Electricity Timeslice\
		,Hour]
	- Decrease in Demand by Hour for Diurnal Net Peak Load Reduction excluding Hybrid Batteries\
		[Electricity Timeslice,Hour]
	~	MW*hr
	~		|

Change in Electricity Demand from Demand Altering Technologies on Peak Summer Day[Hour\
		]=
	SUM(Change in Electricity Demand from Demand Altering Technologies for Net Peak Load Reduction excluding Hybrid Batteries
	[peak summer day electricity timeslice!,Hour])
	/ ELMCOUNT(peak summer day electricity timeslice)
	~	MW*hr
	~		|

Change in Electricity Demand from Demand Altering Technologies on Peak Winter Day[Hour\
		]=
	SUM(Change in Electricity Demand from Demand Altering Technologies for Net Peak Load Reduction excluding Hybrid Batteries
	[peak winter day electricity timeslice!,Hour])
	/ ELMCOUNT(peak winter day electricity timeslice)
	~	MW*hr
	~		|

Change in Electricity Exports=
	Exported Electricity
	- EIaE BAU Exported Electricity
	~	MW*hour
	~		|

Change in Electricity Fuel Taxes Paid[Electricity Source]=
	Total Tax Paid on Electricity Fuels[Electricity Source]
	- BAU Total Tax Paid on Electricity Fuels[Electricity Source]
	~	$
	~		|

Change in Electricity Generation by Type[Electricity Source]=
	Electricity Generation by Type[Electricity Source]
	- BAU Electricity Generation by Type[Electricity Source]
	~	MW*hour
	~		|

Change in Electricity Generation Capacity[Electricity Source]=
	Electricity Generation Capacity[Electricity Source]
	- BAU Electricity Generation Capacity[Electricity Source]
	~	MW
	~		|

Change in Electricity Generation Subsidies Paid[Electricity Source]=
	(This Year Ongoing Subsidies Paid per Unit Electricity Output[Electricity Source]
	- BAU This Year Ongoing Subsidies Paid per Unit Electricity Output[Electricity Source\
		])
	
	+ (Subsidies for Elec Production for Existing Plants Paid This Year[Electricity Source\
		]
	- BAU Subsidies for Elec Production for Existing Plants Paid This Year[Electricity Source\
		])
	~	$
	~		|

Change in Electricity Imports=
	Imported Electricity
	- BAU Imported Electricity
	~	MW*hour
	~		|

Change in Electricity Sector Battery Costs=
	DEPRECIATE STRAIGHTLINE(
	
	  Amount Spent on Grid Batteries
	  - BAU Amount Spent on Grid Batteries,
	 
	  STfESCE Smoothing Time for Electricity Sector Capital Expenditures,
	
	  1,
	
	  0
	)
	~	$
	~	We use a DEPRECIATE STRAIGHTLINE function to even out price spikes that \
		unrealistically affect the price of electricity, because the costs of \
		construction of new generation assets really would be spread out over a \
		few years.  We use an initial value of zero because prior to the start of \
		the model run, the change in construction costs due to policies is zero \
		(none were in effect).
	|

Change in Electricity Sector Capacity Construction Costs[Electricity Source]=
	DEPRECIATE STRAIGHTLINE(
	
	  Cost of Capacity Construction before Construction Subsidies[Electricity Source]
	  + Cost of Capacity Retrofitting before Construction Subsidies[Electricity Source]
	  - BAU Cost of Capacity Construction before Construction Subsidies[Electricity Source\
		]
	  - BAU Cost of Capacity Retrofitting before Construction Subsidies[Electricity Source\
		],
	 
	  STfESCE Smoothing Time for Electricity Sector Capital Expenditures,
	
	  1,
	
	  0
	)
	~	$
	~	We use a DEPRECIATE STRAIGHTLINE function to even out price spikes that \
		unrealistically affect the price of electricity, because the costs of \
		construction of new generation assets really would be spread out over a \
		few years.  We use an initial value of zero because prior to the start of \
		the model run, the change in construction costs due to policies is zero \
		(none were in effect).
	|

