Max Capacity Available for CCUS Retrofits after Mandated Retrofits[CCUS Electricity Source\
		]=
	MAX(0,(Max Capacity Available for CCUS Retrofit[CCUS Electricity Source]
	 - New Policy Mandated Retrofits[CCUS Electricity Source]))
	* IF THEN ELSE(
	    BBPPRTY BAU Ban Power Plant Retrofits This Year[CCUS Electricity Source]>0
	    :OR:
	    Boolean Ban New Power Plant Retrofits This Year[CCUS Electricity Source]>0,
	    0,
	    1
	  )
	~	MW
	~		|

Max Capacity Buildable after Cost Effective and RPS Additions[Electricity Source,Clean Elec Requirement\
		]=
	MAX(
	  0,
	
	  Max Capacity Buildable after Mandated and Required Clean Dispatchable Additions[Electricity Source\
		]
	  - New Capacity Desired due to Cost Effectiveness[Electricity Source,Clean Elec Requirement\
		]
	  - New Capacity Desired due to Cost Effectiveness for Hybrid Power Plants[Electricity Source\
		,Clean Elec Requirement]
	)
	~	MW
	~		|

Max Capacity Buildable after Mandated Additions[Electricity Source]=
	MAX(
	  0,
	
	  Max Capacity Buildable This Year[Electricity Source]
	  - New Policy Mandated Capacity[Electricity Source]
	)
	~	MW
	~		|

Max Capacity Buildable after Mandated and Required Clean Dispatchable Additions[Electricity Source\
		]=
	MAX(0,
	  Max Capacity Buildable after Mandated Additions[Electricity Source]
	  - New Dispatchable Only Clean Capacity Desired for Seasonal Reliability[Electricity Source\
		]
	 )
	~	MW
	~		|

Max Capacity Buildable This Year[Electricity Source]=
	IF THEN ELSE(
	
	  Boolean Ban New Power Plants This Year[Electricity Source] > 0
	  :OR:
	  BBNPPTY BAU Ban New Power Plants This Year[Electricity Source] > 0
	  :OR:
	  Boolean Plant Types that May Not be Built due to Having Been Retired to Zero[Electricity Source\
		] > 0,
	
	  0,
	
	  Max Additional Potential Capacity by Source[Electricity Source]
	)
	~	MW
	~		|

Max Capacity that Can be Retired Economically by Plant Type[Electricity Source]=
	SUM(
	  Last Year Electricity Generation Capacity by Vintage[Electricity Source,Modeled Vintage\
		!]
	  * Retirable Vintages by Year[Modeled Vintage!]
	)
	~	MW
	~		|

Maximum Absolute Increase in Fuel Exports[All Fuels]=
	Initial BAU Fuel Production Imports and Exports[All Fuels,exports]
	* MPIiFE Maximum Percentage Increase in Fuel Exports[All Fuels]
	~	BTU
	~		|

Maximum Absolute Increase in Fuel Imports[All Fuels]=
	Initial BAU Fuel Production Imports and Exports[All Fuels,imports]
	* MPIiFI Maximum Percentage Increase in Fuel Imports[All Fuels]
	~	BTU
	~		|

Maximum Absolute Increase in Fuel Production[All Fuels]=
	Initial BAU Fuel Production Imports and Exports[All Fuels,production]
	* MPIiFP Maximum Percentage Increase in Fuel Production[All Fuels]
	~	BTU
	~		|

Maximum Annual Decrease in Demand from Diurnal Grid Batteries=
	SUM(
	  Last Year Grid and Hybrid Battery Storage Available for Load Shifting[Electricity Timeslice\
		!]
	  * SHELF Days per Electricity Timeslice[Electricity Timeslice!]
	  * ESTRTE Grid Battery Round Trip Efficiency
	)
	~	MW*hour
	~		|

Maximum Annual Decrease in Demand from EVs=
	Maximum Daily Quantity of Electricity Charged by EVs for Diurnal Balancing
	* ESTRTE Grid Battery Round Trip Efficiency
	* Days per Year
	~	MW*hour
	~		|

Maximum Annual Decrease in Demand from Pumped Hydro=
	SUM(Maximum Daily Quantity of Electricity Charged by Pumped Hydro[Electricity Timeslice\
		!]
	  * SHELF Days per Electricity Timeslice[Electricity Timeslice!]
	  )
	* ESTRTE Pumped Hydro Round Trip Efficiency
	~	MW*hour
	~		|

Maximum Annual Decrease in Demand from Seasonal Electricity Storage=
	Maximum Annual Quantity of Electricity Charged by Seasonal Electricity Storage
	* SES Seasonal Electricity Storage Round Trip Efficiency
	~	MW*hour
	~		|

Maximum Annual Quantity of Electricity Absorbed for Seasonal Balancing=
	Maximum Annual Quantity of Electricity Charged by Seasonal Electricity Storage
	* RAF Regional Availability Factor for Demand Altering Technologies
	~	MW*hr
	~		|

Maximum Annual Quantity of Electricity Absorbed for Seasonal Net Peak Load Reduction=
	Maximum Annual Quantity of Electricity Absorbed for Seasonal Balancing
	~	MW*hr
	~		|

Maximum Annual Quantity of Electricity Charged by Seasonal Electricity Storage=
	SES Seasonal Electricity Storage Capacity
	* SES Seasonal Electricity Storage Annual Charge and Discharge Cycles
	~	MW*hr
	~		|

Maximum Capacity Factor after RAF[Electricity Source]=
	MCF Maximum Capacity Factor[Electricity Source]
	* RAF Regional Availability Factor for Generation[Electricity Source]
	~	Dmnl
	~		|

Maximum Daily Quantity of Electricity Absorbed for Diurnal Balancing[Electricity Timeslice\
		]=
	(
	  Last Year Grid and Hybrid Battery Storage Available for Load Shifting[Electricity Timeslice\
		]
	  + Maximum Daily Quantity of Electricity Charged by EVs for Diurnal Balancing
	  + Maximum Daily Quantity of Electricity Charged by Pumped Hydro[Electricity Timeslice\
		]
	)
	* RAF Regional Availability Factor for Demand Altering Technologies
	~	MW*hr
	~		|

Maximum Daily Quantity of Electricity Absorbed for Diurnal Net Peak Load Reduction Excluding Hybrid Batteries\
		[Electricity Timeslice]=
	Maximum Daily Quantity of Electricity Absorbed for Diurnal Balancing[Electricity Timeslice\
		]
	~	MW*hr
	~		|

Maximum Daily Quantity of Electricity Charged by EVs for Diurnal Balancing=
	Total EV Battery Capacity
	* Fraction of EVs Used for Grid Balancing on Average Day
	* BEVGB Fraction of EV Battery Capacity Used for Grid Balancing when EV is Used for Grid Balancing
	~	MW*hr
	~		|

Maximum Daily Quantity of Electricity Charged by Pumped Hydro[Electricity Timeslice]=
	BPHC BAU Pumped Hydro Capacity
	* SUM(SYSHECF Start Year Seasonal Expected Capacity Factor for Pumped Hydro[Electricity Timeslice\
		,Hour!])
	* One Hour
	~	MW*hr
	~		|

Maximum Daily Quantity of Electricity Reduced by Demand Response Programs[peak day electricity timeslice\
		]=
	This Year Demand Response Capacity
	* DRC Average DR Hours per Day on Which DR is Called Upon ~~|
Maximum Daily Quantity of Electricity Reduced by Demand Response Programs[average day electricity timeslice\
		]=
	0
	~	MW*hr
	~	We assume that DR can be called upon for every peak day (i.e. at least the \
		five peak summer and five peak winter days).  In the U.S., an average \
		number of DR days per year is 24, more than enough to be used on all peak \
		days.
	|

Maximum Daily Quantity of Electricity Reduced by Demand Response Programs for Net Peak Load Reduction\
		[Electricity Timeslice]=
	Maximum Daily Quantity of Electricity Reduced by Demand Response Programs[Electricity Timeslice\
		]
	~	MW*hr
	~		|

Maximum Possible LCFS Percentage=
	ZIDZ(
	  SUM(Carbon Free Energy in Absence of LCFS by Vehicle Type[Vehicle Type!,Cargo Type\
		!,Vehicle Technology!,Transportation Fuel!])
	    + SUM(Quantity Carbon Free Energy May be Increased by Fuel by Regulated Vehicle Type\
		[Vehicle Type!,Cargo Type!,Transportation Fuel!]),
	
	  SUM(Fuel that would be Used by Regulated Vehicle Types in Absence of LCFS with Elec Eff Adj\
		[Vehicle Type!,Cargo Type!,Vehicle Technology!,Transportation Fuel!])
	)
	~	Dmnl
	~		~	:SUPPLEMENTARY 
	|

Maximum Potential Binding Hour Electricity Output by Hour for Dispatchable Reliability\
		[Optimization Pass]=
	(SUM(
	 Total Electricity Generation Capacity by Optimization Pass for Seasonal Dispatchable Reliability\
		[Electricity Source!,Optimization Pass
	]
	  * Last Year Hourly Bid Electricity Capacity Factors for Reliability in Binding Hour by Plant Type\
		[Electricity Source!
	]
	 )
	
	
	+(New Grid Battery Capacity Deployed for Seasonal Dispatchable Reliability by Optimization Pass\
		[Optimization Pass]
	  *ESTRTE Grid Battery Round Trip Efficiency
	  /GBSC Diurnal Grid Battery Daily Storage Duration)
	)
	* One Hour
	~	MW*hr
	~		|

Maximum Potential Binding Hour Peak Seasonal Day Electricity Output by Optimization Pass for Dispatchable Reliability under CES\
		[Optimization Pass]=
	SUM(
	Total Electricity Generation Capacity by Optimization Pass for Seasonal Clean Dispatchable Reliability\
		[Clean Dispatchable Electricity Source
	!,Optimization Pass]
	  *Last Year Hourly Bid Electricity Capacity Factors for Clean Firm Reliability in Binding Hour by Plant Type\
		[Clean Dispatchable Electricity Source!]
	)
	* One Hour
	~	MW*hr
	~		|

MCF Maximum Capacity Factor[Electricity Source]:=
	GET DIRECT DATA(
	   'InputData/elec/MCF/MCF.csv',
