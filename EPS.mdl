Boolean Use Non BAU Guaranteed Dispatch Settings=
	0
	~	Dmnl [0,1,1]
	~	This switch toggles the contract-based dispatch mechanism on and off.  \
		When the mechanism is off, dispatch is based on lowest variable costs.  \
		When the mechanism is on, any capacity that is not dispatched under the \
		contract mechanism (e.g. if the contracted amounts are not sufficient to \
		satisfy demand) will be dispatched under the lowest variable cost \
		mechanism.
	|

Boolean Use Non BAU Guaranteed Dispatch Settings This Year=
	Boolean Use Non BAU Guaranteed Dispatch Settings
	* Selected Policy Implementation Schedule[elec non BAU guaranteed dispatch X]
	~	Dmnl
	~		|

Boolean Use Non BAU Industry CCS Subsidies[Industry Category]=
	0
	~	Dmnl
	~		|

Boolean Use Non BAU Industry CCS Subsidies This Year[Industry Category]=
	Boolean Use Non BAU Industry CCS Subsidies[Industry Category]
	* VECTOR ELM MAP(
	    Selected Policy Implementation Schedule[indst non BAU CCS subsidy X agriculture and forestry 01T03\
		],
	
	    (Industry Category-1)
	  )
	~	Dmnl
	~		|

Boolean Use Non BAU LCFS Vehicle Types=
	0
	~	Dmnl [0,1,1]
	~		|

