RPS and CES Revenue at Marginal Capacity Factor[Electricity Source]=
	SUM(RPS Revenue at Marginal Capacity Factor by Optimization Pass[last pass!,Electricity Source\
		])
	+ SUM(CES Revenue at Marginal Capacity Factor by Optimization Pass[last pass!,Electricity Source\
		])
	~	$/MW
	~		|

RPS Credit Price by Optimization Pass[pass1]=
	Initial Guess at RPS Price ~~|
RPS Credit Price by Optimization Pass[current pass]=
	MIN(IF THEN ELSE(
	  RPS Credit Price by Optimization Pass[preceeding pass] = 0,
	
	  0,
	
	  MAX(
	    0,
	
	    IF THEN ELSE(
	      Expected Achievable Annual RPS by Optimization Pass[preceeding pass]
	      < Elec Portfolio Percentage to Seek This Year[RPS],
	  
	      RPS Credit Price by Optimization Pass[preceeding pass]
	      + RPS Optimization Step Size[current pass],
	
	      RPS Credit Price by Optimization Pass[preceeding pass]
	      - RPS Optimization Step Size[current pass]
	    )
	  )
	), Elec Portfolio Alternative Compliance Payment)
	~	$/(MW*hr)
	~		|

RPS Optimization Step Size[pass1]=
	ABS(RPS Credit Price by Optimization Pass[pass1])
	/ 2 ~~|
RPS Optimization Step Size[current pass]=
	IF THEN ELSE(
	  RPS Steps in Same Direction[preceeding pass]
	  > Steps Allowed in Same Direction Without Increasing Step Size,
	
	  RPS Optimization Step Size[preceeding pass] * 1.5,
	
	  IF THEN ELSE(
	    RPS Steps in Same Direction[preceeding pass]
	    > Steps Allowed in Same Direction With Declining Step Size,
	
	    RPS Optimization Step Size[preceeding pass],
	
	    RPS Optimization Step Size[preceeding pass]
	    / 2
	  )
	)
	~	$/(MW*hour)
	~		|

RPS Qualifying Guaranteed Dispatch Amount[Electricity Source,Electricity Timeslice,Hour\
		,Clean Elec Requirement]=
	Expected Capacity by Hour[Electricity Source,Electricity Timeslice,Hour]
	 * Guaranteed Dispatch Percentages for Policy Case[Electricity Source]
	 * Elec Portfolio Qualifying Sources[Electricity Source,Clean Elec Requirement]
	 * One Hour
	~	MW*hr
	~		|

RPS Revenue at Expected Capacity Factor by Optimization Pass[Electricity Source,Optimization Pass\
		]=
	RPS Credit Price by Optimization Pass[Optimization Pass]
	* Expected Capacity Factor x Hours per Year for Plants Built This Year[Electricity Source\
		]
	* Elec Portfolio Qualifying Sources[Electricity Source,RPS]
	~	$/MW
	~		|

RPS Revenue at Marginal Capacity Factor by Optimization Pass[Optimization Pass, Electricity Source\
		]=
	RPS Credit Price by Optimization Pass[Optimization Pass]
	* Marginal Capacity Factor x Hours per Year[Electricity Source,RPS]
	* Elec Portfolio Qualifying Sources[Electricity Source,RPS]
	~	$/MW
	~		|

RPS Steps in Negative Direction[pass1]=
	0 ~~|
RPS Steps in Negative Direction[current pass]=
	IF THEN ELSE(
	  Expected Achievable Annual RPS by Optimization Pass[preceeding pass]
	  > Elec Portfolio Percentage to Seek This Year[RPS],
	
	  RPS Steps in Negative Direction[preceeding pass] + 1,
	
	  0
	)
	~	Dmnl
	~		|

RPS Steps in Positive Direction[pass1]=
	0 ~~|
RPS Steps in Positive Direction[current pass]=
	IF THEN ELSE(
	  Expected Achievable Annual RPS by Optimization Pass[preceeding pass]
	  < Elec Portfolio Percentage to Seek This Year[RPS],
	
	  RPS Steps in Positive Direction[preceeding pass] + 1,
	
	  0
	)
	~	Dmnl
	~		|

RPS Steps in Same Direction[Optimization Pass]=
	MAX(
	  RPS Steps in Positive Direction[Optimization Pass],
	  RPS Steps in Negative Direction[Optimization Pass]
	)
	~	Dmnl
	~		|

