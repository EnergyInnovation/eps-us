Imported Electricity=
	SUM(Imported Electricity by Electricity Source[Electricity Source!])
	* (1 + Perc Change in Sectoral Energy Use due to Exogenous GDP Adjustment[electricity sector\
		])
	~	MW*hr
	~		|

Imported Electricity by Electricity Source[Electricity Source]=
	EIaE BAU Imported Electricity by Electricity Source[Electricity Source]
	* (1 + Percent Change in Electricity Imports This Year[Electricity Source])
	~	MW*hour
	~		|

Imported Electricity by Hour on Peak Summer Day[Hour]=
	SUM(Electricity Imports by Hour[peak summer day electricity timeslice!,Hour,last pass\
		!])
	/ ELMCOUNT(peak summer day electricity timeslice)
	~	MW*hr
	~		|

Imported Electricity by Hour on Peak Winter Day[Hour]=
	SUM(Electricity Imports by Hour[peak winter day electricity timeslice!,Hour,last pass\
		!])
	/ ELMCOUNT(peak winter day electricity timeslice)
	~	MW*hr
	~		|

Imports Exceeding Both Caps[All Fuels]=
	Imports Exceeding Cap[All Fuels]
	- Imports Shifted to Production due to Imports Cap[All Fuels]
	~	BTU
	~		|

Imports Exceeding Cap[All Fuels]=
	MAX(
	  0,
	
	  Change in Fuel Imports before Cap[All Fuels]
	  - Maximum Absolute Increase in Fuel Imports[All Fuels]
	)
	~	BTU
	~		|

Imports of Nonenergy Products[Industry Category] :EXCEPT: [energy industries within industry category\
		]=
	BAU Imported Output by ISIC Code[Industry Category ISIC Code]
	+ Change in Imports of Nonenergy Products[Industry Category] ~~|
Imports of Nonenergy Products[energy industries within industry category]=
	0
	~	$
	~		|

Imports Shifted to Production due to Imports Cap[All Fuels]=
	MIN(
	  Imports Exceeding Cap[All Fuels],
	
	  Spare Capacity under Production Cap[All Fuels]
	)
	~	BTU
	~		|

Improvement in New Industrial Eqpt Energy Intensity vs BAU[Industry Category,Industrial Fuel\
		,Industrial Process]=
	ZIDZ(
	  New Industrial Equipment Energy Intensity[Industry Category,Industrial Fuel,Industrial Process\
		]
	  - BAU New Industrial Equipment Energy Intensity[Industry Category,Industrial Fuel,\
		Industrial Process],
	  BAU New Industrial Equipment Energy Intensity[Industry Category,Industrial Fuel,Industrial Process\
		]
	)
	~	Dmnl
	~		|

Increase in Demand by Hour for Diurnal Net Peak Load Reduction and RPS Compliance[Electricity Timeslice\
		,Hour]=
	Increase in Demand by Hour for Diurnal Net Peak Load Reduction excluding Hybrid Batteries\
		[Electricity Timeslice,Hour]
	~	MW*hr
	~		|

Increase in Demand by Hour for Diurnal Net Peak Load Reduction excluding Hybrid Batteries\
		[Electricity Timeslice,Hour]=
	Excess Electricity vs Daily Average by Hour after Seasonal Net Peak Load Reduction[Electricity Timeslice\
		,Hour]
	* MIN(
	    1,
	
	    ZIDZ(
	      Maximum Daily Quantity of Electricity Absorbed for Diurnal Net Peak Load Reduction Excluding Hybrid Batteries\
		[Electricity Timeslice],
	      SUM(Excess Electricity vs Daily Average by Hour after Seasonal Net Peak Load Reduction\
		[Electricity Timeslice,Hour!])
	    )
	)
	~	MW*hr
	~		|

Increase in Demand by Hour for Seasonal Net Peak Load Reduction[Electricity Timeslice\
		,Hour]=
	Daily Increase in Demand for Seasonal Net Peak Load Reduction[Electricity Timeslice]
	* ZIDZ(
	    Excess Potential Output from Surviving Capacity vs Annual Average by Hour[Electricity Timeslice\
		,Hour],
	    SUM(Excess Potential Output from Surviving Capacity vs Annual Average by Hour[Electricity Timeslice\
		,Hour!])
	  )
	~	MW*hr
	~		|

Increase in Distributed Solar Needed to Meet Capacity Requirement[Building Type,Electricity Source\
		]=
	MAX(
	  0,
	
	  (Minimum Distributed Solar to Meet Capacity Requirement[Building Type,Electricity Source\
		]
	  - Last Year Distributed Electricity Source Capacity[Building Type,Electricity Source\
		])
	  - BAU This Year Increase in Distributed Electricity Source Capacity[Building Type,\
		Electricity Source]
	)
	~	MW
	~		|

