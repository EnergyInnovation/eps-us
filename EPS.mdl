	~	BTU
	~		~	:SUPPLEMENTARY 
	|

BAU Total Primary Energy Use by Producing ISIC Code[ISIC Code]=
	SUM(
	  BAU Total Primary Energy Use[All Fuels!]
	  * FtPICM Fuel to Producing ISIC Code Map[All Fuels!,ISIC Code]
	)
	~	BTU
	~		|

BAU Total Primary Fuel Use[All Fuels]=
	SUM(BAU Total Primary Fuel Use by Sector[Sectors!,All Fuels])
	~	BTU
	~		|

BAU Total Primary Fuel Use by Sector[Sectors,All Fuels] :EXCEPT: [Sectors,primary fuel\
		]=
	0 ~~|
BAU Total Primary Fuel Use by Sector[Sectors,primary fuel]=
	BAU Total Energy Use by Sector[Sectors,primary fuel]
	~	BTU
	~		|

BAU Total Qualifying CES Electricity Demand by Hour After Demand Altering Technologies\
		[Electricity Timeslice,Hour]=
	IF THEN ELSE(
	
	  Boolean Exclude Elec Exports from Elec Portfolio Stds[CES] = 1,
	
	  BAU Total Electricity Demand by Hour After Demand Altering Technologies[Electricity Timeslice\
		,Hour] - BAU Electricity Exports by Hour[Electricity Timeslice,Hour,pass20],
	
	  BAU Total Electricity Demand by Hour After Demand Altering Technologies[Electricity Timeslice\
		,Hour]
	)
	~	MW*hour
	~		|

BAU Total Qualifying RPS Electricity Demand by Hour After Demand Altering Technologies\
		[Electricity Timeslice,Hour]=
	IF THEN ELSE(
	
	  Boolean Exclude Elec Exports from Elec Portfolio Stds[RPS] = 1,
	
	  BAU Total Electricity Demand by Hour After Demand Altering Technologies[Electricity Timeslice\
		,Hour] - BAU Electricity Exports by Hour[Electricity Timeslice,Hour,pass20],
	
	  BAU Total Electricity Demand by Hour After Demand Altering Technologies[Electricity Timeslice\
		,Hour]
	)
	~	MW*hour
	~		|

BAU Total Subsidies per Unit Electricity Output Adjusted for Lifetime[Electricity Source\
		]=
	(BAU CCS Subsidy per MWh[Electricity Source]*BCS Duration of Subsidies for Carbon Sequestration
	  + BS BAU Subsidy per Unit Electricity Output[Electricity Source]*BS Duration of Subsidies per Unit Electricity Output\
		[Electricity Source]
	)
	
	/ RPfFESCC Repayment Period for Financed Electricity Sector Capital Costs
	~	$/(MW*hour)
	~		|

BAU Total Surviving Capacity Used for Low Carbon Hydrogen Production=
	MIN(
	  BAU Low Carbon Hydrogen Demand,
	  BAU Surviving Capacity Available After Green Hydrogen Demand[electrolysis with guaranteed clean electricity\
		]
	  + BAU Surviving Capacity Available After Green Hydrogen Demand[natural gas reforming with CCS\
		]
	)
	~	BTU
	~		|

BAU Total Surviving Capacity Used for Other Hydrogen Demand=
	MAX(
	  0,
	  MIN(
	    SUM(BAU Surviving Capacity Available After Low Carbon Hydrogen Demand[Hydrogen Production Pathway\
		!]),
	    BAU Other Hydrogen Demand
	  )
	)
	~	BTU
	~		|

BAU Total Tax Paid on Buildings Fuels[Building Type,Building Fuel]=
	BAU Building Components Energy Use Excluding Zero Cost Distributed Fuel Use[Building Type\
		,Building Fuel]
	* BAU Buildings Fuel Total Tax or Subsidy Amount per Unit Energy[Building Fuel,Building Type\
		]
	~	$
	~		|

BAU Total Tax Paid on Electricity Fuels[Electricity Source]=
	BAU Electricity Fuel Use[Electricity Source]
	* BAU Electricity Fuel Total Tax or Subsidy Amount per Unit Energy[Electricity Source\
		]
	~	$
	~		|

BAU Total Tax Paid on Fuels to Generate Heat[Industrial Fuel]=
	BAU Fuel Used to Generate Heat[Industrial Fuel]
	* BAU District Heat Fuel Total Tax or Subsidy Amount per Unit Energy[Industrial Fuel\
		]
	~	$
	~		|

BAU Total Tax Paid on Hydrogen Sector Fuels[Industrial Fuel]=
	BAU Hydrogen Sector Fuel Use[Industrial Fuel]
	* BAU Hydrogen Fuel Total Tax or Subsidy Amount per Unit Energy[Industrial Fuel]
	~	$
	~		|

BAU Total Tax Paid on Transportation Fuels[Transportation Fuel,Vehicle Type,Cargo Type\
		,Vehicle Technology]=
	BAU Transportation Sector Fuel Used[Vehicle Type,Cargo Type,Vehicle Technology,Transportation Fuel\
		]
	* BAU Transportation Fuel Total Tax or Subsidy Amount per Unit Energy[Vehicle Type,Transportation Fuel\
		]
	~	$
	~		|

BAU Total Vehicle Battery Production Subsidy Amount Paid[Vehicle Type,Cargo Type,Vehicle Technology\
		]=
	BAU Subsidy for Vehicle Battery Production
	* BAU New Vehicles[Vehicle Type,Cargo Type,Vehicle Technology]
	* This Year Battery Capacity by Vehicle Type[Cargo Type,Vehicle Type,Vehicle Technology\
		]
	* One Year
	~	$
	~		|

BAU Transmission Construction Costs=
	SUM(BAU New Generation Capacity Excluding Retrofit Capacity[Electricity Source!])
	* TCCpUNEC Transmission Construction Cost per Unit New Electricity Capacity
	~	$
	~		|

BAU Transmission OM Costs=
	BAU Electricity Generation Capacity Relative to Start Year
	* SYTaDC Start Year Transmission OM Costs
	~	$
	~		|

BAU Transport Fares Paid[Vehicle Type,Cargo Type]=
	SUM(BAU Cargo Dist Transported by Vehicle Technology[Vehicle Type,Cargo Type,Vehicle Technology\
		!])
	* FpUCD Fares per Unit Cargo Distance[Vehicle Type,Cargo Type]
	~	$
	~		|

BAU Transportation Electricity Demand by Vehicle Type[Vehicle Type,Cargo Type,Vehicle Technology\
		]=
	BAU Transportation Sector Fuel Used[Vehicle Type,Cargo Type,Vehicle Technology,electricity tf\
		]
	* MWh per BTU
	~	MW*hour
	~		|

BAU Transportation Fuel Carbon Tax Amount per Unit Energy[Vehicle Type,Transportation Fuel\
		]=
	BCTR BAU Carbon Tax Rate[transportation sector]
	/ Grams per Metric Ton CO2e
	* BAU Transportation Fuel Taxable CO2e Emissions Intensity[Vehicle Type,Transportation Fuel\
		]
	* BFoVTStCT BAU Fraction of Vehicle Types Subject to Carbon Tax[Vehicle Type]
	~	$/BTU
	~		|

BAU Transportation Fuel Cost per Unit Energy[electricity tf]=
	MAX(BAU Pretax Fuel Price by Sector Including Endogenous Electricity Prices[electricity\
		,transportation sector]
	  + BAU Transportation Fuel Total Tax or Subsidy Amount per Unit Energy[LDVs,electricity tf\
		],
	0
	) ~~|
BAU Transportation Fuel Cost per Unit Energy[natural gas tf]=
	BAU Pretax Fuel Price by Sector Including Endogenous Electricity Prices[natural gas,\
		transportation sector]
	+ BAU Transportation Fuel Total Tax or Subsidy Amount per Unit Energy[HDVs,natural gas tf\
		] ~~|
BAU Transportation Fuel Cost per Unit Energy[petroleum gasoline tf]=
	BAU Pretax Fuel Price by Sector Including Endogenous Electricity Prices[petroleum gasoline\
		,transportation sector]
	+ BAU Transportation Fuel Total Tax or Subsidy Amount per Unit Energy[LDVs,petroleum gasoline tf\
		] ~~|
BAU Transportation Fuel Cost per Unit Energy[petroleum diesel tf]=
	BAU Pretax Fuel Price by Sector Including Endogenous Electricity Prices[petroleum diesel\
		,transportation sector]
	+ BAU Transportation Fuel Total Tax or Subsidy Amount per Unit Energy[HDVs,petroleum diesel tf\
		] ~~|
BAU Transportation Fuel Cost per Unit Energy[biofuel gasoline tf]=
	BAU Pretax Fuel Price by Sector Including Endogenous Electricity Prices[biofuel gasoline\
		,transportation sector]
	+ BAU Transportation Fuel Total Tax or Subsidy Amount per Unit Energy[LDVs,biofuel gasoline tf\
		] ~~|
BAU Transportation Fuel Cost per Unit Energy[biofuel diesel tf]=
	BAU Pretax Fuel Price by Sector Including Endogenous Electricity Prices[biofuel diesel\
		,transportation sector]
	+ BAU Transportation Fuel Total Tax or Subsidy Amount per Unit Energy[HDVs,biofuel diesel tf\
		] ~~|
BAU Transportation Fuel Cost per Unit Energy[jet fuel tf]=
	BAU Pretax Fuel Price by Sector Including Endogenous Electricity Prices[jet fuel or kerosene\
		,transportation sector]
	+ BAU Transportation Fuel Total Tax or Subsidy Amount per Unit Energy[aircraft,jet fuel tf\
		] ~~|
BAU Transportation Fuel Cost per Unit Energy[heavy or residual fuel oil tf]=
	BAU Pretax Fuel Price by Sector Including Endogenous Electricity Prices[heavy or residual fuel oil\
		,transportation sector]
	+ BAU Transportation Fuel Total Tax or Subsidy Amount per Unit Energy[ships,heavy or residual fuel oil tf\
		] ~~|
BAU Transportation Fuel Cost per Unit Energy[LPG propane or butane tf]=
	BAU Pretax Fuel Price by Sector Including Endogenous Electricity Prices[LPG propane or butane\
		,transportation sector]
	+ BAU Transportation Fuel Total Tax or Subsidy Amount per Unit Energy[LDVs,LPG propane or butane tf\
		] ~~|
BAU Transportation Fuel Cost per Unit Energy[hydrogen tf]=
	BAU Pretax Fuel Price by Sector Including Endogenous Electricity Prices[hydrogen,transportation sector\
		]
	+ BAU Transportation Fuel Total Tax or Subsidy Amount per Unit Energy[LDVs,hydrogen tf\
		]
	~	$/BTU
	~	We need this subscripted only by fuel type, not vehicle type, for use \
		calculating percentage differences from BAU.  Carbon intensity of fuels \
		should not vary significantly based on which type of vehicle burns those \
		fuels, as CO2 is not captured or eliminated through control technologies \
		in vehicles (like a catalytic converter for NOx).  Accordingly, we use the \
		main vehicle type that burns each fuel type to populate this variable.
	|

BAU Transportation Fuel Other Tax or Subsidy Amount per Unit Energy[Transportation Fuel\
		]=
	BAU Fuel Tax by Sector[transportation fuel within all fuels,transportation sector]
	~	$/BTU
	~		|

BAU Transportation Fuel Taxable CO2e Emissions Intensity[Vehicle Type,Transportation Fuel\
		]=
	SUM(
	  Transportation Fuel Pollutant Emissions Intensities This Year[Vehicle Type,Pollutant\
		!,Transportation Fuel]
	  * GWP by Pollutant[Pollutant!]
	  * BPTbCP BAU Transportation Pollutants Taxed by Carbon Pricing[Vehicle Type,Pollutant\
		!]
	)
	~	g CO2e/BTU
	~		|

BAU Transportation Fuel Total Tax or Subsidy Amount per Unit Energy[Vehicle Type,Transportation Fuel\
		]=
	BAU Transportation Fuel Carbon Tax Amount per Unit Energy[Vehicle Type,Transportation Fuel\
		]
	+ BAU Transportation Fuel Other Tax or Subsidy Amount per Unit Energy[Transportation Fuel\
		]
	~	$/BTU
	~		|

BAU Transportation Pollutant Emissions Disaggregated[Vehicle Type,Pollutant,Cargo Type\
		,Transportation Fuel]=
	SUM(BAU Transportation Sector Fuel Used[Vehicle Type,Cargo Type,Vehicle Technology!,\
		Transportation Fuel])
	  * Transportation Fuel Pollutant Emissions Intensities This Year[Vehicle Type,Pollutant\
		,Transportation Fuel]
	~	g pollutant
	~		|

BAU Transportation Sector Carbon Tax Revenue[Vehicle Type,Cargo Type]=
	SUM(BAU Transportation Sector Fuel Used[Vehicle Type,Cargo Type,Vehicle Technology!,\
		Transportation Fuel!]
	* BAU Transportation Fuel Carbon Tax Amount per Unit Energy[Vehicle Type,Transportation Fuel\
		!])
	~	$
	~		|

BAU Transportation Sector Electricity Demand[Vehicle Type,Cargo Type]=
	SUM(BAU Transportation Electricity Demand by Vehicle Type[Vehicle Type,Cargo Type,Vehicle Technology\
		!])
	~	MW*hour
	~		|

BAU Transportation Sector Fuel that would be Used in Absence of LCFS[Vehicle Type,Cargo Type\
		,Vehicle Technology,Transportation Fuel]=
	ZIDZ(
	  BAU Cargo Dist Transported by Vehicle Technology[Vehicle Type,Cargo Type,Vehicle Technology\
		],
	  BAU Fleet Avg Fuel Economy[Vehicle Type,Cargo Type,Vehicle Technology]
	)
	* BPoEFUbVT BAU Perc of Each Fuel Used by Veh Technology[Vehicle Type,Cargo Type,Vehicle Technology\
		,Transportation Fuel
	]
	~	BTU
	~		|

BAU Transportation Sector Fuel that would be Used in Absence of LCFS by Regulated Vehicle Types\
		[Vehicle Type,Cargo Type,
Vehicle Technology,Transportation Fuel]=
	BAU Transportation Sector Fuel that would be Used in Absence of LCFS[Vehicle Type,Cargo Type\
		,Vehicle Technology,Transportation Fuel
	]
	* BVTStL BAU Vehicle Types Subject to LCFS[Vehicle Type,Cargo Type]
	~	BTU
	~		|

BAU Transportation Sector Fuel Used[Vehicle Type,Cargo Type,Vehicle Technology,Transportation Fuel\
		]=
	BAU Transportation Sector Fuel that would be Used in Absence of LCFS[Vehicle Type,Cargo Type\
		,Vehicle Technology,Transportation Fuel]
	+ BAU Change in Fuel Use by Fuel and Technology due to LCFS[Vehicle Type,Cargo Type,\
		Vehicle Technology,Transportation Fuel]
	~	BTU
	~		|

BAU Transportation Sector Other Fuel Tax Revenue=
	SUM(BAU Transportation Sector Fuel Used[Vehicle Type!,Cargo Type!,Vehicle Technology\
		!,Transportation Fuel!]
	* BAU Transportation Fuel Other Tax or Subsidy Amount per Unit Energy[Transportation Fuel\
		!])
	~	$
	~		|

BAU Transportation Sector Pollutant Emissions[Pollutant]=
	SUM(BAU Transportation Pollutant Emissions Disaggregated[Vehicle Type!,Pollutant,Cargo Type\
		!,Transportation Fuel!])
	~	g pollutant
	~		|

BAU Two Year Average Green Hydrogen Cost=
	DEPRECIATE STRAIGHTLINE(
	  BAU This Year Green Hydrogen Cost,
	  2,
	  1,
	  0
	)
	~	$/BTU
	~		|

BAU Two Year Average Low Carbon Hydrogen Cost=
	DEPRECIATE STRAIGHTLINE(
	  BAU This Year Low Carbon Hydrogen Cost,
	  2,
	  1,
	  0
	)
	~	$/BTU
	~		|

BAU Two Year Average Net Energy Market Revenue by Plant Type Excluding Subsidies for Hybrid Power Plants\
		[Hybrid Electricity Source]=
	DEPRECIATE STRAIGHTLINE(
	 BAU One Year Average Net Energy Market Revenue by Plant Type Excluding Subsidies for Hybrid Power Plants\
		[Hybrid Electricity Source],
	 2,
	 1,
	 0
	)
	~	$/MW
	~		|

BAU Two Year Average Other Hydrogen Cost=
	DEPRECIATE STRAIGHTLINE(
	  BAU This Year Other Hydrogen Cost,
	  2,
	  1,
	  0
	)
	~	$/BTU
	~		|

BAU Two Year Average Total Predicted Net Energy Market Revenue per MW[Electricity Source\
		]=
	DEPRECIATE STRAIGHTLINE(
	 BAU Last Year Total Five Year Average Net Energy Market Revenue per MW[Electricity Source\
		], 
	 2, 
	 1, 
	 0
	)
	~	$/MW
	~		|

BAU Two Year Average Wholesale Energy Market Costs=
	DEPRECIATE STRAIGHTLINE(
	 BAU One Year Average Wholesale Energy Market Costs,
	 2,
	 1,
	 0
	)
	~	$
	~		|

BAU Two Years Prior Hypothetical Hourly Electricity Capacity Factor[Electricity Timeslice\
		,Hour,Electricity Source]= DELAY FIXED (
	BAU Last Year Hypothetical Hourly Electricity Capacity Factor[Electricity Timeslice,\
		Hour,Electricity Source],
	1,
	SYSHECF Start Year Seasonal Expected Hourly Electricity Capacity Factors[Electricity Source\
		,Electricity Timeslice,Hour]
	* RAF Regional Availability Factor for Generation[Electricity Source])
	~	Dmnl
	~		|

BAU Two Years Prior Net Loss per Unit Capacity[Electricity Source,Optimization Pass]=\
		 DELAY FIXED (
	BAU Last Year Net Loss per Unit Capacity[Electricity Source,Optimization Pass],
	1,
	0)
	~	$/MW
	~		|

BAU Two Years Prior Net Loss per Unit Capacity Excluding Capacity Payment[Electricity Source\
		]=
	DELAY FIXED(BAU Last Year Net Loss per Unit Capacity Excluding Predicted Capacity Payment\
		[Electricity Source],
	1,
	0)
	~	$/MW
	~		|

BAU Unmet Electricity Demand After Guaranteed Dispatch[Electricity Timeslice,Hour]=
	MAX(
	  0,
	
	  BAU Total Electricity Demand by Hour After Demand Altering Technologies[Electricity Timeslice
	,Hour]
	  - SUM(BAU Electricity Dispatched by Guaranteed Dispatch by Hour[Electricity Source\
		!,Electricity Timeslice,Hour])
	)
	~	MW*hr
	~		|

BAU Unmet Electricity Demand After RPS Allocation Steps[Electricity Timeslice,Hour]=
	BAU Unmet Electricity Demand After Zero and Negative Cost RPS Dispatch[Electricity Timeslice\
		,Hour]
	- SUM(BAU Positive Cost Electricity Dispatched to Meet RPS[Electricity Timeslice,Hour\
		,Electricity Source!])
	~	MW*hour
	~		|

BAU Unmet Electricity Demand After RPS and Zero and Negative Cost CES Allocation Steps\
		[Electricity Timeslice,Hour]=
	BAU Unmet Electricity Demand After RPS Allocation Steps[Electricity Timeslice,Hour]
	- SUM(BAU Zero and Negative Cost Electricity Dispatched to Meet CES[Electricity Source\
		!,Electricity Timeslice,Hour])
	~	MW*hour
	~		|

BAU Unmet Electricity Demand After RPS Dispatch[Electricity Timeslice,Hour]=
	QUANTUM(
	  MAX(
	    0,
	
	    BAU Unmet Electricity Demand After Guaranteed Dispatch[Electricity Timeslice,Hour\
		]
	    - SUM(BAU Electricity Dispatched to Meet Elec Portfolio Stds[Electricity Timeslice\
		,Hour,Electricity Source!])
	  ),
	 1
	)
	~	MW*hr
	~		|

BAU Unmet Electricity Demand After Zero and Negative Cost RPS Dispatch[Electricity Timeslice\
		,Hour]=
	MAX(0,
	    BAU Unmet Electricity Demand After Guaranteed Dispatch[Electricity Timeslice,Hour\
		]
	    -SUM(BAU Zero and Negative Cost Electricity Dispatched to Meet RPS[Electricity Timeslice\
		,Hour,Electricity Source!])
	     )
	~	MW*hr
	~		|

BAU Unmet Electricity Demand by Hour[Electricity Timeslice,Hour]=
	QUANTUM(
	  MAX(
	    0,
	
	    BAU Total Electricity Demand by Hour After Demand Altering Technologies[Electricity Timeslice
	,Hour]
	    - BAU Total Electricity Dispatched by Hour[Electricity Timeslice,Hour]
	  ),
	
	  BAU Quantization Size for Hourly Dispatch
	)
	~	MW*hr
	~		|

BAU Unmet Electricity Demand Summed Across Hours[Electricity Timeslice]=
	SUM(BAU Unmet Electricity Demand by Hour[Electricity Timeslice,Hour!])
	~	MW*hr
	~		~	:SUPPLEMENTARY 
	|

BAU Value Added by ISIC Code by Year[ISIC Code]=
	BVAbIC BAU Value Added by ISIC Code[ISIC Code]
	* (1 + BAU Percent Change in Output by ISIC Code Using Endogenous Energy Revenues[ISIC Code\
		])
	* (1 - FoPTaFbIC Fractions of Products That are Fuels by ISIC Code[ISIC Code])
	
	+ BVAbIC BAU Value Added by ISIC Code[ISIC Code]
	* (1 + Percent Change in BAU Energy Production and Imports vs Initial Year by ISIC Code\
		[ISIC Code])
	* FoPTaFbIC Fractions of Products That are Fuels by ISIC Code[ISIC Code]
	~	$
	~		|

BAU Value of CCS[Industry Category,process emissions]=
	BCTR BAU Carbon Tax Rate[industry sector]
	* (1 - Does Carbon Tax Exempt Process Emissions This Year[Industry Category])
	
	+ BCS BAU Industry CCS Subsidy
	+ CCSTaSC CCS Transportation and Storage Subsidies ~~|
BAU Value of CCS[Industry Category,energy related emissions]=
	BCTR BAU Carbon Tax Rate[industry sector]
	+ BCS BAU Industry CCS Subsidy
	+ CCSTaSC CCS Transportation and Storage Subsidies
	~	$/metric ton CO2e
	~		|

BAU Variable Costs per Unit New Elec Output[Electricity Source]=
	BAU Fuel Cost per Unit Output for Plants Built This Year[Electricity Source]
	+ BAU Variable OM Cost per Unit Output for Plants Built This Year[Electricity Source\
		]
	+ BAU Electricity Sector CCS Transportation and Storage Costs per MWh[Electricity Source\
		]
	- BAU Carbon Price Credit per MWh[Electricity Source]
	- BAU Subsidy per Unit Electricity Output Adjusted for Subsidy Duration[Electricity Source\
		]
	- BAU CCS Subsidy per MWh Adjusted for Subsidy Duration[Electricity Source]
	~	$/(MW*hr)
	~		|

BAU Variable OM Cost per Unit Output for Plants Built This Year[Electricity Source]=
	SUM(
	  CCaMC Variable OM Cost per Unit Output[Electricity Source,Modeled Vintage!]
	  * This Year Modeled Vintage Flag[Modeled Vintage!]
	)
	~	$/(MW*hour)
	~		|

BAU Variable Subsidies per Unit Electricity Output[Electricity Source]=
	BAU CCS Subsidy per Unit Output for Dispatch[Electricity Source]
	+BAU Subsidy per Unit Electricity Output for Dispatch[Electricity Source]
	+BAU Carbon Price Credit per MWh[Electricity Source]
	+ BS BAU Subsidy per Unit Electricity Output for Existing Plants[Electricity Source]
	~	$/(MW*hr)
	~		|

BAU Variable Subsidies per Unit New Electricity Output[Electricity Source]=
	BAU Carbon Price Credit per MWh[Electricity Source]
	+BAU CCS Subsidy per MWh Adjusted for Subsidy Duration[Electricity Source]
	+BAU Subsidy per Unit Electricity Output Adjusted for Subsidy Duration[Electricity Source\
		]
	~	$/(MW*hr)
	~		|

BAU Vehicle Subsidy Perc[Cargo Type,Vehicle Type,Vehicle Technology]=
	BVS BAU Vehicle Subsidy[Cargo Type,Vehicle Type,Vehicle Technology]
	~	$/vehicle
	~		|

BAU Vehicle Technologies Qualifying as ZEVs[Vehicle Type,Vehicle Technology]=
	BVTQaZ BAU Vehicle Technologies Qualifying as ZEVs[Vehicle Type,Vehicle Technology]
	~	Dmnl
	~		|

BAU Vehicles[Vehicle Type,Cargo Type,Vehicle Technology]=
	BAU Last Year Vehicles[Vehicle Type,Cargo Type,Vehicle Technology]
	+ BAU New Vehicles[Vehicle Type,Cargo Type,Vehicle Technology] * One Year
	- BAU Retiring Vehicles[Vehicle Type,Cargo Type,Vehicle Technology] * One Year
	~	vehicles
	~		|

BAU Water Consumed by Power Plants[Electricity Source]=
	BAU Electricity Generation by Type[Electricity Source]
	* WUbPPT Water Consumption by Power Plant Type[Electricity Source]
	~	l
	~		~	:SUPPLEMENTARY 
	|

BAU Water Withdrawn by Power Plants[Electricity Source]=
	BAU Electricity Generation by Type[Electricity Source]
	* WUbPPT Water Withdrawals by Power Plant Type[Electricity Source]
	~	l
	~		~	:SUPPLEMENTARY 
	|

BAU Weighted Average Annual Capital Costs per Unit Capacity[Electricity Source]=
	ZIDZ(
	  SUM(
	   CCaMC Annual CAPEX per Unit Capacity[Electricity Source,Modeled Vintage!]
	    * BAU Electricity Generation Capacity by Vintage[Electricity Source,Modeled Vintage\
		!]
	  ),
	
	   BAU Electricity Generation Capacity[Electricity Source]
	)
	~	$/MW
	~		|

BAU Weighted Average Annual Fixed OM Cost per Unit Capacity[Electricity Source]=
	ZIDZ(
	  SUM(
	    CCaMC Annual Fixed OM Cost per Unit Capacity[Electricity Source,Modeled Vintage!\
		]
	    * BAU Electricity Generation Capacity by Vintage[Electricity Source,Modeled Vintage\
		!]
	  ),
	
	  BAU Electricity Generation Capacity[Electricity Source]
	)
	~	$/MW
	~		|

BAU Weighted Average Charging Cost for Diurnal Technologies=
	ZIDZ(
	  SUM(
	    BAU Increase in Demand by Hour for Diurnal Net Peak Load Reduction and RPS Compliance\
		[Electricity Timeslice!,Hour!]
	    * SHELF Days per Electricity Timeslice[Electricity Timeslice!]
	    * BAU Last Year Five Year Average Marginal Dispatch Cost by Hour[Electricity Timeslice\
		!,Hour!]
	  ),
	
	  SUM(
	    BAU Increase in Demand by Hour for Diurnal Net Peak Load Reduction and RPS Compliance\
		[Electricity Timeslice!,Hour!]
	    * SHELF Days per Electricity Timeslice[Electricity Timeslice!]
	  )
	)
	* Days per Year
	~	$/(MW*hr)
	~		|

BAU Weighted Average Compensation per Employee=
	ZIDZ(
	  SUM(
	    BAU Compensation per Employee by ISIC Code[ISIC Code!]
	    * BAU Domestic Employment by ISIC Code[ISIC Code!]
	  ),
	
	  SUM(BAU Domestic Employment by ISIC Code[ISIC Code!])
	)
	~	$/job
	~		|

BAU Weighted Average Discharging Revenue for Diurnal Technologies=
	ZIDZ(
	  SUM(
	    BAU Decrease in Demand by Hour for Diurnal Net Peak Load Reduction and RPS Compliance\
		[Electricity Timeslice!,Hour!]
	    * SHELF Days per Electricity Timeslice[Electricity Timeslice!]
	    * BAU Last Year Five Year Average Marginal Dispatch Cost by Hour[Electricity Timeslice\
		!,Hour!]
	  ),
	
	  SUM(
	    BAU Decrease in Demand by Hour for Diurnal Net Peak Load Reduction and RPS Compliance\
		[Electricity Timeslice!,Hour!]
	    * SHELF Days per Electricity Timeslice[Electricity Timeslice!]
	  )
	)
	* Days per Year
	~	$/(MW*hr)
	~		|

BAU Weighted Average Discharging Revenue for Grid Batteries after Subsidies=
	BAU Weighted Average Discharging Revenue for Diurnal Technologies
	+ Levelized BAU Subsidy per Unit Grid Battery Capacity Deployed
	~	$/(MW*hr)
	~		|

BAU Weighted Average Elec Portfolio Percentage by Year[Future Year,RPS]=
	MIN(
	  1,
	
	  SUM(
	    BRPSDbS BAU RPS Percentages by Subregion[Subregion!,Future Year]
	    * BRPSDbS BAU Electricity Shares by Subregion[Subregion!]
	  )
	 ) ~~|
BAU Weighted Average Elec Portfolio Percentage by Year[Future Year,CES]=
	MIN(
	  1,
	
	  SUM(
	    BRPSDbS BAU CES Percentages by Subregion[Subregion!,Future Year]
	    * BRPSDbS BAU Electricity Shares by Subregion[Subregion!]
	  )
	 )
	~	Dmnl
	~		|

BAU Weighted Average Electricity Fuel Cost per Unit Electricity Output[Electricity Source\
		]=
	BAU Electricity Fuel Cost per Unit Energy[Electricity Source]
	* BAU Weighted Average Heat Rate by Electricity Fuel[Electricity Source]
	~	$/(MW*hour)
	~	The fuel surcharge for power plants that have higher fuel prices than \
		other plants that buy the same fuel (i.e., natural gas peakers and natural \
		gas steam turbines) is handled on the Fuels sheet, which automatically \
		integrates these surcharges into cash flows.
	|

BAU Weighted Average Expected Capacity Factors by Hour Without Hypothetical Adjustments\
		[Electricity Source,Electricity Timeslice,Hour]=
	Start Year Seasonal Expected Hourly Electricity Capacity Factors after RAF[Electricity Source\
		,Electricity Timeslice
	,Hour
	]
	* (1 + BAU Weighted Average Increase in Capacity Factors for All Plants due to Technological Improvements\
		[Electricity Source
	])
	~	Dmnl
	~		|

BAU Weighted Average Expected Capacity Factors by Hour without RAF[Electricity Source\
		,Electricity Timeslice,Hour]=
	SYSHECF Start Year Seasonal Expected Hourly Electricity Capacity Factors[Electricity Source\
		,Electricity Timeslice,Hour]
	* (1 + BAU Weighted Average Increase in Capacity Factors for All Plants due to Technological Improvements\
		[Electricity Source])
	~	Dmnl
	~		|

BAU Weighted Average Heat Rate by Electricity Fuel[Electricity Source]=
	IF THEN ELSE(
	  ABS(BAU Electricity Generation Capacity[Electricity Source])*MW Tolerance Unit Correction Factor\
		 < Tolerance,
	  SUM(BHRaSYC BAU Heat Rates[Electricity Source,Modeled Vintage!]*This Year Modeled Vintage Flag\
		[Modeled Vintage!]),
	
	  ZIDZ(
	    SUM(
	      BHRaSYC BAU Heat Rates[Electricity Source,Modeled Vintage!]
	      * BAU Electricity Generation Capacity by Vintage[Electricity Source,Modeled Vintage\
		!]
	    ),
	
	    BAU Electricity Generation Capacity[Electricity Source]
	  )
	)
	~	BTU/(MW*hour)
	~		|

BAU Weighted Average Increase in Capacity Factors for All Plants due to Technological Improvements\
		[Electricity Source]=
	ZIDZ(
	  SUM(
	    (BAU Last Year Increase in Capacity Factors for New Plants Due to Technological Improvements by Vintage NEW\
		[Electricity Source,Modeled Vintage!]
	    + IiCFfNPdtTI Increase in Capacity Factors for New Plants due to Technological Improvements\
		[Electricity Source] * This Year Modeled Vintage Flag[Modeled Vintage!])
	    * BAU Electricity Generation Capacity by Vintage[Electricity Source,Modeled Vintage\
		!]
	  ),
	
	  BAU Electricity Generation Capacity[Electricity Source]
	)
	~	Dmnl
	~		|

BAU Weighted Average Round Trip Efficiency for Diurnal Shifting Excluding Hybrid Batteries\
		[Electricity Timeslice]=
	ZIDZ(
	  (
	    ESTRTE Grid Battery Round Trip Efficiency
	    * (BAU Last Year Grid and Hybrid Battery Storage Available for Load Shifting[Electricity Timeslice\
		]
	       + BAU Maximum Daily Quantity of Electricity Charged by EVs for Diurnal Balancing
	      )
	
	    + ESTRTE Pumped Hydro Round Trip Efficiency
	      * BAU Maximum Daily Quantity of Electricity Charged by Pumped Hydro[Electricity Timeslice\
		]
	  ),
	
	  (
	    BAU Last Year Grid and Hybrid Battery Storage Available for Load Shifting[Electricity Timeslice\
		]
	    + BAU Maximum Daily Quantity of Electricity Charged by EVs for Diurnal Balancing
	    + BAU Maximum Daily Quantity of Electricity Charged by Pumped Hydro[Electricity Timeslice\
		]
	  )
	)
	~	Dmnl
	~		|

BAU Weighted Average Round Trip Efficiency for Seasonal Shifting=
	ZIDZ(
	  (
	    SES Seasonal Electricity Storage Round Trip Efficiency
	    * BAU Maximum Annual Quantity of Electricity Charged by Seasonal Electricity Storage
	  ),
	
	  (
	    BAU Maximum Annual Quantity of Electricity Charged by Seasonal Electricity Storage
	  )
	)
	~	Dmnl
	~		|

BAU Weighted Average Variable OM Cost per Unit Electricity Output[Electricity Source]\
		=
	IF THEN ELSE(
	  ABS(BAU Electricity Generation Capacity[Electricity Source])*MW Tolerance Unit Correction Factor\
		 < Tolerance,
	  SUM(CCaMC Variable OM Cost per Unit Output[Electricity Source,Modeled Vintage!]*This Year Modeled Vintage Flag\
		[Modeled Vintage!]),
	  ZIDZ(
	    SUM(
	      CCaMC Variable OM Cost per Unit Output[Electricity Source,Modeled Vintage!]
	      * BAU Electricity Generation Capacity by Vintage[Electricity Source,Modeled Vintage\
		!]
	    ),
	
	    BAU Electricity Generation Capacity[Electricity Source]
	  )
	)
	~	$/(MW*hour)
	~		|

BAU Weighted Avg Fuel Cost per Unit Energy by Vehicle Technology[Vehicle Type,Cargo Type\
		,Vehicle Technology]=
	XIDZ(
	  SUM(BAU Transportation Fuel Cost per Unit Energy[Transportation Fuel!]
	      * BAU Last Year Transportation Sector Fuel Used[Vehicle Type,Cargo Type,Vehicle Technology\
		,Transportation Fuel!]),
	
	  SUM(BAU Last Year Transportation Sector Fuel Used[Vehicle Type,Cargo Type,Vehicle Technology\
		,Transportation Fuel!]),
	
	  SUM(BAU Transportation Fuel Cost per Unit Energy[Transportation Fuel!]
	    * BPoEFUbVT BAU Perc of Each Fuel Used by Veh Technology[Vehicle Type,Cargo Type\
		,Vehicle Technology,Transportation Fuel!])
	)
	~	$/BTU
	~	In the event there are no vehicles of a given technology (such as no \
		battery electric vehicles), we don't want a weighted average fuel cost of \
		zero, because this makes that vehicle technology have an artifically low \
		lifetime NPV cost, and the model will choose to build more of that type \
		than it should.  Accordingly, we estimate the cost based on the BAU fuel \
		shares by vehicle technology.
	|

BAU Wholesale Energy Market Costs=
	IF THEN ELSE(
	 Time - INITIAL TIME <= 1,
	 BAU One Year Average Wholesale Energy Market Costs,
	 
	 IF THEN ELSE(
	  Time - INITIAL TIME = 2,
	  BAU Two Year Average Wholesale Energy Market Costs,
	  BAU Three Year Average Wholesale Energy Market Costs
	 )
	)
	~	$
	~		|

BAU ZEC Subsidies Paid[Electricity Source]=
	BAU Electricity Generation by Type[Electricity Source]
	* BZECfNP BAU Zero Emissions Credit for Nuclear Plants[Electricity Source]
	~	$
	~		|

BAU Zero and Negative Cost Electricity Dispatched to Meet CES[Electricity Source,Electricity Timeslice\
		,Hour]=
	BAU Expected CES Qualifying Output After Guaranteed and RPS Dispatch[Electricity Source\
		,Electricity Timeslice,Hour]
	* BAU Plant Types with Zero or Negative Dispatch Cost After Subsidies[Electricity Source\
		]
	* MIN(
	    1,
	
	    ZIDZ(
	      BAU Unmet Electricity Demand After RPS Allocation Steps[Electricity Timeslice,\
		Hour],
	
	      SUM(
	        BAU Expected CES Qualifying Output After Guaranteed and RPS Dispatch[Electricity Source\
		!,Electricity Timeslice,Hour]
	        * BAU Plant Types with Zero or Negative Dispatch Cost After Subsidies[Electricity Source\
		!]
	      )
	    )
	  )
	~	MW*hour
	~		|

BAU Zero and Negative Cost Electricity Dispatched to Meet RPS[Electricity Timeslice,Hour\
		,Electricity Source]=
	BAU Expected RPS Qualifying Capacity After Guaranteed Dispatch[Electricity Timeslice\
		,Hour,Electricity Source]
	* BAU Plant Types with Zero or Negative Dispatch Cost After Subsidies[Electricity Source\
		]
	* MIN(
	    1,
	
	    ZIDZ(
	      BAU Unmet Electricity Demand After Guaranteed Dispatch[Electricity Timeslice,Hour\
		],
	
	      SUM(
	        BAU Expected RPS Qualifying Capacity After Guaranteed Dispatch[Electricity Timeslice\
		,Hour,Electricity Source!]
	        * BAU Plant Types with Zero or Negative Dispatch Cost After Subsidies[Electricity Source\
		!]
	      )
	    )
	  )
	~	MW*hr
	~		|

BAU ZEV Sales Share Without ZEV Standard[Subregion,Vehicle Type,Cargo Type]=
	ZIDZ(
	  SUM(
	    BAU New Vehicles before ZEV Standards by Subregion[Subregion,Vehicle Type,Cargo Type\
		,Vehicle Technology!]
	    * BAU Vehicle Technologies Qualifying as ZEVs[Vehicle Type,Vehicle Technology!]
	  ),
	
	  SUM(BAU New Vehicles before ZEV Standards by Subregion[Subregion,Vehicle Type,Cargo Type\
		,Vehicle Technology!])
	)
	~	Dmnl
	~		|

