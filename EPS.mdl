Quantity Carbon Free Energy May be Increased by Fuel by Regulated Vehicle Type[Vehicle Type\
		,Cargo Type,Transportation Fuel] :EXCEPT: [Vehicle Type,Cargo Type,electricity tf],\
		[Vehicle Type,Cargo Type,biofuel gasoline tf],[Vehicle Type,Cargo Type
,biofuel diesel tf]=
	0 ~~|
Quantity Carbon Free Energy May be Increased by Fuel by Regulated Vehicle Type[Vehicle Type\
		,Cargo Type,electricity tf]=
	SUM(Quantity Each Fuel May be Increased in Regulated Vehicle Types with Elec Eff Adj\
		[Vehicle Type,Cargo Type,Vehicle Technology!,electricity tf])
	* (1 - Carbon Intensity Ratios by Transportation Fuel[electricity tf]) ~~|
Quantity Carbon Free Energy May be Increased by Fuel by Regulated Vehicle Type[Vehicle Type\
		,Cargo Type,biofuel gasoline tf]=
	(SUM(Quantity Each Fuel May be Increased in Regulated Vehicle Types with Elec Eff Adj\
		[Vehicle Type,Cargo Type,Vehicle Technology!,biofuel gasoline tf
	])
	  - Quantity Each Fuel May be Increased in Regulated Vehicle Types with Elec Eff Adj\
		[Vehicle Type,Cargo Type,plugin hybrid vehicle,biofuel gasoline tf
	])
	* (1 - Carbon Intensity Ratios by Transportation Fuel[biofuel gasoline tf]) ~~|
Quantity Carbon Free Energy May be Increased by Fuel by Regulated Vehicle Type[Vehicle Type\
		,Cargo Type,biofuel diesel tf]=
	(SUM(Quantity Each Fuel May be Increased in Regulated Vehicle Types with Elec Eff Adj\
		[Vehicle Type,Cargo Type,Vehicle Technology!,biofuel diesel tf
	])
	  - Quantity Each Fuel May be Increased in Regulated Vehicle Types with Elec Eff Adj\
		[Vehicle Type,Cargo Type,plugin hybrid vehicle,biofuel diesel tf
	])
	* (1 - Carbon Intensity Ratios by Transportation Fuel[biofuel diesel tf])
	~	BTU
	~	Plug-in hybrids can shift to either electricity or biofuels.  To model \
		this explicitly would be very difficult, as we'd need to account for three \
		possible shifts (petroleum gasoline to biofuel gasoline, petroleum \
		gasoline to electricity, and biofuel gasoline to electricity).  In \
		practice, biofuel gasoline is hardly used by plug-in hybrids, and \
		electricity will always be the more economical choice for satisfying an \
		LCFS via generation of carbon-free energy.  Therefore, we only allow for \
		one of these three types of shifts in plug-in hybrids: petroleum gasoline \
		to electricity.  Accordingly, we must subtract out the (small) quantity by \
		which biofuels could be increased in plug-in hybrids when calculating the \
		total amount of potential increase in biofuels, to avoid exceeding the \
		maximum allowable shift in gasoline or diesel vehicles (when the shift is \
		assigned to those vehicles, rather than to plug-in hybrids, later in the \
		calculation steps).
	|

Quantity Each Fuel May be Increased in Regulated Vehicle Types[Vehicle Type,Cargo Type\
		,Vehicle Technology,Transportation Fuel]=
	Perc Points Each Transportation Fuel May be Increased[Vehicle Type,Cargo Type,Vehicle Technology\
		,Transportation Fuel]
	* SUM(Transportation Sector Fuel that would be Used in Absence of LCFS by Regulated Vehicle Types\
		[Vehicle Type,Cargo Type,Vehicle Technology,Transportation Fuel!])
	~	BTU
	~		|

Quantity Each Fuel May be Increased in Regulated Vehicle Types with Elec Eff Adj[Vehicle Type\
		,Cargo Type,Vehicle Technology,Transportation Fuel] :EXCEPT: [Vehicle Type,Cargo Type\
		,Vehicle Technology,electricity tf]=
	Quantity Each Fuel May be Increased in Regulated Vehicle Types[Vehicle Type,Cargo Type\
		,Vehicle Technology,Transportation Fuel] ~~|
Quantity Each Fuel May be Increased in Regulated Vehicle Types with Elec Eff Adj[Vehicle Type\
		,Cargo Type,Vehicle Technology,electricity tf]=
	Quantity Each Fuel May be Increased in Regulated Vehicle Types[Vehicle Type,Cargo Type\
		,Vehicle Technology,electricity tf]
	/ (1 - PTFURfE Percentage Transportation Fuel Use Reduction for Electricity[Vehicle Type\
		,Cargo Type])
	~	BTU
	~		|

Quantization Size for Annual Dispatch=
	10000
	~	MW*hour
	~		|

Quantization Size for Dollars=
	1
	~	$
	~		|

Quantization Size for Hourly Dispatch=
	SUM(Electricity Generation by Type[Electricity Source!])
	* 2.5e-07
	~	MW*hr
	~		|

Quantization Size for Jobs=
	1
	~	job
	~		|

Quantization Size for Percentage Changes=
	1e-05
	~	Dmnl
	~		|

race:
	white,
	black,
	asian,
	other race
	~	
	~		|

RACP RPS Alternative Compliance Payment=
	GET DIRECT CONSTANTS(
	   'InputData/elec/RACP/RACP-RACP.csv',
	   ',',
	   'B2*'
	)
	~	$/(MW*hr)
	~		|

RAF Regional Availability Factor for Capacity[Electricity Source]=
	GET DIRECT CONSTANTS(
	   'InputData/elec/RAF/RAF-capacity.csv',
	   ',',
	   'B2*'
	)
	~	Dmnl
	~		|

RAF Regional Availability Factor for Demand Altering Technologies=
	GET DIRECT CONSTANTS(
	   'InputData/elec/RAF/RAF-demand-altering-techs.csv',
	   ',',
	   'B2*'
	)
	~	Dmnl
	~		|

RAF Regional Availability Factor for Generation[Electricity Source]:=
	GET DIRECT DATA(
	   'InputData/elec/RAF/RAF-generation.csv',
	   ',',
	   '1',
	   'B2'
	)
	~	Dmnl
	~		|

Range Anxiety Shadow Cost=
	BRASC BAU Range Anxiety Shadow Cost
	* (1 - Reduce EV Range Anxiety This Year)
	~	$/vehicle
	~		|

Raw BAU Industrial Energy Intensity in Electricity Equivalent[Industry Category]=
	ZIDZ(
	  BAU Fuel Use for Energy Purposes in Electricity Equivalent[Industry Category],
	  BAU Last Year Output by ISIC Code[Industry Category ISIC Code]
	)
	~	BTU/$
	~		|

RBFF Recipient Buildings Fuel Fractions[Source Building Fuel,Target Building Fuel]=
	GET DIRECT CONSTANTS(
	   'InputData/bldgs/RBFF/RBFF.csv',
	   ',',
	   'B2*'
	)
	~	Dmnl
	~		|

Recipient Cash Flow Entity<->
	Cash Flow Entity
	~	
	~		|

Reduce EV Range Anxiety=
	0
	~	Dmnl [0,1]
	~		|

Reduce EV Range Anxiety This Year=
	Reduce EV Range Anxiety
	* Selected Policy Implementation Schedule[trans reduce EV range anxiety and charging time X\
		]
	~	Dmnl
	~		|

Reduction Achieved by Marginal Cost[Industry by Process Emissions Policy,Marginal Abatement Cost\
		]=
	Reduction Achieved by Marginal Cost Excluding Carbon Tax Driven Reductions[Industry by Process Emissions Policy\
		,Marginal Abatement Cost]
	+ Process Emissions Abated due to Carbon Tax by Marginal Cost[Industry by Process Emissions Policy\
		,Marginal Abatement Cost]
	~	g CO2e
	~		|

Reduction Achieved by Marginal Cost Excluding Carbon Tax Driven Reductions[Industry by Process Emissions Policy\
		,Marginal Abatement Cost]=
	ALLOCATE AVAILABLE(
	  Remaining Avoidable Process Emissions after Carbon Tax[Industry by Process Emissions Policy\
		,Marginal Abatement Cost],
	  Process Emissions Cost Parameters as Vector[Marginal Abatement Cost,ptype],
	  Increase in Process CO2e by Policy and Industry[Industry by Process Emissions Policy\
		]
	)
	~	g CO2e
	~		|

Reduction in All Existing Buildings Energy Use due to Retrofitting Preexisting Buildings\
		[Building Type,Building Fuel,Building Component]=
	Components Energy Use after Macroeconomic Feedbacks[Building Type,Building Fuel,Building Component\
		]
	* Percent Reduction in All Existing Buildings Energy Use due to Retrofitting Preexisting Buildings\
		[Building Type,Building Component]
	~	BTU
	~		|

Reduction in Carbon Intensity of This Fuel Relative to Reference Fuel[Vehicle Type,Transportation Fuel\
		] :EXCEPT:  [LDVs,Transportation Fuel
],[motorbikes,Transportation Fuel]=
	Transportation Fuel Pollutant Emissions Intensities This Year[Vehicle Type,CO2,petroleum diesel tf\
		]
	* (1 - Carbon Intensity Ratios by Transportation Fuel[Transportation Fuel]) ~~|
Reduction in Carbon Intensity of This Fuel Relative to Reference Fuel[LDVs,Transportation Fuel\
		]=
	Transportation Fuel Pollutant Emissions Intensities This Year[LDVs,CO2,petroleum gasoline tf\
		]
	* (1 - Carbon Intensity Ratios by Transportation Fuel[Transportation Fuel]) ~~|
Reduction in Carbon Intensity of This Fuel Relative to Reference Fuel[motorbikes,Transportation Fuel\
		]=
	Transportation Fuel Pollutant Emissions Intensities This Year[motorbikes,CO2,petroleum gasoline tf\
		]
	* (1 - Carbon Intensity Ratios by Transportation Fuel[Transportation Fuel])
	~	g pollutant/BTU
	~		|

Reduction in Child and Adult Premature Mortality by Demographic Trait[demographic trait excluding age bracket\
		]=
	QUANTUM(
	
	  -SUM(
	    Change in Total Pollutant Emissions by Sector Excluding Imported Electricity Emissions\
		[Sectors!,pollutant with calculated health outcomes!]
	    * HOIpTP Health Outcome Incidence per Ton Pollutant[Premature mortality,Sectors!\
		,pollutant with calculated health outcomes!]
	    * FoCaAPMbDT Fraction of Child and Adult Premature Mortality by Demographic Trait\
		[Sectors!,pollutant with calculated health outcomes!,demographic trait excluding age bracket\
		]
	    / Grams per Metric Ton Pollutant
	  ),
	
	  QSfHO Quantization Size for Health Outcomes
	)
	~	incidents
	~		|

Reduction in CO2 Emissions due to LCFS[Vehicle Type,Cargo Type,Vehicle Technology,Transportation Fuel\
		]=
	Change in Fuel Use by Fuel and Technology due to LCFS with Elec Eff Adj[Vehicle Type\
		,Cargo Type,Vehicle Technology,Transportation Fuel]
	* Reduction in Carbon Intensity of This Fuel Relative to Reference Fuel[Vehicle Type\
		,Transportation Fuel]
	~	g pollutant
	~		|

Reduction in E Use Allowed by Component Eff Std[Building Component,Building Type]=
	0,	0,	0;	{heating}
	0,	0,	0;	{cooling and ventilation}
	0,	0,	0;	{envelope}
	0,	0,	0;	{light}
	0,	0,	0;	{appln}
	0,	0,	0;	{other}
	{urb-r}	{rur-r}	{com}
	~	Dmnl [0,0.82]
	~		|

Reduction in E Use Allowed by Component Eff Std This Year[Building Component,Building Type\
		]=
	Reduction in E Use Allowed by Component Eff Std[Building Component,Building Type]
	* VECTOR ELM MAP(
	    Selected Policy Implementation Schedule[bldgs efficiency standards X heating X urban residential\
		],
	
	    (Building Component-1)*ELMCOUNT(Building Type) + (Building Type-1)
	  )
	~	Dmnl
	~		|

Reduction in Industrial Energy Use due to New Waste Heat Recovery Equipment[Industry Category\
		]=
	(This Year Reduction in Industrial Energy Consumption for Heat Generation due to Waste Heat Recovery\
		[Industry Category]
	  - Last Year Reduction in Industrial Energy Use due to Waste Heat Recovery[Industry Category\
		])
	* SUM(Industrial Equipment Energy Use by Fuel Type and Process before Waste Heat Recovery\
		[Industry Category,Industrial Fuel!,Industrial Process!])
	~	BTU
	~		|

Reduction in Infant Premature Mortality by Demographic Trait[demographic trait excluding age bracket\
		]=
	QUANTUM(
	
	  -SUM(
	    Change in Total Pollutant Emissions by Sector Excluding Imported Electricity Emissions\
		[Sectors!,pollutant with calculated health outcomes
	!]
	    * HOIpTP Health Outcome Incidence per Ton Pollutant[Premature mortality,Sectors!\
		,pollutant with calculated health outcomes
	!]
	    * FoIPMbDT Fraction of Infant Premature Mortality by Demographic Trait[Sectors!,\
		pollutant with calculated health outcomes
	!,demographic trait excluding age bracket]
	    / Grams per Metric Ton Pollutant
	  ),
	
	  QSfHO Quantization Size for Health Outcomes
	)
	~	incidents
	~		|

Reduction in Negative Health Outcomes[Health Outcome]=
	QUANTUM(
	
	  -SUM(
	    Change in Total Pollutant Emissions by Sector Excluding Imported Electricity Emissions\
		[Sectors!,Pollutant!]
	    * HOIpTP Health Outcome Incidence per Ton Pollutant[Health Outcome,Sectors!,Pollutant\
		!]
	    / Grams per Metric Ton Pollutant
	  ),
	
	  QSfHO Quantization Size for Health Outcomes
	)
	~	incidents
	~		|

Remaining Avoidable Process Emissions after Carbon Tax[Industry by Process Emissions Policy\
		,Marginal Abatement Cost]=
	MAX(
	  0,
	
	  PERAC Mass CO2e Avoidable by Marginal Cost[Industry by Process Emissions Policy,Marginal Abatement Cost\
		]
	  - Process Emissions Abated due to Carbon Tax by Marginal Cost[Industry by Process Emissions Policy\
		,Marginal Abatement Cost
	]
	)
	~	g CO2e
	~		|

Remaining CES Required Generation after Guaranteed Dispatch and RPS Dispatch=
	MAX(0,
	  SUM(Total Electricity Demand by Hour After Demand Altering Technologies[Electricity Timeslice
	!,Hour!]*Elec Portfolio Percentage to Seek This Year[CES]
	*SHELF Days per Electricity Timeslice  [Electricity Timeslice!])
	  
	   -SUM(Electricity Dispatched by Guaranteed Dispatch by Hour[Electricity Source!,Electricity Timeslice\
		!,Hour!]*Elec Portfolio Qualifying Sources
	[Electricity Source!,CES]*SHELF Days per Electricity Timeslice[Electricity Timeslice\
		!])
	  
	   -SUM(Zero and Negative Cost Electricity Dispatched to Meet RPS[Electricity Timeslice\
		!,Hour!,Electricity Source!]*Elec Portfolio Qualifying Sources
	[Electricity Source!,CES]*SHELF Days per Electricity Timeslice
	[Electricity Timeslice!])
	
	-SUM(Positive Cost Electricity Dispatched to Meet RPS[Electricity Timeslice!,Hour!,Electricity Source\
		!]*Elec Portfolio Qualifying Sources
	[Electricity Source!,CES]*SHELF Days per Electricity Timeslice
	[Electricity Timeslice!])
	
	- SUM(Zero and Negative Cost Electricity Dispatched to Meet CES[Electricity Source!,\
		Electricity Timeslice!,Hour!]*Elec Portfolio Qualifying Sources[Electricity Source!\
		,CES]*SHELF Days per Electricity Timeslice[Electricity Timeslice!])
	)
	~	MW*hour
	~		|

Remaining Electricity Exports by Electricity Timeslice by Optimization Pass[Electricity Timeslice\
		,Optimization Pass]=
	IF THEN ELSE(Daily Net Imported Electricity>=0,0,
	  -Daily Net Imported Electricity-SUM(Electricity Exports by Hour[Electricity Timeslice\
		,Hour!,Optimization Pass])
	 )
	~	MW*hr
	~		|

Remaining Electricity Imports by Electricity Timeslice and Optimization Pass[Electricity Timeslice\
		, Optimization Pass]=
	IF THEN ELSE(Daily Net Imported Electricity<=0,0,
	  Daily Net Imported Electricity-SUM(Electricity Imports by Hour[Electricity Timeslice\
		,Hour!,Optimization Pass])
	 )
	~	MW*hr
	~		|

Remaining Potential Solar Capacity by Building Type[Building Type]=
	MDSC Maximum Distributed Solar Capacity[Building Type,solar PV es] -
	Distributed Solar Capacity Before Capacity Requirement This Year[Building Type]
	~	MW
	~		|

Remaining RPS Required Generation after Guaranteed Dispatch and Zero and Negative Cost Electricity Dispatched to Meet RPS\
		=
	MAX(0,
	  SUM(Total Electricity Demand by Hour After Demand Altering Technologies[Electricity Timeslice
	!,Hour!]*Elec Portfolio Percentage to Seek This Year[RPS]
	*SHELF Days per Electricity Timeslice  [Electricity Timeslice!])
	  
	   -SUM(Electricity Dispatched by Guaranteed Dispatch by Hour[Electricity Source!,Electricity Timeslice\
		!,Hour!]*Elec Portfolio Qualifying Sources
	[Electricity Source!,RPS]*SHELF Days per Electricity Timeslice[Electricity Timeslice\
		!])
	  
	   -SUM(Zero and Negative Cost Electricity Dispatched to Meet RPS[Electricity Timeslice\
		!,Hour!,Electricity Source!]*Elec Portfolio Qualifying Sources[Electricity Source!,\
		RPS]*SHELF Days per Electricity Timeslice
	[Electricity Timeslice!])
	)
	~	MW*hr
	~		|

Remaining Years of Repayment for Historical Capacity Additions[Modeled Vintage]=
	IF THEN ELSE( 
	  Time > INITIAL TIME,
	  0,
	  IF THEN ELSE(
	    Modeled Vintage Age[Modeled Vintage] > RPfFESCC Repayment Period for Financed Electricity Sector Capital Costs\
		,
	    0,
	    RPfFESCC Repayment Period for Financed Electricity Sector Capital Costs - Modeled Vintage Age\
		[Modeled Vintage]
	  )
	)
	~	Year
	~		|

Renewable Electricity Generation Converted to Primary Energy[hydro es]=
	Electricity Generation by Type Including Distributed Generation[hydro es]
	/ MWh per BTU ~~|
Renewable Electricity Generation Converted to Primary Energy[onshore wind es]=
	Electricity Generation by Type Including Distributed Generation[onshore wind es]
	/ MWh per BTU ~~|
Renewable Electricity Generation Converted to Primary Energy[solar PV es]=
	Electricity Generation by Type Including Distributed Generation[solar PV es]
	/ MWh per BTU ~~|
Renewable Electricity Generation Converted to Primary Energy[solar thermal es]=
	Electricity Generation by Type Including Distributed Generation[solar thermal es]
	/ MWh per BTU ~~|
Renewable Electricity Generation Converted to Primary Energy[geothermal es]=
	Electricity Generation by Type Including Distributed Generation[geothermal es]
	/ MWh per BTU ~~|
Renewable Electricity Generation Converted to Primary Energy[offshore wind es]=
	Electricity Generation by Type Including Distributed Generation[offshore wind es]
	/ MWh per BTU
	~	BTU
	~		|

Renewable Portfolio Std Percentage=
	0
	~	Dmnl [0,1]
	~	This is the percentage of power demand that must be met by qualifying \
		renewable sources.
	|

Repayment for Buildings Sector Financed Capital Expenses Expiring After Financing Period\
		[Building Type]= DELAY FIXED (
	Annual Repayment for Financed Buildings Sector Capital Expenses[Building Type],RPfFBSCC Repayment Period for Financed Buildings Sector Capital Costs\
		, 0)
	~	$
	~		|

Repayment of Financing for Electricity Sector Capital Expenditures Including Construction Subsidies\
		=
	DEPRECIATE STRAIGHTLINE(
	
	  Annual Repayment for This Year Electricty Transmission Distribution and Storage Expenses
	  * RPfFESCC Repayment Period for Financed Electricity Sector Capital Costs / One Year\
		,
	 
	  RPfFESCC Repayment Period for Financed Electricity Sector Capital Costs,
	
	  1,
	
	  0
	)
	~	$
	~		|

Repayment Period for Capacity Market Charges=
	3
	~	Year
	~	We assume that utility costs are recovered over three years through bills.
	|

Required Increase in Carbon Free Energy=
	MAX(
	  0,
	
	  SUM(Fuel that would be Used by Regulated Vehicle Types in Absence of LCFS with Elec Eff Adj\
		[Vehicle Type!,Cargo Type!,Vehicle Technology!,Transportation Fuel!])
	  * Required LCFS Percentage
	  - SUM(Carbon Free Energy in Absence of LCFS by Vehicle Type[Vehicle Type!,Cargo Type\
		!,Vehicle Technology!,Transportation Fuel!])
	)
	~	BTU
	~		|

Required Increase in Carbon Free Energy Assigned to Vehicle and Fuel Types[Vehicle Type\
		,Cargo Type,Transportation Fuel]=
	Quantity Carbon Free Energy May be Increased by Fuel by Regulated Vehicle Type[Vehicle Type\
		,Cargo Type,Transportation Fuel]
	* MIN(
	    1,
	
	    ZIDZ(
	      Required Increase in Carbon Free Energy,
	      SUM(Quantity Carbon Free Energy May be Increased by Fuel by Regulated Vehicle Type\
		[Vehicle Type!,Cargo Type!,Transportation Fuel!])
	    )
	  )
	~	BTU
	~		|

Required LCFS Percentage=
	BLP BAU LCFS Percentage
	+ Additional LCFS Percentage This Year
	~	Dmnl
	~		|

Required Share of Peak Demand from Clean Firm Resources=
	(1-exp(-((Elec Portfolio Percentage to Seek This Year[CES])/CDRDfRCP Clean Dispatchable Resource Demand for Reliability Curve Parameter B\
		)^CDRDfRCP Clean Dispatchable Resource Demand for Reliability Curve Parameter A))*CDRDfRCP Required Share of Peak Demand from Clean Dispatchable Resources at 100 Percent CES
	~	Dmnl
	~		|

Required ZEV Sales Percentage by Subregion[Subregion,Cargo Type,Vehicle Type]=
	IF THEN ELSE(
	
	  Boolean Use Non BAU Minimum Required ZEV Sales Percentage This Year by Subregion[Cargo Type\
		,Vehicle Type] > 0,
	
	  RZSPbS BAU Required ZEV Sales Percentage by Subregion[Subregion,Vehicle Type,Cargo Type\
		],
	
	  BRZSPbS BAU Required ZEV Sales Percentage by Subregion[Subregion,Vehicle Type,Cargo Type\
		]
	)
	~	Dmnl
	~		|

Retirable Vintages by Year[Modeled Vintage]=
	IF THEN ELSE(
	  Dimensionless Time - Modeled Vintage to Year Mapping[Modeled Vintage]
	  <= MLfPPR Minimum Lifetime for Power Plant Retirements/One Year,
	
	  0,
	
	  1
	)
	~	Dmnl
	~		|

Retired Vehicles Contribution to Percentage Change to Fleet Avg Fuel Economy[Vehicle Type\
		,Cargo Type,Vehicle Technology]=
	MAX(
	  0,
	
	  - Percentage of Vehicle Stock Retired This Year[Vehicle Type,Cargo Type,Vehicle Technology\
		]
	  * Percentage Difference in Retired Vehicle vs Fleet Avg Fuel Economy[Vehicle Type,\
		Cargo Type,Vehicle Technology]
	)
	~	Dmnl
	~	We do not allow retiring vehicles to cause fleet average fuel economy to \
		worsen, because the less-efficient vehicles are the ones that should \
		retire first, and not including this check can cause discontinuities in \
		output when the number of vehicles of a certain type and technology \
		approaches zero during the model run (for example, in a scenario with a \
		100% EV sales mandate fully ramped in by 2030, so we run out of gasoline \
		LDVs in the 2040s).
	|

Retiring Components Potential Energy Use[Building Type,Building Fuel,Building Component\
		]=
	MAX(
	  0,
	
	  MIN(
	    Last Year Components Potential Energy Use[Building Type,Building Fuel,Building Component\
		]
	    / One Year,
	
	    IF THEN ELSE(
	      Time < INITIAL TIME + CL Component Lifetime[Building Type,Building Component],
	
	      ZIDZ(
	        SYCEU Start Year Components Energy Use[Building Type,Building Fuel,Building Component\
		],
	        CL Component Lifetime[Building Type,Building Component]
	      ),
	
	      New Components Potential Energy Use after Envelope Effects after Lifetime[Building Type\
		,Building Fuel,Building Component]
	    )
	  )
	)
	~	BTU/Year
	~		|

Retiring Components Potential Energy Use Summed Across Fuels[Building Type,Building Component\
		]=
	SUM(Retiring Components Potential Energy Use[Building Type,Building Fuel!,Building Component\
		])
	~	BTU/Year
	~		~	:SUPPLEMENTARY 
	|

Retiring Generation Capacity[Electricity Source]=
	MAX(
	    0,
	    MIN(
	      SUM(Retiring Generation Capacity including Economic and Policy Mandated Retirements\
		[Electricity Source,last pass!]),
	      Last Year Electricity Generation Capacity[Electricity Source]
	     )
	  )
	~	MW
	~		|

Retiring Generation Capacity Excluding Capacity Payment[Electricity Source]=
	MAX(
	    0,
	    MIN(
	      Retiring Generation Capacity Including Economic and Policy Mandated Retirements Excluding Capacity Payment\
		[Electricity Source],
	      Last Year Electricity Generation Capacity[Electricity Source]
	     )
	  )
	~	MW
	~		|

Retiring Generation Capacity including Economic and Policy Mandated Retirements[Electricity Source\
		,Optimization Pass]=
	Economic Capacity Retirements by Optimization Pass[Electricity Source,Optimization Pass\
		]
	
	+Planned and Policy Mandated Capacity Retirements[Electricity Source]
	
	+SUM(Capacity Retirements Based on Economic Lifetime[Electricity Source,Modeled Vintage\
		!])
	~	MW
	~		|

Retiring Generation Capacity Including Economic and Policy Mandated Retirements Excluding Capacity Payment\
		[Electricity Source]=
	Economic Capacity Retirements Excluding Capacity Payment[Electricity Source]
	+ Planned and Policy Mandated Capacity Retirements[Electricity Source]
	+ SUM(Capacity Retirements Based on Economic Lifetime[Electricity Source,Modeled Vintage\
		!])
	~	MW
	~		|

Retiring Hydrogen Production Capacity Installed During Model Run by Vintage[Hydrogen Production Pathway\
		,Model Run Vintage]=
	Last Year Hydrogen Production Capacity Installed During Model Run by Vintage[Hydrogen Production Pathway\
		,Model Run Vintage] / One Year
	* Fraction of Hydrogen Production Equipment Retired by Age[Model Run Vintage]
	~	BTU/Year
	~		|

Retiring Preexisting Hydrogen Production Capacity[Hydrogen Production Pathway]=
	Last Year Preexisting Hydrogen Production Capacity[Hydrogen Production Pathway] / One Year
	* PHERP Preexisting Hydrogen Equipment Retirement Profile
	~	BTU/Year
	~		|

Retiring Share of Industrial Equipment Desired Due to Equipment Age[Industrial Process\
		,Model Run Vintage]=
	IESD FoIERbA Fraction of Industrial Equipment Retiring by Age[Industrial Process](Years Elapsed Since Model Run Vintage\
		[Model Run Vintage] / One Year)
	~	Dmnl
	~		|

Retiring Vehicle Fuel Economy[Vehicle Type,Cargo Type,Vehicle Technology]=
	IF THEN ELSE(
	  Time - INITIAL TIME <= AVL Avg Vehicle Lifetime[Cargo Type,Vehicle Type] - 1,
	
	  BHNVFEAL BAU Historical New Vehicle Fuel Economy After Lifetime[Vehicle Type,Cargo Type\
		,Vehicle Technology],
	
	  New Vehicle Fuel Economy After Lifetime[Vehicle Type,Cargo Type,Vehicle Technology\
		]
	)
	~	thing*miles/BTU
	~		|

Retiring Vehicles[Vehicle Type,Cargo Type,Vehicle Technology]=
	IF THEN ELSE(
	  Time - INITIAL TIME <
	  MODULO(
	      SYVbT Start Year Vehicles by Technology[Vehicle Type,Cargo Type,Vehicle Technology\
		] / One Vehicle * One Year,
	      AVL Avg Vehicle Lifetime[Cargo Type,Vehicle Type]
	  ),
	  
	  INTEGER(
	    ZIDZ(
	      SYVbT Start Year Vehicles by Technology[Vehicle Type,Cargo Type,Vehicle Technology\
		],
	      AVL Avg Vehicle Lifetime[Cargo Type,Vehicle Type]
	    )
	  )
	  + 1,
	  
	  IF THEN ELSE(
	    Time - INITIAL TIME <= AVL Avg Vehicle Lifetime[Cargo Type,Vehicle Type] - 1,
		
		INTEGER(
	      ZIDZ(
	        SYVbT Start Year Vehicles by Technology[Vehicle Type,Cargo Type,Vehicle Technology\
		],
	        AVL Avg Vehicle Lifetime[Cargo Type,Vehicle Type]
	      )
	    ),
		
		INTEGER(
	      MIN(
	        New Vehicles After Lifetime[Vehicle Type,Cargo Type,Vehicle Technology],
	        Last Year Vehicles[Vehicle Type,Cargo Type,Vehicle Technology] / One Year
	      )
	    )
	  )
	)
	~	vehicles/Year
	~	Let L be the lifetime of a given type of vehicle (in years).  In the first \
		L years of the model run, we want to retire 1/L of the starting number of \
		vehicles.  Since we only work with whole numbers of vehicles (integers), \
		and the Vensim "INTEGER" function truncates (rounds down), this may leave \
		us with a remainder, R.  (R will always be smaller than L.)  We deal with \
		this remainder by retiring one additional vehicle in each of the first R \
		years of the model run, in addition to the 1/L vehicles that are retired \
		in each those years.  After L years have elapsed, we simply retire the \
		vehicles we added to the fleet L years ago.
	|

Retiring Vehicles Summed Across Technologies[Vehicle Type,Cargo Type]=
	SUM(Retiring Vehicles[Vehicle Type,Cargo Type,Vehicle Technology!])
	~	vehicles/Year
	~		~	:SUPPLEMENTARY 
	|

Retrofit Capacity after Quantization[Electricity Source]=
	New Policy Mandated Retrofits[Electricity Source] 
	+ Retrofit Capacity Desired due to Cost Effectiveness[Electricity Source,CES]
	+ Retrofit Capacity for Clean Dispatchable Reliability[Electricity Source]
	~	MW
	~		|

Retrofit Capacity Desired due to Cost Effectiveness[Electricity Source,Clean Elec Requirement\
		] :EXCEPT:      [CCUS Electricity Source,Clean Elec Requirement]=
	0 ~~|
Retrofit Capacity Desired due to Cost Effectiveness[CCUS Electricity Source,RPS]=
	QUANTUM(
	  MAX(0,
	    SUM(Retrofitted Capacity Desired due to Cost Effectiveness by Optimization Pass[\
		CCUS Electricity Source,last pass!,RPS])
	    -Retrofit Capacity for Clean Dispatchable Reliability[CCUS Electricity Source]),
	  MPPC Minimum Power Plant Capacity[CCUS Electricity Source]
	) ~~|
Retrofit Capacity Desired due to Cost Effectiveness[CCUS Electricity Source,CES]=
	QUANTUM(
	  MAX(0,
	    SUM(Retrofitted Capacity Desired due to Cost Effectiveness by Optimization Pass[\
		CCUS Electricity Source,last pass!,CES])
	    -Retrofit Capacity for Clean Dispatchable Reliability[CCUS Electricity Source]),
	  MPPC Minimum Power Plant Capacity[CCUS Electricity Source]
	)
	~	MW
	~		|

Retrofit Capacity for Clean Dispatchable Reliability[Electricity Source] :EXCEPT:     \
		[CCUS Electricity Source]=
	0 ~~|
Retrofit Capacity for Clean Dispatchable Reliability[CCUS Electricity Source]=
	SUM(Retrofitted Capacity Desired for Seasonal Clean Dispatchable Reliability by Optimization Pass\
		[CCUS Electricity Source,last pass!])
	~	MW
	~		|

Retrofitted Capacity Desired due to Cost Effectiveness by Optimization Pass[Electricity Source\
		, Optimization Pass,Clean Elec Requirement] :EXCEPT:       [CCUS Electricity Source\
		, Optimization Pass,Clean Elec Requirement]=
	0 ~~|
Retrofitted Capacity Desired due to Cost Effectiveness by Optimization Pass[CCUS Electricity Source\
		, Optimization Pass,RPS]=
	QUANTUM(
	  MIN(
	    Max Capacity Available for CCUS Retrofit after CES Clean Firm Reliability Additions\
		[CCUS Electricity Source],
	
	    Profitable Capacity for CCUS Retrofits[CCUS Electricity Source,Optimization Pass\
		,RPS]
	    * CSCSoCECBiaSY Share of Cost Effective Capacity Built in a Single Year[CCUS Electricity Source\
		]
	  ),
	  MPPC Minimum Power Plant Capacity[CCUS Electricity Source]
	) ~~|
Retrofitted Capacity Desired due to Cost Effectiveness by Optimization Pass[CCUS Electricity Source\
		,Optimization Pass,CES]=
	QUANTUM(
	  MIN(
	    Max Capacity Available for CCUS Retrofit after CES Clean Firm Reliability Additions\
		[CCUS Electricity Source],
	
	    Profitable Capacity for CCUS Retrofits[CCUS Electricity Source,Optimization Pass\
		,CES]
	    * CSCSoCECBiaSY Share of Cost Effective Capacity Built in a Single Year[CCUS Electricity Source\
		]
	  ),
	  MPPC Minimum Power Plant Capacity[CCUS Electricity Source]
	)
	~	MW
	~		|

Retrofitted Capacity Desired due to Cost Effectiveness without CES[Electricity Source\
		] :EXCEPT:    [CCUS Electricity Source
]=
	0 ~~|
Retrofitted Capacity Desired due to Cost Effectiveness without CES[CCUS Electricity Source\
		]=
	QUANTUM(
	  MIN(
	    Max Capacity Available for CCUS Retrofit after CES Clean Firm Reliability Additions\
		[CCUS Electricity Source],
	
	    Profitable Capacity for CCUS Retrofits without CES[CCUS Electricity Source]
	    * CSCSoCECBiaSY Share of Cost Effective Capacity Built in a Single Year[CCUS Electricity Source\
		]
	  ),
	 MPPC Minimum Power Plant Capacity[CCUS Electricity Source]
	 )
	~	MW
	~		|

Retrofitted Capacity Desired for Seasonal Clean Dispatchable Reliability by Optimization Pass\
		[Clean Dispatchable Electricity Source,Optimization Pass]=
	QUANTUM(
	  MAX(0,MIN(
	    Max Capacity Available for CCUS Retrofits after Mandated Retrofits[Clean Dispatchable Electricity Source\
		],
	
	    (
	      Profitable Capacity for Seasonal Dispatchable Clean Reliability CCUS Retrofits\
		[Clean Dispatchable Electricity Source,Optimization Pass]
	      * CSCSoCECBiaSY Share of Cost Effective Capacity Built in a Single Year[Clean Dispatchable Electricity Source\
		]
	    )
	  )
	  ),
	  MPPC Minimum Power Plant Capacity[Clean Dispatchable Electricity Source]
	)
	~	MW
	~		|

Revenue from CES Credits per Unit Electricity Output by Plant Type[Electricity Source\
		]=
	Optimized RPS Credit Price
	  * Elec Portfolio Qualifying Sources[Electricity Source,RPS]
	
	+ 
	
	(
	  Optimized CES Credit Price
	  + BZECfNP BAU Zero Emissions Credit for Nuclear Plants[Electricity Source]
	)
	  * Elec Portfolio Qualifying Sources[Electricity Source,CES]
	~	$/(MW*hr)
	~		|

