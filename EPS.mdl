Cost of Providing Demand Response by Recipient[Cash Flow Entity]=
	This Year DR Capacity by Provider[Cash Flow Entity]
	* DRCo Annual Cost per Unit Demand Response Capacity[Cash Flow Entity]
	~	$
	~		|

Cost per MW for CCUS Retrofits Excluding Subsidies[Electricity Source] :EXCEPT:    [CCUS Electricity Source\
		]=
	9999 ~~|
Cost per MW for CCUS Retrofits Excluding Subsidies[CCUS Electricity Source]=
	Change in Annualized Fixed Costs per Unit Retrofitted Capacity[CCUS Electricity Source\
		]
	~	$/MW
	~		|

Cost per Unit Distributed Solar Capacity=
	(Last Year Cost per Unit Distributed Solar Capacity - Last Year Soft Costs per Unit Distributed Solar Capacity\
		)
	* This Year Solar and Wind Hard Costs as Fraction of Last Year Hard Costs[solar PV es\
		]
	
	+ CpUDSC Soft Costs per Unit Distributed Solar Capacity
	~	$/MW
	~		|

Cost per Unit New Elec Output Unit Correction Factor=
	1
	~	$/(MW*hr)
	~		|

Cost per Unit New Elec Output Using Expected Capacity Factors[Electricity Source]=
	Annualized Fixed Costs per Unit New Elec Output Using Expected Capacity Factors[Electricity Source\
		]
	+ Variable Costs per Unit New Elec Output[Electricity Source]
	~	$/(MW*hr)
	~		|

Cost per Unit New Hydrogen Production[Hydrogen Production Pathway]=
	Cost per Unit New Hydrogen Production Before Subsidies[Hydrogen Production Pathway]
	- 
	(Subsidy for Hydrogen Production by Pathway[Hydrogen Production Pathway]
	  * Discount Factor to Levelize Subsidy)
	~	$/BTU
	~		|

Cost per Unit New Hydrogen Production Before Carbon Tax Rebate[Hydrogen Production Pathway\
		] :EXCEPT:    [natural gas reforming with CCS
]=
	Cost per Unit New Hydrogen Production before CCS[Hydrogen Production Pathway] ~~|
Cost per Unit New Hydrogen Production Before Carbon Tax Rebate[natural gas reforming with CCS\
		]=
	Cost per Unit New Hydrogen Production before CCS[natural gas reforming with CCS]
	+ CCS Cost per Ton Blue Hydrogen Produced
	~	$/BTU
	~		|

Cost per Unit New Hydrogen Production before CCS[Hydrogen Production Pathway] :EXCEPT:\
		                   [electrolysis with guaranteed clean electricity
]=
	ZIDZ(Hydrogen Production Equipment CapEx[Hydrogen Production Pathway],
	  Discount Factor to Levelize Capital Costs)
	
	+ HPEC Hydrogen Production Equipment OpEx[Hydrogen Production Pathway]
	
	+ 
	
	SUM(FIoHP Fuel Intensity of Hydrogen Production[Hydrogen Production Pathway,Industrial Fuel\
		!]
	  * Hydrogen Fuel Cost per Unit Energy[Industrial Fuel!]) ~~|
Cost per Unit New Hydrogen Production before CCS[electrolysis with guaranteed clean electricity\
		]=
	ZIDZ(Hydrogen Production Equipment CapEx[electrolysis with guaranteed clean electricity\
		],
	  Discount Factor to Levelize Capital Costs)
	
	+ HPEC Hydrogen Production Equipment OpEx[electrolysis with guaranteed clean electricity\
		]
	
	+ 
	
	SUM(FIoHP Fuel Intensity of Hydrogen Production[electrolysis with guaranteed clean electricity\
		,Industrial Fuel!])
	* 
	SUM(Cost per Unit New Elec Output Using Expected Capacity Factors[Electricity Source\
		!] 
	  * Share of Off Grid Electricity Demand That is New This Year Met by Power Plant Type\
		[Electricity Source!])
	* MWh per BTU
	
	+
	
	SUM(FIoHP Fuel Intensity of Hydrogen Production[electrolysis with guaranteed clean electricity\
		,Industrial Fuel!])
	* 
	SUM(
	  ZIDZ(Share of Off Grid Electricity Demand That is New This Year Met by Power Plant Type\
		[Electricity Source!],
	  Expected Capacity Factor x Hours per Year for Plants Built This Year[Electricity Source\
		!])
	)
	* TCCpUNEC Transmission Construction Cost per Unit New Electricity Capacity
	* MWh per BTU
	~	$/BTU
	~		|

Cost per Unit New Hydrogen Production Before Subsidies[Hydrogen Production Pathway] :EXCEPT:\
		   [natural gas reforming with CCS
]=
	Cost per Unit New Hydrogen Production Before Carbon Tax Rebate[Hydrogen Production Pathway\
		] ~~|
Cost per Unit New Hydrogen Production Before Subsidies[natural gas reforming with CCS\
		]=
	Cost per Unit New Hydrogen Production Before Carbon Tax Rebate[natural gas reforming with CCS\
		]
	
	- SUM(FIoHP Fuel Intensity of Hydrogen Production[natural gas reforming with CCS,Industrial Fuel\
		!] * Hydrogen Fuel Carbon Tax Amount per Unit Energy[Industrial Fuel!])
	~	$/BTU
	~		|

