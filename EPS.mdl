Start Year BAU Fuel Type Shares in Electricity Equivalent[Industry Category,Industrial Process\
		,Industrial Fuel]= INITIAL(
	ZIDZ(
	  BAU Industrial Equipment Energy Use from Input Data by Industrial Process in Electricity Equivalent\
		[Industry Category,Industrial Fuel,Industrial Process],
	  SUM(BAU Industrial Equipment Energy Use from Input Data by Industrial Process in Electricity Equivalent\
		[Industry Category,Industrial Fuel!,Industrial Process])
	))
	~	Dmnl
	~		|

Start Year Bid Capacity Factors[Electricity Source,Electricity Timeslice,Hour] :EXCEPT:\
		      [Electricity Source
,peak day electricity timeslice,Hour]=
	IF THEN ELSE(
	  BDTPTUMCF Boolean Does This Plant Type Use Maximum Capacity Factor[Electricity Source\
		] > 0,
	
	  Maximum Capacity Factor after RAF[Electricity Source],
	
	  Start Year Seasonal Expected Hourly Electricity Capacity Factors after RAF[Electricity Source\
		,Electricity Timeslice,Hour
	]
	) ~~|
Start Year Bid Capacity Factors[Electricity Source,peak day electricity timeslice,Hour\
		]=
	IF THEN ELSE(
	  BDTPTUMCF Boolean Does This Plant Type Use Maximum Capacity Factor[Electricity Source\
		] > 0,
	
	  MCF Maximum Capacity Factor[Electricity Source],
	
	  Start Year Seasonal Expected Hourly Electricity Capacity Factors after RAF[Electricity Source\
		,peak day electricity timeslice,Hour
	]
	)
	~	Dmnl
	~		|

Start Year Cargo Dist Transported[Vehicle Type,Cargo Type,Vehicle Technology]= INITIAL\
		(
	SYVbT Start Year Vehicles by Technology[Vehicle Type,Cargo Type,Vehicle Technology]
	* SYAVLo Start Year Average Vehicle Loading[Cargo Type,Vehicle Type]
	* SYAADTbVT Start Year Average Annual Dist Traveled by Vehicle Type[Cargo Type,Vehicle Type\
		])
	~	thing*miles
	~		|

Start Year Distributed Electricity Capacity[Building Type,Electricity Source] :EXCEPT:\
		  [Building Type,solar PV es]=
	SYDEC Start Year Distributed Electricity Capacity[Building Type,Electricity Source] ~~|
Start Year Distributed Electricity Capacity[Building Type,solar PV es]=
	MIN(
	  MDSC Maximum Distributed Solar Capacity[Building Type,solar PV es],
	  SYDEC Start Year Distributed Electricity Capacity[Building Type,solar PV es]
	)
	~	MW
	~		|

Start Year District Heat and Hydrogen Fuel Use[Industrial Fuel]=
	( 
	  SUM(SYCEU Start Year Components Energy Use[Building Type!,heat bf,Building Component\
		!]) 
	  + BIFU Start Year Industrial Fuel Use[heat if]
	)
	* 
	BFoHPbF BAU Fraction of Heat Provided by Fuel[Industrial Fuel]
	
	+ 
	
	SUM(
	  SYAHPC Start Year Annual Hydrogen Production Capacity[Hydrogen Production Pathway!\
		]
	  * FIoHP Fuel Intensity of Hydrogen Production[Hydrogen Production Pathway!,Industrial Fuel\
		]
	)
	~	BTU
	~		|

Start Year Domestic Energy Revenue by Producing ISIC Code[ISIC Code]=
	SUM(
	  Start Year Fuel Industry Revenue[All Fuels!]
	  * FtPICM Fuel to Producing ISIC Code Map[All Fuels!,ISIC Code]
	  * BAU Domestic Content Share of Consumption by ISIC Code from Exogenous Data[ISIC Code\
		]
	  * Start Year Share of Fuel Production by Fuel within ISIC Code[All Fuels!,ISIC Code\
		]
	)
	~	$
	~		|

Start Year Electricity Generation Capacity[Electricity Source]=
	SUM(BHRaSYC Start Year Electricity Generation Capacity by Vintage[Electricity Source\
		,Modeled Vintage!])
	~	MW
	~		|

Start Year Electricity Generation Capacity Summed Across Vintages[Electricity Source]\
		= INITIAL(
	SUM(BHRaSYC Start Year Electricity Generation Capacity by Vintage[Electricity Source\
		,Modeled Vintage!]))
	~	MW
	~		|

Start Year Electricity Prices by Sector[Sectors]= INITIAL(
	BAU Pretax Fuel Price by Sector[electricity,Sectors])
	~	$/BTU
	~		|

Start Year Electricity Supplier Expenditures after Subsidies per Unit Electricity Produced\
		= INITIAL(
	BAU Electricity Supplier Costs Recovered through Electricity Rates per Unit Electricity Delivered\
		*(1-SoEDtICoS Share of Electricity Demand that Is Cost of Service)
	+ BAU Electricity Supplier Costs Recovered through Electricity Rates per Unit Electricity Delivered for Cost of Service Rates\
		*SoEDtICoS Share of Electricity Demand that Is Cost of Service)
	~	$/BTU
	~		|

Start Year Energy Intensity of Industrial Production by Fuel and Process in Electricity Equivalent\
		[Industry Category,Industrial Fuel
,Industrial Process]=
	Start Year Energy Intensity of Industrial Production in Electricity Equivalent[Industry Category\
		]
	* BAU Percentage Fuel Use by Industrial Process with Fallback Data[Industry Category\
		,Industrial Fuel,Industrial Process]
	~	BTU/$
	~		|

Start Year Energy Intensity of Industrial Production in Electricity Equivalent[Industry Category\
		]= INITIAL(
	Raw BAU Industrial Energy Intensity in Electricity Equivalent[Industry Category])
	~	BTU/$
	~		|

Start Year Energy Use[All Fuels,Sectors] :EXCEPT:       [electricity source within all fuels\
		,electricity sector],[building fuel within all fuels,residential buildings sector],\
		[building fuel within all fuels,commercial buildings sector],[industrial fuel within all fuels\
		,industry sector],[industrial fuel within all fuels,district heat and hydrogen sector\
		],[transportation fuel within all fuels,transportation sector]=
	0 ~~|
Start Year Energy Use[electricity source within all fuels,electricity sector] :EXCEPT:\
		    [natural gas,electricity sector],[solar,electricity sector],[wind,electricity sector\
		],[hard coal,electricity sector],[biomass,electricity sector],[lignite,electricity sector\
		],[nuclear,electricity sector],[hydrogen,electricity sector]=
	Start Year Estimate Electricity Sector Fuel Use[Electricity Source] ~~|
Start Year Energy Use[building fuel within all fuels,residential buildings sector]=
	SUM(SYCEU Start Year Components Energy Use[urban residential,Building Fuel,Building Component\
		!])
	+ SUM(SYCEU Start Year Components Energy Use[rural residential,Building Fuel,Building Component\
		!]) ~~|
Start Year Energy Use[building fuel within all fuels,commercial buildings sector]=
	SUM(SYCEU Start Year Components Energy Use[commercial,Building Fuel,Building Component\
		!]) ~~|
Start Year Energy Use[industrial fuel within all fuels,industry sector] :EXCEPT: [hydrogen\
		,industry sector]=
	BIFU Start Year Industrial Fuel Use[Industrial Fuel] ~~|
Start Year Energy Use[industrial fuel within all fuels,district heat and hydrogen sector\
		] :EXCEPT: [hydrogen,district heat and hydrogen sector]=
	Start Year District Heat and Hydrogen Fuel Use[Industrial Fuel] ~~|
Start Year Energy Use[transportation fuel within all fuels,transportation sector]=
	SUM(Est Start Year Transportation Sector Fuel Used[Vehicle Type!,Cargo Type!,Vehicle Technology\
		!,Transportation Fuel]) ~~|
Start Year Energy Use[natural gas,electricity sector]=
	Start Year Estimate Electricity Sector Fuel Use[natural gas steam turbine es]
	+ Start Year Estimate Electricity Sector Fuel Use[natural gas combined cycle es]
	+ Start Year Estimate Electricity Sector Fuel Use[natural gas peaker es]
	+ Start Year Estimate Electricity Sector Fuel Use[natural gas combined cycle w CCS es\
		] ~~|
Start Year Energy Use[solar,electricity sector]=
	Start Year Estimate Electricity Sector Fuel Use[solar PV es]
	+ Start Year Estimate Electricity Sector Fuel Use[solar thermal es] ~~|
Start Year Energy Use[wind,electricity sector]=
	Start Year Estimate Electricity Sector Fuel Use[onshore wind es]
	+ Start Year Estimate Electricity Sector Fuel Use[offshore wind es] ~~|
Start Year Energy Use[hard coal,electricity sector]=
	Start Year Estimate Electricity Sector Fuel Use[hard coal es]
	+ Start Year Estimate Electricity Sector Fuel Use[hard coal w CCS es] ~~|
Start Year Energy Use[biomass,electricity sector]=
	Start Year Estimate Electricity Sector Fuel Use[biomass es]
	+ Start Year Estimate Electricity Sector Fuel Use[biomass w CCS es] ~~|
Start Year Energy Use[lignite,electricity sector]=
	Start Year Estimate Electricity Sector Fuel Use[lignite es]
	+ Start Year Estimate Electricity Sector Fuel Use[lignite w CCS es] ~~|
Start Year Energy Use[nuclear,electricity sector]=
	Start Year Estimate Electricity Sector Fuel Use[nuclear es]
	+ Start Year Estimate Electricity Sector Fuel Use[small modular reactor es] ~~|
Start Year Energy Use[hydrogen,electricity sector]=
	Start Year Estimate Electricity Sector Fuel Use[hydrogen combustion turbine es]
	+ Start Year Estimate Electricity Sector Fuel Use[hydrogen combined cycle es] ~~|
Start Year Energy Use[hydrogen,industry sector]=
	BIFU Start Year Industrial Fuel Use[hydrogen if]
	+ BIFU Start Year Industrial Fuel Use[green hydrogen if]
	+ BIFU Start Year Industrial Fuel Use[low carbon hydrogen if] ~~|
Start Year Energy Use[hydrogen,district heat and hydrogen sector]=
	Start Year District Heat and Hydrogen Fuel Use[hydrogen if]
	+ Start Year District Heat and Hydrogen Fuel Use[green hydrogen if]
	+ Start Year District Heat and Hydrogen Fuel Use[low carbon hydrogen if]
	~	BTU
	~		|

Start Year Estimate Electricity Sector Fuel Use[Electricity Source]=
	Start Year Estimated Electricity Generation by Type[Electricity Source]
	* Start Year Weighted Average Heat Rate[Electricity Source]
	~	BTU
	~		|

Start Year Estimated Electricity Generation by Type[Electricity Source]= INITIAL(
	Last Year Electricity Generation Capacity[Electricity Source]
	* Start Year Expected Capacity Factors[Electricity Source]
	* Hours per Year)
	~	MW*hour
	~		|

Start Year EV Battery Capacity Deployed=
	SUM(SYBCbVT Start Year Battery Capacity by Vehicle Type[Cargo Type!,Vehicle Type!,Vehicle Technology\
		!]
	   * SYVbT Start Year Vehicles by Technology[Vehicle Type!,Cargo Type!,Vehicle Technology\
		!]
	)
	~	MW*hr
	~		|

Start Year Expected Capacity Factors[Electricity Source]=
	SUM(
	  Start Year Seasonal Expected Hourly Electricity Capacity Factors after RAF[Electricity Source\
		,Electricity Timeslice!,Hour!]
	  * SHELF Days per Electricity Timeslice[Electricity Timeslice!]
	)
	~	Dmnl
	~		|

Start Year Fuel Industry Revenue[All Fuels]=
	Start Year Fuel Industry Revenue Before Exports[All Fuels]
	+
	BFPIaE Start Year Fuel Exports[All Fuels]
	* IMFPbFT Start Year International Market Fuel Prices Including Electricity[All Fuels\
		]
	~	$
	~		|

Start Year Fuel Industry Revenue Before Exports[All Fuels]=
	SUM(
	  Start Year Energy Use[All Fuels,Sectors!]
	  * BFPaT Start Year Pretax Fuel Price[All Fuels,Sectors!]
	)
	~	$
	~		|

Start Year Grid Battery Storage Capacity in MWh=
	GBSC Start Year Grid Battery Storage Capacity
	* GBSC Diurnal Grid Battery Daily Storage Duration
	~	MW*hr
	~		|

Start Year Low Carbon Hydrogen Production Shares by Pathway[Hydrogen Production Pathway\
		]=
	IF THEN ELSE(
	  SUM(
	    Hydrogen Production Pathways Qualifying as Low Carbon[Hydrogen Production Pathway\
		!]
	    * SYAHPC Start Year Annual Hydrogen Production Capacity[Hydrogen Production Pathway\
		!]
	  )
	  = 0,
	
	  ZIDZ(
	    Hydrogen Production Pathways Qualifying as Low Carbon[Hydrogen Production Pathway\
		],
	    SUM(
	      Hydrogen Production Pathways Qualifying as Low Carbon[Hydrogen Production Pathway\
		!]
	    )
	  ),
	
	  ZIDZ(
	     SYAHPC Start Year Annual Hydrogen Production Capacity[Hydrogen Production Pathway\
		]
	    * Hydrogen Production Pathways Qualifying as Low Carbon[Hydrogen Production Pathway\
		],
	    SUM(
	      Hydrogen Production Pathways Qualifying as Low Carbon[Hydrogen Production Pathway\
		!]
	      * SYAHPC Start Year Annual Hydrogen Production Capacity[Hydrogen Production Pathway\
		!]
	    )
	  )
	)
	~	Dmnl
	~		|

Start Year Other Hydrogen Production Shares by Pathway[Hydrogen Production Pathway]=
	IF THEN ELSE(
	  SUM(SYAHPC Start Year Annual Hydrogen Production Capacity[Hydrogen Production Pathway\
		!]) = 0,
	
	  ZIDZ(1, ELMCOUNT(Hydrogen Production Pathway)),
	
	  ZIDZ(SYAHPC Start Year Annual Hydrogen Production Capacity[Hydrogen Production Pathway\
		],
	  SUM(SYAHPC Start Year Annual Hydrogen Production Capacity[Hydrogen Production Pathway\
		!]))
	)
	~	Dmnl
	~		|

Start Year Output by ISIC Code by Year[ISIC Code]=
	Start Year Domestic Energy Revenue by Producing ISIC Code[ISIC Code]
	* FoPTaFbIC Fractions of Products That are Fuels by ISIC Code[ISIC Code]
	
	+ SYObIC Start Year Output by ISIC Code[ISIC Code]
	  * (1 - FoPTaFbIC Fractions of Products That are Fuels by ISIC Code[ISIC Code])
	~	$
	~		|

Start Year Seasonal Expected Hourly Electricity Capacity Factors after RAF[Electricity Source\
		,Electricity Timeslice,Hour]=
	SYSHECF Start Year Seasonal Expected Hourly Electricity Capacity Factors[Electricity Source\
		,Electricity Timeslice,Hour]
	* RAF Regional Availability Factor for Generation[Electricity Source]
	~	Dmnl
	~		|

Start Year Share of Fuel Production by Fuel within ISIC Code[All Fuels,ISIC Code]=
	ZIDZ(
	  BFPIaE Start Year Fuel Production[All Fuels]
	  * FtPICM Fuel to Producing ISIC Code Map[All Fuels,ISIC Code],
	
	  SUM(
	    BFPIaE Start Year Fuel Production[All Fuels!]
	    * FtPICM Fuel to Producing ISIC Code Map[All Fuels!,ISIC Code!]
	  )
	)
	~	Dmnl
	~		|

Start Year Weighted Average Heat Rate[Electricity Source]=
	ZIDZ(
	  SUM(
	    BHRaSYC BAU Heat Rates[Electricity Source,Modeled Vintage!]
	    * BHRaSYC Start Year Electricity Generation Capacity by Vintage[Electricity Source\
		,Modeled Vintage!]
	  ),
	  Start Year Electricity Generation Capacity[Electricity Source]
	)
	~	BTU/(MW*hour)
	~		|

Steps Allowed in Same Direction With Declining Step Size=
	1
	~	Dmnl
	~		|

Steps Allowed in Same Direction Without Increasing Step Size=
	2
	~	Dmnl
	~		|

STfESCE Smoothing Time for Electricity Sector Capital Expenditures=
	GET DIRECT CONSTANTS(
	   'InputData/elec/STfESCE/STfESCE.csv',
	   ',',
	   'B2*'
	)
	~	Year
	~		|

strict industries within industry category:
	coal mining 05,
	oil and gas extraction 06,
	other mining and quarrying 07T08,
	food beverage and tobacco 10T12,
	textiles apparel and leather 13T15,
	wood products 16,
	pulp paper and printing 17T18,
	refined petroleum and coke 19,
	chemicals 20,
	rubber and plastic products 22,
	glass and glass products 231,
	cement and other nonmetallic minerals 239,
	iron and steel 241,
	other metals 242,
	metal products except machinery and vehicles 25,
	computers and electronics 26,
	appliances and electrical equipment 27,
	other machinery 28,
	road vehicles 29,
	nonroad vehicles 30,
	other manufacturing 31T33,
	energy pipelines and gas processing 352T353,
	construction 41T43
	~	
	~		|

Subregion:
	(subregion1-subregion60)
	~	
	~		|

Subsidies for Elec Production for Existing Plants Paid This Year[Electricity Source]=
	Electricity Generation by Type[Electricity Source]
	* (BS BAU Subsidy per Unit Electricity Output for Existing Plants[Electricity Source\
		]
	      * (1 - Percent Reduction in BAU Subsidies This Year[electricity source within all fuels\
		])
	)
	~	$
	~		|

Subsidies Paid for Grid Battery Production Not Passed Through to Consumers=
	(New Grid Battery Capacity+Policy Mandated Grid Battery Storage Additions
	  + SUM(New Hybrid Grid Battery Storage Capacity[Electricity Source!]))
	
	* Subsidy for Grid Battery Production Not Passed Through to Consumers
	~	$
	~		|

Subsidies Paid for Grid Battery Production Passed Through to Consumers=
	Subsidy for Grid Battery Production Passed Through to Consumers
	
	*
	
	(New Grid Battery Capacity + Policy Mandated Grid Battery Storage Additions +
	  SUM(New Hybrid Grid Battery Storage Capacity[Electricity Source!]))
	~	$
	~		|

Subsidies Paid for New Grid Battery Construction=
	(New Grid Battery Capacity+Policy Mandated Grid Battery Storage Additions)
	* Subsidy per Unit Grid Battery Capacity Deployed
	~	$
	~		|

Subsidies Paid per Unit Electricity Output for Newly Eligible Generation Capacity[Electricity Source\
		]=
	New and Retrofit Generation Capacity[Electricity Source]
	* Expected Capacity Factor x Hours per Year for Plants Built This Year[Electricity Source\
		]
	* Subsidy per Unit Electricity Output[Electricity Source]
	~	$
	~		|

Subsidy for Clean Industrial Heat Production[industrial heating process]=
	0,	{boilers}
	0,	{nonboiler low temp}
	0,	{nonboiler med temp}
	0	{nonboiler high temp}
	~	output currency unit/output TPE unit [0,20]
	~		|

Subsidy for Clean Industrial Heat Production in Dollars[industrial heating process]=
	Subsidy for Clean Industrial Heat Production[industrial heating process]
	* OCCF Dollars per Small Output Currency Unit
	~	$/output TPE unit
	~		|

Subsidy for Clean Industrial Heat Production This Year[industrial heating process]=
	Subsidy for Clean Industrial Heat Production in Dollars[industrial heating process]
	* VECTOR ELM MAP(
	    Selected Policy Implementation Schedule[indst clean heat PTC X boilers],
	
	    (industrial heating process-1)
	  )
	~	$/output TPE unit
	~		|

Subsidy for Elec Production by Fuel[Electricity Source]=
	0,	{hard coal}
	0,	{natural gas steam turbine}
	0,	{natural gas combined cycle}
	0,	{nuclear}
	0,	{hydro}
	0,	{onshore wind}
	0,	{solar PV}
	0,	{solar thermal}
	0,	{biomass}
	0,	{geothermal}
	0,	{petroleum}
	0,	{natural gas peaker}
	0,	{lignite}
	0,	{offshore wind}
	0,	{crude oil}
	0,	{heavy or residual fuel oil}
	0,	{municipal solid waste}
	0,      {hard coal w CCS}
	0,      {natural gas combined cycle w CCS}
	0,      {biomass w CCS}
	0,      {lignite w CCS}
	0,      {small modular reactor}
	0,      {hydrogen combustion turbine}
	0       {hydrogen combined cycle}
	~	output currency unit/(MW*hour) [0,60]
	~		|

Subsidy for Elec Production by Fuel in Dollars[Electricity Source]=
	Subsidy for Elec Production by Fuel[Electricity Source]
	* OCCF Dollars per Small Output Currency Unit
	~	$/(MW*hour)
	~		|

Subsidy for Elec Production by Fuel This Year[Electricity Source]=
	Subsidy for Elec Production by Fuel in Dollars[Electricity Source]
	* VECTOR ELM MAP(
	    Selected Policy Implementation Schedule[elec generation subsidy X hard coal es],
	
	    (Electricity Source-1)
	  )
	~	$/(MW*hour)
	~		|

Subsidy for Grid Battery Production=
	BAU Subsidy for Grid Battery Production
	
	+ 
	
	(Additional Subsidy for Grid Battery Production This Year
	  * kWh per MWh
	  * FoGBPD Fraction of Grid Batteries Produced Domestically)
	~	$/(MW*hr)
	~		|

Subsidy for Grid Battery Production Not Passed Through to Consumers=
	Subsidy for Grid Battery Production
	- Subsidy for Grid Battery Production Passed Through to Consumers
	~	$/(MW*hr)
	~		|

Subsidy for Grid Battery Production Passed Through to Consumers=
	Subsidy for Grid Battery Production
	* FoSfBPPTtC Fraction of Subsidy for Battery Production Passed Through to Consumers
	~	$/(MW*hr)
	~		|

Subsidy for Hydrogen Production by Pathway[Hydrogen Production Pathway]=
	BSfHPbP BAU Subsidy for Hydrogen Production by Pathway[Hydrogen Production Pathway]
	+ 
	(Additional Subsidy for Hydrogen Production This Year[Hydrogen Production Pathway]
	  / BpMMTH BTU per MMT Hydrogen
	  * Kilogram per Million Metric Ton
	)
	~	$/BTU
	~		|

Subsidy for Thermal Fuels per Energy Unit Produced[All Fuels,Sectors]=
	BS BAU Subsidy for Thermal Fuels per Energy Unit Produced[All Fuels,Sectors]
	* (1 - Percent Reduction in BAU Subsidies This Year[All Fuels])
	~	$/BTU
	~		|

Subsidy for Vehicle Battery Production=
	(BSfVBP BAU Subsidy for Vehicle Battery Production
	+ Additional Subsidy for Vehicle Battery Production This Year)
	
	* FoVBPD Fraction of Vehicle Batteries Produced Domestically
	~	$/(kW*hr)
	~		|

Subsidy for Vehicle Battery Production Passed Through to Consumers=
	Subsidy for Vehicle Battery Production
	* FoSfBPPTtC Fraction of Subsidy for Battery Production Passed Through to Consumers
	~	$/(kW*hr)
	~		|

Subsidy Paid for Retrofitting Buildings[Building Type]=
	SUM(Amount Spent on Retrofitting Buildings[Building Type,Building Component!])
	* SoBRCBbG Share of Building Retrofit Costs Borne by Government[Building Type]
	~	$
	~		|

Subsidy Paid on Distributed Solar Capacity[Building Type]=
	This Year Change in Distributed Electricity Source Capacity[Building Type,solar PV es\
		]
	* Cost per Unit Distributed Solar Capacity
	* MIN((Additional Perc Subsidy for Distributed Solar PV Capacity This Year[Building Type\
		] + BPSfDSPC BAU Perc Subsidy for Distributed Solar PV Capacity[Building Type]),1)
	~	$
	~		|

Subsidy Payments per Unit Electricity Output Expiring After Subsidy Duration Period[Electricity Source\
		]= DELAY FIXED (
	Subsidies Paid per Unit Electricity Output for Newly Eligible Generation Capacity[Electricity Source\
		], BS Duration of Subsidies per Unit Electricity Output[Electricity Source], 0)
	~	$
	~		|

Subsidy per Unit Electricity Capacity Built[Electricity Source]=
	BS BAU Subsidy per Unit Electricity Capacity Built[Electricity Source]
	* (1 - Percent Reduction in BAU Subsidies This Year[electricity source within all fuels\
		])
	*Construction Cost per Unit Capacity before Construction Subsidies[Electricity Source\
		]
	
	+ Construction Cost per Unit Capacity before Construction Subsidies[Electricity Source\
		]
	  * Perc Subsidy for Elec Capacity Construction This Year[Electricity Source]
	
	- BS BAU Subsidy per Unit Electricity Capacity Built[Electricity Source]
	  * (1 - Percent Reduction in BAU Subsidies This Year[electricity source within all fuels\
		])
	  * Perc Subsidy for Elec Capacity Construction This Year[Electricity Source]
	  *Construction Cost per Unit Capacity before Construction Subsidies[Electricity Source\
		]
	~	$/MW
	~		|

Subsidy per Unit Electricity Output[Electricity Source]=
	BS BAU Subsidy per Unit Electricity Output[Electricity Source]
	  * (1 - Percent Reduction in BAU Subsidies This Year[electricity source within all fuels\
		])
	+ Subsidy for Elec Production by Fuel This Year[Electricity Source]
	~	$/(MW*hour)
	~		|

Subsidy per Unit Electricity Output Adjusted for Subsidy Duration[Electricity Source]\
		=
	BS BAU Subsidy per Unit Electricity Output[Electricity Source]
	  * (1 - Percent Reduction in BAU Subsidies This Year[electricity source within all fuels\
		])
	  *Duration Multiplier for Subsidies per Unit Electricity Output[Electricity Source]
	+ Subsidy for Elec Production by Fuel This Year[Electricity Source]
	  *Duration Multiplier for Subsidies per Unit Electricity Output[Electricity Source]
	~	$/(MW*hr)
	~		|

Subsidy per Unit Electricity Output for Dispatch[Electricity Source]=
	IF THEN ELSE(
	  Last Year Electricity Generation Capacity[Electricity Source] = 0,
	                 
	  Subsidy per Unit Electricity Output[Electricity Source],
	
	  ZIDZ(
	
	    SUM(
	      Last Year Electricity Generation Capacity by Vintage[Electricity Source,Modeled Vintage\
		!]
	      * Subsidy per Unit Electricity Output for Dispatch by Vintage[Electricity Source\
		,Modeled Vintage!]
	    ),
	
	    Last Year Electricity Generation Capacity[Electricity Source]
	  )
	)
	~	$/(MW*hr)
	~		|

Subsidy per Unit Electricity Output for Dispatch by Vintage[Electricity Source,Modeled Vintage\
		]=
	DEPRECIATE STRAIGHTLINE(
	
	  Subsidy per Unit Electricity Output[Electricity Source]
	  * BS Duration of Subsidies per Unit Electricity Output[Electricity Source] / One Year
	  *This Year Modeled Vintage Flag[Modeled Vintage],
	 
	  BS Duration of Subsidies per Unit Electricity Output[Electricity Source],
	
	  1,
	
	  0
	)
	~	$/(MW*hr)
	~		|

Subsidy per Unit Grid Battery Capacity Deployed=
	(Total Battery Cost per Unit Capacity 
	* Percent Subsidy per Unit Grid Battery Capacity Deployed)
	~	$/(MW*hour)
	~		|

Sum of Buildings Sector Changes in Cash Flows=
	SUM(Buildings Sector Change in Energy Expenditures by Entity[Cash Flow Entity!])
	+ SUM(Buildings Sector Change in Nonenergy Expenditures by Entity[Cash Flow Entity!]\
		)
	
	- SUM(Buildings Sector Change in Revenue by Entity[Cash Flow Entity!])
	~	$
	~		~	:SUPPLEMENTARY 
	|

Sum of Changes in Cash Flows=
	SUM(Direct Change in Cash Flow by Entity[Cash Flow Entity!])
	~	$
	~		~	:SUPPLEMENTARY 
	|

Sum of Components of Government Contribution to Change in Global Output=
	SUM(Government Contribution to Change in Global Output by ISIC Code[ISIC Code!])
	
	- Government Revenue Change Allocated by Mechanism[regular spending]
	~	$
	~		~	:SUPPLEMENTARY 
	|

Sum of Components of Household Contribution to Change in Global Output=
	SUM(Household Contribution to Change in Global Output by ISIC Code[ISIC Code!])
	+ Change in Household Savings * One Year
	
	- Change in Cash Flow by Entity From IO Outputs[labor and consumers]
	- Government Revenue Change Allocated by Mechanism[household taxes]
	~	$
	~		~	:SUPPLEMENTARY 
	|

Sum of Components of Industry Contribution to Change in Domestic Output=
	SUM(Industry Contribution to Change in Global Output by ISIC Code before Passthrough Costs\
		[ISIC Code!])
	
	- Direct Change in Revenue by Entity[nonenergy industries]
	- SUM(Direct Change in Revenue by Entity[energy supplier cash flow entity!])
	- Government Revenue Change Allocated by Mechanism[payroll taxes]
	- Government Revenue Change Allocated by Mechanism[corporate taxes]
	~	$
	~		~	:SUPPLEMENTARY 
	|

Sum of District Heating Changes in Cash Flows=
	SUM(District Heating Change in Energy Expenditures by Entity[Cash Flow Entity!])
	+ SUM(District Heating Change in Nonenergy Expenditures by Entity[Cash Flow Entity!]\
		)
	
	- SUM(District Heating Change in Revenue by Entity[Cash Flow Entity!])
	~	$
	~		~	:SUPPLEMENTARY 
	|

Sum of Electricity Sector Changes in Cash Flows=
	SUM(Electricity Sector Change in Energy Expenditures by Entity[Cash Flow Entity!])
	+ SUM(Electricity Sector Change in Nonenergy Expenditures by Entity[Cash Flow Entity\
		!])
	
	- SUM(Electricity Sector Change in Revenue by Entity[Cash Flow Entity!])
	~	$
	~		~	:SUPPLEMENTARY 
	|

Sum of Fuel Industry Revenue Changes Step One=
	SUM(Direct Change in Revenue by Entity[energy supplier cash flow entity!])
	
	- SUM(Change in Fuel Industry Revenue by Fuel Including Subsidies and Rebates[All Fuels\
		!])
	~	$
	~		~	:SUPPLEMENTARY 
	|

Sum of Fuel Industry Revenue Changes Step Two=
	SUM(Change in Fuel Industry Revenue by Fuel[All Fuels!])
	
	- SUM(Direct Change in Fuel Industry Revenue by ISIC Code[ISIC Code!])
	~	$
	~		~	:SUPPLEMENTARY 
	|

Sum of Fuel Trade and Subsidy Changes in Cash Flows=
	SUM(Fuel Trade and Subsidy Change in Energy Expenditures by Entity[Cash Flow Entity!\
		])
	
	- SUM(Fuel Trade and Subsidy Change in Revenue by Entity[Cash Flow Entity!])
	~	$
	~		~	:SUPPLEMENTARY 
	|

Sum of Geoengineering Changes in Cash Flows=
	SUM(Geoengineering Sector Change in Energy Expenditures by Entity[Cash Flow Entity!]\
		)
	+ SUM(Geoengineering Sector Change in Nonenergy Expenditures by Entity[Cash Flow Entity\
		!])
	
	- SUM(Geoengineering Sector Change in Revenue by Entity[Cash Flow Entity!])
	~	$
	~		~	:SUPPLEMENTARY 
	|

Sum of Government Revenue Change Allocation=
	Change in Cash Flow by Entity From IO Outputs[government]
	- SUM(Government Revenue Change Allocated by Mechanism[Government Revenue Mechanism!\
		])
	~	$
	~		~	:SUPPLEMENTARY 
	|

Sum of Hydrogen Sector Changes in Cash Flows=
	SUM(Hydrogen Sector Change in Energy Expenditures by Entity[Cash Flow Entity!])
	+ SUM(Hydrogen Sector Change in Nonenergy Expenditures by Entity[Cash Flow Entity!])
	
	- SUM(Hydrogen Sector Change in Revenue by Entity[Cash Flow Entity!])
	~	$
	~		~	:SUPPLEMENTARY 
	|

Sum of Industry Sector Changes in Cash Flows=
	SUM(Industry Sector Change in Energy Expenditures by Entity[Cash Flow Entity!])
	+ SUM(Industry Sector Change in Nonenergy Expenditures by Entity[Cash Flow Entity!])
	
	- SUM(Industry Sector Change in Revenue by Entity[Cash Flow Entity!])
	~	$
	~		~	:SUPPLEMENTARY 
	|

Sum of LULUCF Changes in Cash Flows=
	SUM(LULUCF Change in Nonenergy Expenditures by Entity[Cash Flow Entity!])
	
	- SUM(LULUCF Change in Revenue by Entity[Cash Flow Entity!])
	~	$
	~		~	:SUPPLEMENTARY 
	|

Sum of Pre and Post Reallocation Cash Flows=
	Change in Cash Flow by Entity From IO Outputs[government]
	+ Change in Cash Flow by Entity From IO Outputs[labor and consumers]
	
	+ SUM(Direct Change in Revenue by Entity[energy supplier cash flow entity!])
	+ Direct Change in Revenue by Entity[nonenergy industries]
	
	
	- SUM(Government Contribution to Change in Global Output by ISIC Code[ISIC Code!])
	- SUM(Household Contribution to Change in Global Output by ISIC Code[ISIC Code!])
	- SUM(Industry Contribution to Change in Global Output by ISIC Code before Passthrough Costs\
		[ISIC Code!])
	+ Change in Budget Deficit * One Year
	- Change in Household Savings * One Year
	~	$
	~	Change in budget deficit has the opposite sign.  (An increase in budget \
		deficit increases the amount sent to the other entities, so budget deficit \
		needs to be intverted to cancel these shifts out.)
	~	:SUPPLEMENTARY 
	|

Sum of Shareweights by Vehicle and Cargo Type[Vehicle Type,Cargo Type]=
	SUM(
	  TTS Transportation Technology Shareweights[Vehicle Type,Cargo Type,Vehicle Technology\
		!]
	  * Vehicle Technologies Qualifying as ZEVs[Vehicle Type,Vehicle Technology!]
	)
	~	Dmnl
	~		|

Sum of Transportation Sector Changes in Cash Flows=
	SUM(Transportation Sector Change in Energy Expenditures by Entity[Cash Flow Entity!]\
		)
	+ SUM(Transportation Sector Change in Nonenergy Expenditures by Entity[Cash Flow Entity\
		!])
	
	- SUM(Transportation Sector Change in Revenue by Entity[Cash Flow Entity!])
	~	$
	~		~	:SUPPLEMENTARY 
	|

Surviving Capacity Available After Green Hydrogen Demand[Hydrogen Production Pathway]\
		 :EXCEPT: [electrolysis with guaranteed clean electricity]=
	Surviving Hydrogen Production Capacity[Hydrogen Production Pathway] ~~|
Surviving Capacity Available After Green Hydrogen Demand[electrolysis with guaranteed clean electricity\
		]=
	Surviving Hydrogen Production Capacity[electrolysis with guaranteed clean electricity\
		]
	- Surviving Capacity Used for Green Hydrogen Production
	~	BTU
	~		|

Surviving Capacity Available After Low Carbon Hydrogen Demand[Hydrogen Production Pathway\
		]=
	Surviving Capacity Available After Green Hydrogen Demand[Hydrogen Production Pathway\
		]
	- Surviving Capacity Used for Low Carbon Hydrogen Production[Hydrogen Production Pathway\
		]
	~	BTU
	~		|

Surviving Capacity Available for Low Carbon Hydrogen Production[Hydrogen Production Pathway\
		]=
	Surviving Capacity Available After Green Hydrogen Demand[Hydrogen Production Pathway\
		]
	* Hydrogen Production Pathways Qualifying as Low Carbon[Hydrogen Production Pathway]
	~	BTU
	~		|

Surviving Capacity Used for Green Hydrogen Production=
	MIN(
	  Green Hydrogen Demand,
	  Surviving Green Hydrogen Production Capacity
	)
	~	BTU
	~		|

Surviving Capacity Used for Hydrogen Production[Hydrogen Production Pathway] :EXCEPT:\
		 [electrolysis with guaranteed clean electricity]=
	Surviving Capacity Used for Low Carbon Hydrogen Production[Hydrogen Production Pathway\
		]
	+ Surviving Capacity Used for Other Hydrogen Production[Hydrogen Production Pathway]\
		 ~~|
Surviving Capacity Used for Hydrogen Production[electrolysis with guaranteed clean electricity\
		]=
	Surviving Capacity Used for Green Hydrogen Production
	+ Surviving Capacity Used for Low Carbon Hydrogen Production[electrolysis with guaranteed clean electricity\
		]
	+ Surviving Capacity Used for Other Hydrogen Production[electrolysis with guaranteed clean electricity\
		]
	~	BTU
	~		|

Surviving Capacity Used for Low Carbon Hydrogen Production[Hydrogen Production Pathway\
		]=
	ALLOCATE AVAILABLE(
	  Surviving Capacity Available for Low Carbon Hydrogen Production[Hydrogen Production Pathway\
		],
	  Hydrogen Production Dispatch Cost Parameters as Vector[Hydrogen Production Pathway\
		,ptype],
	  Total Surviving Capacity Used for Low Carbon Hydrogen Production
	)
	~	BTU
	~		|

Surviving Capacity Used for Other Hydrogen Production[Hydrogen Production Pathway]=
	ALLOCATE AVAILABLE(
	  Surviving Capacity Available After Low Carbon Hydrogen Demand[Hydrogen Production Pathway\
		],
	  Hydrogen Production Dispatch Cost Parameters as Vector[Hydrogen Production Pathway\
		,ptype],
	  Total Surviving Capacity Used for Other Hydrogen Demand
	)
	~	BTU
	~		|

Surviving Electricity Generation Capacity[Electricity Source]=
	Surviving Electricity Generation Capacity before Economic Retirements[Electricity Source\
		]
	- Economic Capacity Retirements by Optimization Pass[Electricity Source,pass20]
	~	MW
	~		|

Surviving Electricity Generation Capacity before Economic Retirements[Electricity Source\
		]=
	MAX(
	  0,
	
	  Last Year Electricity Generation Capacity[Electricity Source]
	  - Planned and Policy Mandated Capacity Retirements[Electricity Source]
	)
	~	MW
	~		|

Surviving Green Hydrogen Production Capacity=
	Surviving Hydrogen Production Capacity[electrolysis with guaranteed clean electricity\
		]
	~	BTU
	~		|

Surviving Hydrogen Production Capacity[Hydrogen Production Pathway]=
	Surviving Preexisting Hydrogen Production Capacity[Hydrogen Production Pathway]
	+ Surviving Hydrogen Production Capacity Installed During Model Run[Hydrogen Production Pathway\
		]
	~	BTU
	~		|

Surviving Hydrogen Production Capacity Installed During Model Run[Hydrogen Production Pathway\
		]=
	SUM(
	  Last Year Hydrogen Production Capacity Installed During Model Run by Vintage[Hydrogen Production Pathway\
		,Model Run Vintage!]
	  - Retiring Hydrogen Production Capacity Installed During Model Run by Vintage[Hydrogen Production Pathway\
		,Model Run Vintage!] * One Year
	)
	~	BTU
	~		|

Surviving Potential Elec Portfolio Qualifying Output[Clean Elec Requirement]=
	SUM(
	  Surviving Potential Elec Portfolio Qualifying Output by Hour[Electricity Timeslice\
		!,Hour!,Clean Elec Requirement]
	  * SHELF Days per Electricity Timeslice[Electricity Timeslice!]
	)
	~	MW*hr
	~		|

Surviving Potential Elec Portfolio Qualifying Output by Hour[Electricity Timeslice,Hour\
		,Clean Elec Requirement]=
	MIN(
	  SUM(
	    Surviving Electricity Generation Capacity before Economic Retirements[Electricity Source\
		!]
	    * Last Year Achieved Capacity Factors by Hour[Electricity Timeslice,Hour,Electricity Source\
		!]
	    * Elec Portfolio Qualifying Sources[Electricity Source!,Clean Elec Requirement]
	    * One Hour
	  ),
	
	  Total Electricity Demand by Hour After Demand Altering Technologies excluding New Hybrid Batteries\
		[Electricity Timeslice
	,Hour]
	)
	~	MW*hr
	~		|

Surviving Preexisting Hydrogen Production Capacity[Hydrogen Production Pathway]=
	Last Year Preexisting Hydrogen Production Capacity[Hydrogen Production Pathway]
	- Retiring Preexisting Hydrogen Production Capacity[Hydrogen Production Pathway] * One Year
	~	BTU
	~		|

