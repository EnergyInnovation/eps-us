first modeled vintage:
	GET DIRECT SUBSCRIPT(
	  'InputData/ctrl-settings/MV/FMV.csv',
	  ',',
	  'A2',
	  'A',
	  ''
	)
	~	
	~		|

First Pass Electricity Dispatched by Guaranteed Dispatch by Hour[Electricity Source,Electricity Timeslice\
		,Hour]=
	IF THEN ELSE(
	 
	 SUM(Guaranteed Dispatch Amount[Electricity Source!,Electricity Timeslice,Hour]) > Total Electricity Demand by Hour After Demand Altering Technologies\
		[Electricity Timeslice,Hour],
	
	 First Tier Guaranteed Dispatch Amount[Electricity Source,Electricity Timeslice,Hour\
		]
	
	 + Second Tier Guaranteed Dispatch Amount[Electricity Source,Electricity Timeslice,Hour\
		]
	   * MIN( 
	         1,
	         MAX(
	           0,  
	           ZIDZ((Total Electricity Demand by Hour After Demand Altering Technologies\
		[Electricity Timeslice,Hour] - SUM(First Tier Guaranteed Dispatch Amount[Electricity Source\
		!,Electricity Timeslice,Hour])),
	           SUM(Second Tier Guaranteed Dispatch Amount[Electricity Source!,Electricity Timeslice\
		,Hour])
	               )
	             )
	        ),
	
	 Guaranteed Dispatch Amount[Electricity Source,Electricity Timeslice,Hour]
	)
	~	MW*hour
	~	If the amount of guaranteed dispatch exceeds the total amount of \
		electricity demand in a given hour, the first pass scales back the second \
		tier sources of guaranteed dispatch are proportionately (to a maximum of \
		zero).
	|

First Tier Guaranteed Dispatch Amount[Electricity Source,Electricity Timeslice,Hour]=
	Guaranteed Dispatch Amount[Electricity Source,Electricity Timeslice,Hour]
	* DPbES Dispatch Priority by Electricity Source[Electricity Source]
	~	MW*hour
	~		|

first vintage:
	GET DIRECT SUBSCRIPT(
	  'InputData/plcy-schd/V/FV.csv',
	  ',',
	  'A2',
	  'A',
	  ''
	)
	~	
	~		|

First Year Battery Energy Cost per Unit Capacity= INITIAL(
	BCpUC Battery Energy Cost per Unit Capacity)
	~	$/(MW*hr)
	~		|

First Year Battery Power Cost per Unit Capacity= INITIAL(
	BCpUC Battery Power Cost per Unit Capacity
	)
	~	$/MW
	~		|

First Year BAU Construction Cost per Unit Capacity[Electricity Source]= INITIAL(
	CCaMC BAU Construction Cost per Unit Capacity[Electricity Source])
	~	$/MW
	~		|

First Year BAU Soft Costs per Unit Capacity[Electricity Source]= INITIAL(
	CCaMC BAU Soft Costs per Unit Capacity[Electricity Source])
	~	$/MW
	~		|

First Year Cost per Unit Distributed Solar Capacity=
	INITIAL(CpUDSC Cost per Unit Distributed Solar Capacity)
	~	$/MW
	~		|

First Year NPV of CapEx and OpEx through This Year=
	NPV(
	  Total Change in CapEx and OpEx,
	  DR Discount Rate / One Year,
	  0,
	  1
	)
	/ One Year
	~	$
	~		|

First Year Soft Costs per Unit Distributed Solar Capacity=
	INITIAL(CpUDSC Soft Costs per Unit Distributed Solar Capacity)
	~	$/MW
	~		|

First Year Total Heat Use= INITIAL(
	Total District Heat Use)
	~	BTU
	~		|

Five Year Average Annual Expected Dispatch Costs by Power Plant Type[Electricity Source\
		]=
	ZIDZ(SUM(Five Year Average Hourly Expected Dispatch Costs by Power Plant Type[Electricity Timeslice\
		!,Hour!,Electricity Source]*SHELF Days per Electricity Timeslice[Electricity Timeslice\
		!]),Electricity Generation Capacity[Electricity Source])
	~	$/MW
	~		|

Five Year Average Annual Net Energy Market Revenue per MW by Power Plant Type[Electricity Source\
		]=
	ZIDZ(SUM(Five Year Average Hourly Net Energy Market Revenue from Total Electricity Dispatched by Power Plant Type\
		[Electricity Timeslice!,Hour!,Electricity Source]*SHELF Days per Electricity Timeslice\
		[Electricity Timeslice!]),Electricity Generation Capacity[Electricity Source])
	~	$/MW
	~		|

Five Year Average Dispatch Cost per Unit Electricity Output[Electricity Source]=
	Five Year Average Dispatch Cost per Unit Electricity Output before Subsidies[Electricity Source\
		]
	- Variable Subsidies per Unit Elec Output[Electricity Source]
	~	$/(MW*hour)
	~		|

Five Year Average Dispatch Cost per Unit Electricity Output before Subsidies[Electricity Source\
		]=
	Five Year Forward Weighted Average Electricity Fuel Cost per Unit Electricity Output\
		[Electricity Source]
	+ Weighted Average Variable OM Cost per Unit Electricity Output[Electricity Source]
	~	$/(MW*hour)
	~		|

Five Year Average Dispatch or Opportunity Cost per Unit Electricity Output[Electricity Source\
		] :EXCEPT:     [hydro es]=
	Five Year Average Dispatch Cost per Unit Electricity Output[Electricity Source] ~~|
Five Year Average Dispatch or Opportunity Cost per Unit Electricity Output[hydro es]=
	HOC Hydro Opportunity Cost
	~	$/(MW*hr)
	~		|

Five Year Average Electricity Dispatched by Least Cost by Hour[Electricity Timeslice,\
		Hour,Electricity Source]=
	IF THEN ELSE(
	     Unmet Electricity Demand After Elec Portfolio Std Dispatch[Electricity Timeslice\
		,Hour]*MWhr Tolerance Unit Correction Factor
	<Tolerance,
	     0,
	     SUPPLY AT PRICE(
	         Available Capacity for Least Cost Dispatch Mapped[Electricity Timeslice,Hour\
		,Electricity Source
	],
	        Five Year Average Power Plant Dispatch Parameters as Vector[Electricity Source\
		,ptype],
	        Five Year Average Electricity Market Price Adjusted for Zero Least Cost Dispatch Hours\
		[Electricity Timeslice,Hour
	])
	  )
	~	MW*hr
	~		|

Five Year Average Electricity Market Price[Electricity Timeslice,Hour]=
	FIND MARKET PRICE(
	 Electricity Demand Mapped to ElecDemand[Electricity Timeslice,Hour,demand1],Fixed Electricity Demand Vector
	[demand1,ptype],
	Available Capacity for Least Cost Dispatch Mapped[Electricity Timeslice,Hour,hard coal es\
		],Five Year Average Power Plant Dispatch Parameters as Vector
	[hard coal es,ptype])
	~	$/(MW*hour)
	~		|

Five Year Average Electricity Market Price Adjusted for Zero Least Cost Dispatch Hours\
		[Electricity Timeslice,Hour]=
	IF THEN ELSE(Electricity Demand Mapped to ElecDemand[Electricity Timeslice,Hour,demand1\
		]*MWhr Tolerance Unit Correction Factor<Tolerance,0,Five Year Average Electricity Market Price
	[Electricity Timeslice,Hour])
	~	$/(MW*hour)
	~		|

Five Year Average Hourly CDF Values for Total Dispatch by Power Plant Type[Electricity Source\
		,Electricity Timeslice,Hour]=
	IF THEN ELSE(Five Year Average Hourly Z Score by Power Plant Type for Total Dispatch\
		[Electricity Source,Electricity Timeslice,Hour]>=0,
	
	  1 - Five Year Average Hourly PDF Values for Total Dispatch by Power Plant Type[Electricity Source\
		,Electricity Timeslice,Hour] * (Abramowitz and Stegun Values for CDF
	[a1]*Five Year Average Hourly T Values for Total Dispatch by Power Plant Type[Electricity Source
	  ,Electricity Timeslice,Hour] + Abramowitz and Stegun Values for CDF[a2]*Five Year Average Hourly T Values for Total Dispatch by Power Plant Type
	[Electricity Source,Electricity Timeslice,Hour
	]^2
	   +Abramowitz and Stegun Values for CDF[a3]*Five Year Average Hourly T Values for Total Dispatch by Power Plant Type\
		[Electricity Source,
	Electricity Timeslice,Hour]^3+Abramowitz and Stegun Values for CDF
	  [a4]*Five Year Average Hourly T Values for Total Dispatch by Power Plant Type[Electricity Source\
		,Electricity Timeslice,Hour]^4+Abramowitz and Stegun Values for CDF
	[a5]*Five Year Average Hourly T Values for Total Dispatch by Power Plant Type[Electricity Source
	  ,Electricity Timeslice,Hour]^5),
	
	  1-(1 - Five Year Average Hourly PDF Values for Total Dispatch by Power Plant Type[\
		Electricity Source,Electricity Timeslice,Hour] * (Abramowitz and Stegun Values for CDF
	[a1]*Five Year Average Hourly T Values for Total Dispatch by Power Plant Type[Electricity Source
	  ,Electricity Timeslice,Hour] + Abramowitz and Stegun Values for CDF[a2]*Five Year Average Hourly T Values for Total Dispatch by Power Plant Type
	[Electricity Source,Electricity Timeslice,Hour
	]^2
	   +Abramowitz and Stegun Values for CDF[a3]*Five Year Average Hourly T Values for Total Dispatch by Power Plant Type\
		[Electricity Source,
	Electricity Timeslice,Hour]^3+Abramowitz and Stegun Values for CDF
	  [a4]*Five Year Average Hourly T Values for Total Dispatch by Power Plant Type[Electricity Source\
		,Electricity Timeslice,Hour]^4+Abramowitz and Stegun Values for CDF
	[a5]*Five Year Average Hourly T Values for Total Dispatch by Power Plant Type[Electricity Source
	  ,Electricity Timeslice,Hour]^5)))
	~	Dmnl
	~		|

Five Year Average Hourly Expected Dispatch Cost per Unit Total Electricity Dispatched by Power Plant Type\
		[Electricity Source,Electricity Timeslice,Hour]=
	Five Year Average Dispatch Cost per Unit Electricity Output before Subsidies[Electricity Source\
		]
	  -(Five Year Average Standard Deviation of Dispatch Costs[Electricity Source])*ZIDZ\
		(Five Year Average Hourly PDF Values for Total Dispatch by Power Plant Type
	[Electricity Source
	,Electricity Timeslice,Hour],Five Year Average Hourly CDF Values for Total Dispatch by Power Plant Type\
		[Electricity Source
	,Electricity Timeslice,Hour])
	~	$/(MW*hour)
	~		|

Five Year Average Hourly Expected Dispatch Costs by Power Plant Type[Electricity Timeslice\
		,Hour,Electricity Source]=
	Five Year Average Hourly Expected Dispatch Cost per Unit Total Electricity Dispatched by Power Plant Type\
		[Electricity Source
	,Electricity Timeslice,Hour]*Total Electricity Dispatched by Hour by Plant Type Using Five Year Averages\
		[Electricity Timeslice,Hour,Electricity Source]
	~	$
	~		|

Five Year Average Hourly Net Energy Market Revenue from Total Electricity Dispatched by Power Plant Type\
		[Electricity Timeslice,Hour,Electricity Source]=
	Five Year Average Hourly Revenue from Total Electricity Dispatched by Power Plant Type\
		[Electricity Timeslice,Hour,Electricity Source]
	-Five Year Average Hourly Expected Dispatch Costs by Power Plant Type[Electricity Timeslice\
		,Hour,Electricity Source]
	~	$
	~		|

Five Year Average Hourly PDF Values for Total Dispatch by Power Plant Type[Electricity Source\
		,Electricity Timeslice,Hour]=
	(1/sqrt(2*3.14159))*exp(-Five Year Average Hourly Z Score by Power Plant Type for Total Dispatch\
		[Electricity Source,Electricity Timeslice,Hour]^2/2)
	~	Dmnl
	~		|

Five Year Average Hourly Revenue from Total Electricity Dispatched by Power Plant Type\
		[Electricity Timeslice,Hour,Electricity Source]=
	Five Year Average Marginal Dispatch Cost by Hour[Electricity Timeslice,Hour]
	*Total Electricity Dispatched by Hour by Plant Type Using Five Year Averages[Electricity Timeslice\
		,Hour,Electricity Source]
	~	$
	~		|

Five Year Average Hourly T Values for Total Dispatch by Power Plant Type[Electricity Source\
		,Electricity Timeslice,Hour]=
	1/(1+0.231642*ABS(Five Year Average Hourly Z Score by Power Plant Type for Total Dispatch\
		[Electricity Source,Electricity Timeslice,Hour]))
	~	Dmnl
	~		|

Five Year Average Hourly Z Score by Power Plant Type for Total Dispatch[Electricity Source\
		, Electricity Timeslice, Hour]=
	ZIDZ((Five Year Average Marginal Dispatch Cost by Hour[Electricity Timeslice,Hour]-Five Year Average Dispatch Cost per Unit Electricity Output
	[Electricity Source]),Five Year Average Standard Deviation of Dispatch Costs[Electricity Source\
		])
	~	Dmnl
	~		|

Five Year Average Marginal Dispatch Cost by Hour[Electricity Timeslice,Hour]=
	IF THEN ELSE(ABS(SUM(Total Electricity Dispatched by Hour by Plant Type Using Five Year Averages\
		[Electricity Timeslice,
	Hour,Electricity Source!]))*MWhr Tolerance Unit Correction Factor < Tolerance,
	  EIaE Imported Electricity Price,
	
	  IF THEN ELSE(
	    ABS(
	      Five Year Average Electricity Market Price Adjusted for Zero Least Cost Dispatch Hours\
		[Electricity Timeslice,Hour
	]
	    )
	    *Dollar per MWhr Tolerance Unit Correction Factor 
	    < Tolerance
	
	    :OR: 
	
	    ABS(
	      SUM(
	        Five Year Average Electricity Dispatched by Least Cost by Hour[Electricity Timeslice\
		,Hour,Electricity Source!]
	      )
	      *MWhr Tolerance Unit Correction Factor
	    )
	    
	   < Tolerance,
	 
	    SUM(Five Year Average Dispatch Cost per Unit Electricity Output[Electricity Source\
		!]*Share of Total Electricity Dispatched by Hour by Plant Type[Electricity Timeslice\
		,Hour,Electricity Source!]),
	
	    Five Year Average Electricity Market Price Adjusted for Zero Least Cost Dispatch Hours\
		[Electricity Timeslice,Hour]
	  )
	)
	~	$/(MW*hour)
	~		|

Five Year Average Power Plant Dispatch Parameters as Vector[Electricity Source,ptype]\
		=
	3 ~~|
Five Year Average Power Plant Dispatch Parameters as Vector[Electricity Source,ppriority\
		]=
	Five Year Average Dispatch or Opportunity Cost per Unit Electricity Output[Electricity Source
	] ~~|
Five Year Average Power Plant Dispatch Parameters as Vector[Electricity Source,pwidth\
		]=
	MAX(
	  ABS(MAX(NSDoDC Normalized Standard Deviation of Dispatch Costs[Electricity Source]\
		,0.01)
	    *(Five Year Average Dispatch or Opportunity Cost per Unit Electricity Output[Electricity Source\
		]
	    + Variable Subsidies per Unit Elec Output[Electricity Source])
	  ),
	
	  0.01
	) ~~|
Five Year Average Power Plant Dispatch Parameters as Vector[Electricity Source,pextra\
		]=
	0
	~	$/(MW*hour)
	~	We require pwidth to be a minimum of 0.01 so that the dispatch allocations \
		do not result in an error due to 0 dispatch costs for some power plant \
		types
	|

Five Year Average Power Plant Dispatch Parameters as Vector for New Plants[Electricity Source\
		,ptype]=
	3 ~~|
Five Year Average Power Plant Dispatch Parameters as Vector for New Plants[Electricity Source\
		,ppriority]=
	Five Year Average Dispatch or Opportunity Cost per Unit Electricity Output[Electricity Source
	]
	+ Variable Subsidies per Unit Elec Output[Electricity Source]
	- Total Subsidies per Unit Electricity Output Adjusted for Lifetime[Electricity Source\
		] ~~|
Five Year Average Power Plant Dispatch Parameters as Vector for New Plants[Electricity Source\
		,pwidth]=
	MAX(
	  ABS(MAX(NSDoDC Normalized Standard Deviation of Dispatch Costs[Electricity Source]\
		,0.01)
	    *(Five Year Average Dispatch or Opportunity Cost per Unit Electricity Output[Electricity Source\
		]
	    + Variable Subsidies per Unit Elec Output[Electricity Source])
	  ),
	
	  0.01
	) ~~|
Five Year Average Power Plant Dispatch Parameters as Vector for New Plants[Electricity Source\
		,pextra]=
	0
	~	$/(MW*hour)
	~		|

Five Year Average Standard Deviation of Dispatch Costs[Electricity Source]=
	ABS(Five Year Average Dispatch Cost per Unit Electricity Output[Electricity Source]*\
		NSDoDC Normalized Standard Deviation of Dispatch Costs
	[Electricity Source])
	~	$/(MW*hour)
	~		|

Five Year Foresight Elec Portfolio Values for Reliability Check[Clean Elec Requirement\
		]=
	MAX(
	  SUM(Weighted Average Elec Portfolio Percentage by Year[Future Year!,Clean Elec Requirement\
		]
	  * This Year Flag for Five Year Reliability Check[Future Year!]),
	
	  SUM(Weighted Average Elec Portfolio Percentage by Year[Future Year!,Clean Elec Requirement\
		]
	  * This Year Flag[Future Year!])
	)
	~	Dmnl
	~		|

Five Year Forward Average Electricity Fuel Cost per Unit Energy[Electricity Source]=
	MAX(Five Year Forward Pretax Fuel Cost per Unit Energy by Sector after Fuel Price Deregulation\
		[electricity source within all fuels
	,electricity sector]
	    * (1 + FSPbPPT Fuel Surcharge Percentage by Power Plant Type[Electricity Source]\
		)
	
	  + Five Year Forward Average Electricity Fuel Other Tax or Subsidy Amount per Unit Energy\
		[Electricity Source]
	  +Electricity Fuel Carbon Tax Amount per Unit Energy[Electricity Source],
	0
	)
	~	$/BTU
	~		|

Five Year Forward Average Electricity Fuel Other Tax or Subsidy Amount per Unit Energy\
		[Electricity Source]=
	MAX(BAU Five Year Forward Average Fuel Tax by Sector[electricity source within all fuels\
		,electricity sector]
	  + BAU Five Year Forward Average Pretax Fuel Price by Sector[electricity source within all fuels\
		,electricity sector]
	    * Additional Fuel Tax or Subsidy Rate by Fuel This Year[electricity source within all fuels\
		,electricity sector],
	
	BAU Five Year Forward Average Pretax Fuel Price by Sector[electricity source within all fuels\
		,electricity sector]* -1
	)
	~	$/BTU
	~		|

Five Year Forward Future Year to Year Mapping[Future Year]=
	IF THEN ELSE(Numerical Future Year Definitions[Future Year]<=Time+4 :AND: Numerical Future Year Definitions\
		[Future Year]>=Time,1,0)
	~	Dmnl
	~		|

Five Year Forward Pretax Fuel Cost per Unit Energy by Sector after Fuel Price Deregulation\
		[All Fuels,Sectors]=
	Five Year Forward Pretax Fuel Cost per Unit Energy by Sector After Reduction of BAU Subsidies\
		[All Fuels,Sectors]
	* (1 - Fuel Price Deregulation This Year[All Fuels])
	+
	IMFPbFT International Market Fuel Price by Fuel Type[All Fuels]
	* Fuel Price Deregulation This Year[All Fuels]
	~	$/BTU
	~		|

Five Year Forward Pretax Fuel Cost per Unit Energy by Sector After Modeled Price Adjustments\
		[All Fuels,Sectors]=
	IF THEN ELSE(
	  BAU Five Year Forward Pretax Fuel Cost per Unit Energy by Sector with Sensitivity Analysis Adjustment\
		[All Fuels,Sectors] > 0,
	
	  MAX(
	    0,
	
	    BAU Five Year Forward Pretax Fuel Cost per Unit Energy by Sector with Sensitivity Analysis Adjustment\
		[All Fuels,Sectors]
	    + Change in Baseline Energy Costs[All Fuels]
	  ),
	
	  0
	)
	~	$/BTU
	~		|

Five Year Forward Pretax Fuel Cost per Unit Energy by Sector After Reduction of BAU Subsidies\
		[All Fuels,Sectors]=
	IF THEN ELSE(
	  Five Year Forward Pretax Fuel Cost per Unit Energy by Sector After Modeled Price Adjustments\
		[All Fuels,Sectors] > 0,
	
	  Five Year Forward Pretax Fuel Cost per Unit Energy by Sector After Modeled Price Adjustments\
		[All Fuels,Sectors]
	  + Added Thermal Fuel Cost per Unit Energy from Ending Subsidies[All Fuels,Sectors]\
		,
	
	  0
	)
	~	$/BTU
	~		|

Five Year Forward Weighted Average Electricity Fuel Cost per Unit Electricity Output[\
		Electricity Source]=
	Five Year Forward Average Electricity Fuel Cost per Unit Energy[Electricity Source]
	* Weighted Average Heat Rate by Electricity Fuel[Electricity Source]
	~	$/(MW*hr)
	~		|

Fixed Electricity Demand Vector[ElecDemand,pprofile]=
	0
	~	$/(MW*hr)
	~		|

Fleet Avg Fuel Economy[Vehicle Type,Cargo Type,Vehicle Technology]=
	MAX(
	  0,
	
	  Last Year Fleet Avg Fuel Economy[Vehicle Type,Cargo Type,Vehicle Technology]
	  * (1 + Percentage Change in Fleet Avg Fuel Economy[Vehicle Type,Cargo Type,Vehicle Technology\
		])
	)
	~	thing*miles/BTU
	~		|

Fleet Avg Fuel Economy in Vehicle Distance[Vehicle Type,Cargo Type,Vehicle Technology\
		]=
	ZIDZ(
	  Fleet Avg Fuel Economy[Vehicle Type,Cargo Type,Vehicle Technology],
	  AVLo Average Vehicle Loading[Vehicle Type,Cargo Type]
	)
	~	miles/BTU
	~		|

FLRbI Foreign Leakage Rate by Industry[Industry Category]=
	GET DIRECT CONSTANTS(
	   'InputData/indst/FLRbI/FLRbI.csv',
	   ',',
	   'B2*'
	)
	~	Dmnl
	~	For every unit of CO2e not emitted in this country as a result of the \
		modeled policy package, this fraction of a unit of CO2e is emitted in a \
		foreign country.  This may be due to businesses relocating or opening \
		elsewhere rather than in this country, or it may be due changes in \
		production levels of existing businesses.  These leakage rates were \
		determined via a computer model based on a carbon tax, so leakage can be \
		negative if a foreign firm has a lower carbon intensity than a U.S. firm \
		when producing a particular good (this is the case for natural gas and \
		coal), or if imports to the U.S. are reduced (this is the case for oil).
	|

FoBObE Fraction of Buildings Owned by Entity[cash flow entity excluding energy suppliers\
		,Building Type]=
	GET DIRECT CONSTANTS(
	   'InputData/bldgs/FoBObE/FoBObE.csv',
	   ',',
	   'B2'
	) ~~|
FoBObE Fraction of Buildings Owned by Entity[energy supplier cash flow entity,Building Type\
		]=
	0
	~	Dmnl
	~		|

