Two Year Average Green Hydrogen Cost=
	DEPRECIATE STRAIGHTLINE(
	  This Year Green Hydrogen Cost,
	  2,
	  1,
	  0
	)
	~	$/BTU
	~		|

Two Year Average Low Carbon Hydrogen Cost=
	DEPRECIATE STRAIGHTLINE(
	  This Year Low Carbon Hydrogen Cost,
	  2,
	  1,
	  0
	)
	~	$/BTU
	~		|

Two Year Average Net Energy Market Revenue by Plant Type Excluding Subsidies for Hybrid Power Plants\
		[Hybrid Electricity Source]=
