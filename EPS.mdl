VTStFES Vehicle Technologies Subject to Fuel Economy Standard[Vehicle Type,Vehicle Technology\
		]=
	GET DIRECT CONSTANTS(
	   'InputData/trans/VTStFES/VTStFES.csv',
	   ',',
	   'B2'
	)
	~	Dmnl
	~		|

Waste Management CO2e Emissions[Pollutant]=
	Industrial Sector Pollutant Emissions[water and waste 36T39,Pollutant]
	* GWP by Pollutant[Pollutant]
	~	g CO2e
	~		|

Waste Management Pollutant Emissions[Pollutant]=
	Industrial Sector Pollutant Emissions[water and waste 36T39,Pollutant]
	~	g pollutant
	~		|

Water Consumed by Hydrogen Plants[Hydrogen Production Pathway]=
	Hydrogen Production by Pathway[Hydrogen Production Pathway]
	* WCoHPbP Water Consumption of Hydrogen Production by Pathway[Hydrogen Production Pathway\
		]
	~	l
	~		|

Water Consumed by Power Plants[Electricity Source]=
	Electricity Generation by Type[Electricity Source]
	* WUbPPT Water Consumption by Power Plant Type[Electricity Source]
	~	l
	~		|

Water Withdrawn by Power Plants[Electricity Source]=
	Electricity Generation by Type[Electricity Source]
	* WUbPPT Water Withdrawals by Power Plant Type[Electricity Source]
	~	l
	~		|

WCoHPbP Water Consumption of Hydrogen Production by Pathway[Hydrogen Production Pathway\
		]=
	GET DIRECT CONSTANTS(
	   'InputData/hydgn/WCoHPbP/WCoHPbP.csv',
	   ',',
	   'B2*'
	)
	~	l/BTU
	~		|

Weighted Average Annual Capital Costs per Unit Capacity[Electricity Source]=
	ZIDZ(
	  SUM(
	   CCaMC Annual CAPEX per Unit Capacity[Electricity Source,Modeled Vintage!]
	    * Electricity Generation Capacity by Vintage[Electricity Source,Modeled Vintage!\
		]
	  ),
	
	   Electricity Generation Capacity[Electricity Source]
	)
	~	$/MW
	~		|

Weighted Average Annual Fixed OM Cost per Unit Capacity[Electricity Source]=
	ZIDZ(
	  SUM(
	    CCaMC Annual Fixed OM Cost per Unit Capacity[Electricity Source,Modeled Vintage!\
		]
	    * Electricity Generation Capacity by Vintage[Electricity Source,Modeled Vintage!\
		]
	  ),
	
	  Electricity Generation Capacity[Electricity Source]
	)
	~	$/MW
	~		|

Weighted Average Charging Cost for Diurnal Technologies=
	ZIDZ(
	SUM(
	    Increase in Demand by Hour for Diurnal Net Peak Load Reduction and RPS Compliance\
		[Electricity Timeslice!,Hour!]
	    * SHELF Days per Electricity Timeslice[Electricity Timeslice!]
	    * Last Year Five Year Average Marginal Dispatch Cost by Hour[Electricity Timeslice\
		!,Hour!]
	  ),
	
	  SUM(
	    Increase in Demand by Hour for Diurnal Net Peak Load Reduction and RPS Compliance\
		[Electricity Timeslice!,Hour!]
	    * SHELF Days per Electricity Timeslice[Electricity Timeslice!]
	  )
	)
	* Days per Year
	~	$/(MW*hr)
	~		|

Weighted Average Compensation per Employee=
	ZIDZ(
	  SUM(
	    Compensation per Employee by ISIC Code[ISIC Code!]
	    * Domestic Employment by ISIC Code[ISIC Code!]
	  ),
	
	  SUM(Domestic Employment by ISIC Code[ISIC Code!])
	)
	~	$/job
	~		|

Weighted Average Discharging Revenue for Diurnal Technologies=
	ZIDZ(
	SUM(
	    Decrease in Demand by Hour for Diurnal Net Peak Load Reduction and RPS Compliance\
		[Electricity Timeslice!,Hour!]
	    * SHELF Days per Electricity Timeslice[Electricity Timeslice!]
	    * Last Year Five Year Average Marginal Dispatch Cost by Hour[Electricity Timeslice\
		!,Hour!]
	  ),
	
	  SUM(
	    Decrease in Demand by Hour for Diurnal Net Peak Load Reduction and RPS Compliance\
		[Electricity Timeslice!,Hour!]
	    * SHELF Days per Electricity Timeslice[Electricity Timeslice!]
	  )
	)
	* Days per Year
	~	$/(MW*hr)
	~		|

Weighted Average Discharging Revenue for Grid Batteries after Subsidies=
	Weighted Average Discharging Revenue for Diurnal Technologies
	+ Levelized Subsidy per Unit Grid Battery Capacity Deployed
	~	$/(MW*hr)
	~		|

Weighted Average Elec Portfolio Percentage by Year[Future Year,Clean Elec Requirement\
		]=
	MIN(
	  1,
	
	  MAX(Elec Portfolio Percentage by Year from Policy Setting[Future Year,Clean Elec Requirement\
		],
	      BAU Weighted Average Elec Portfolio Percentage by Year[Future Year,Clean Elec Requirement\
		])
	)
	~	Dmnl
	~		|

Weighted Average Electricity Fuel Cost per Unit Electricity Output[Electricity Source\
		]=
	Electricity Fuel Cost per Unit Energy[Electricity Source]
	* Weighted Average Heat Rate by Electricity Fuel[Electricity Source]
	~	$/(MW*hour)
	~	The fuel surcharge for power plants that have higher fuel prices than \
		other plants that buy the same fuel (i.e., natural gas peakers and natural \
		gas steam turbines) is handled on the Fuels sheet, which automatically \
		integrates these surcharges into cash flows.
	|

Weighted Average Expected Capacity Factors by Hour Without Hypothetical Adjustments[Electricity Source\
		,Electricity Timeslice,Hour]=
	Start Year Seasonal Expected Hourly Electricity Capacity Factors after RAF[Electricity Source\
		,Electricity Timeslice,Hour
	]
	* (1 + Weighted Average Increase in Capacity Factors for All Plants due to Technological Improvements\
		[Electricity Source
	])
	~	Dmnl
	~		|

Weighted Average Expected Capacity Factors by Hour without RAF[Electricity Source,Electricity Timeslice\
		,Hour]=
	SYSHECF Start Year Seasonal Expected Hourly Electricity Capacity Factors[Electricity Source\
		,Electricity Timeslice,Hour]
	* (1 + Weighted Average Increase in Capacity Factors for All Plants due to Technological Improvements\
		[Electricity Source
	])
	~	Dmnl
	~		|

Weighted Average Heat Rate by Electricity Fuel[Electricity Source]=
	Weighted Average Heat Rate by Electricity Fuel before Fuel Use Reduction[Electricity Source\
		]
	* (1 - RnD Electricity Fuel Use Perc Reduction This Year[Electricity Source])
	~	BTU/(MW*hour)
	~		|

Weighted Average Heat Rate by Electricity Fuel before Fuel Use Reduction[Electricity Source\
		]=
	IF THEN ELSE(
	  ABS(Electricity Generation Capacity[Electricity Source])*MW Tolerance Unit Correction Factor\
		 < Tolerance,
	
	  SUM(BHRaSYC BAU Heat Rates[Electricity Source,Modeled Vintage!]*This Year Modeled Vintage Flag\
		[Modeled Vintage!]),
	  
	    ZIDZ(
	    SUM(
	      BHRaSYC BAU Heat Rates[Electricity Source,Modeled Vintage!]
	      * Electricity Generation Capacity by Vintage[Electricity Source,Modeled Vintage\
		!]
	    ),
	
	    Electricity Generation Capacity[Electricity Source]
	  )
	)
	~	BTU/(MW*hour)
	~		|

Weighted Average Increase in Capacity Factors for All Plants due to Technological Improvements\
		[Electricity Source]=
	ZIDZ(
	  SUM(
	    (Last Year Increase in Capacity Factors for New Plants due to Technological Improvements by Vintage\
		[Electricity Source,Modeled Vintage!] 
	      + IiCFfNPdtTI Increase in Capacity Factors for New Plants due to Technological Improvements\
		[Electricity Source] * This Year Modeled Vintage Flag[Modeled Vintage!])
	    * Electricity Generation Capacity by Vintage[Electricity Source,Modeled Vintage!\
		]
	  ),
	
	  Electricity Generation Capacity[Electricity Source]
	)
	~	Dmnl
	~		|

Weighted Average Last Year Percent Change in Industry Contribution to Gross Domestic Product Excluding Most Direct Impacts\
		=
	ZIDZ(
	  SUM(
	    Last Year Percent Change in Contribution to Gross Domestic Product Excluding Most Direct Impacts by ISIC Code\
		[Industry Category ISIC Code!]
	    * Last Year Domestic Output by ISIC Code[Industry Category ISIC Code!]
	  ),
	
	  SUM(Last Year Domestic Output by ISIC Code[Industry Category ISIC Code!])
	)
	~	Dmnl
	~	The denominator is zero in the first simulated year because the "Last \
		Year" variable starts with a zero as its initial value, so we need a \
		ZIDZ() function here.
	|

Weighted Average Percent Change in Cost of Goods by Industry Category[Industry Category\
		]=
	Change in Passthrough Expenses as Share of Nonenergy Industry Output by Industry Category\
		[Industry Category]
	* Domestic Content Share of Consumption Before Import Substitution by ISIC Code[Industry Category ISIC Code\
		]
	
	+ Carbon Tax Effects on Expenditures by Nonenergy Industries As Share of Nonenergy Industry Output\
		[Industry Category]
	* (1 - Domestic Content Share of Consumption Before Import Substitution by ISIC Code\
		[Industry Category ISIC Code])
	~	Dmnl
	~		|

Weighted Average Pretax Fuel Price by Fuel[All Fuels]=
	ZIDZ(
	
	  SUM(
	    Total Energy Use by Sector[Sectors!,All Fuels]
	    * BAU Pretax Fuel Price by Sector Including Endogenous Electricity Prices[All Fuels\
		,Sectors!]
	  )
	  + Fuel Exports[All Fuels]
	    * IMFPbFT International Market Fuel Price by Fuel Type[All Fuels],
	
	  SUM(Total Energy Use by Sector[Sectors!,All Fuels])
	  + Fuel Exports[All Fuels]
	)
	~	$/BTU
	~	This variable helps to adjust within-industry "jobs per unit output" \
		itensities in the I/O model.  We use pretax prices because taxes don't \
		turn into revenue for the fuel industry, so they don't turn into fuel \
		industry jobs.
	|

Weighted Average Pretax Fuel Price by Producing ISIC Code[ISIC Code]=
	ZIDZ(
	  SUM(
	    Weighted Average Pretax Fuel Price by Fuel[All Fuels!]
	    * Total Energy Use by Sector[Sectors!,All Fuels!]
	    * FtPICM Fuel to Producing ISIC Code Map[All Fuels!,ISIC Code]
	  ),
	
	  SUM(
	    Total Energy Use by Sector[Sectors!,All Fuels!]
	    * FtPICM Fuel to Producing ISIC Code Map[All Fuels!,ISIC Code]
	  )
	)
	~	$/BTU
	~	Some ISIC codes supply more than one fuel type, so we need to weight the \
		impact on each ISIC code by the share of each type of fuel it supplies.  \
		We weight using total fuel use (not total fuel production) so that a \
		weighted average price can be computed even in regions with zero or low \
		fuel production, but with fuel imports (for instance, a region that \
		imports and sells natural gas but doesn't produce natural gas, such as \
		some U.S. states).
	|

Weighted Average Round Trip Efficiency for Diurnal Shifting Excluding Hybrid Batteries\
		[Electricity Timeslice]=
	ZIDZ(
	  (
	    ESTRTE Grid Battery Round Trip Efficiency
	    * (Last Year Grid and Hybrid Battery Storage Available for Load Shifting[Electricity Timeslice\
		]
	       + Maximum Daily Quantity of Electricity Charged by EVs for Diurnal Balancing
	      )
	
	    + ESTRTE Pumped Hydro Round Trip Efficiency
	      * Maximum Daily Quantity of Electricity Charged by Pumped Hydro[Electricity Timeslice\
		]
	  ),
	
	  (
	    Last Year Grid and Hybrid Battery Storage Available for Load Shifting[Electricity Timeslice\
		]
	    + Maximum Daily Quantity of Electricity Charged by EVs for Diurnal Balancing
	    + Maximum Daily Quantity of Electricity Charged by Pumped Hydro[Electricity Timeslice\
		]
	  )
	)
	~	Dmnl
	~		|

Weighted Average Round Trip Efficiency for Seasonal Shifting=
	ZIDZ(
	  (
	    SES Seasonal Electricity Storage Round Trip Efficiency
	    * Maximum Annual Quantity of Electricity Charged by Seasonal Electricity Storage
	  ),
	
	  (
	    Maximum Annual Quantity of Electricity Charged by Seasonal Electricity Storage
	  )
	)
	~	Dmnl
	~		|

Weighted Average Variable OM Cost per Unit Electricity Output[Electricity Source]=
	IF THEN ELSE(
	  ABS(Electricity Generation Capacity[Electricity Source])*MW Tolerance Unit Correction Factor\
		 < Tolerance,
	  SUM(CCaMC Variable OM Cost per Unit Output[Electricity Source,Modeled Vintage!]*This Year Modeled Vintage Flag\
		[Modeled Vintage!]),
	
	  ZIDZ(
	    SUM(
	      CCaMC Variable OM Cost per Unit Output[Electricity Source,Modeled Vintage!]
	      * Electricity Generation Capacity by Vintage[Electricity Source,Modeled Vintage\
		!]
	    ),
	
	    Electricity Generation Capacity[Electricity Source]
	  )
	)
	~	$/(MW*hour)
	~		|

Weighted Avg Fuel Cost per Unit Energy by Vehicle Technology[Vehicle Type,Cargo Type,\
		Vehicle Technology]=
	XIDZ(
	  SUM(Transportation Fuel Cost per Unit Energy[Transportation Fuel!]
	      * Last Year Transportation Sector Fuel Used[Vehicle Type,Cargo Type,Vehicle Technology\
		,Transportation Fuel!]),
	
	  SUM(Last Year Transportation Sector Fuel Used[Vehicle Type,Cargo Type,Vehicle Technology\
		,Transportation Fuel!]),
	
	  SUM(Transportation Fuel Cost per Unit Energy[Transportation Fuel!]
	    * BPoEFUbVT BAU Perc of Each Fuel Used by Veh Technology[Vehicle Type,Cargo Type\
		,Vehicle Technology,Transportation Fuel!])
	)
	~	$/BTU
	~	In the event there are no vehicles of a given technology (such as no \
		battery electric vehicles), we don't want a weighted average fuel cost of \
		zero, because this makes that vehicle technology have an artifically low \
		lifetime NPV cost, and the model will choose to build more of that type \
		than it should.  Accordingly, we estimate the cost based on the BAU fuel \
		shares by vehicle technology.
	|

Wholesale Energy Market Costs=
	IF THEN ELSE(
	 Time - INITIAL TIME <= 1,
	 One Year Average Wholesale Energy Market Costs,
	 
	 IF THEN ELSE(
	  Time - INITIAL TIME = 2,
	  Two Year Average Wholesale Energy Market Costs,
	  Three Year Average Wholesale Energy Market Costs
	 )
	)
	~	$
	~		|

WHRCC Waste Heat Recovery Capital Cost=
	GET DIRECT CONSTANTS(
	   'InputData/indst/WHRCC/WHRCC.csv',
	   ',',
	   'B2*'
	)
	~	$/BTU
	~		|

WHRPbI Waste Heat Recovery Potential by Industry[Industry Category]=
	GET DIRECT CONSTANTS(
	   'InputData/indst/WHRPbI/WHRPbI.csv',
	   ',',
	   'B2*'
	)
	~	Dmnl
	~		|

Within Industry Compensation per Employed Person[ISIC Code]=
	ZIDZ(
	
	  BAU Employee Compensation by ISIC Code by Year[ISIC Code],
	
	  BAU Employment by ISIC Code by Year[ISIC Code]
	)
	~	$/job
	~		|

Within Industry Jobs per Unit Energy Production[ISIC Code]=
	ZIDZ(
	
	  BAU Employment by ISIC Code by Year[ISIC Code],
	
	  BAU Fuel Production Mapped to ISIC Codes[ISIC Code]
	)
	~	jobs/BTU
	~		|

Within Industry Jobs per Unit Output[ISIC Code]=
	ZIDZ(
	    BAU Employment by ISIC Code by Year[ISIC Code],
	
	    BAU Output by ISIC Code by Year[ISIC Code]
	  )
	~	jobs/$
	~		|

Within Industry Value Added per Unit Energy Production[ISIC Code]=
	ZIDZ(
	
	  BAU Value Added by ISIC Code by Year[ISIC Code],
	
	  BAU Fuel Production Mapped to ISIC Codes[ISIC Code]
	)
	~	$/BTU
	~		|

Within Industry Value Added per Unit Output[ISIC Code]=
	ZIDZ(
	  BAU Value Added by ISIC Code by Year[ISIC Code],
	
	  BAU Output by ISIC Code by Year[ISIC Code]
	)
	~	Dmnl
	~		|

WMITR Worker Marginal Income Tax Rate=
	GET DIRECT CONSTANTS(
	   'InputData/io-model/WMITR/WMITR.csv',
	   ',',
	   'B2'
	)
	~	Dmnl
	~		|

WUbPPT Water Consumption by Power Plant Type[Electricity Source]=
	GET DIRECT CONSTANTS(
	   'InputData/elec/WUbPPT/WUbPPT-consumption.csv',
	   ',',
	   'B2*'
	)
	~	l/(MW*hour)
	~		|

WUbPPT Water Withdrawals by Power Plant Type[Electricity Source]=
	GET DIRECT CONSTANTS(
	   'InputData/elec/WUbPPT/WUbPPT-withdrawals.csv',
	   ',',
	   'B2*'
	)
	~	l/(MW*hour)
	~		|

Years Elapsed Since Model Run Vintage[Model Run Vintage]=
	MAX(
	  0,
	
	  Time - Model Run Vintage to Year Mapping[Model Run Vintage]*One Year
	)
	~	years
	~		|

ZEC Subsidies Paid[Electricity Source]=
	Electricity Generation by Type[Electricity Source]
	* BZECfNP BAU Zero Emissions Credit for Nuclear Plants[Electricity Source]
	~	$
	~		|

Zero and Negative Cost Electricity Dispatched to Meet CES[Electricity Source,Electricity Timeslice\
		,Hour]=
	Expected CES Qualifying Output After Guaranteed and RPS Dispatch[Electricity Source,\
		Electricity Timeslice,Hour]
	* Plant Types with Zero or Negative Dispatch Cost After Subsidies[Electricity Source\
		]
	* MIN(
	    1,
	
	    ZIDZ(
	      Unmet Electricity Demand after RPS Allocation Steps[Electricity Timeslice,Hour\
		],
	
	      SUM(
	        Expected CES Qualifying Output After Guaranteed and RPS Dispatch[Electricity Source\
		!,Electricity Timeslice,Hour]
	        * Plant Types with Zero or Negative Dispatch Cost After Subsidies[Electricity Source\
		!]
	      )
	    )
	  )
	~	MW*hour
	~		|

Zero and Negative Cost Electricity Dispatched to Meet RPS[Electricity Timeslice,Hour,\
		Electricity Source]=
	Expected RPS Qualifying Capacity After Guaranteed Dispatch[Electricity Timeslice,Hour\
		,Electricity Source]
	* Plant Types with Zero or Negative Dispatch Cost After Subsidies[Electricity Source\
		]
	* MIN(
	    1,
	
	    ZIDZ(
	      Unmet Electricity Demand After Guaranteed Dispatch[Electricity Timeslice,Hour]\
		,
	
	      SUM(
	        Expected RPS Qualifying Capacity After Guaranteed Dispatch[Electricity Timeslice\
		,Hour,Electricity Source!]
	        * Plant Types with Zero or Negative Dispatch Cost After Subsidies[Electricity Source\
		!]
	      )
	    )
	  )
	~	MW*hr
	~		|

ZEV Sales Share Without ZEV Standard[Subregion,Vehicle Type,Cargo Type]=
	ZIDZ(
	  SUM(
	    New Vehicles before ZEV Standards by Subregion[Subregion,Vehicle Type,Cargo Type\
		,Vehicle Technology!]
	    * Vehicle Technologies Qualifying as ZEVs[Vehicle Type,Vehicle Technology!]
	  ),
	
	  SUM(New Vehicles before ZEV Standards by Subregion[Subregion,Vehicle Type,Cargo Type\
		,Vehicle Technology!])
	)
	~	Dmnl
	~		|

ZEV Standard by Subregion[Subregion,Vehicle Type,Cargo Type]=
	MAX(
	  Required ZEV Sales Percentage by Subregion[Subregion,Cargo Type,Vehicle Type],
	
	  MAX(
	    MIN(
	    BRZSPbMR BAU Required ZEV Sales Percentage by Model Region[Vehicle Type,Cargo Type\
		]
	    + Additional Minimum Required ZEV Sales Percentage for Model Region This Year[Cargo Type\
		,Vehicle Type],
	  
	    1
	    ),
	
	  0
	  )
	)
	~	Dmnl
	~		|

********************************************************
	.Control
********************************************************~
		Simulation Control Parameters
	|

FINAL TIME=
	GET DIRECT CONSTANTS(
	   'InputData/plcy-schd/FT/FT.csv',
	   ',',
	   'B2*'
	)
	~	Year
	~	The final time for the simulation.
	|

INITIAL TIME=
	GET DIRECT CONSTANTS(
	   'InputData/plcy-schd/IT/IT.csv',
	   ',',
	   'B2*'
	)
	~	Year
	~	The initial time for the simulation.
	|

Last Year Change in Energy Supplier Cost per Unit Fuel Produced[All Fuels] :EXCEPT:   \
		[electricity],[heat],[hydrogen],[coal mining industry fuel within all fuels
],[NGPS industry fuel within all fuels],[biomass and biofuel within all fuels]=
	0 ~~|
Last Year Change in Energy Supplier Cost per Unit Fuel Produced[electricity]=
	0 ~~|
Last Year Change in Energy Supplier Cost per Unit Fuel Produced[heat]= DELAY FIXED (
	Change in District Heat Supplier Expenditures per Unit Heat Produced, 1, 0) ~~|
Last Year Change in Energy Supplier Cost per Unit Fuel Produced[hydrogen]= DELAY FIXED\
		 (
	Change in Hydrogen Supplier Expenditures per Unit Hydrogen Produced, 1, 0) ~~|
Last Year Change in Energy Supplier Cost per Unit Fuel Produced[coal mining industry fuel within all fuels\
		]= DELAY FIXED (
	Change in Fuel Supplier Expenditures per Unit Fuel Produced[coal mining industry fuel within all fuels\
		], 1,
	 0) ~~|
Last Year Change in Energy Supplier Cost per Unit Fuel Produced[NGPS industry fuel within all fuels\
		]= DELAY FIXED (
	Change in Fuel Supplier Expenditures per Unit Fuel Produced[NGPS industry fuel within all fuels\
		], 1, 0) ~~|
Last Year Change in Energy Supplier Cost per Unit Fuel Produced[biomass and biofuel within all fuels\
		]= DELAY FIXED (
	Change in Fuel Supplier Expenditures per Unit Fuel Produced[biomass and biofuel within all fuels\
		], 1, 0)
	~	$/BTU
	~		|

SAVEPER  = 
        TIME STEP
	~	Year [0,?]
	~	The frequency with which output is stored.
	|

TIME STEP  = 1
	~	Year [0,?]
	~	The time step for the simulation.
	|

Total Energy Market and Capacity Market Revenue for Seasonal Dispatchable Reliability\
		[Electricity Source,Optimization Pass]=
	Total Energy Market and CES Revenue and Variable Subsidies[Electricity Source]
	-RPS and CES Revenue at Marginal Capacity Factor[Electricity Source]
	+ (
	Capacity Market Price for Seasonal Dispatchable Reliability by Optimization Pass[Optimization Pass
	]
	  * Last Year Hourly Bid Electricity Capacity Factors for Reliability in Binding Hour by Plant Type\
		[Electricity Source
	]
	  * Days per Year
	  * One Day)
	~	$/MW
	~		|

