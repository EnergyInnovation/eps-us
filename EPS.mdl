Absolute Change in In Scope Emissions due to Electricity Imports[Pollutant,Electricity Source\
		]=
	IF THEN ELSE(
	  BIEfIE Boolean Include Emissions from Imported Electricity > 0,
	
	  Pollutant Emissions from Imported Electricity[Pollutant,Electricity Source],
	
	  0
	)
	~	g pollutant
	~		|

Achieved Capacity Factors[Electricity Source]=
	MAX(0,
	 SUM(Achieved Capacity Factors by Hour[Electricity Timeslice!,Hour!,Electricity Source\
		]
	     * SHELF Days per Electricity Timeslice[Electricity Timeslice!]
	     * One Hour)
	 /Hours per Year
	)
	~	Dmnl
	~		|

Achieved Capacity Factors by Hour[Electricity Timeslice,Hour,Electricity Source]=
	ZIDZ(Total Electricity Dispatched by Hour by Plant Type[Electricity Timeslice,Hour,Electricity Source\
		],
	     Electricity Generation Capacity[Electricity Source]*One Hour* (1 - Share of Electricity Generation Capacity Built This Year\
		[Electricity Source] * TACFMfPBTY Time Adjusted Capacity Factor Multiplier for Plants Built This Year
	[Electricity Source]))
	~	Dmnl
	~		|

Achieved LCFS Percentage=
	ZIDZ(
	  SUM(Carbon Free Energy after LCFS[Vehicle Type!,Cargo Type!,Vehicle Technology!,Transportation Fuel\
		!]),
	
	  SUM(Fuel that would be Used by Regulated Vehicle Types in Absence of LCFS with Elec Eff Adj\
		[Vehicle Type!,Cargo Type!,Vehicle Technology!,Transportation Fuel!])
	)
	~	Dmnl
	~		~	:SUPPLEMENTARY 
	|

Achieved LCFS Percentage before Fuel Shifts=
	ZIDZ(
	  SUM(Carbon Free Energy in Absence of LCFS by Vehicle Type[Vehicle Type!,Cargo Type\
		!,Vehicle Technology!,Transportation Fuel!]),
	
	  SUM(Fuel that would be Used by Regulated Vehicle Types in Absence of LCFS with Elec Eff Adj\
		[Vehicle Type!,Cargo Type!,Vehicle Technology!,Transportation Fuel!])
	)
	~	Dmnl
	~		~	:SUPPLEMENTARY 
	|

ACTR Average Corporate Tax Rate:INTERPOLATE::=
	GET DIRECT DATA(
	   'InputData/io-model/ACTR/ACTR.csv',
	   ',',
	   '1',
	   'B2'
	)
	~	Dmnl
	~		|

Actual Elec Portfolio Std Qualifying Electricity Generation[Clean Elec Requirement]=
	SUM(
	  Electricity Generation by Type[Electricity Source!]
	  * Elec Portfolio Qualifying Sources[Electricity Source!,Clean Elec Requirement]
	)
	~	MW*hour
	~		~	:SUPPLEMENTARY 
	|

Actual Total Electricity Demand=
	SUM(
	Total Electricity Demand by Hour After Demand Altering Technologies[Electricity Timeslice\
		!,Hour!]
	  * SHELF Days per Electricity Timeslice[Electricity Timeslice!]
	)
	~	MW*hour
	~		~	:SUPPLEMENTARY 
	|

Actual Total Electricity Generation=
	SUM(Electricity Generation by Type[Electricity Source!])
	~	MW*hour
	~		~	:SUPPLEMENTARY 
	|

Added Thermal Fuel Cost per Unit Energy from Ending Subsidies[All Fuels,Sectors]=
	BS BAU Subsidy for Thermal Fuels per Energy Unit Produced[All Fuels,Sectors]
	- Subsidy for Thermal Fuels per Energy Unit Produced[All Fuels,Sectors]
	~	$/BTU
	~		|

Additional Carbon Free Energy Allocated by Fuel and Technology[Vehicle Type,Cargo Type\
		,Vehicle Technology,Transportation Fuel] :EXCEPT: [Vehicle Type,Cargo Type,gasoline vehicle\
		,biofuel gasoline tf],[Vehicle Type,Cargo Type,diesel vehicle,biofuel diesel tf],[Vehicle Type\
		,Cargo Type,plugin hybrid vehicle,electricity tf]=
	0 ~~|
Additional Carbon Free Energy Allocated by Fuel and Technology[Vehicle Type,Cargo Type\
		,gasoline vehicle,biofuel gasoline tf]=
	Required Increase in Carbon Free Energy Assigned to Vehicle and Fuel Types[Vehicle Type\
		,Cargo Type,biofuel gasoline tf] ~~|
Additional Carbon Free Energy Allocated by Fuel and Technology[Vehicle Type,Cargo Type\
		,diesel vehicle,biofuel diesel tf]=
	Required Increase in Carbon Free Energy Assigned to Vehicle and Fuel Types[Vehicle Type\
		,Cargo Type,biofuel diesel tf] ~~|
Additional Carbon Free Energy Allocated by Fuel and Technology[Vehicle Type,Cargo Type\
		,plugin hybrid vehicle,electricity tf]=
	Required Increase in Carbon Free Energy Assigned to Vehicle and Fuel Types[Vehicle Type\
		,Cargo Type,electricity tf]
	~	BTU
	~	See the note in the variable "Quantity Carbon Free Energy May be Increased \
		by Fuel by Regulated Vehicle Type" for an explanation of why we assign all \
		biofuels to the "gasoline vehicle" and "petroleum vehicle" technologies \
		(rather than giving a share to the "plugin hybrid vehicle" technology).
	|

Additional Carbon Price by Year from Policy Setting[Sectors,Future Year]=
	Additional Carbon Tax Rate in Dollars[Sectors]
	
	* VECTOR ELM MAP(
	    Selected Policy Implementation Schedule for Future Years[cross carbon tax X transportation sector\
		,Future Year],
	
	    (Sectors-1)*ELMCOUNT(Future Year)
	  )
	~	$/metric ton CO2e
	~		|

Additional Carbon Tax Rate[Sectors]=
	0,	{transportation sector}
	0,	{electricity sector}
	0,	{residential buildings sector}
	0,	{commercial buildings sector}
	0,	{industry sector}
	0,	{district heat and hydrogen sector}
	0,	{LULUCF sector - NOT USED}
	0	{geoengineering sector - NOT USED}
	~	output currency unit/metric ton CO2e [0,300]
	~		|

Additional Carbon Tax Rate in Dollars[Sectors]=
	Additional Carbon Tax Rate[Sectors]
	* OCCF Dollars per Small Output Currency Unit
	~	$/metric ton CO2e
	~		|

Additional Carbon Tax Rate This Year[Sectors]=
	Additional Carbon Tax Rate in Dollars[Sectors]
	* VECTOR ELM MAP(
	    Selected Policy Implementation Schedule[cross carbon tax X transportation sector\
		],
	
	    (Sectors-1)
	  )
	~	$/metric ton CO2e
	~		|

