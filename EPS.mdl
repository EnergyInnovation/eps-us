Spare Capacity under Imports Cap[All Fuels]=
	MAX(
	  0,
	
	  Maximum Absolute Increase in Fuel Imports[All Fuels]
	  - Change in Fuel Imports before Cap[All Fuels]
	)
	~	BTU
	~		|

Spare Capacity under Production Cap[All Fuels]=
	MAX(
	  0,
	
	  Maximum Absolute Increase in Fuel Production[All Fuels]
	  - Change in Fuel Production before Cap[All Fuels]
	)
	~	BTU
	~		|

Spare Potential Output from Surviving Capacity by Hour[Electricity Timeslice,Hour]=
	Potential Output from Surviving Capacity by Hour[Electricity Timeslice,Hour]
	-Total Electricity Demand by Hour Before Demand Altering Technologies[Electricity Timeslice\
		,Hour]
	~	MW*hr
	~	This variable must be allowed to become negative to reflect the \
		possibility of a shortfall in a given hour.
	|

Spare Potential Output from Surviving Capacity by Hour after Seasonal Net Peak Load Reduction\
		[Electricity Timeslice,Hour]=
	Potential Output from Surviving Capacity by Hour[Electricity Timeslice,Hour]
	- Total Electricity Demand by Hour after Seasonal Net Peak Load Reduction[Electricity Timeslice\
		,Hour]
	~	MW*hr
	~	This variable must be allowed to become negative to reflect the \
		possibility of a shortfall in a given hour.
	|

Spare Potential Output from Surviving Capacity by Hour by Optimization Pass[Electricity Timeslice\
		,Hour,pass1]=
	Total Electricity Demand by Hour before Net Imports[Electricity Timeslice,Hour] ~~|
Spare Potential Output from Surviving Capacity by Hour by Optimization Pass[Electricity Timeslice\
		,Hour,current pass]=
	Total Electricity Demand by Hour before Net Imports[Electricity Timeslice,Hour]
	  *IF THEN ELSE(Share of Max Hourly Imports Met[Electricity Timeslice,Hour,preceeding pass\
		]=1,0,1)
	~	MW*hr
	~		|

Spur Line Construction Costs[Electricity Source]=
	New Generation Capacity Excluding Retrofit Capacity[Electricity Source]
	* CCaMC Spur Line Construction Cost per Unit Capacity[Electricity Source]
	~	$
	~		|

