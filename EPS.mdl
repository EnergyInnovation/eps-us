MPPC Minimum Power Plant Capacity[Electricity Source]=
	GET DIRECT CONSTANTS(
	   'InputData/elec/MPPC/MPPC.csv',
	   ',',
	   'B2*'
	)
	~	MW
	~		|

MSCdtRPbQL Market Share Changes due to Rebate Program by Quality Level[Building Component Quality\
		]=
	GET DIRECT CONSTANTS(
	   'InputData/bldgs/MSCdtRPbQL/MSCdtRPbQL.csv',
	   ',',
	   'B2'
	)
	~	Dmnl
	~		|

MW per GW=
	1000
	
	{
	Wikipedia
	List of SI Prefixes
	https://en.wikipedia.org/wiki/Metric_prefix#List_of_SI_prefixes
	}
	~	MW/GW
	~		|

MW Tolerance Unit Correction Factor=
	1
	~	1/MW
	~		|

MWh per BTU=
	2.931e-07
	
	{
	Google Unit Converter
	https://www.google.com/search?q=mwh+per+btu
	}
	~	MW*hour/BTU
	~	This variable is used in several places in the model where a direct unit \
		conversion (not a change of energy carrier) is needed.  It converts \
		between 1 BTU of electricity and 1 MWh of electricity.  Since this is a \
		strict unit conversion, there is no efficiency loss, and this value \
		applies globally (to all countries that may be modeled).
	|

MWh per TWh=
	1e+06
	~	MW*hour/(TW*hr)
	~		|

MWhr Tolerance Unit Correction Factor=
	1
	~	1/(MW*hr)
	~		|

NBICS Non BAU Industry CCS Subsidy[Industry Category]:INTERPOLATE::=
	GET DIRECT DATA(
	   'InputData/ccs/NBICS/NBICS.csv',
	   ',',
	   '1',
	   'B2'
	)
	~	$/metric ton CO2e
	~		|

NBPoNVP Non Battery Portion of New Vehicle Price[LDVs,passenger,Vehicle Technology]:INTERPOLATE:\
		:=
	GET DIRECT DATA(
	   'InputData/trans/NBPoNVP/NBPoNVP-LDVs-psgr.csv',
	   ',',
