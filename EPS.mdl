BUCLfCR Boolean Use Capacity Lifetimes for Capacity Retirements=
	GET DIRECT CONSTANTS(
	   'InputData/ctrl-settings/BUCLfCR/BUCLfCR.csv',
	   ',',
	   'B2*'
	)
	~	Dmnl [0,1,1]
	~		|

BUCMfNCR Boolean Use Capacity Market for New Capacity Revenue=
	GET DIRECT CONSTANTS(
	   'InputData/ctrl-settings/BUCMfNCR/BUCMfNCR.csv',
	   ',',
	   'B2*'
	)
	~	Dmnl [0,1,1]
	~	This contol setting defines how capacity revenues are allocated and \
		collected in the model. If set to 1 (on), the model runs a regional \
		capacity market to collect revenue for new capacity for reliability. If \
		the value is set to zero, the capacity costs for new capacity are only \
		collected for new resources and not paid out to all resources in the \
		market.
	|

Building Component:
	heating,
	cooling and ventilation,
	envelope,
	lighting,
	appliances,
	other component
	~	
	~		|

Building Component Quality:
	standard compliant,
	rebate qualifying
	~	
	~		|

Building Component Rebate Amount Paid[Building Type,Building Component]=
	Amount Spent on Rebate Qualifying Components[Building Type,Building Component]
	* RPbBCT Rebate Percentage by Building Component Type[Building Type,Building Component\
		]
	* Boolean Rebate Program for Efficient Components This Year[Building Component]
	~	$
	~		|

Building Component Rebate Amount Paid by Entity[Building Type,Building Component,Cash Flow Entity\
		] :EXCEPT: [Building Type,Building Component,energy supplier cash flow entity]=
	0 ~~|
Building Component Rebate Amount Paid by Entity[Building Type,Building Component,electricity suppliers\
		]=
	Building Component Rebate Amount Paid[Building Type,Building Component]
	* ZIDZ(
	    Building Components Energy Use[Building Type,electricity bf,Building Component],
	
	    SUM(Building Components Energy Use[Building Type,Building Fuel!,Building Component\
		])
	  ) ~~|
Building Component Rebate Amount Paid by Entity[Building Type,Building Component,coal suppliers\
		]=
	Building Component Rebate Amount Paid[Building Type,Building Component]
	* ZIDZ(
	    Building Components Energy Use[Building Type,hard coal bf,Building Component],
	
	    SUM(Building Components Energy Use[Building Type,Building Fuel!,Building Component\
		])
	  ) ~~|
Building Component Rebate Amount Paid by Entity[Building Type,Building Component,natural gas and petroleum suppliers\
		]=
	Building Component Rebate Amount Paid[Building Type,Building Component]
	* ZIDZ(
	    Building Components Energy Use[Building Type,natural gas bf,Building Component]
	    + Building Components Energy Use[Building Type,petroleum diesel bf,Building Component\
		]
	    + Building Components Energy Use[Building Type,kerosene bf,Building Component]
	    + Building Components Energy Use[Building Type,heavy or residual fuel oil bf,Building Component\
		]
	    + Building Components Energy Use[Building Type,LPG propane or butane bf,Building Component\
		],
	
	    SUM(Building Components Energy Use[Building Type,Building Fuel!,Building Component\
		])
	  ) ~~|
Building Component Rebate Amount Paid by Entity[Building Type,Building Component,biomass and biofuel suppliers\
		]=
	Building Component Rebate Amount Paid[Building Type,Building Component]
	* ZIDZ(
	    Building Components Energy Use[Building Type,biomass bf,Building Component],
	
	    SUM(Building Components Energy Use[Building Type,Building Fuel!,Building Component\
		])
	  ) ~~|
Building Component Rebate Amount Paid by Entity[Building Type,Building Component,other energy suppliers\
		]=
	Building Component Rebate Amount Paid[Building Type,Building Component]
	* ZIDZ(
	    Building Components Energy Use[Building Type,heat bf,Building Component]
	    + Building Components Energy Use[Building Type,hydrogen bf,Building Component],
	
	    SUM(Building Components Energy Use[Building Type,Building Fuel!,Building Component\
		])
	  )
	~	$
	~		|

Building Components Energy Use[Building Type,Building Fuel,Building Component] :EXCEPT:\
		   [commercial,Building Fuel,Building Component]=
	(Components Energy Use after Retrofitting Preexisting Buildings[Building Type,Building Fuel\
		,Building Component]
	  + Correction for Difference in Input vs Calculated BAU Components Energy Use[Building Type\
		,Building Fuel,Building Component])
	* (1 + Perc Change in Sectoral Energy Use due to Exogenous GDP Adjustment[residential buildings sector\
		]) ~~|
Building Components Energy Use[commercial,Building Fuel,Building Component]=
	(Components Energy Use after Retrofitting Preexisting Buildings[commercial,Building Fuel\
		,Building Component]
	  + Correction for Difference in Input vs Calculated BAU Components Energy Use[commercial\
		,Building Fuel,Building Component])
	* (1 + Perc Change in Sectoral Energy Use due to Exogenous GDP Adjustment[commercial buildings sector\
		])
	~	BTU
	~		|

Building Components Energy Use Excluding Zero Cost Distributed Fuel Use[Building Type\
		,Building Fuel] :EXCEPT:    [Building Type,electricity bf]=
	SUM(Building Components Energy Use[Building Type,Building Fuel,Building Component!])\
		 ~~|
Building Components Energy Use Excluding Zero Cost Distributed Fuel Use[Building Type\
		,electricity bf]=
	SUM(Building Components Energy Use[Building Type,electricity bf,Building Component!]\
		)
	- SUM(Annual Output from Distributed Electricity Capacity by Building Type[Clean Dispatchable Electricity Source\
		!,Building Type])/MWh per BTU
	~	BTU
	~		|

Building Fuel:
	electricity bf,
	hard coal bf,
	natural gas bf,
	petroleum diesel bf,
	heat bf,
	biomass bf,
	kerosene bf,
	heavy or residual fuel oil bf,
	LPG propane or butane bf,
	hydrogen bf
	-> building fuel within all fuels
	~	
	~		|

building fuel within all fuels:
	electricity,
	hard coal,
	natural gas,
	petroleum diesel,
	heat,
	biomass,
	jet fuel or kerosene,
	heavy or residual fuel oil,
	LPG propane or butane,
	hydrogen
	-> Building Fuel
	~	
	~		|

Building Type:
	urban residential,
	rural residential,
	commercial
	~	
	~		|

Buildings Energy Use by Fuel[Building Fuel]=
	SUM(Building Components Energy Use[Building Type!,Building Fuel,Building Component!]\
		)
	~	BTU
	~		~	:SUPPLEMENTARY 
	|

Buildings Fuel Carbon Tax Amount per Unit Energy[Building Fuel,urban residential]=
	Carbon Tax Rate[residential buildings sector]
	/ Grams per Metric Ton CO2e
	* Buildings Fuel Taxable CO2e Emissions Intensity[Building Fuel,urban residential] ~~|
Buildings Fuel Carbon Tax Amount per Unit Energy[Building Fuel,rural residential]=
	Carbon Tax Rate[residential buildings sector]
	/ Grams per Metric Ton CO2e
	* Buildings Fuel Taxable CO2e Emissions Intensity[Building Fuel,rural residential] ~~|
Buildings Fuel Carbon Tax Amount per Unit Energy[Building Fuel,commercial]=
	Carbon Tax Rate[commercial buildings sector]
	/ Grams per Metric Ton CO2e
	* Buildings Fuel Taxable CO2e Emissions Intensity[Building Fuel,commercial]
	~	$/BTU
	~		|

Buildings Fuel Cost per Unit Energy[Building Fuel,urban residential]=
	MAX(Pretax Fuel Cost per Unit Energy by Sector after Fuel Price Deregulation[building fuel within all fuels\
		,residential buildings sector]
	  + Buildings Fuel Total Tax or Subsidy Amount per Unit Energy[Building Fuel,urban residential\
		],
	0
	) ~~|
Buildings Fuel Cost per Unit Energy[Building Fuel,rural residential]=
	Pretax Fuel Cost per Unit Energy by Sector after Fuel Price Deregulation[building fuel within all fuels\
		,residential buildings sector]
	+ Buildings Fuel Total Tax or Subsidy Amount per Unit Energy[Building Fuel,rural residential\
		] ~~|
Buildings Fuel Cost per Unit Energy[Building Fuel,commercial]=
	Pretax Fuel Cost per Unit Energy by Sector after Fuel Price Deregulation[building fuel within all fuels\
		,commercial buildings sector]
	+ Buildings Fuel Total Tax or Subsidy Amount per Unit Energy[Building Fuel,commercial\
		]
	~	$/BTU
	~		|

Buildings Fuel Other Tax or Subsidy Amount per Unit Energy[Building Fuel,urban residential\
		]=
	Fuel Tax or Subsidy by Sector[building fuel within all fuels,residential buildings sector\
		] ~~|
Buildings Fuel Other Tax or Subsidy Amount per Unit Energy[Building Fuel,rural residential\
		]=
	Fuel Tax or Subsidy by Sector[building fuel within all fuels,residential buildings sector\
		] ~~|
Buildings Fuel Other Tax or Subsidy Amount per Unit Energy[Building Fuel,commercial]=
	Fuel Tax or Subsidy by Sector[building fuel within all fuels,commercial buildings sector\
		]
	~	$/BTU
	~		|

Buildings Fuel Pollutant Emissions Intensities This Year[Pollutant,Building Fuel]=
	PEI Buildings Fuel Pollutant Emissions Intensities[Pollutant,Building Fuel]
	  * (1 - PEIIR Buildings Fuel Pollutant Emissions Intensity Improvement Rate[Pollutant\
		,Building Fuel])
	    ^(Dimensionless Time - Initial Time Dimensionless)
	~	g pollutant/BTU
	~		|

Buildings Fuel Taxable CO2e Emissions Intensity[Building Fuel,Building Type]=
	SUM(
	  Buildings Fuel Pollutant Emissions Intensities This Year[Pollutant!,Building Fuel]
	  * GWP by Pollutant[Pollutant!]
	  * Buildings Pollutants Taxed by Carbon Pricing[Building Type,Pollutant!]
	)
	~	g CO2e/BTU
	~		|

Buildings Fuel Total Tax or Subsidy Amount per Unit Energy[Building Fuel,Building Type\
		]=
	Buildings Fuel Carbon Tax Amount per Unit Energy[Building Fuel,Building Type]
	+ Buildings Fuel Other Tax or Subsidy Amount per Unit Energy[Building Fuel,Building Type\
		]
	~	$/BTU
	~		|

Buildings Pollutants Taxed by Carbon Pricing[Building Type,Pollutant]=
	IF THEN ELSE(
	  Boolean Non BAU Pollutants Affected by Carbon Tax This Year = 0,
	  BPTbCP BAU Buildings Pollutants Taxed by Carbon Pricing[Building Type,Pollutant],
	  PTbCP Buildings Pollutants Taxed by Carbon Pricing[Building Type,Pollutant]
	)
	~	Dmnl
	~		|

Buildings Sector Carbon Tax Revenue=
	SUM(Building Components Energy Use[Building Type!,Building Fuel!,Building Component!\
		]
	* Buildings Fuel Carbon Tax Amount per Unit Energy[Building Fuel!,Building Type!])
	~	$
	~		|

Buildings Sector Change in Energy Expenditures by Entity[Cash Flow Entity]=
	SUM(
	  Change in Amount Spent on Buildings Fuels[Building Type!,Building Fuel!]
	  * Fraction of Buildings Owned by Entity after Allocation to Energy Supplier Entities\
		[Cash Flow Entity,Building Type!]
	)
	~	$
	~		|

Buildings Sector Change in Energy Expenditures by Entity and Fuel[Building Fuel,Cash Flow Entity\
		]=
	SUM(
	  Change in Amount Spent on Buildings Fuels[Building Type!,Building Fuel]
	  * Fraction of Buildings Owned by Entity after Allocation to Energy Supplier Entities\
		[Cash Flow Entity,Building Type!]
	)
	~	$
	~		|

Buildings Sector Change in Fuel Industry Cash Flow[Building Fuel]=
	Buildings Sector Change in Fuel Industry Cash Flow before Subsidies and Rebates[Building Fuel\
		]
	
	+ SUM(Change in Revenue from Buildings Sector Subsidies and Rebates by Entity[energy supplier cash flow entity\
		!])
	  * SUM(Building Components Energy Use[Building Type!,Building Fuel,Building Component\
		!])
	    / SUM(Building Components Energy Use[Building Type!,Building Fuel!,Building Component\
		!])
	~	$
	~	Buildings sector subsidies and rebates are given to energy-supplying cash \
		flow entities in proportion to the share of the modeled region's buildings \
		owned by these entities.  Energy-supplying entities likely own buildings \
		in proportion to their total energy production, not just their energy \
		production as used by the buildings sector.  But this variable is \
		subscripted by Building Fuel, which would prevent it being used for \
		handling these rebates and subsidies.  These rebates and subsidies are \
		extremely minor due to the vanishingly small share of all buildings that \
		are owned by energy-supplying entities, so it is not worth building \
		complex new structure to handle this.  Instead, we simply assign the \
		subsidies and rebates to Building Fuels in proportion to the usage of \
		those fuels in buildings.  Although this likely significantly \
		under-estimates the share of petroleum in oil-exporting countries, it \
		nonetheless is more than accurate enough for us here, because the \
		subsidies and rebates are tiny, and we mostly simply want to account for \
		them in order to have conservation of cash flows and avoid warnings on the \
		Debugging Assistance sheet.
	|

Buildings Sector Change in Fuel Industry Cash Flow before Subsidies and Rebates[Building Fuel\
		]=
	SUM(Change in Amount Spent on Buildings Fuels[Building Type!,Building Fuel])
	- SUM(Change in Buildings Fuel Taxes Paid[Building Type!,Building Fuel])
	~	$
	~		|

Buildings Sector Change in Fuel Industry Cash Flow Including Subsidies Mapped to All Fuels Subscript\
		[All Fuels] :EXCEPT:     [building fuel within all fuels]=
	0 ~~|
Buildings Sector Change in Fuel Industry Cash Flow Including Subsidies Mapped to All Fuels Subscript\
		[building fuel within all fuels]=
	Buildings Sector Change in Fuel Industry Cash Flow[Building Fuel]
	~	$
	~		|

Buildings Sector Change in Fuel Industry Cash Flow Mapped to All Fuels Subscript[All Fuels\
		] :EXCEPT: [building fuel within all fuels]=
	0 ~~|
Buildings Sector Change in Fuel Industry Cash Flow Mapped to All Fuels Subscript[building fuel within all fuels\
		]=
	Buildings Sector Change in Fuel Industry Cash Flow before Subsidies and Rebates[Building Fuel\
		]
	~	$
	~		|

Buildings Sector Change in Nonenergy Expenditures by Entity[Cash Flow Entity] :EXCEPT:\
		        [government],[nonenergy industries]=
	SUM(
	  Change in Amount Spent on New Building Components[Building Type!,Building Component\
		!]
	  * Fraction of Buildings Owned by Entity after Allocation to Energy Supplier Entities\
		[Cash Flow Entity,Building Type!]
	)
	
	+ SUM(Building Component Rebate Amount Paid by Entity[Building Type!,Building Component\
		!,Cash Flow Entity])
	
	+ SUM(Change in Repayment for Buildings Sector Financed Capital Expenses[Building Type\
		!]
	    *Fraction of Buildings Owned by Entity after Allocation to Energy Supplier Entities\
		[Cash Flow Entity,Building Type!]
	     ) ~~|
Buildings Sector Change in Nonenergy Expenditures by Entity[government]=
	SUM(
	  Change in Amount Spent on New Building Components[Building Type!,Building Component\
		!]
	  * Fraction of Buildings Owned by Entity after Allocation to Energy Supplier Entities\
		[government,Building Type!]
	)
	
	+ SUM(Building Component Rebate Amount Paid by Entity[Building Type!,Building Component\
		!,government])
	
	+ SUM(Change in Subsidy Paid on Distributed Solar Capacity[Building Type!])
	
	+ SUM(Subsidy Paid for Retrofitting Buildings[Building Type!])
	
	+ SUM(Change in Repayment for Buildings Sector Financed Capital Expenses[Building Type\
		!]
	    *Fraction of Buildings Owned by Entity after Allocation to Energy Supplier Entities\
		[government,Building Type!]
	     ) ~~|
Buildings Sector Change in Nonenergy Expenditures by Entity[nonenergy industries]=
	+ SUM(Change in Amount Spent on Distributed Solar Capacity[Building Type!])
	
	+ SUM(Amount Spent on Retrofitting Buildings[Building Type!,Building Component!])
	
	+ SUM(Change in Repayment for Buildings Sector Financed Capital Expenses[Building Type\
		!]
	    *Fraction of Buildings Owned by Entity after Allocation to Energy Supplier Entities\
		[nonenergy industries,Building Type!]
	     )
	
	+ SUM(
	    Change in Amount Spent on New Building Components[Building Type!,Building Component\
		!]
	    * Fraction of Buildings Owned by Entity after Allocation to Energy Supplier Entities\
		[nonenergy industries,Building Type
	!]
	)
	
	+ SUM(Building Component Rebate Amount Paid by Entity[Building Type!,Building Component\
		!,nonenergy industries])
	~	$
	~		|

Buildings Sector Change in Nonenergy Industry Expenditures by ISIC Code[ISIC Code] :EXCEPT:\
		          [ISIC 64T66]=
	(Buildings Sector Change in Energy Expenditures by Entity[nonenergy industries]
	  + Buildings Sector Change in Nonenergy Expenditures by Entity[nonenergy industries\
		]
	  - SUM(Change in Amount Spent on Distributed Solar Capacity[Building Type!])
	  - SUM(Amount Spent on Retrofitting Buildings[Building Type!,Building Component!])
	)
	* Percent of Nonenergy Industry Electricity and Natural Gas Spending by ISIC Code[ISIC Code\
		] ~~|
Buildings Sector Change in Nonenergy Industry Expenditures by ISIC Code[ISIC 64T66]=
	(Buildings Sector Change in Energy Expenditures by Entity[nonenergy industries]
	  + Buildings Sector Change in Nonenergy Expenditures by Entity[nonenergy industries\
		]
	  - SUM(Change in Amount Spent on Distributed Solar Capacity[Building Type!])
	  - SUM(Amount Spent on Retrofitting Buildings[Building Type!,Building Component!])
	)
	* Percent of Nonenergy Industry Electricity and Natural Gas Spending by ISIC Code[ISIC 64T66\
		]
	
	+ SUM(Change in Amount Spent on Distributed Solar Capacity[Building Type!])
	
	+ SUM(Amount Spent on Retrofitting Buildings[Building Type!,Building Component!])
	~	$
	~		|

Buildings Sector Change in Nonenergy Industry Revenue by ISIC Code[ISIC Code] :EXCEPT:\
		        [ISIC 64T66]=
	Change in Amount Spent on Building Components by Recipient ISIC Code[ISIC Code]
	
	+ Change in Amount Spent on Distributed Solar Capacity by Recipient ISIC Code[ISIC Code\
		]
	
	+ (Change in Revenue from Buildings Sector Subsidies and Rebates by Entity[nonenergy industries\
		]
	    - SUM(Change in Subsidy Paid on Distributed Solar Capacity[Building Type!])
	    - SUM(Subsidy Paid for Retrofitting Buildings[Building Type!])
	  )
	  * Percent of Nonenergy Industry Electricity and Natural Gas Spending by ISIC Code[\
		ISIC Code] ~~|
Buildings Sector Change in Nonenergy Industry Revenue by ISIC Code[ISIC 64T66]=
	Change in Amount Spent on Building Components by Recipient ISIC Code[ISIC 64T66]
	
	+ Change in Amount Spent on Distributed Solar Capacity by Recipient ISIC Code[ISIC 64T66\
		]
	
	+ SUM(Change in Subsidy Paid on Distributed Solar Capacity[Building Type!])
	
	+ SUM(Subsidy Paid for Retrofitting Buildings[Building Type!])
	
	+ SUM(Change in Repayment for Buildings Sector Financed Capital Expenses[Building Type\
		!])
	~	$
	~		|

Buildings Sector Change in Revenue by Entity[government]=
	SUM(Change in Buildings Fuel Taxes Paid[Building Type!,Building Fuel!])
	+ Change in Revenue from Buildings Sector Subsidies and Rebates by Entity[government\
		] ~~|
Buildings Sector Change in Revenue by Entity[nonenergy industries]=
	SUM(Buildings Sector Change in Nonenergy Industry Revenue by ISIC Code[ISIC Code!])
	
	
	{change in revenue from distributed solar capacity subsidies is already included in Buildings Sector Change in Nonenergy Industry Revenue by ISIC Code}\
		 ~~|
Buildings Sector Change in Revenue by Entity[labor and consumers]=
	Change in Revenue from Buildings Sector Subsidies and Rebates by Entity[labor and consumers\
		] ~~|
Buildings Sector Change in Revenue by Entity[foreign entities]=
	0 ~~|
Buildings Sector Change in Revenue by Entity[electricity suppliers]=
	Buildings Sector Change in Fuel Industry Cash Flow before Subsidies and Rebates[electricity bf\
		]
	+ Change in Revenue from Buildings Sector Subsidies and Rebates by Entity[electricity suppliers\
		] ~~|
Buildings Sector Change in Revenue by Entity[coal suppliers]=
	Buildings Sector Change in Fuel Industry Cash Flow before Subsidies and Rebates[hard coal bf\
		]
	+ Change in Revenue from Buildings Sector Subsidies and Rebates by Entity[coal suppliers\
		] ~~|
Buildings Sector Change in Revenue by Entity[natural gas and petroleum suppliers]=
	Buildings Sector Change in Fuel Industry Cash Flow before Subsidies and Rebates[natural gas bf\
		]
	+ Buildings Sector Change in Fuel Industry Cash Flow before Subsidies and Rebates[petroleum diesel bf\
		]
	+ Buildings Sector Change in Fuel Industry Cash Flow before Subsidies and Rebates[kerosene bf\
		]
	+ Buildings Sector Change in Fuel Industry Cash Flow before Subsidies and Rebates[heavy or residual fuel oil bf\
		]
	+ Buildings Sector Change in Fuel Industry Cash Flow before Subsidies and Rebates[LPG propane or butane bf\
		]
	+ Change in Revenue from Buildings Sector Subsidies and Rebates by Entity[natural gas and petroleum suppliers\
		] ~~|
Buildings Sector Change in Revenue by Entity[biomass and biofuel suppliers]=
	Buildings Sector Change in Fuel Industry Cash Flow before Subsidies and Rebates[biomass bf\
		]
	+ Change in Revenue from Buildings Sector Subsidies and Rebates by Entity[biomass and biofuel suppliers\
		] ~~|
Buildings Sector Change in Revenue by Entity[other energy suppliers]=
	Buildings Sector Change in Fuel Industry Cash Flow before Subsidies and Rebates[heat bf\
		]
	+ Buildings Sector Change in Fuel Industry Cash Flow before Subsidies and Rebates[hydrogen bf\
		]
	+ Change in Revenue from Buildings Sector Subsidies and Rebates by Entity[other energy suppliers\
		]
	~	$
	~		|

Buildings Sector Electricity Demand[Building Type, Building Component]=
	Building Components Energy Use[Building Type,electricity bf,Building Component]*MWh per BTU
	~	MW*hr
	~	AEO has a line item for electricity produced onsite vs purchased \
		electricity so our data here is total electricity demand, and we don't \
		need to worry about factoring in generation produced onsite.
	|

Buildings Sector Other Fuel Tax Revenue=
	SUM(Building Components Energy Use[Building Type!,Building Fuel!,Building Component!\
		]
	* Buildings Fuel Other Tax or Subsidy Amount per Unit Energy[Building Fuel!,Building Type\
		!])
	~	$
	~		|

Buildings Sector Pollutant Emissions[Building Type,Pollutant]=
	SUM(Direct Buildings Pollutant Emissions[Building Type,Building Component!,Building Fuel\
		!,Pollutant])
	+ Distributed Electricity Sources Buildings Pollutant Emissions[Building Type,Pollutant\
		]
	~	g pollutant
	~		|

Buildings Sector Pollutant Emissions Summed Across Building Types[Pollutant]=
	SUM(Buildings Sector Pollutant Emissions[Building Type!,Pollutant])
	~	g pollutant
	~	This variable is only used to populate a graph in Vensim.
	~	:SUPPLEMENTARY 
	|

Buildings Subtotal Change in Capital Expenditures=
	SUM(Change in Amount Spent on Distributed Solar Capacity[Building Type!])
	+ SUM(Change in Amount Spent on New Building Components[Building Type!,Building Component\
		!])
	~	$
	~		|

Buildings Subtotal Change in Tax Revenues=
	SUM(Change in Buildings Fuel Taxes Paid[Building Type!,Building Fuel!])
	~	$
	~		|

BUTYGV Boolean Use Twenty Year GWP Values=
	GET DIRECT CONSTANTS(
	   'InputData/ctrl-settings/BUTYGV/BUTYGV.csv',
	   ',',
	   'B2*'
	)
	~	Dmnl [0,1,1]
	~	When this variable is off (the default), 100-year GWP values are used for \
		all GHGs.  When enabled, 20-year GWP values are used for all GHGs except F \
		gases.  100-year GWP values continue to be used for F gases.  (F gases \
		were provided by our input data source in CO2e terms.  Although we have \
		GWPs for very many particular F gases, we do not know the proportions of \
		different chemicals that compose the F gases mixture, so we are unable to \
		determine the mixture's 20-year GWP value.)
	|

