Desired Cost Driven Capacity Retirements[Electricity Source,Optimization Pass]=
	{MAX(
	  0,
	
	  IF THEN ELSE(
	    Time = INITIAL TIME + 1 :OR: Time = INITIAL TIME,
	
	    Net Loss per Unit Output[Electricity Source],
	
	    IF THEN ELSE(
	      Time = INITIAL TIME + 2,
	
	      MIN(
	        Net Loss per Unit Output[Electricity Source],
	        Last Year Net Loss per Unit Output[Electricity Source]
	      ),
	
	      MIN(
	        MIN(
	          Net Loss per Unit Output[Electricity Source],
	          Last Year Net Loss per Unit Output[Electricity Source]
	        ),
	        Two Years Prior Net Loss per Unit Output[Electricity Source]
	      )
	    )
	  )
	)}
	
	Average Three Year Prior Net Loss per Unit Output[Electricity Source,Optimization Pass\
		]
	* CRpUNL Capacity Retired per Unit Net Loss[Electricity Source]
	~	MW
	~		|

Desired Cost Driven Capacity Retirements Excluding Capacity Payment[Electricity Source\
		]=
	Average Three Year Prior Net Loss per Unit Output Excluding Capacity Payment[Electricity Source\
		]
	* CRpUNL Capacity Retired per Unit Net Loss[Electricity Source]
	~	MW
	~		|

Difference Between This Year and First Year Battery Cost=
	(First Year Battery Energy Cost per Unit Capacity
	  + First Year Battery Power Cost per Unit Capacity
	  / GBSC Diurnal Grid Battery Daily Storage Duration
	)
	
	- Total Battery Cost per Unit Capacity
	~	$/(MW*hour)
	~		|

Dimensionless Time=
	Time / One Year
	~	Dmnl
	~		|

Direct Buildings Pollutant Emissions[Building Type,Building Component,Building Fuel,Pollutant\
		]=
	Building Components Energy Use[Building Type,Building Fuel,Building Component]
	* Buildings Fuel Pollutant Emissions Intensities This Year[Pollutant,Building Fuel]
	~	g pollutant
	~		|

Direct Change in Cash Flow by Entity[Cash Flow Entity]=
	Direct Change in Revenue by Entity[Cash Flow Entity]
	
	- Direct Change in Energy Expenditures by Entity[Cash Flow Entity]
	- Direct Change in Nonenergy Expenditures by Entity[Cash Flow Entity]
	~	$
	~		|

Direct Change in Domestic Compensation by ISIC Code[ISIC Code]=
	QUANTUM(
	
	  Direct Change in Domestic Jobs after Productivity Effects by ISIC Code[ISIC Code]
	
	  * Within Industry Compensation per Employed Person[ISIC Code]
	,
	
	  QSfCF Quantization Size for Cash Flows
	)
	~	$
	~		|

Direct Change in Domestic Jobs after Productivity Effects by ISIC Code[ISIC Code]=
	QUANTUM(
	  Direct Change in Domestic Jobs by ISIC Code[ISIC Code]
	  / (1 + LPGRbIC Labor Productivity Growth Rate by ISIC Code[ISIC Code])^(Dimensionless Time\
		 - Initial Time Dimensionless),
	
	  Quantization Size for Jobs
	)
	~	jobs
	~		|

Direct Change in Domestic Jobs by ISIC Code[ISIC Code] :EXCEPT:    [Fossil and Energy Utility ISIC Code\
		]=
	Industry Contribution to Change in Domestic Output by ISIC Code[ISIC Code]
	* Within Industry Jobs per Unit Output[ISIC Code] ~~|
Direct Change in Domestic Jobs by ISIC Code[Fossil and Energy Utility ISIC Code]=
	Change in Fuel Production Mapped to ISIC Codes[Fossil and Energy Utility ISIC Code]
	* Within Industry Jobs per Unit Energy Production[Fossil and Energy Utility ISIC Code\
		]
	* FoPTaFbIC Fractions of Products That are Fuels by ISIC Code[Fossil and Energy Utility ISIC Code\
		]
	
	+ Industry Contribution to Change in Domestic Output by ISIC Code[Fossil and Energy Utility ISIC Code\
		]
	* Within Industry Jobs per Unit Output[Fossil and Energy Utility ISIC Code]
	* (1 - FoPTaFbIC Fractions of Products That are Fuels by ISIC Code[Fossil and Energy Utility ISIC Code\
		])
	~	jobs
	~		|

Direct Change in Domestic Output Due to Buy In Region Policy[ISIC Code]=
	Direct Change in Domestic Output Due to Buy In Region Policy Effects on Other Policies Direct Effects\
		[ISIC Code]
	+ BAU Imported Output Shifted to In Region Suppliers by ISIC Code[ISIC Code]
	~	$
	~		|

Direct Change in Domestic Output Due to Buy In Region Policy Effects on Other Policies Direct Effects\
		[ISIC Code]=
	Industry Contribution to Change in Domestic Output by ISIC Code before Shifting BAU Imported Output\
		[ISIC Code]
	* Change in Domestic Content Share of Consumption by ISIC Code[ISIC Code]
	~	$
	~		|

Direct Change in Domestic Revenue by Entity[Cash Flow Entity]=
	Direct Change in Revenue by Entity[Cash Flow Entity]
	- Direct Change in Export Revenue by Entity[Cash Flow Entity]
	~	$
	~		|

Direct Change in Domestic Value Added by ISIC Code[ISIC Code] :EXCEPT:  [Fossil and Energy Utility ISIC Code\
		]=
	QUANTUM(
	
	  (Industry Contribution to Change in Domestic Output by ISIC Code[ISIC Code]
	    + Domestic Nonenergy Industry Expenses Passed Through to Buyers by Producer ISIC Code\
		[ISIC Code]
	  )
	  * Within Industry Value Added per Unit Output[ISIC Code],
	
	  QSfCF Quantization Size for Cash Flows
	) ~~|
Direct Change in Domestic Value Added by ISIC Code[Fossil and Energy Utility ISIC Code\
		]=
	QUANTUM(
	Change in Fuel Production Mapped to ISIC Codes[Fossil and Energy Utility ISIC Code]
	* Within Industry Value Added per Unit Energy Production[Fossil and Energy Utility ISIC Code\
		]
	* FoPTaFbIC Fractions of Products That are Fuels by ISIC Code[Fossil and Energy Utility ISIC Code\
		]
	
	+ QUANTUM(
	
	  (Industry Contribution to Change in Domestic Output by ISIC Code[Fossil and Energy Utility ISIC Code\
		]
	    + Domestic Nonenergy Industry Expenses Passed Through to Buyers by Producer ISIC Code\
		[Fossil and Energy Utility ISIC Code]
	  )
	  * Within Industry Value Added per Unit Output[Fossil and Energy Utility ISIC Code]\
		,
	
	  QSfCF Quantization Size for Cash Flows
	)
	* (1 - FoPTaFbIC Fractions of Products That are Fuels by ISIC Code[Fossil and Energy Utility ISIC Code\
		]),
	
	QSfCF Quantization Size for Cash Flows
	)
	~	$
	~		|

Direct Change in Domestic Value Added Due to Buy In Region Policy[ISIC Code]=
	Direct Change in Domestic Output Due to Buy In Region Policy[ISIC Code]
	* Within Industry Value Added per Unit Output[ISIC Code]
	~	$
	~		|

Direct Change in Energy Expenditures by Entity[Cash Flow Entity]=
	QUANTUM(
	  Transportation Sector Change in Energy Expenditures by Entity[Cash Flow Entity]
	  + Electricity Sector Change in Energy Expenditures by Entity[Cash Flow Entity]
	  + Buildings Sector Change in Energy Expenditures by Entity[Cash Flow Entity]
	  + Industry Sector Change in Energy Expenditures by Entity[Cash Flow Entity]
	  + District Heating Change in Energy Expenditures by Entity[Cash Flow Entity]
	  + Hydrogen Sector Change in Energy Expenditures by Entity[Cash Flow Entity]
	  + Fuel Trade and Subsidy Change in Energy Expenditures by Entity[Cash Flow Entity]
	  + Geoengineering Sector Change in Energy Expenditures by Entity[Cash Flow Entity],
	
	  QSfCF Quantization Size for Cash Flows
	)
	~	$
	~		|

Direct Change in Expenditures by Industry Without Most Production Effects[Industry Category\
		]=
	SUM(Change in Amount Spent on Industry Fuels[Industry Category,Industrial Fuel!])
	+ Change in Miscellaneous Expenditures by Industry[Industry Category]
	
	- Change in Industry Sector Carbon Tax Rebate due to CCS[Industry Category]
	+ Change in Upfront Capital Expenditures by Industry for Non Financed Equipment[Industry Category\
		]
	~	$
	~		|

Direct Change in Export Revenue by Entity[government]=
	0 ~~|
Direct Change in Export Revenue by Entity[nonenergy industries]=
	QUANTUM(
	  SUM(Change in Nonenergy Industry Revenues due to Production Changes by Purchasing Entity\
		[Industry Category!,foreign entities]),
	
	  QSfCF Quantization Size for Cash Flows
	) ~~|
Direct Change in Export Revenue by Entity[labor and consumers]=
	0 ~~|
Direct Change in Export Revenue by Entity[foreign entities]=
	Direct Change in Revenue by Entity[foreign entities] ~~|
Direct Change in Export Revenue by Entity[electricity suppliers]=
	QUANTUM(
	  Change in Energy Export Revenue including Electricity[electricity],
	
	  QSfCF Quantization Size for Cash Flows
	) ~~|
Direct Change in Export Revenue by Entity[coal suppliers]=
	QUANTUM(
	  SUM(Change in Energy Export Revenue including Electricity[coal mining industry fuel within all fuels\
		!]),
	
	  QSfCF Quantization Size for Cash Flows
	) ~~|
Direct Change in Export Revenue by Entity[natural gas and petroleum suppliers]=
	QUANTUM(
	  SUM(Change in Energy Export Revenue including Electricity[NGPS industry fuel within all fuels\
		!]),
	
	  QSfCF Quantization Size for Cash Flows
	) ~~|
Direct Change in Export Revenue by Entity[biomass and biofuel suppliers]=
	QUANTUM(
	  Change in Energy Export Revenue including Electricity[biomass]
	  + Change in Energy Export Revenue including Electricity[biofuel gasoline]
	  + Change in Energy Export Revenue including Electricity[biofuel diesel],
	
	  QSfCF Quantization Size for Cash Flows
	) ~~|
Direct Change in Export Revenue by Entity[other energy suppliers]=
	QUANTUM(
	  Change in Energy Export Revenue including Electricity[nuclear]
	  + Change in Energy Export Revenue including Electricity[heat]
	  + Change in Energy Export Revenue including Electricity[municipal solid waste]
	  + Change in Energy Export Revenue including Electricity[hydrogen],
	
	  QSfCF Quantization Size for Cash Flows
	)
	~	$
	~	For foreign entities, we only track their export revenue (to the modeled \
		region), so for foreign entities, all changes in revenue are changes in \
		export revenue.
	|

Direct Change in Fuel Industry Revenue by ISIC Code[ISIC Code]=
	SUM(
	  Change in Fuel Industry Revenue by Fuel[All Fuels!]
	  * FtPICM Fuel to Producing ISIC Code Map[All Fuels!,ISIC Code]
	)
	~	$
	~		|

Direct Change in Nonenergy Expenditures by Entity[Cash Flow Entity] :EXCEPT:  [government\
		]=
	QUANTUM(
	  Transportation Sector Change in Nonenergy Expenditures by Entity[Cash Flow Entity]
	  + Electricity Sector Change in Nonenergy Expenditures by Entity[Cash Flow Entity]
	  + Buildings Sector Change in Nonenergy Expenditures by Entity[Cash Flow Entity]
	  + Industry Sector Change in Nonenergy Expenditures by Entity[Cash Flow Entity]
	  + District Heating Change in Nonenergy Expenditures by Entity[Cash Flow Entity]
	  + Hydrogen Sector Change in Nonenergy Expenditures by Entity[Cash Flow Entity]
	  + LULUCF Change in Nonenergy Expenditures by Entity[Cash Flow Entity]
	  + Geoengineering Sector Change in Nonenergy Expenditures by Entity[Cash Flow Entity\
		],
	
	  QSfCF Quantization Size for Cash Flows
	) ~~|
Direct Change in Nonenergy Expenditures by Entity[government]=
	QUANTUM(
	  Transportation Sector Change in Nonenergy Expenditures by Entity[government]
	  + Electricity Sector Change in Nonenergy Expenditures by Entity[government]
	  + Buildings Sector Change in Nonenergy Expenditures by Entity[government]
	  + Industry Sector Change in Nonenergy Expenditures by Entity[government]
	  + District Heating Change in Nonenergy Expenditures by Entity[government]
	  + Hydrogen Sector Change in Nonenergy Expenditures by Entity[government]
	  + LULUCF Change in Nonenergy Expenditures by Entity[government]
	  + Geoengineering Sector Change in Nonenergy Expenditures by Entity[government]
	
	  + SUM(Last Year Change in National Debt Interest Received by Cash Flow Entity[Cash Flow Entity\
		!]),
	
	  QSfCF Quantization Size for Cash Flows
	)
	~	$
	~		|

Direct Change in Revenue by Entity[Cash Flow Entity]=
	QUANTUM(
	  Transportation Sector Change in Revenue by Entity[Cash Flow Entity]
	  + Electricity Sector Change in Revenue by Entity[Cash Flow Entity]
	  + Buildings Sector Change in Revenue by Entity[Cash Flow Entity]
	  + Industry Sector Change in Revenue by Entity[Cash Flow Entity]
	  + District Heating Change in Revenue by Entity[Cash Flow Entity]
	  + Hydrogen Sector Change in Revenue by Entity[Cash Flow Entity]
	  + LULUCF Change in Revenue by Entity[Cash Flow Entity]
	  + Fuel Trade and Subsidy Change in Revenue by Entity[Cash Flow Entity]
	  + Geoengineering Sector Change in Revenue by Entity[Cash Flow Entity]
	
	  + Last Year Change in National Debt Interest Received by Cash Flow Entity[Cash Flow Entity\
		]
	  + Changes in Revenue due to VAT or Sales Tax on Nonenergy ISIC Codes by Cash Flow Entity\
		[Cash Flow Entity],
	
	  QSfCF Quantization Size for Cash Flows
	)
	~	$
	~		|

Direct Change in Revenue for Nonenergy ISIC Codes[ISIC Code] :EXCEPT:  [ISIC 64T66]=
	Transportation Sector Change in Nonenergy Industry Revenue by ISIC Code[ISIC Code]
	+ Electricity Sector Change in Nonenergy Industry Revenue by ISIC Code[ISIC Code]
	+ Buildings Sector Change in Nonenergy Industry Revenue by ISIC Code[ISIC Code]
	+ Industry Sector Change in Nonenergy Industry Revenue by ISIC Code[ISIC Code]
	+ District Heating Change in Nonenergy Industry Revenue by ISIC Code[ISIC Code]
	+ Hydrogen Sector Change in Nonenergy Industry Revenue by ISIC Code[ISIC Code]
	+ LULUCF Change in Nonenergy Industry Revenue by ISIC Code[ISIC Code]
	+ Geoengineering Sector Change in Nonenergy Industry Revenue by ISIC Code[ISIC Code]\
		 ~~|
Direct Change in Revenue for Nonenergy ISIC Codes[ISIC 64T66 {Financial and insurance activities}\
		]=
	Transportation Sector Change in Nonenergy Industry Revenue by ISIC Code[ISIC 64T66]
	+ Electricity Sector Change in Nonenergy Industry Revenue by ISIC Code[ISIC 64T66]
	+ Buildings Sector Change in Nonenergy Industry Revenue by ISIC Code[ISIC 64T66]
	+ Industry Sector Change in Nonenergy Industry Revenue by ISIC Code[ISIC 64T66]
	+ District Heating Change in Nonenergy Industry Revenue by ISIC Code[ISIC 64T66]
	+ Hydrogen Sector Change in Nonenergy Industry Revenue by ISIC Code[ISIC 64T66]
	+ LULUCF Change in Nonenergy Industry Revenue by ISIC Code[ISIC 64T66]
	+ Geoengineering Sector Change in Nonenergy Industry Revenue by ISIC Code[ISIC 64T66\
		]
	
	+ Last Year Change in National Debt Interest Received by Cash Flow Entity[nonenergy industries\
		]
	~	$
	~	All changes in interest paid on the national debt that are going to \
		non-energy industries are assigned to ISIC 64T66 (Financial and insurance \
		activities).
	|

Direct Plus Indirect Change in Jobs[ISIC Code]=
	Direct Change in Domestic Jobs after Productivity Effects by ISIC Code[ISIC Code]
	+ Indirect Change in Domestic Jobs after Productivity Effects by ISIC Code[ISIC Code\
		]
	~	jobs
	~		|

Discount Factor to Levelize Capital Costs=
	10.3696
	~	Dmnl
	~	Assumes 30-year lifetime equipment. Net present value = SUM_t=0-N \
		(R_t/(1+i)^t). This variable is = SUM_t=1-30 (1/(1+i)^t). It can act as a \
		denominator to levelize upfront capital expenditures paid in the first \
		year of equipment operation.
	|

Discount Factor to Levelize Subsidy=
	0.651811
	~	Dmnl
	~	The 45Q tax credit lasts only 10 years, so the subsequent years without \
		subsidy need to be accounted for. Net present value = SUM_t=0-N \
		(R_t/(1+i)^t). This variable is = SUM_t=1-10 (1/(1+i)^t) divided by \
		SUM_t=1-30 (1/(1+i)^t).
	|

Dispatch Cost per Unit Electricity Output[Electricity Source]=
	Dispatch Cost per Unit Electricity Output before Subsidies[Electricity Source]
	- Variable Subsidies per Unit Elec Output[Electricity Source]
	~	$/(MW*hour)
	~		|

Dispatch Cost per Unit Electricity Output before Subsidies[Electricity Source]=
	Weighted Average Electricity Fuel Cost per Unit Electricity Output[Electricity Source\
		]
	+ Weighted Average Variable OM Cost per Unit Electricity Output[Electricity Source]
	~	$/(MW*hour)
	~		|

Dispatch or Opportunity Cost per Unit Electricity Output[Electricity Source] :EXCEPT:\
		     [hydro es]=
	Dispatch Cost per Unit Electricity Output[Electricity Source] ~~|
Dispatch or Opportunity Cost per Unit Electricity Output[hydro es]=
	HOC Hydro Opportunity Cost
	~	$/(MW*hr)
	~		|

Distributed Electricity Source Capacity[Building Type,Electricity Source] :EXCEPT:  [\
		Building Type,solar PV es]=
	BDESC BAU Distributed Electricity Source Capacity[Building Type,Electricity Source] ~~|
Distributed Electricity Source Capacity[Building Type,solar PV es]=
	MAX(
	
	    BAU Distributed Electricity Source Capacity[Building Type,solar PV es]
	    + Cumulative Total Distributed Solar Capacity Caused by Policies[Building Type],
	
	  0
	
	)
	~	MW
	~		|

Distributed Electricity Sources Buildings Pollutant Emissions[Building Type,Pollutant\
		]=
	SUM(Annual Output from Distributed Electricity Capacity[Electricity Source!]
	  / MWh per BTU
	  * Electricity Fuel Pollutant Emissions Intensities This Year[Pollutant,Electricity Source\
		!]
	  * Share of Distributed Electricity Emissions by Building Type[Building Type,Electricity Source\
		!]
	)
	~	g pollutant
	~		|

Distributed Solar Capacity Before Capacity Requirement This Year[Building Type]=
	MIN(Last Year Distributed Electricity Source Capacity[Building Type,solar PV es]
	    + BAU This Year Increase in Distributed Electricity Source Capacity[Building Type\
		,solar PV es]
	    + MAX(Distributed Solar Capacity Caused by Subsidy and Policy Mandated Change in Capacity This Year\
		[Building Type],
	          Increase in Distributed Solar Needed to Meet Capacity Requirement[Building Type\
		,solar PV es]),
	    MDSC Maximum Distributed Solar Capacity[Building Type,solar PV es]
	)
	~	MW
	~		|

Distributed Solar Capacity Caused by Capacity Requirement This Year[Building Type]=
	New Solar Capacity Needed to Meet Capacity Requirement This Year *
	ZIDZ(Remaining Potential Solar Capacity by Building Type[Building Type],
	     SUM(Remaining Potential Solar Capacity by Building Type[Building Type!])
	)
	~	MW
	~	Mandated distributed solar capacity is assigned to building types in \
		proportion to the amount of distributed solar capacity those building \
		types already possess.
	|

Distributed Solar Capacity Caused by Policies This Year[Building Type]=
	IF THEN ELSE(
	
	  Boolean Use Non BAU Distributed Solar Capacity This Year[Building Type] > 0,
	
	  Distributed Solar Capacity Caused by Subsidy and Policy Mandated Change in Capacity This Year\
		[Building Type] / One Year
	,
	
	  (MAX(Distributed Solar Capacity Caused by Subsidy and Policy Mandated Change in Capacity This Year\
		[Building Type],
	     Increase in Distributed Solar Needed to Meet Capacity Requirement[Building Type\
		,solar PV es])
	  + Distributed Solar Capacity Caused by Capacity Requirement This Year[Building Type\
		])
	  / One Year
	)
	~	MW/Year
	~		|

Distributed Solar Capacity Caused by Subsidy and Policy Mandated Change in Capacity This Year\
		[Building Type]=
	BAU This Year Increase in Distributed Electricity Source Capacity[Building Type,solar PV es\
		]
	* (1 - BPSfDSPC BAU Perc Subsidy for Distributed Solar PV Capacity[Building Type])
	* Additional Perc Subsidy for Distributed Solar PV Capacity This Year[Building Type]
	* EoDSDwSP Elasticity of Distributed Solar Deployment wrt Subsidy Perc[Building Type\
		]
	
	+ Policy Mandated Change in Distributed Electricity Source Capacity This Year[Building Type\
		,solar PV es]
	~	MW
	~		|

Distributed Solar Capacity Factor x Hours per Year=
	SUM(SYSHECF Start year Seasonal Expected Capacity Factor for Distributed Sources[solar PV es\
		,Electricity Timeslice!,Hour!]*SHELF Days per Electricity Timeslice[Electricity Timeslice\
		!])*One Hour
	~	hours
	~		|

Distribution Construction Costs=
	Change in Peak Load*DCCpUIiPL Distribution Construction Cost per Unit Increase in Peak Load
	~	$
	~		|

Distribution OM Costs=
	Peak Electricity Load Growth Relative to Start Year
	* SYTaDC Start Year Distribution OM Costs
	~	$
	~		|

District Heat and Hydrogen Fuel Other Tax or Subsidy Amount per Unit Energy[Industrial Fuel\
		]=
	Fuel Tax or Subsidy by Sector[industrial fuel within all fuels,district heat and hydrogen sector\
		]
	~	$/BTU
	~		|

District Heat and Hydrogen Sector Other Fuel Tax Revenue=
	SUM(
	  (Fuel Used to Generate Heat[Industrial Fuel!]
	    + Hydrogen Sector Fuel Use[Industrial Fuel!]
	  )
	  * District Heat and Hydrogen Fuel Other Tax or Subsidy Amount per Unit Energy[Industrial Fuel\
		!]
	)
	~	$
	~		|

District Heat Electricity Demand=
	Fuel Used to Generate Heat[electricity if]
	* MWh per BTU
	~	MW*hr
	~		|

District Heat Fuel Carbon Tax Amount per Unit Energy[Industrial Fuel]=
	Carbon Tax Rate[district heat and hydrogen sector]
	/ Grams per Metric Ton CO2e
	* District Heat Fuel Taxable CO2e Emissions Intensity[Industrial Fuel]
	~	$/BTU
	~	We need this subscripted only by fuel type, not industry type, for use \
		calculating percentage differences from BAU.  Carbon intensity of fuels \
		should not vary significantly based on which industry burns those fuels, \
		as CCS is not considered here.  Accordingly, we use the cement industry as \
		our model, as cement is produced worldwide, is a major emitter, and has \
		unique process emissions, and therefore is unlikely to be repurposed as \
		another industry in an EPS adaptation.
	|

District Heat Fuel Cost per Unit Energy[Industrial Fuel]=
	MAX(Pretax Fuel Cost per Unit Energy by Sector after Fuel Price Deregulation[industrial fuel within all fuels\
		,district heat and hydrogen sector]
	  + District Heat Fuel Total Tax or Subsidy Amount per Unit Energy[Industrial Fuel],
	0
	)
	~	$/BTU
	~		|

District Heat Fuel Taxable CO2e Emissions Intensity[Industrial Fuel]=
	SUM(
	  Industrial Fuel Pollutant Emissions Intensities This Year[cement and other nonmetallic minerals 239\
		,Pollutant!,Industrial Fuel
	]
	  * GWP by Pollutant[Pollutant!]
	  * District Heat Pollutants Taxed by Carbon Pricing[Pollutant!]
	)
	~	g CO2e/BTU
	~		|

District Heat Fuel Total Tax or Subsidy Amount per Unit Energy[Industrial Fuel]=
	District Heat Fuel Carbon Tax Amount per Unit Energy[Industrial Fuel]
	+ District Heat and Hydrogen Fuel Other Tax or Subsidy Amount per Unit Energy[Industrial Fuel\
		]
	~	$/BTU
	~		|

District Heat Pollutants Taxed by Carbon Pricing[Pollutant]=
	IF THEN ELSE(
	  Boolean Non BAU Pollutants Affected by Carbon Tax This Year = 0,
	  BPTbCP BAU District Heat Pollutants Taxed by Carbon Pricing[Pollutant],
	  PTbCP District Heat Pollutants Taxed by Carbon Pricing[Pollutant]
	)
	~	Dmnl
	~		|

District Heat Provided by Dedicated Facilities[Industrial Fuel]=
	Total District Heat Use by Fuel before CHP[Industrial Fuel]
	* (1 - Fraction of District Heat from CHP[Industrial Fuel])
	~	BTU
	~		|

District Heat Sector Carbon Tax Revenue=
	SUM(
	  Fuel Used to Generate Heat[Industrial Fuel!]
	  * District Heat Fuel Carbon Tax Amount per Unit Energy[Industrial Fuel!]
	)
	~	$
	~		|

District Heating Change in Energy Expenditures by Entity[Cash Flow Entity] :EXCEPT: [\
		other energy suppliers]=
	0 ~~|
District Heating Change in Energy Expenditures by Entity[other energy suppliers]=
	SUM(Change in Amount Spent on District Heating Fuels[Industrial Fuel!])
	~	$
	~		|

District Heating Change in Fuel Industry Cash Flow[Industrial Fuel]=
	Change in Amount Spent on District Heating Fuels[Industrial Fuel]
	- Change in Taxes Paid on Fuels to Generate Heat[Industrial Fuel]
	~	$
	~		|

District Heating Change in Fuel Industry Cash Flow Mapped to All Fuels Subscript[All Fuels\
		] :EXCEPT: [industrial fuel within all fuels]=
	0 ~~|
District Heating Change in Fuel Industry Cash Flow Mapped to All Fuels Subscript[industrial fuel within all fuels\
		] :EXCEPT: [hydrogen]=
	District Heating Change in Fuel Industry Cash Flow[Industrial Fuel] ~~|
District Heating Change in Fuel Industry Cash Flow Mapped to All Fuels Subscript[hydrogen\
		]=
	District Heating Change in Fuel Industry Cash Flow[hydrogen if]
	+ District Heating Change in Fuel Industry Cash Flow[green hydrogen if]
	+ District Heating Change in Fuel Industry Cash Flow[low carbon hydrogen if]
	~	$
	~		|

District Heating Change in Nonenergy Expenditures by Entity[Cash Flow Entity] :EXCEPT:\
		 [other energy suppliers]=
	0 ~~|
District Heating Change in Nonenergy Expenditures by Entity[other energy suppliers]=
	Cost of CHP Conversion for Heat
	~	$
	~		|

District Heating Change in Nonenergy Industry Revenue by ISIC Code[ISIC Code] :EXCEPT:\
		  [ISIC 28]=
	0 ~~|
District Heating Change in Nonenergy Industry Revenue by ISIC Code[ISIC 28 {Machinery and equipment n.e.c.}\
		]=
	Cost of CHP Conversion for Heat
	~	$
	~		|

District Heating Change in Revenue by Entity[government]=
	SUM(Change in Taxes Paid on Fuels to Generate Heat[Industrial Fuel!]) ~~|
District Heating Change in Revenue by Entity[nonenergy industries]=
	SUM(District Heating Change in Nonenergy Industry Revenue by ISIC Code[ISIC Code!]) ~~|
District Heating Change in Revenue by Entity[labor and consumers]=
	0 ~~|
District Heating Change in Revenue by Entity[foreign entities]=
	0 ~~|
District Heating Change in Revenue by Entity[electricity suppliers]=
	District Heating Change in Fuel Industry Cash Flow[electricity if] ~~|
District Heating Change in Revenue by Entity[coal suppliers]=
	District Heating Change in Fuel Industry Cash Flow[hard coal if] ~~|
District Heating Change in Revenue by Entity[natural gas and petroleum suppliers]=
	District Heating Change in Fuel Industry Cash Flow[natural gas if]
	+ District Heating Change in Fuel Industry Cash Flow[petroleum diesel if]
	+ District Heating Change in Fuel Industry Cash Flow[crude oil if]
	+ District Heating Change in Fuel Industry Cash Flow[heavy or residual fuel oil if]
	+ District Heating Change in Fuel Industry Cash Flow[LPG propane or butane if] ~~|
District Heating Change in Revenue by Entity[biomass and biofuel suppliers]=
	District Heating Change in Fuel Industry Cash Flow[biomass if] ~~|
District Heating Change in Revenue by Entity[other energy suppliers]=
	District Heating Change in Fuel Industry Cash Flow[heat if]
	+ District Heating Change in Fuel Industry Cash Flow[hydrogen if]
	~	$
	~		|

District Heating Pollutant Emissions[Pollutant,Industrial Fuel]=
	Fuel Used to Generate Heat[Industrial Fuel]
	  * Industrial Fuel Pollutant Emissions Intensities This Year[cement and other nonmetallic minerals 239\
		,Pollutant,Industrial Fuel]
	~	g pollutant
	~	District heating isn't an industry, but it uses industrial sector fuel \
		emissions intensities.  Since the emissions intensities are subscripted by \
		industry, we must choose an industry to use, though the emissions \
		intensities may be the same for all industries.  We use the cement \
		industry as our model, as cement is produced all over the world, is a \
		major emitter, and therefore is unlikely to be repurposed as another \
		industry in EPS model adaptations.
	|

District Heating Pollutant Emissions Summed Across Fuels[Pollutant]=
	SUM(District Heating Pollutant Emissions[Pollutant,Industrial Fuel!])
	~	g pollutant
	~		~	:SUPPLEMENTARY 
	|

District Heating Subtotal Change in Tax Revenues=
	SUM(Change in Taxes Paid on Fuels to Generate Heat[Industrial Fuel!])
	~	$
	~		|

DLIM Domestic Leontief Inverse Matrix[Source ISIC Code, Target ISIC Code]=
	GET DIRECT CONSTANTS(
	   'InputData/io-model/DLIM/DLIM.csv',
	   ',',
	   'B2'
	)
	~	Dmnl
	~		|

Do Producers Have Foresight to Future NonBAU Elec Portfolio Values=
	IF THEN ELSE(
	  Renewable Portfolio Std Percentage
	  * Selected Policy Implementation Schedule[elec renewable portfolio standards X]
	  > 0,
	
	  1,
	
	  0
	)
	~	Dmnl
	~	Even if foresight is enabled, we deny foresight into non-BAU (i.e., policy \
		case) RPS values until the RPS policy begins to be used (i.e., has a \
		non-BAU setting). This is because the first couple years of the model run \
		are often historical years, and we don't want foresight to cause the RPS \
		line to begin diverging from the BAU line in historical years (as this \
		would be counter to known history).
	|

