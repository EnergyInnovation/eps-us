Grams per Metric Ton CO2e=
	1e+06
	
	{
	Google Unit Converter
	https://www.google.com/search?q=grams+per+metric+ton
	}
	~	g CO2e/metric ton CO2e
	~		|

Grams per Metric Ton Pollutant=
	1e+06
	~	g pollutant/metric ton pollutant
	~		|

Grams Pollutant per Gram CO2e Unit Converter=
	1
	~	g pollutant/g CO2e
	~		|

Green Hydrogen Demand=
	SUM(Green Hydrogen Demand by Sector[Sectors!])
	~	BTU
	~		|

Green Hydrogen Demand by Sector[Sectors] :EXCEPT:      [industry sector],[geoengineering sector\
		],[district heat and hydrogen sector]=
	Hydrogen Demand by Sector[Sectors]
	* SoHDTiGaLCbS Share of Hydrogen Demand That is Green by Sector[Sectors] ~~|
Green Hydrogen Demand by Sector[industry sector]=
	SUM(Industrial Fuel Use[green hydrogen if,Industry Category!]) ~~|
Green Hydrogen Demand by Sector[geoengineering sector]=
	Geoengineering Sector Energy Use[green hydrogen if] ~~|
Green Hydrogen Demand by Sector[district heat and hydrogen sector]=
	Fuel Used to Generate Heat[green hydrogen if]
	~	BTU
	~		|

Green Hydrogen Electricity Capacity Construction Subsidies Paid[Electricity Source]=
	Off Grid Capacity for Green Hydrogen Demand[Electricity Source]
	* Subsidy per Unit Electricity Capacity Built[Electricity Source]
	~	$
	~		|

Green Hydrogen Electricity Fixed OM Costs[Electricity Source]=
	Off Grid Capacity for Green Hydrogen Demand[Electricity Source]
	* Weighted Average Annual Fixed OM Cost per Unit Capacity[Electricity Source]
	~	$
	~		|

Green Hydrogen Electricity Generation Subsidies Paid[Electricity Source]=
	Off Grid Electricity Demand for Green Hydrogen by Power Plant Type[Electricity Source\
		]
	* Subsidy per Unit Electricity Output Adjusted for Subsidy Duration[Electricity Source\
		]
	~	$
	~		|

Green Hydrogen Electricity Variable OM Costs[Electricity Source]=
	Off Grid Electricity Demand for Green Hydrogen by Power Plant Type[Electricity Source\
		]
	* Weighted Average Variable OM Cost per Unit Electricity Output[Electricity Source]
	~	$
	~		|

Grid Batteries Capacity Market Revenue for Seasonal Dispatchable Reliability per Unit Elec Output\
		[Optimization Pass]=
	MAX(0,
	  Capacity Market Price for Seasonal Dispatchable Reliability by Optimization Pass[Optimization Pass\
		]
	  * ( 1 - Battery Storage Usage Factor Discount in Binding Peak Hour)
	  * Days per Year
	  * One Day)
	 
	*ESTRTE Grid Battery Round Trip Efficiency
	/GBSC Diurnal Grid Battery Daily Storage Duration
	~	$/(MW*hr)
	~		|

Grid Batteries Net Energy Market Revenue per Unit Elec Output=
	MAX(
	  0,
	
	  Weighted Average Discharging Revenue for Grid Batteries after Subsidies
	  - Weighted Average Charging Cost for Diurnal Technologies
	)
	
	+ Decline in Grid Battery Cost
	~	$/(MW*hr)
	~		|

Gross Domestic Product=
	BGDP BAU Gross Domestic Product
	+ SUM(Change in Domestic Value Added by ISIC Code[ISIC Code!])
	~	$
	~		|

Gross Domestic Product by ISIC Code[ISIC Code]=
	BAU Gross Domestic Product by ISIC Code[ISIC Code]
	+ Change in Domestic Value Added by ISIC Code[ISIC Code]
	~	$
	~		|

Gross Domestic Product Excluding Most Direct Impacts by ISIC Code[ISIC Code]=
	MAX(
	  0,
	
	  BAU Gross Domestic Product by ISIC Code[ISIC Code]
	  + Indirect Change in Domestic Value Added by ISIC Code Excluding Passthrough Expenses\
		[ISIC Code]
	  + Induced Change in Domestic Value Added by ISIC Code[ISIC Code]
	  + Direct Change in Domestic Value Added Due to Buy In Region Policy[ISIC Code]
	)
	~	$
	~		|

Guaranteed Dispatch Amount[Electricity Source,Electricity Timeslice,Hour]=
	MAX(
	
	RPS Qualifying Guaranteed Dispatch Amount[Electricity Source,Electricity Timeslice,Hour\
		,RPS]
	+ Non RPS Qualifying Guaranteed Dispatch Amount after RPS Policy[Electricity Source,\
		Electricity Timeslice,Hour,RPS],
	
	RPS Qualifying Guaranteed Dispatch Amount[Electricity Source,Electricity Timeslice,Hour\
		,CES]
	+ Non RPS Qualifying Guaranteed Dispatch Amount after RPS Policy[Electricity Source,\
		Electricity Timeslice,Hour,CES]
	)
	~	MW*hour
	~		|

Guaranteed Dispatch Percentage for Elec Portfolio Std Qualifying Resources[Electricity Source\
		,RPS]=
	RQSD RPS Qualifying Source Definitions[Electricity Source]
	* Guaranteed Dispatch Percentages for Policy Case[Electricity Source] ~~|
Guaranteed Dispatch Percentage for Elec Portfolio Std Qualifying Resources[Electricity Source\
		,CES]=
	RQSD CES Qualifying Source Definitions[Electricity Source]
	* Guaranteed Dispatch Percentages for Policy Case[Electricity Source]
	~	Dmnl
	~		|

Guaranteed Dispatch Percentages for Policy Case[Electricity Source]=
	IF THEN ELSE(
	  Boolean Use Non BAU Guaranteed Dispatch Settings This Year > 0,
	
	  GDPbES Guaranteed Dispatch Percentage by Electricity Source[Electricity Source],
	
	  BGDPbES BAU Guaranteed Dispatch Percentage by Electricity Source[Electricity Source\
		]
	)
	~	Dmnl
	~		|

GWP by Pollutant[Pollutant]=
	IF THEN ELSE(
	  BUTYGV Boolean Use Twenty Year GWP Values > 0,
	
	  GbPbT GWP by Pollutant by Timeframe[Pollutant,twenty years], 
	
	  GbPbT GWP by Pollutant by Timeframe[Pollutant,one hundred years]
	)
	~	g CO2e/g pollutant
	~		|

GWP Timeframe:
	twenty years,
	one hundred years
	~	
	~		|

HDL Heat Distribution Losses:=
	GET DIRECT DATA(
	   'InputData/dist-heat/HDL/HDL.csv',
	   ',',
	   '1',
	   'B2'
	)
	~	Dmnl
	~		|

Health Outcome:
	Premature mortality,
	Infant mortality,
	Asthma symptoms,
	Asthma incidence,
	Hay fever rhinitis incidence,
	Respiratory emergency room visits,
	Respiratory hospital admissions,
	Non fatal heart attacks,
	Minor restricted activity days,
	Work loss days,
	Lung cancer incidence,
	Cardiovascular hospital admissions,
	Alzheimers disease hospital admissions,
	Parkinsons disease hospital admissions,
	Stroke incidence,
	Out of hospital cardiac arrest incidence,
	Cardiac emergency room visits,
	School loss days
	~	incidents
	~		|

Heat Rate by Electricity Fuel for Plants Built This Year[Electricity Source]=
	BAU Heat Rate by Electricity Fuel for Plants Built This Year[Electricity Source]
	* (1 - RnD Electricity Fuel Use Perc Reduction This Year[Electricity Source])
	~	BTU/(MW*hour)
	~		|

Heat Shifted to CHP Facilities=
	MAX(
	  SUM(BAU District Heat Provided by Dedicated Facilities[Industrial Fuel!])
	  - SUM(District Heat Provided by Dedicated Facilities[Industrial Fuel!])
	  + Change in Total Heat Use,
	
	  0
	)
	~	BTU
	~		|

Heat Shifted to CHP Facilities This Year=
	MAX(
	  Heat Shifted to CHP Facilities
	  - Last Year Heat Shifted to CHP Facilities,
	
	  0
	)
	~	BTU
	~		|

