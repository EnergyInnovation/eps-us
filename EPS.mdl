Percent Change in Agriculture Industry Production due to Nonanimal Product Shifting=
	-Percent Animal Products Shifted to Nonanimal Products This Year
	* BSoAIGtAP BAU Share of Agriculture Industry Going to Animal Products
	
	+ Percent Animal Products Shifted to Nonanimal Products This Year
	  * BSoAIGtAP BAU Share of Agriculture Industry Going to Animal Products
	  / RoNEPtAPPpULA Ratio of Nutritionally Equivalent Plant to Animal Products Produced per Unit Land Area
	~	Dmnl
	~		|

Percent Change in BAU Energy Production and Imports vs Initial Year by ISIC Code[ISIC Code\
		]=
	MAX(
	  -1,
	
	  ZIDZ(
	    SUM(Change in BAU Energy Production vs Initial Year[All Fuels!]*Share of Fuel Production by Fuel within ISIC Code\
		[All Fuels!,ISIC Code])
	  + SUM(Change in BAU Energy Imports vs Initial Year[All Fuels!]*Share of Fuel Production by Fuel within ISIC Code\
		[All Fuels!,ISIC Code]),
	
	    SUM(Initial BAU Energy Production including Energy Carriers[All Fuels!]*Share of Fuel Production by Fuel within ISIC Code\
		[All Fuels!,ISIC Code])
	  + SUM( Initial BAU Energy Imports including Electricity[All Fuels!]*Share of Fuel Production by Fuel within ISIC Code\
		[All Fuels!,ISIC Code])
	  )
	)
	~	Dmnl
	~		|

Percent Change in Child and Adult Deaths=
	ZIDZ(
	
	  SUM(
	    Child and Adult Deaths by Demographic Trait[sex!]
	    - BDbDT BAU Child and Adult Deaths by Demographic Trait[sex!]
	  ),
	
	  SUM(BDbDT BAU Child and Adult Deaths by Demographic Trait[sex!])
	)
	~	Dmnl
	~		|

Percent Change in Child and Adult Deaths by Demographic Trait[demographic trait excluding age bracket\
		]=
	ZIDZ(
	
	  Child and Adult Deaths by Demographic Trait[demographic trait excluding age bracket\
		]
	  - BDbDT BAU Child and Adult Deaths by Demographic Trait[demographic trait excluding age bracket\
		],
	
	  BDbDT BAU Child and Adult Deaths by Demographic Trait[demographic trait excluding age bracket\
		]
	)
	~	Dmnl
	~		|

Percent Change in Components Energy Use[Building Type,Building Component]=
	XIDZ(
	  SUM(New Components Potential Energy Use after Fuel Shifting[Building Type,Building Fuel\
		!,Building Component]),
	
	  SUM(Hypothetical BAU New Components Energy Use after Fuel Shifting[Building Type,Building Fuel\
		!,Building Component]),
	
	  1
	)
	- 1
	~	Dmnl
	~	In this variable, we are looking to capture the improvement in efficiency \
		of components deployed this year.  Our baseline energy use is in \
		Hypothetical BAU New Components Energy Use after Electrification, so we \
		don't mistake fuel switching for efficiency improvements.  Our \
		non-baseline energy use comes before envelope effects are applied to the \
		heating and cooling components, because envelope is a separate component \
		with its own pricing that corresponds to its own efficiency improvements.
	|

Percent Change in Contribution to Gross Domestic Product by ISIC Code[ISIC Code]=
	ZIDZ(
	  Gross Domestic Product by ISIC Code[ISIC Code]
	  - BAU Gross Domestic Product by ISIC Code[ISIC Code],
	
	  BAU Gross Domestic Product by ISIC Code[ISIC Code]
	)
	~	Dmnl
	~		~	:SUPPLEMENTARY 
	|

Percent Change in Contribution to Gross Domestic Product Excluding Most Direct Impacts by ISIC Code\
		[ISIC Code]=
	ZIDZ(
	  Gross Domestic Product Excluding Most Direct Impacts by ISIC Code[ISIC Code]
	  - BAU Gross Domestic Product by ISIC Code[ISIC Code],
	
	  BAU Gross Domestic Product by ISIC Code[ISIC Code]
	)
	~	Dmnl
	~		|

Percent Change in Domestic Fuel Industry Production[Industry Category] :EXCEPT: [energy industries within industry category\
		]=
	0 ~~|
Percent Change in Domestic Fuel Industry Production[coal mining 05]=
	ZIDZ(
	  SUM(
	    Percent Change in Domestic Fuel Production by Fuel[coal mining industry fuel within all fuels\
		!]
	    * BAU Fuel Production Imports and Exports[coal mining industry fuel within all fuels\
		!,production]
	  ),
	
	  SUM(BAU Fuel Production Imports and Exports[coal mining industry fuel within all fuels\
		!,production])
	) ~~|
Percent Change in Domestic Fuel Industry Production[oil and gas extraction 06]=
	ZIDZ(
	  Percent Change in Domestic Fuel Production by Fuel[natural gas]
	    * BAU Fuel Production Imports and Exports[natural gas,production]
	  + Percent Change in Domestic Fuel Production by Fuel[crude oil]
	    * BAU Fuel Production Imports and Exports[crude oil,production],
	
	  BAU Fuel Production Imports and Exports[natural gas,production]
	  + BAU Fuel Production Imports and Exports[crude oil,production]
	) ~~|
Percent Change in Domestic Fuel Industry Production[refined petroleum and coke 19]=
	ZIDZ(
	  SUM(
	    Percent Change in Domestic Fuel Production by Fuel[secondary petroleum product within all fuels\
		!]
	    * BAU Fuel Production Imports and Exports[secondary petroleum product within all fuels\
		!,production]
	  ),
	
	  SUM(BAU Fuel Production Imports and Exports[secondary petroleum product within all fuels\
		!,production])
	) ~~|
Percent Change in Domestic Fuel Industry Production[energy pipelines and gas processing 352T353\
		]=
	ZIDZ(
	  Percent Change in Domestic Fuel Production by Fuel[natural gas]
	    * BAU Fuel Production Imports and Exports[natural gas,production]
	  + Percent Change in Domestic Fuel Production by Fuel[heat]
	    * BAU Fuel Production Imports and Exports[heat,production],
	
	  BAU Fuel Production Imports and Exports[natural gas,production]
	  + BAU Fuel Production Imports and Exports[heat,production]
	)
	~	Dmnl
	~	We do not include hydrogen in the calculation for "energy pipelines and \
		gas processing 352T353" due to the likelihood that hydrogen will largely \
		be generated on-site or in industrial parks for high-volume users, rather \
		than having a national distribution system with lots of pipelines, so the \
		energy pipelines and gas processing industry won't grow much in response \
		to increases in hydrogen demand.
	|

Percent Change in Domestic Fuel Production by Fuel[All Fuels] :EXCEPT:  [electricity]\
		=
	MAX(
	  -1,
	
	  ZIDZ(
	    Change in Fuel Production[All Fuels],
	    BAU Fuel Production Imports and Exports[All Fuels,production]
	  )
	) ~~|
