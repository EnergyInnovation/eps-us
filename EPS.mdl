Off Grid Capacity for Green Hydrogen Demand[Electricity Source]=
	New Off Grid Capacity for Green Hydrogen Demand[Electricity Source]
	+ Last Year Cumulative Off Grid Capacity for Green Hydrogen Demand[Electricity Source\
		]
	~	MW
	~		|

Off Grid Electricity Demand for Green Hydrogen by Power Plant Type[Electricity Source\
		]=
	Off Grid Electricity Demand for Green Hydrogen That is New This Year by Power Plant Type With Quantization\
		[Electricity Source]
	+ Last Year Cumulative Off Grid Electricity Demand for Green Hydrogen by Power Plant Type\
		[Electricity Source]
	~	MW*hr
	~		|

Off Grid Electricity Demand for Green Hydrogen That is New This Year by Power Plant Type\
		[Electricity Source]=
	Share of Off Grid Electricity Demand That is New This Year Met by Power Plant Type[Electricity Source\
		]
	
	* Hydrogen Sector Off Grid Electricity Demand for Green Hydrogen That is New This Year
	~	MW*hr
	~		|

Off Grid Electricity Demand for Green Hydrogen That is New This Year by Power Plant Type With Quantization\
		[Electricity Source]=
	New Off Grid Capacity for Green Hydrogen Demand[Electricity Source]
	* Expected Capacity Factor x Hours per Year for Plants Built This Year Without Hypothetical Calculations\
		[Electricity Source]
	~	MW*hr
	~		|

One BTU=
	1
	~	BTU
	~		|

One Day=
	1
	~	day
	~		|

One Dollar=
	1
	~	$
	~		|

One Hour=
	1
	~	hour
	~		|

One Metric Ton CO2e=
	1
	~	metric tons CO2e
	~		|

One Vehicle=
	1
	~	vehicle
	~		|

One Year=
	1
	~	years
	~	This variable exists to avoid Vensim unit check errors when there is no \
		actual problem with the model.
	|

One Year Average Net Energy Market Revenue by Plant Type Excluding Subsidies for Hybrid Power Plants\
		[Hybrid Electricity Source]=
	SUM(Expected Capacity Factors by Hour for Hybrid Plants Built This Year[Hybrid Electricity Source\
		,Electricity Timeslice
	!,Hour!]
	*Last Year Five Year Average Marginal Dispatch Cost by Hour[Electricity Timeslice!,Hour\
		!]
	*SHELF Days per Electricity Timeslice[Electricity Timeslice!]
	* One Hour)
	-Last Year Five Year Average Annual Expected Dispatch Costs by Power Plant Type[Hybrid Electricity Source\
		]
	~	$/MW
	~		|

One Year Average Wholesale Energy Market Costs=
	SUM(
	 (Total Electricity Dispatched by Hour[Electricity Timeslice!,Hour!])
	 *Marginal Dispatch Cost by Hour[Electricity Timeslice!,Hour!]
	 *SHELF Days per Electricity Timeslice[Electricity Timeslice!])
	~	$
	~		|

Ongoing Capital Costs for Green Hydrogen Electricity[Electricity Source]=
	Off Grid Capacity for Green Hydrogen Demand[Electricity Source]
	* Weighted Average Annual Capital Costs per Unit Capacity[Electricity Source]
	~	$
	~		|

Optimization Pass:
	(pass1-pass20)
	~	
	~		|

Optimized CES Credit Price=
	MAX(
	  0,
	
	  SUM(CES Credit Price by Optimization Pass[last pass!])
	)
	~	$/(MW*hr)
	~	Although "last pass" is intended to contain a single element, we must sum \
		across it becuase it is technically a subrange.
	|

Optimized RPS Credit Price=
	MAX(
	  0,
	
	  SUM(RPS Credit Price by Optimization Pass[last pass!])
	)
	~	$/(MW*hr)
	~	Although "last pass" is intended to contain a single element, we must sum \
		across it becuase it is technically a subrange.
	|

Other Changes in Industry Sector Tax and Tax Rebate Revenues[Cash Flow Entity] :EXCEPT:\
		  [government],[nonenergy industries
],[coal suppliers],[natural gas and petroleum suppliers]=
	0 ~~|
Other Changes in Industry Sector Tax and Tax Rebate Revenues[government]=
	SUM(Change in Carbon Tax on Process Emissions by Industry[Industry Category!])
	+ SUM(Change in Taxes Paid on Industry Fuels[Industry Category!,Industrial Fuel!]) ~~|
Other Changes in Industry Sector Tax and Tax Rebate Revenues[nonenergy industries]=
	SUM(Change in Carbon Tax Rebates[Industry Category!]) ~~|
Other Changes in Industry Sector Tax and Tax Rebate Revenues[coal suppliers]=
	Change in Carbon Tax Rebates[coal mining 05] ~~|
Other Changes in Industry Sector Tax and Tax Rebate Revenues[natural gas and petroleum suppliers\
		]=
	Change in Carbon Tax Rebates[oil and gas extraction 06]
	+ Change in Carbon Tax Rebates[refined petroleum and coke 19]
	+ Change in Carbon Tax Rebates[energy pipelines and gas processing 352T353]
	~	$
	~		|

other energy supplier fuel within all fuels:
	nuclear,
	heat,
	municipal solid waste,
	hydrogen
	~	
	~		|

Other Hydrogen Demand=
	Total Hydrogen Demand
	- Green Hydrogen Demand
	- Low Carbon Hydrogen Demand
	~	BTU
	~		|

Other Hydrogen Production by Pathway[Hydrogen Production Pathway]=
	ZIDZ(
	  New Other Hydrogen Production Capacity This Year[Hydrogen Production Pathway]
	  + Surviving Capacity Used for Other Hydrogen Production[Hydrogen Production Pathway\
		],
	
	  SUM(
	    New Other Hydrogen Production Capacity This Year[Hydrogen Production Pathway!]
	    + Surviving Capacity Used for Other Hydrogen Production[Hydrogen Production Pathway\
		!]
	  )
	)
	~	Dmnl
	~		|

Other Hydrogen Production Shares with Fallback[Hydrogen Production Pathway]=
	IF THEN ELSE(
	  SUM(Other Hydrogen Production by Pathway[Hydrogen Production Pathway!]) = 0,
	
	  IF THEN ELSE(
	    SUM(New Other Hydrogen Production Capacity Shares This Year[Hydrogen Production Pathway\
		!]) = 0,
	    Start Year Other Hydrogen Production Shares by Pathway[Hydrogen Production Pathway\
		],
	    New Other Hydrogen Production Capacity Shares This Year[Hydrogen Production Pathway\
		]
	  ),
	
	  ZIDZ( 
	    Other Hydrogen Production by Pathway[Hydrogen Production Pathway],
	    SUM(Other Hydrogen Production by Pathway[Hydrogen Production Pathway!])
	  )
	)
	~	Dmnl
	~		|

