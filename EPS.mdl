Preexisting Industrial Equipment Fuel Type Shares in Electricity Equivalent Adjusted by Early Retirement Policy\
		[Industry Category
,Industrial Process,Industrial Fuel]=
	IF THEN ELSE(
	  BIISRP Boolean Use Individual Industrial Site Retirement Profile[Industry Category\
		] = 0,
	
	  Start Year BAU Fuel Type Shares in Electricity Equivalent[Industry Category,Industrial Process\
		,Industrial Fuel]
	  *
	  IF THEN ELSE(
	    IFTQfEERP Industrial Fuel Types Qualifying for Early Equipment Retirement Policy\
		[Industrial Fuel] = 1,
	    ZIDZ(
	      1 - 
	      MAX(Minimum Share of Start Year Industrial Equipment Retired To Date[Industry Category\
		,Industrial Process],
	        IESD Fraction of Preexisting Equipment Retired Naturally by Age[Industrial Process\
		]),
	      1 - Fraction of All Preexisting Industrial Equipment Retired[Industry Category\
		,Industrial Process]
	    ),
	    ZIDZ(
	      1 - IESD Fraction of Preexisting Equipment Retired Naturally by Age[Industrial Process\
		],
	      1 - Fraction of All Preexisting Industrial Equipment Retired[Industry Category\
		,Industrial Process]
	    )
	  ),
	
	  Start Year BAU Fuel Type Shares in Electricity Equivalent[Industry Category,Industrial Process\
		,Industrial Fuel]
	  *
	  IF THEN ELSE(
	    IFTQfEERP Industrial Fuel Types Qualifying for Early Equipment Retirement Policy\
		[Industrial Fuel] = 1,
	    ZIDZ(
	      1 - 
	      MAX(Minimum Share of Start Year Industrial Equipment Retired To Date[Industry Category\
		,Industrial Process],
	        BIISRP BAU Individual Industrial Site Retirement Profile[Industry Category])\
		,
	      1 - Fraction of All Preexisting Industrial Equipment Retired[Industry Category\
		,Industrial Process]
	    ),
	    ZIDZ(
	      1 - BIISRP BAU Individual Industrial Site Retirement Profile[Industry Category\
		],
	      1 - Fraction of All Preexisting Industrial Equipment Retired[Industry Category\
		,Industrial Process]
	    )
	  )
	)
	~	Dmnl
	~		|

Present Value of Clean Industrial Heat Subsidy[Industry Category,Industrial Fuel,industrial heating process\
		]=
	SUM(
	  ZIDZ(
	    Clean Industrial Heat Subsidy Rate by Fuel Type in Future Years[Industrial Fuel,\
		industrial heating process,Future Year!],
	    (1 + BCoISC Weighted Average Cost of Capital by Industry[Industry Category])
	    ^ ((Numerical Future Year Definitions[Future Year!] - Time) / One Year)
	  )    
	)
	~	$/BTU
	~		|

Present Value of Industrial Equipment Annualized Capital Costs[Industry Category,Industrial Fuel\
		,Industrial Process]=
	SUM(
	  ZIDZ(
	    Industrial Equipment Annualized Capital Costs per Unit Energy in Future Years[Industry Category\
		,Industrial Fuel,Industrial Process
	,Future Year!],
	    (1 + BCoISC Weighted Average Cost of Capital by Industry[Industry Category])
	    ^ ((Numerical Future Year Definitions[Future Year!] - Time) / One Year)
	  )    
	)
	~	$/BTU
	~		|

Present Value of Industrial Equipment Costs per Unit Energy[Industry Category,Industrial Fuel\
		,Industrial Process]=
	Present Value of Industrial Equipment Annualized Capital Costs[Industry Category,Industrial Fuel\
		,Industrial Process]
	+ Present Value of Industrial Equipment Costs per Unit Energy including Clean Heat Subsidy\
		[Industry Category,Industrial Fuel,Industrial Process]
	~	$/BTU
	~		|

Present Value of Industrial Equipment Costs per Unit Energy including Clean Heat Subsidy\
		[Industry Category,Industrial Fuel,Industrial Process] :EXCEPT:                 [Industry Category\
		,Industrial Fuel,industrial heating process]=
	(Present Value of Pretax Industrial Fuel Price in Future Years[Industry Category,Industrial Fuel\
		,Industrial Process]
	 + Present Value of Industrial Fuel Tax or Subsidy Rate by Fuel in Future Years[Industry Category\
		,Industrial Fuel,Industrial Process])
	
	* (1 - SoFCTiBoSFbI Share of Fuel Consumption That is Byproduct or Secondary Fuels by Industry\
		[Industry Category,Industrial Fuel
	])
	
	+ Present Value of Industrial Fuel Carbon Tax per Unit Energy in Future Years[Industry Category\
		,Industrial Fuel,Industrial Process] ~~|
Present Value of Industrial Equipment Costs per Unit Energy including Clean Heat Subsidy\
		[Industry Category,Industrial Fuel,industrial heating process]=
	(Present Value of Pretax Industrial Fuel Price in Future Years[Industry Category,Industrial Fuel\
		,industrial heating process]
	 + Present Value of Industrial Fuel Tax or Subsidy Rate by Fuel in Future Years[Industry Category\
		,Industrial Fuel,industrial heating process])
	
	* (1 - SoFCTiBoSFbI Share of Fuel Consumption That is Byproduct or Secondary Fuels by Industry\
		[Industry Category,Industrial Fuel
	])
	
	+ Present Value of Industrial Fuel Carbon Tax per Unit Energy in Future Years[Industry Category\
		,Industrial Fuel,industrial heating process]
	
	- Present Value of Clean Industrial Heat Subsidy[Industry Category,Industrial Fuel,industrial heating process
	]
	~	$/BTU
	~		|

Present Value of Industrial Fuel Carbon Tax per Unit Energy in Future Years[Industry Category\
		,Industrial Fuel,Industrial Process]=
	SUM(
	  ZIDZ(
	    Industrial Fuel Carbon Tax Amount per Unit Energy in Future Years[Industry Category\
		,Industrial Fuel,Future Year!],
	    (1 + BCoISC Weighted Average Cost of Capital by Industry[Industry Category])
	    ^ ((Numerical Future Year Definitions[Future Year!] - Time) / One Year)
	
	  * IF THEN ELSE(Numerical Future Year Definitions[Future Year!] - Time >= IESD Average Age at Which Equipment Retires\
		[Industrial Process],
	      0,
	      IF THEN ELSE(Numerical Future Year Definitions[Future Year!] < Time,
	        0,
	        1
	      )
	    )
	  )    
	)
	~	$/BTU
	~		|

Present Value of Industrial Fuel Tax or Subsidy Rate by Fuel in Future Years[Industry Category\
		,Industrial Fuel,Industrial Process]=
	SUM(
	  ZIDZ(
	    Fuel Tax or Subsidy Rate by Fuel in Future Years[industrial fuel within all fuels\
		,industry sector,Future Year!],
	    (1 + BCoISC Weighted Average Cost of Capital by Industry[Industry Category])
	    ^ ((Numerical Future Year Definitions[Future Year!] - Time) / One Year)
	
	  * IF THEN ELSE(Numerical Future Year Definitions[Future Year!] - Time >= IESD Average Age at Which Equipment Retires\
		[Industrial Process],
	      0,
	      IF THEN ELSE(Numerical Future Year Definitions[Future Year!] < Time,
	        0,
	        1
	      )
	    )
	  )    
	)
	~	$/BTU
	~		|

Present Value of Pretax Industrial Fuel Price in Future Years[Industry Category,Industrial Fuel\
		,Industrial Process] :EXCEPT:    [Industry Category,green hydrogen if,Industrial Process\
		],[Industry Category,low carbon hydrogen if,Industrial Process],[Industry Category,\
		hydrogen if,Industrial Process]=
	SUM(
	  ZIDZ(
	    Pretax Fuel Price by Sector in Future Years after Fuel Price Deregulation[industrial fuel within all fuels\
		,industry sector
	,Future Year!],
	    (1 + BCoISC Weighted Average Cost of Capital by Industry[Industry Category])
	    ^ ((Numerical Future Year Definitions[Future Year!] - Time) / One Year)
	
	  * IF THEN ELSE(Numerical Future Year Definitions[Future Year!] - Time >= IESD Average Age at Which Equipment Retires\
		[
	Industrial Process],
	      0,
	      IF THEN ELSE(Numerical Future Year Definitions[Future Year!] < Time,
	        0,
	        1
	      )
	    )
	  )    
	) ~~|
Present Value of Pretax Industrial Fuel Price in Future Years[Industry Category,green hydrogen if\
		,Industrial Process]=
	SUM(
	  ZIDZ(
	    Smoothed Green Hydrogen Cost,
	    (1 + BCoISC Weighted Average Cost of Capital by Industry[Industry Category])
	    ^ ((Numerical Future Year Definitions[Future Year!] - Time) / One Year)
	
	  * IF THEN ELSE(Numerical Future Year Definitions[Future Year!] - Time >= IESD Average Age at Which Equipment Retires\
		[
	Industrial Process],
	      0,
	      IF THEN ELSE(Numerical Future Year Definitions[Future Year!] < Time,
	        0,
	        1
	      )
	    )
	  )    
	) ~~|
Present Value of Pretax Industrial Fuel Price in Future Years[Industry Category,low carbon hydrogen if\
		,Industrial Process]=
	SUM(
	  ZIDZ(
	    Smoothed Low Carbon Hydrogen Cost,
	    (1 + BCoISC Weighted Average Cost of Capital by Industry[Industry Category])
	    ^ ((Numerical Future Year Definitions[Future Year!] - Time) / One Year)
	
	  * IF THEN ELSE(Numerical Future Year Definitions[Future Year!] - Time >= IESD Average Age at Which Equipment Retires\
		[
	Industrial Process],
	      0,
	      IF THEN ELSE(Numerical Future Year Definitions[Future Year!] < Time,
	        0,
	        1
	      )
	    )
	  )    
	) ~~|
Present Value of Pretax Industrial Fuel Price in Future Years[Industry Category,hydrogen if\
		,Industrial Process]=
	SUM(
	  ZIDZ(
	    Smoothed Other Hydrogen Cost,
	    (1 + BCoISC Weighted Average Cost of Capital by Industry[Industry Category])
	    ^ ((Numerical Future Year Definitions[Future Year!] - Time) / One Year)
	
	  * IF THEN ELSE(Numerical Future Year Definitions[Future Year!] - Time >= IESD Average Age at Which Equipment Retires\
		[
	Industrial Process],
	      0,
	      IF THEN ELSE(Numerical Future Year Definitions[Future Year!] < Time,
	        0,
	        1
	      )
	    )
	  )    
	)
	~	$/BTU
	~		|

Pretax Fuel Cost per Unit Energy by Sector after Fuel Price Deregulation[All Fuels,Sectors\
		]=
	Pretax Fuel Cost per Unit Energy by Sector After Reduction of BAU Subsidies[All Fuels\
		,Sectors]
	* (1 - Fuel Price Deregulation This Year[All Fuels])
	+
	IMFPbFT International Market Fuel Price by Fuel Type[All Fuels]
	* Fuel Price Deregulation This Year[All Fuels]
	~	$/BTU
	~		|

Pretax Fuel Cost per Unit Energy by Sector After Modeled Price Adjustments[All Fuels,\
		Sectors]=
	IF THEN ELSE(
	  BAU Pretax Fuel Cost per Unit Energy by Sector with Sensitivity Analysis Adjustment\
		[All Fuels,Sectors] > 0,
	
	  MAX(
	    0,
	
	    BAU Pretax Fuel Cost per Unit Energy by Sector with Sensitivity Analysis Adjustment\
		[All Fuels,Sectors]
	    + Change in Baseline Energy Costs[All Fuels]
	  ),
	
	  0
	)
	~	$/BTU
	~	A price of zero typically means a fuel isn't used in a given sector, so we \
		only add the value of the change in baseline fuel cost to sectors where \
		the fuel has a non-zero price, for clarity of output in the model.  (The \
		price of a fuel that is not used makes no difference to the numerical \
		results.)
	|

Pretax Fuel Cost per Unit Energy by Sector After Reduction of BAU Subsidies[All Fuels\
		,Sectors]=
	IF THEN ELSE(
	  Pretax Fuel Cost per Unit Energy by Sector After Modeled Price Adjustments[All Fuels\
		,Sectors] > 0,
	
	  Pretax Fuel Cost per Unit Energy by Sector After Modeled Price Adjustments[All Fuels\
		,Sectors]
	  + Added Thermal Fuel Cost per Unit Energy from Ending Subsidies[All Fuels,Sectors]\
		,
	
	  0
	)
	~	$/BTU
	~	A price of zero typically means a fuel isn't used in a given sector, so we \
		only add the value of the removed subsidies to sectors where the fuel has \
		a non-zero price, for clarity of output in the model.  (The price of a \
		fuel that is not used makes no difference to the numerical results.)
	|

Pretax Fuel Price by Sector in Future Years after Fuel Price Deregulation[All Fuels,Sectors\
		,Future Year] :EXCEPT:       [
electricity
,Sectors,Future Year]=
	IF THEN ELSE(
	  Dimensionless Time < FYIbFP First Year Impacted by Future Policies,
	  Pretax Fuel Price by Sector in Future Years After Reduction of BAU Subsidies[All Fuels\
		,Sectors,Future Year], 
	  
	  Pretax Fuel Price by Sector in Future Years After Reduction of BAU Subsidies[All Fuels\
		,Sectors,Future Year]
	  * (1 - Fuel Price Deregulation This Year[All Fuels])
	  +
	  IMFPbFT International Market Fuel Price by Fuel Type[All Fuels]
	  * Fuel Price Deregulation This Year[All Fuels]
	) ~~|
Pretax Fuel Price by Sector in Future Years after Fuel Price Deregulation[electricity\
		,Sectors,Future Year]=
	Average Five Year Prior Pretax Electricity Price by Sector[Sectors]
	~	$/BTU
	~		|

Pretax Fuel Price by Sector in Future Years After Modeled Price Adjustments[All Fuels\
		,Sectors,Future Year]=
	IF THEN ELSE(
	  Dimensionless Time < FYIbFP First Year Impacted by Future Policies,
	  BFPAT BAU Pretax Fuel Price by Sector[All Fuels,Sectors,Future Year],
	
	  IF THEN ELSE(
	    BFPAT BAU Pretax Fuel Price by Sector[All Fuels,Sectors,Future Year] > 0,
	 
	    MAX(
	      0,
	
	      BFPAT BAU Pretax Fuel Price by Sector[All Fuels,Sectors,Future Year]
	      + Change in Baseline Energy Costs[All Fuels]
	    ),
	
	    0
	  )
	)
	~	$/BTU
	~		|

Pretax Fuel Price by Sector in Future Years After Reduction of BAU Subsidies[All Fuels\
		,Sectors,Future Year]=
	IF THEN ELSE(
	  Dimensionless Time < FYIbFP First Year Impacted by Future Policies,
	  Pretax Fuel Price by Sector in Future Years After Modeled Price Adjustments[All Fuels\
		,Sectors,Future Year],
	
	  IF THEN ELSE(
	    Pretax Fuel Price by Sector in Future Years After Modeled Price Adjustments[All Fuels\
		,Sectors,Future Year] > 0,
	
	    Pretax Fuel Price by Sector in Future Years After Modeled Price Adjustments[All Fuels\
		,Sectors,Future Year]
	    + Added Thermal Fuel Cost per Unit Energy from Ending Subsidies[All Fuels,Sectors\
		],
	  
	    0
	  )
	)
	~	$/BTU
	~		|

Price Increase for New Indst Eqpt Due to Eff Standards[Industry Category,Industrial Fuel\
		,Industrial Process]=
	- Improvement in New Industrial Eqpt Energy Intensity vs BAU[Industry Category,Industrial Fuel\
		,Industrial Process]
	* EoIEPwEEI Elasticity of Industrial Eqpt Price wrt Energy Eff Improvement[Industrial Process\
		,Industrial Fuel]
	~	Dmnl
	~		|

