Output Industry Sector Electricity Use=
	(
	  SUM(Industrial Fuel Use[electricity if,Industry Category!])
	  - Industrial Fuel Use[electricity if,agriculture and forestry 01T03]
	  - Industrial Fuel Use[electricity if,water and waste 36T39]
	)
	* MWh per BTU
	/ MWh per TWh
	~	TW*hr
	~		~	:SUPPLEMENTARY 
	|

Output Industry Sector Energy Related CO2 Emissions by Industry[Industry Category]=
	SUM(Industrial Sector Energy Related Emissions after CCS[Industrial Fuel!,Industry Category\
		,CO2])
	  / MOU Grams per Large Mass Output Unit Pollutant
	~	mass output unit
	~		~	:SUPPLEMENTARY 
	|

Output Industry Sector Energy Related CO2e Emissions by Industry[Industry Category]=
	Output Industry Sector CO2e Emissions by Industry[Industry Category]
	- Output Process Emissions in CO2e by Industry[Industry Category]
	~	mass output unit
	~		|

Output Industry Sector Energy Related CO2e Emissions by Pollutant[Pollutant]=
	Output Industry Sector CO2e Emissions by Pollutant[Pollutant]
	- Output Process Emissions in CO2e by Pollutant[Pollutant]
	~	mass output unit
	~		~	:SUPPLEMENTARY 
	|

Output Industry Sector Energy Related CO2e Emissions Excluding Ag and Waste=
	SUM(Output Industry Sector Energy Related CO2e Emissions by Industry[strict industries within industry category\
		!])
	~	mass output unit
	~		~	:SUPPLEMENTARY 
	|

Output Industry Sector Excluding Ag and Waste CO2e Emissions=
	(SUM(Industry Sector CO2e Emissions[Industry Category!,Pollutant!])
	  - SUM(Agriculture CO2e Emissions[Pollutant!])
	  - SUM(Waste Management CO2e Emissions[Pollutant!])
	)
	/ MOU Grams per Large Mass Output Unit CO2e
	~	mass output unit
	~		~	:SUPPLEMENTARY 
	|

Output Industry Sector Excluding Ag and Waste Pollutant Emissions in KMT[Pollutant]=
	Industry Sector Excluding Ag and Waste Pollutant Emissions[Pollutant]
	/ MOU Grams per Small Mass Output Pollutant
	~	mass output unit
	~		~	:SUPPLEMENTARY 
	|

Output Industry Sector Excluding Ag and Waste Pollutant Emissions in MMT[Pollutant]=
	Industry Sector Excluding Ag and Waste Pollutant Emissions[Pollutant]
	/ MOU Grams per Large Mass Output Unit Pollutant
	~	mass output unit
	~		~	:SUPPLEMENTARY 
	|

Output Industry Sector Process Emissions in CO2e Excluding Ag and Waste=
	SUM(Output Process Emissions in CO2e by Industry[strict industries within industry category\
		!])
	~	mass output unit
	~		~	:SUPPLEMENTARY 
	|

Output Liquid Biofuels Export Revenue=
	(Energy Export Revenue including Electricity[biofuel gasoline]
	  + Energy Export Revenue including Electricity[biofuel diesel])
	/ OCCF Dollars per Large Output Currency Unit
	~	output currency units
	~		~	:SUPPLEMENTARY 
	|

Output Liquid Biofuels Exports=
	(Energy Exports including Electricity[biofuel gasoline]
	  + Energy Exports including Electricity[biofuel diesel])
	/ BCF BTU per Energy Import Export Output Unit
	~	energy output unit
	~		~	:SUPPLEMENTARY 
	|

Output Liquid Biofuels Final Energy Use=
	SUM(Total Final Energy Use by Sector[Sectors!,biofuel gasoline]
	  + Total Final Energy Use by Sector[Sectors!,biofuel diesel]
	)
	/ BpTPEU BTU per Large Primary Energy Unit
	~	output TPE unit
	~		~	:SUPPLEMENTARY 
	|

Output Liquid Biofuels Import Expenditures=
	(Energy Import Expenditures including Electricity[biofuel gasoline]
	  + Energy Import Expenditures including Electricity[biofuel diesel])
	/ OCCF Dollars per Large Output Currency Unit
	~	output currency units
	~		~	:SUPPLEMENTARY 
	|

Output Liquid Biofuels Imports=
	(Energy Imports including Electricity[biofuel gasoline]
	  + Energy Imports including Electricity[biofuel diesel])
	/ BCF BTU per Energy Import Export Output Unit
	~	energy output unit
	~		~	:SUPPLEMENTARY 
	|

Output Liquid Biofuels Production=
	(Energy Production including Energy Carriers[biofuel gasoline]
	  + Energy Production including Energy Carriers[biofuel diesel])
	/ BpTPEU BTU per Large Primary Energy Unit
	~	output TPE unit
	~		~	:SUPPLEMENTARY 
	|

Output Manufacturing and Construction Contribution to Perc Change in GDP=
	SUM(Percentage Points Contributed to Change in Gross Domestic Product by ISIC Code[Manufacturing and Construction ISIC Code\
		!])
	* 100
	~	Dmnl
	~		~	:SUPPLEMENTARY 
	|

Output Net Imports of Electricity=
	MAX(
	  0,
	
	  Net Imports of Electricity
	  / MWh per TWh
	)
	~	TW*hr
	~		~	:SUPPLEMENTARY 
	|

Output New Equipment Fuel Use Excluding Feedstocks by Fuel[Industrial Fuel]=
	SUM(New Industrial Equipment Fuel Use for Energy before CCS and Methane Capture[Industrial Fuel\
		,Industry Category!])
	/ BpTPEU BTU per Large Primary Energy Unit
	~	output TPE unit
	~		|

Output New Vehicles in Millions[Vehicle Type,Cargo Type,Vehicle Technology]=
	New Vehicles[Vehicle Type,Cargo Type,Vehicle Technology] * One Year
	/ Vehicles per Million Vehicles
	~	million vehicles
	~		~	:SUPPLEMENTARY 
	|

Output New Vehicles in Thousands[Vehicle Type,Cargo Type,Vehicle Technology]=
	New Vehicles[Vehicle Type,Cargo Type,Vehicle Technology] * One Year
	/ Vehicles per Thousand Vehicles
	~	thousand vehicles
	~		~	:SUPPLEMENTARY 
	|

Output Non Solar Distributed Capacity=
	(SUM(Distributed Electricity Source Capacity[Building Type!,Electricity Source!])
	   - SUM(Distributed Electricity Source Capacity[Building Type!,solar PV es]))
	/ MW per GW
	~	GW
	~		~	:SUPPLEMENTARY 
	|

Output Non Solar Distributed Output=
	(SUM(Annual Output from Distributed Electricity Capacity[Electricity Source!])-Annual Output from Distributed Electricity Capacity\
		[solar PV es])
	/ MWh per TWh
	~	TW*hr
	~		~	:SUPPLEMENTARY 
	|

Output Nonenergy Production[Industry Category] :EXCEPT: [energy industries within industry category\
		]=
	Output by ISIC Code by Year[Industry Category ISIC Code]
	/ OCCF Dollars per Large Output Currency Unit ~~|
Output Nonenergy Production[energy industries within industry category]=
	0
	~	output currency unit
	~		~	:SUPPLEMENTARY 
	|

Output Other Contribution to Perc Change in GDP=
	(SUM(Percentage Points Contributed to Change in Gross Domestic Product by ISIC Code[\
		ISIC Code!])
	  - SUM(Percentage Points Contributed to Change in Gross Domestic Product by ISIC Code\
		[Fossil and Energy Utility ISIC Code!])
	  - SUM(Percentage Points Contributed to Change in Gross Domestic Product by ISIC Code\
		[Manufacturing and Construction ISIC Code!])
	)
	* 100
	~	Dmnl
	~		~	:SUPPLEMENTARY 
	|

Output Other Industry Hydrogen Demand=
	(
	  SUM(Industrial Fuel Use[hydrogen if,Industry Category!]
	  + Industrial Fuel Use[green hydrogen if,Industry Category!]
	  + Industrial Fuel Use[low carbon hydrogen if,Industry Category!])
	
	)
	/ BpMMTH BTU per MMT Hydrogen
	
	- Output Cement Sector Hydrogen Demand
	- Output Chemicals Sector Hydrogen Demand
	- Output Refining Sector Hydrogen Demand
	- Output Steel Sector Hydrogen Demand
	~	MMT
	~		|

Output Passenger Dist Transported[Vehicle Type,Cargo Type]=
	SUM(Cargo Dist Transported by Vehicle Technology[Vehicle Type,Cargo Type,Vehicle Technology\
		!])
	/ CDCF Passenger Miles per Passenger Distance Output Unit
	~	passenger distance output unit
	~		~	:SUPPLEMENTARY 
	|

Output Peak Summer Day Commercial Building Electricity Demand by Hour and Component[Hour\
		,Building Component]=
	SUM(Output Commercial Building Electricity Demand by Hour and Component[peak summer day electricity timeslice\
		!,Hour,Building Component])
	/ ELMCOUNT(peak summer day electricity timeslice)
	~	TW*hr
	~		|

Output Peak Summer Day Data Center Electricity Demand by Hour[Hour]=
	SUM(Output Data Center Electricity Demand by Hour[peak summer day electricity timeslice\
		!,Hour])
	/ ELMCOUNT(peak summer day electricity timeslice)
	~	TW*hr
	~		|

Output Peak Summer Day District Heat Electricity Demand by Hour[Hour]=
	SUM(Output District Heat Electricity Demand by Hour[peak summer day electricity timeslice\
		!,Hour])
	/ ELMCOUNT(peak summer day electricity timeslice)
	~	TW*hr
	~		|

Output Peak Summer Day Geoengineering Electricity Demand by Hour[Hour]=
	SUM(Output Geoengineering Sector Electricity Demand by Hour[peak winter day electricity timeslice\
		!,Hour])
	/ ELMCOUNT(peak winter day electricity timeslice)
	~	TW*hr
	~		|

Output Peak Summer Day Hydrogen Sector Electricity Demand by Hour[Hour]=
	SUM(Output Hydrogen Sector Electricity Demand by Hour[peak summer day electricity timeslice\
		!,Hour])
	/ ELMCOUNT(peak summer day electricity timeslice)
	~	TW*hr
	~		|

Output Peak Summer Day Industrial Electricity Demand by Hour and Industry Category[Hour\
		,Industry Category]=
	SUM(Output Industrial Electricity Demand by Hour and Industry Category[peak summer day electricity timeslice\
		!,Hour,Industry Category])
	/ ELMCOUNT(peak summer day electricity timeslice)
	~	TW*hr
	~		|

Output Peak Summer Day Residential Building Electricity Demand by Hour and Component[\
		Hour,Building Component]=
	SUM(Output Residential Building Electricity Demand by Hour and Component[peak summer day electricity timeslice\
		!,Hour,Building Component])
	/ ELMCOUNT(peak summer day electricity timeslice)
	~	TW*hr
	~		|

Output Peak Summer Day Transportation Electricity Demand by Hour and Vehicle Type[Hour\
		,Vehicle Type]=
	SUM(Output Transportation Electricity Demand by Hour and Vehicle Type[peak summer day electricity timeslice\
		!,Hour,Vehicle Type])
	/ ELMCOUNT(peak summer day electricity timeslice)
	~	TW*hr
	~		|

Output Peak Winter Day Commercial Building Electricity Demand by Hour and Component[Hour\
		,Building Component]=
	SUM(Output Commercial Building Electricity Demand by Hour and Component[peak winter day electricity timeslice\
		!,Hour,Building Component])
	/ ELMCOUNT(peak winter day electricity timeslice)
	~	TW*hr
	~		|

Output Peak Winter Day Data Center Electricity Demand by Hour[Hour]=
	SUM(Output Data Center Electricity Demand by Hour[peak winter day electricity timeslice\
		!,Hour])
	/ ELMCOUNT(peak winter day electricity timeslice)
	~	TW*hr
	~		|

Output Peak Winter Day District Heat Electricity Demand by Hour[Hour]=
	SUM(Output District Heat Electricity Demand by Hour[peak winter day electricity timeslice\
		!,Hour])
	/ ELMCOUNT(peak winter day electricity timeslice)
	~	TW*hr
	~		|

Output Peak Winter Day Geoengineering Electricity Demand by Hour[Hour]=
	SUM(Output Geoengineering Sector Electricity Demand by Hour[peak winter day electricity timeslice\
		!,Hour])
	/ ELMCOUNT(peak winter day electricity timeslice)
	~	TW*hr
	~		|

Output Peak Winter Day Hydrogen Sector Electricity Demand by Hour[Hour]=
	SUM(Output Hydrogen Sector Electricity Demand by Hour[peak winter day electricity timeslice\
		!,Hour])
	/ ELMCOUNT(peak winter day electricity timeslice)
	~	TW*hr
	~		|

Output Peak Winter Day Industrial Electricity Demand by Hour and Industry Category[Hour\
		,Industry Category]=
	SUM(Output Industrial Electricity Demand by Hour and Industry Category[peak winter day electricity timeslice\
		!,Hour,Industry Category])
	/ ELMCOUNT(peak winter day electricity timeslice)
	~	TW*hr
	~		|

Output Peak Winter Day Residential Building Electricity Demand by Hour and Component[\
		Hour,Building Component]=
	SUM(Output Residential Building Electricity Demand by Hour and Component[peak winter day electricity timeslice\
		!,Hour,Building Component])
	/ ELMCOUNT(peak winter day electricity timeslice)
	~	TW*hr
	~		|

Output Peak Winter Day Transportation Electricity Demand by Hour and Vehicle Type[Hour\
		,Vehicle Type]=
	SUM(Output Transportation Electricity Demand by Hour and Vehicle Type[peak winter day electricity timeslice\
		!,Hour,Vehicle Type])
	/ ELMCOUNT(peak winter day electricity timeslice)
	~	TW*hr
	~		|

Output Perc Change in GDP=
	SUM(Percentage Points Contributed to Change in Gross Domestic Product by ISIC Code[ISIC Code\
		!])
	* 100
	~	Dmnl
	~		~	:SUPPLEMENTARY 
	|

Output Percent Change in Deaths=
	Percent Change in Child and Adult Deaths
	* 100
	~	Dmnl
	~		~	:SUPPLEMENTARY 
	|

Output Percent Change in Deaths by Demographic Trait[demographic trait excluding age bracket\
		]=
	Percent Change in Child and Adult Deaths by Demographic Trait[demographic trait excluding age bracket\
		]
	* 100
	~	Dmnl
	~		~	:SUPPLEMENTARY 
	|

Output Percent Change in Domestic Jobs by Union Status[Union Status]=
	Percent Change in Domestic Jobs by Union Status[Union Status]
	* 100
	~	Dmnl
	~		~	:SUPPLEMENTARY 
	|

Output Percent Change in Employment by Demographic Trait[Demographic Trait]=
	Percent Change in Employment by Demographic Trait[Demographic Trait]
	* 100
	~	Dmnl
	~		~	:SUPPLEMENTARY 
	|

Output Primary Energy Use by Electricity Sector=
	(SUM(Electricity Fuel Use[Electricity Source!])
	  + Renewable Electricity Generation Converted to Primary Energy[hydro es]
	  + Renewable Electricity Generation Converted to Primary Energy[onshore wind es]
	  + Renewable Electricity Generation Converted to Primary Energy[offshore wind es]
	  + Renewable Electricity Generation Converted to Primary Energy[solar PV es]
	  + Renewable Electricity Generation Converted to Primary Energy[solar thermal es]
	  + Renewable Electricity Generation Converted to Primary Energy[geothermal es])
	/ BpTPEU BTU per Large Primary Energy Unit
	~	output TPE unit
	~		~	:SUPPLEMENTARY 
	|

Output Process CO2 Emissions by Industry[Industry Category]=
	Process Emissions after CCS[Industry Category,CO2]
	  / MOU Grams per Large Mass Output Unit Pollutant
	~	mass output unit
	~		~	:SUPPLEMENTARY 
	|

Output Process Emissions in CO2e=
	SUM(Process Emissions in CO2e after CCS[Industry Category!,Pollutant!])
	/ MOU Grams per Large Mass Output Unit CO2e
	~	mass output unit
	~		~	:SUPPLEMENTARY 
	|

Output Process Emissions in CO2e by Industry[Industry Category]=
	SUM(Process Emissions in CO2e after CCS[Industry Category,Pollutant!])
	/ MOU Grams per Large Mass Output Unit CO2e
	~	mass output unit
	~		|

Output Process Emissions in CO2e by Pollutant[Pollutant]=
	(SUM(Process Emissions in CO2e after CCS[Industry Category!,Pollutant])
	  - Process Emissions in CO2e after CCS[agriculture and forestry 01T03,Pollutant]
	  - Process Emissions in CO2e after CCS[water and waste 36T39,Pollutant]
	)
	/ MOU Grams per Large Mass Output Unit CO2e
	~	mass output unit
	~		|

Output Rebate of Taxes Less Subsidies=
	-(Government Revenue Change Allocated by Mechanism[household taxes]
	  + Government Revenue Change Allocated by Mechanism[payroll taxes]
	  + Government Revenue Change Allocated by Mechanism[corporate taxes]
	)
	/ OCCF Dollars per Large Output Currency Unit
	~	output currency units
	~		~	:SUPPLEMENTARY 
	|

Output Refined Petroleum Fuels Consumption=
	Total Energy Use[petroleum gasoline]
	/ BCF BTU per Large Fuel Output Unit[petroleum gasoline]
	+
	Total Energy Use[petroleum diesel]
	/ BCF BTU per Large Fuel Output Unit[petroleum diesel]
	+
	Total Energy Use[jet fuel or kerosene]
	/ BCF BTU per Large Fuel Output Unit[jet fuel or kerosene]
	+
	Total Energy Use[heavy or residual fuel oil]
	/ BCF BTU per Large Fuel Output Unit[heavy or residual fuel oil]
	+
	Total Energy Use[LPG propane or butane]
	/ BCF BTU per Large Fuel Output Unit[LPG propane or butane]
	~	large fuel output unit
	~		~	:SUPPLEMENTARY 
	|

Output Refined Petroleum Fuels Export Revenue=
	(Energy Export Revenue including Electricity[petroleum diesel]
	  + Energy Export Revenue including Electricity[petroleum gasoline]
	  + Energy Export Revenue including Electricity[jet fuel or kerosene]
	  + Energy Export Revenue including Electricity[heavy or residual fuel oil]
	  + Energy Export Revenue including Electricity[LPG propane or butane]
	)
	/ OCCF Dollars per Large Output Currency Unit
	~	output currency units
	~		~	:SUPPLEMENTARY 
	|

Output Refined Petroleum Fuels Exports=
	(Energy Exports including Electricity[petroleum diesel]
	  + Energy Exports including Electricity[petroleum gasoline]
	  + Energy Exports including Electricity[jet fuel or kerosene]
	  + Energy Exports including Electricity[heavy or residual fuel oil]
	  + Energy Exports including Electricity[LPG propane or butane]
	)
	/ BCF BTU per Energy Import Export Output Unit
	~	energy output unit
	~		~	:SUPPLEMENTARY 
	|

Output Refined Petroleum Fuels Final Energy Use=
	SUM(Total Final Energy Use by Sector[Sectors!,petroleum gasoline]
	  + Total Final Energy Use by Sector[Sectors!,petroleum diesel]
	  + Total Final Energy Use by Sector[Sectors!,jet fuel or kerosene]
	  + Total Final Energy Use by Sector[Sectors!,heavy or residual fuel oil]
	  + Total Final Energy Use by Sector[Sectors!,LPG propane or butane]
	)
	/ BpTPEU BTU per Large Primary Energy Unit
	~	output TPE unit
	~		~	:SUPPLEMENTARY 
	|

Output Refined Petroleum Fuels Import Expenditures=
	(Energy Import Expenditures including Electricity[petroleum diesel]
	  + Energy Import Expenditures including Electricity[petroleum gasoline]
	  + Energy Import Expenditures including Electricity[jet fuel or kerosene]
	  + Energy Import Expenditures including Electricity[heavy or residual fuel oil]
	  + Energy Import Expenditures including Electricity[LPG propane or butane]
	)
	/ OCCF Dollars per Large Output Currency Unit
	~	output currency units
	~		~	:SUPPLEMENTARY 
	|

Output Refined Petroleum Fuels Imports=
	(Energy Imports including Electricity[petroleum gasoline]
	  + Energy Imports including Electricity[petroleum diesel]
	  + Energy Imports including Electricity[jet fuel or kerosene]
	  + Energy Imports including Electricity[heavy or residual fuel oil]
	  + Energy Imports including Electricity[LPG propane or butane]
	)
	/ BCF BTU per Energy Import Export Output Unit
	~	energy output unit
	~		~	:SUPPLEMENTARY 
	|

Output Refined Petroleum Fuels Production=
	(Energy Production including Energy Carriers[petroleum diesel]
	  + Energy Production including Energy Carriers[petroleum gasoline]
	  + Energy Production including Energy Carriers[jet fuel or kerosene]
	  + Energy Production including Energy Carriers[heavy or residual fuel oil]
	  + Energy Production including Energy Carriers[LPG propane or butane]
	)
	/ BpTPEU BTU per Large Primary Energy Unit
	~	output TPE unit
	~		~	:SUPPLEMENTARY 
	|

Output Refining Sector Hydrogen Demand=
	(
	  Industrial Fuel Use[hydrogen if,refined petroleum and coke 19]
	  + Industrial Fuel Use[green hydrogen if,refined petroleum and coke 19]
	  + Industrial Fuel Use[low carbon hydrogen if,refined petroleum and coke 19]
	)
	
	/ BpMMTH BTU per MMT Hydrogen
	~	MMT
	~		|

Output Residential Building Electricity Demand by Hour and Component[Electricity Timeslice\
		,Hour,Building Component]=
	(Buildings Sector Electricity Demand[rural residential,Building Component]
	 + Buildings Sector Electricity Demand[urban residential,Building Component])
	* Adjusted Load Factors for Residential Buildings Sector[Building Component,Electricity Timeslice\
		,Hour]
	/ MWh per TWh
	~	TW*hr
	~		|

Output Road Transport Hydrogen Demand=
	SUM(Transportation Sector Fuel Used[road vehicle type!,Cargo Type!,Vehicle Technology\
		!,hydrogen tf])
	/ BpMMTH BTU per MMT Hydrogen
	~	MMT
	~		|

Output Share of Generation from Clean Sources[Clean Elec Requirement]=
	SUM(Percentage Clean Electricity Generation by Source[Electricity Source!,Clean Elec Requirement\
		])
	* 100
	~	Dmnl
	~		~	:SUPPLEMENTARY 
	|

Output Shipping Hydrogen Demand=
	SUM(Transportation Sector Fuel Used[ships,Cargo Type!,Vehicle Technology!,hydrogen tf\
		])
	/ BpMMTH BTU per MMT Hydrogen
	~	MMT
	~		|

Output Social Benefits from Emissions Reduction=
	Social Benefits from Emissions Reduction
	/ OCCF Dollars per Large Output Currency Unit
	~	output currency units
	~		~	:SUPPLEMENTARY 
	|

Output Steel Sector Hydrogen Demand=
	(
	  Industrial Fuel Use[hydrogen if,iron and steel 241]
	  + Industrial Fuel Use[green hydrogen if,iron and steel 241]
	  + Industrial Fuel Use[low carbon hydrogen if,iron and steel 241]
	)
	
	/ BpMMTH BTU per MMT Hydrogen
	~	MMT
	~		|

Output Total Biomass Consumption=
	Total Energy Use[biomass]
	/ BCF BTU per Large Fuel Output Unit[biomass]
	~	large fuel output unit
	~		~	:SUPPLEMENTARY 
	|

Output Total Buildings Energy Use=
	SUM(Building Components Energy Use[Building Type!,Building Fuel!,Building Component!\
		])
	/ BpTPEU BTU per Large Primary Energy Unit
	~	output TPE unit
	~		~	:SUPPLEMENTARY 
	|

Output Total Change in CapEx and OpEx=
	Total Change in CapEx and OpEx
	/ OCCF Dollars per Large Output Currency Unit
	~	output currency units
	~		~	:SUPPLEMENTARY 
	|

Output Total Change in Capital Expenditures=
	Total Change in Capital Expenditures
	/ OCCF Dollars per Large Output Currency Unit
	~	output currency units
	~		~	:SUPPLEMENTARY 
	|

Output Total Change in Fuel and OM Expenditures=
	(Total Change in Fuel Expenditures
	  + Total Change in OM Expenditures
	)
	/ OCCF Dollars per Large Output Currency Unit
	~	output currency units
	~		~	:SUPPLEMENTARY 
	|

Output Total Change in Household Energy Expenditures=
	Direct Change in Energy Expenditures by Entity[labor and consumers]
	/ OCCF Dollars per Small Output Currency Unit
	~	output currency unit
	~		|

Output Total CO2e Emissions=
	Total CO2e Emissions
	/ MOU Grams per Large Mass Output Unit CO2e
	~	mass output unit
	~		|

Output Total CO2e Emissions by Pollutant[Pollutant]=
	Total CO2e Emissions by Pollutant[Pollutant]
	/ MOU Grams per Large Mass Output Unit CO2e
	~	mass output unit
	~		~	:SUPPLEMENTARY 
	|

Output Total CO2e Emissions by Sector[Sectors]=
	Total CO2e Emissions by Sector[Sectors]
	/ MOU Grams per Large Mass Output Unit CO2e
	~	mass output unit
	~		|

Output Total CO2e Emissions Excluding LULUCF=
	Output Total CO2e Emissions
	- Output Total CO2e Emissions by Sector[LULUCF sector]
	~	mass output unit
	~		|

Output Total CO2e Emissions Excluding LULUCF Last Year=
	DELAY FIXED(Output Total CO2e Emissions Excluding LULUCF,
	1,
	0
	)
	~	mass output unit
	~		|

Output Total CO2e Emissions Last Year=
	DELAY FIXED(Output Total CO2e Emissions,
	1,
	0
	)
	~	mass output unit
	~		|

Output Total CO2e Emissions per Unit GDP=
	Total CO2e Emissions per Unit GDP
	* OCCF Dollars per Small Output Currency Unit
	~	g CO2e/output currency unit
	~		~	:SUPPLEMENTARY 
	|

Output Total Electricity Demand=
	Total Electricity Demand Including TnD Losses
	/ MWh per TWh
	~	TW*hr
	~		~	:SUPPLEMENTARY 
	|

Output Total Electricity Dispatched by Hour by Plant Type[Electricity Timeslice,Hour,\
		Electricity Source]=
	Total Electricity Dispatched by Hour by Plant Type[Electricity Timeslice,Hour,Electricity Source\
		]
	/ MWh per TWh
	~	TW*hr
	~		~	:SUPPLEMENTARY 
	|

Output Total Electricity Dispatched by Hour by Plant Type on Peak Summer Day[Hour,Electricity Source\
		]=
	Total Electricity Dispatched by Hour by Plant Type on Peak Summer Day[Hour,Electricity Source\
		]
	/ MWh per TWh
	~	TW*hr
	~		~	:SUPPLEMENTARY 
	|

Output Total Electricity Dispatched by Hour by Plant Type on Peak Winter Day[Hour,Electricity Source\
		]=
	Total Electricity Dispatched by Hour by Plant Type on Peak Winter Day[Hour,Electricity Source\
		]
	/ MWh per TWh
	~	TW*hr
	~		~	:SUPPLEMENTARY 
	|

Output Total Final Energy Use by Agriculture=
	SUM(Industry Sector Final Energy Use by Industry[All Fuels!,agriculture and forestry 01T03\
		])
	/ BpTPEU BTU per Large Primary Energy Unit
	~	output TPE unit
	~		|

Output Total Final Energy Use by Industry Sector Excluding Ag and Waste=
	Output Total Final Energy Use by Sector[industry sector]
	- Output Total Final Energy Use by Agriculture
	- Output Total Final Energy Use by Waste Management
	~	output TPE unit
	~		~	:SUPPLEMENTARY 
	|

Output Total Final Energy Use by Sector[Sectors]=
	SUM(Total Final Energy Use by Sector[Sectors,All Fuels!])
	/ BpTPEU BTU per Large Primary Energy Unit
	~	output TPE unit
	~		|

Output Total Final Energy Use by Type[All Fuels]=
	SUM(Total Final Energy Use by Sector[Sectors!,All Fuels])
	/ BpTPEU BTU per Large Primary Energy Unit
	~	output TPE unit
	~		~	:SUPPLEMENTARY 
	|

Output Total Final Energy Use by Waste Management=
	SUM(Industry Sector Final Energy Use by Industry[All Fuels!,water and waste 36T39])
	/ BpTPEU BTU per Large Primary Energy Unit
	~	output TPE unit
	~		|

Output Total Hard Coal Consumption=
	Total Energy Use[hard coal]
	/ BCF BTU per Large Fuel Output Unit[hard coal]
	~	large fuel output unit
	~		~	:SUPPLEMENTARY 
	|

Output Total Hydrogen Consumption=
	SUM(Hydrogen Demand by Sector[Sectors!])
	/ BCF BTU per Large Fuel Output Unit[hydrogen]
	~	large fuel output unit
	~		~	:SUPPLEMENTARY 
	|

Output Total Industrial Fuel Use=
	(SUM(Industrial Fuel Use[Industrial Fuel!,Industry Category!])
	  - SUM(Industrial Fuel Use[Industrial Fuel!,agriculture and forestry 01T03])
	  - SUM(Industrial Fuel Use[Industrial Fuel!,water and waste 36T39])
	)
	/ BpTPEU BTU per Large Primary Energy Unit
	~	output TPE unit
	~		~	:SUPPLEMENTARY 
	|

Output Total Industrial Fuel Use for Energy Purposes=
	MAX(
	  0,
	
	  SUM(Industrial Fuel Use[Industrial Fuel!,Industry Category!])
	    - SUM(Industrial Fuel Use[Industrial Fuel!,water and waste 36T39])
	    - SUM(Industrial Fuel Use[Industrial Fuel!,agriculture and forestry 01T03])
	
	    - SUM(Industrial Fuel Use for Non Energy Purposes[Industry Category!,Industrial Fuel\
		!])
	      + SUM(Industrial Fuel Use for Non Energy Purposes[water and waste 36T39,Industrial Fuel\
		!])
	      + SUM(Industrial Fuel Use for Non Energy Purposes[agriculture and forestry 01T03\
		,Industrial Fuel!])
	)
	/ BpTPEU BTU per Large Primary Energy Unit
	~	output TPE unit
	~		~	:SUPPLEMENTARY 
	|

Output Total Lignite Consumption=
	Total Energy Use[lignite]
	/ BCF BTU per Large Fuel Output Unit[lignite]
	~	large fuel output unit
	~		~	:SUPPLEMENTARY 
	|

Output Total Liquid Biofuels Consumption=
	Total Energy Use[biofuel gasoline]
	/ BCF BTU per Large Fuel Output Unit[biofuel gasoline]
	+
	Total Energy Use[biofuel diesel]
	/ BCF BTU per Large Fuel Output Unit[biofuel diesel]
	~	large fuel output unit
	~		~	:SUPPLEMENTARY 
	|

Output Total LPG Propane and Butane Consumption=
	Total Energy Use[LPG propane or butane]
	/ BCF BTU per Large Fuel Output Unit[LPG propane or butane]
	~	large fuel output unit
	~		~	:SUPPLEMENTARY 
	|

Output Total Municipal Solid Waste Consumption=
	Total Energy Use[municipal solid waste]
	/ BCF BTU per Large Fuel Output Unit[municipal solid waste]
	~	large fuel output unit
	~		~	:SUPPLEMENTARY 
	|

Output Total Natural Gas Consumption=
	Total Energy Use[natural gas]
	/ BCF BTU per Large Fuel Output Unit[natural gas]
	~	large fuel output unit
	~		~	:SUPPLEMENTARY 
	|

Output Total Petroleum Fuels Consumption=
	Total Energy Use[petroleum gasoline]
	/ BCF BTU per Large Fuel Output Unit[petroleum gasoline]
	+
	Total Energy Use[petroleum diesel]
	/ BCF BTU per Large Fuel Output Unit[petroleum diesel]
	+
	Total Energy Use[jet fuel or kerosene]
	/ BCF BTU per Large Fuel Output Unit[jet fuel or kerosene]
	+
	Total Energy Use[crude oil]
	/ BCF BTU per Large Fuel Output Unit[crude oil]
	+
	Total Energy Use[heavy or residual fuel oil]
	/ BCF BTU per Large Fuel Output Unit[heavy or residual fuel oil]
	~	large fuel output unit
	~		~	:SUPPLEMENTARY 
	|

Output Total Pollutant Emissions by Sector in KMT[Sectors,Pollutant]=
	Total Pollutant Emissions by Sector[Sectors,Pollutant]
	/ MOU Grams per Small Mass Output Pollutant
	~	mass output unit
	~		~	:SUPPLEMENTARY 
	|

Output Total Pollutant Emissions by Sector in MMT[Sectors,Pollutant]=
	Total Pollutant Emissions by Sector[Sectors,Pollutant]
	/ MOU Grams per Large Mass Output Unit Pollutant
	~	mass output unit
	~		~	:SUPPLEMENTARY 
	|

Output Total Primary Energy Use by Agriculture=
	SUM(Industry Sector Primary Energy Use by Industry[agriculture and forestry 01T03,All Fuels\
		!])
	/ BpTPEU BTU per Large Primary Energy Unit
	~	output TPE unit
	~		|

Output Total Primary Energy Use by Buildings Sector=
	Output Total Primary Energy Use by Sector[residential buildings sector]
	+ Output Total Primary Energy Use by Sector[commercial buildings sector]
	~	output TPE unit
	~		~	:SUPPLEMENTARY 
	|

Output Total Primary Energy Use by Industry Sector Excluding Ag and Waste=
	Output Total Primary Energy Use by Sector[industry sector]
	- Output Total Primary Energy Use by Agriculture
	- Output Total Primary Energy Use by Waste Management
	~	output TPE unit
	~		~	:SUPPLEMENTARY 
	|

Output Total Primary Energy Use by Sector[Sectors]=
	SUM(Total Primary Fuel Use by Sector[Sectors,All Fuels!])
	/ BpTPEU BTU per Large Primary Energy Unit
	~	output TPE unit
	~		|

Output Total Primary Energy Use by Type[All Fuels]=
	Total Primary Energy Use[All Fuels]
	/ BpTPEU BTU per Large Primary Energy Unit
	~	output TPE unit
	~		~	:SUPPLEMENTARY 
	|

Output Total Primary Energy Use by Waste Management=
	SUM(Industry Sector Primary Energy Use by Industry[water and waste 36T39,All Fuels!]\
		)
	/ BpTPEU BTU per Large Primary Energy Unit
	~	output TPE unit
	~		|

Output Total Primary Energy Use per Unit GDP=
	Total Primary Energy Use per Unit GDP
	* OCCF Dollars per Small Output Currency Unit
	/ BpTPEU BTU per Small Primary Energy Unit
	~	output TPE unit/output currency unit
	~		~	:SUPPLEMENTARY 
	|

Output Transportation Electricity Demand by Hour and Vehicle Type[Electricity Timeslice\
		,Hour,Vehicle Type]=
	SUM(Transportation Sector Electricity Demand[Vehicle Type,Cargo Type!])
	* Adjusted Load Factors for Transporation Sector[Vehicle Type,Electricity Timeslice,\
		Hour]
	/ MWh per TWh
	~	TW*hr
	~		|

Output Transportation Pollutant Emissions by Vehicle Type[Vehicle Type,Cargo Type,Pollutant\
		]=
	SUM(Transportation Pollutant Emissions Disaggregated[Vehicle Type,Pollutant,Cargo Type\
		,Transportation Fuel!])
	/ MOU Grams per Large Mass Output Unit Pollutant
	~	mass output unit
	~		~	:SUPPLEMENTARY 
	|

Output Transportation Sector Carbon Tax Revenue[Vehicle Type]=
	SUM(Transportation Sector Carbon Tax Revenue[Vehicle Type,Cargo Type!]/ OCCF Dollars per Large Output Currency Unit\
		)
	~	output currency unit
	~		~	:SUPPLEMENTARY 
	|

Output Transportation Sector Electricity Use=
	SUM(Transportation Sector Fuel Used[Vehicle Type!,Cargo Type!,Vehicle Technology!,electricity tf\
		])
	* MWh per BTU
	/ MWh per TWh
	~	TW*hr
	~		~	:SUPPLEMENTARY 
	|

Output Transportation Sector Fuel Used=
	SUM(Transportation Sector Fuel Used[Vehicle Type!,Cargo Type!,Vehicle Technology!,Transportation Fuel\
		!])
	/ BpTPEU BTU per Large Primary Energy Unit
	~	output TPE unit
	~		~	:SUPPLEMENTARY 
	|

Output Transportation Sector Fuel Used by Fuel[Transportation Fuel]=
	SUM(Transportation Sector Fuel Used[Vehicle Type!,Cargo Type!,Vehicle Technology!,Transportation Fuel\
		])
	/ BpTPEU BTU per Large Primary Energy Unit
	~	output TPE unit
	~		~	:SUPPLEMENTARY 
	|

Output Transportation Sector Fuel Used by Vehicle Type[Vehicle Type,Cargo Type]=
	SUM(Transportation Sector Fuel Used[Vehicle Type,Cargo Type,Vehicle Technology!,Transportation Fuel\
		!])
	/ BpTPEU BTU per Large Primary Energy Unit
	~	output TPE unit
	~		~	:SUPPLEMENTARY 
	|

Output Vehicles in Millions[Vehicle Type,Cargo Type,Vehicle Technology]=
	Vehicles[Vehicle Type,Cargo Type,Vehicle Technology]
	/ Vehicles per Million Vehicles
	~	million vehicles
	~		~	:SUPPLEMENTARY 
	|

Output Vehicles in Thousands[Vehicle Type,Cargo Type,Vehicle Technology]=
	Vehicles[Vehicle Type,Cargo Type,Vehicle Technology]
	/ Vehicles per Thousand Vehicles
	~	thousand vehicles
	~		~	:SUPPLEMENTARY 
	|

Output Waste Management CO2e Emissions=
	SUM(Waste Management CO2e Emissions[Pollutant!])
	/ MOU Grams per Large Mass Output Unit CO2e
	~	mass output unit
	~		~	:SUPPLEMENTARY 
	|

Output Waste Management Electricity Use=
	Industrial Fuel Use[electricity if,water and waste 36T39]
	* MWh per BTU
	/ MWh per TWh
	~	TW*hr
	~		~	:SUPPLEMENTARY 
	|

Output Waste Management Pollutant Emissions in KMT[Pollutant]=
	Waste Management Pollutant Emissions[Pollutant]
	/ MOU Grams per Small Mass Output Pollutant
	~	mass output unit
	~		~	:SUPPLEMENTARY 
	|

Output Waste Management Pollutant Emissions in MMT[Pollutant]=
	Waste Management Pollutant Emissions[Pollutant]
	/ MOU Grams per Large Mass Output Unit Pollutant
	~	mass output unit
	~		~	:SUPPLEMENTARY 
	|

Output Water Consumed by Hydrogen Plants[Hydrogen Production Pathway]=
	Water Consumed by Hydrogen Plants[Hydrogen Production Pathway]
	/ LpWOU Liters per Water Output Unit
	~	water output units
	~		|

Output Water Consumed by Power Plants[Electricity Source]=
	Water Consumed by Power Plants[Electricity Source]
	/ LpWOU Liters per Water Output Unit
	~	water output units
	~		~	:SUPPLEMENTARY 
	|

Output Water Withdrawn by Power Plants[Electricity Source]=
	Water Withdrawn by Power Plants[Electricity Source]
	/ LpWOU Liters per Water Output Unit
	~	water output units
	~		~	:SUPPLEMENTARY 
	|

Payment Period for Decommissioning Costs=
	3
	~	Year
	~		|

PCFURfE Percentage Components Fuel Use Reduction for Electricity[Building Component]=
	GET DIRECT CONSTANTS(
	   'InputData/bldgs/PCFURfE/PCFURfE.csv',
	   ',',
	   'B2*'
	)
	~	Dmnl
	~	For building components that can use either electricity or other fuels \
		(such as "heating"), this variable specifies the percentage reduction in \
		fuel use (on a BTU basis) for electric components relative to natural \
		gas-burning components due to the fact that electricity can be converted \
		into work more efficiently than other fuel types.
	|

